<%- include('partials/header') %>
<nav class="breadcrumb-bar">Sei in: <strong>Home</strong></nav>

<style>
/* ── Dashboard Live ───────────────────────────────────── */
.dash-live-badge {
  display: inline-block; font-size:.62rem; font-weight:700; letter-spacing:.5px;
  color:var(--color-success); border:1px solid var(--color-success);
  border-radius:9999px; padding:.12rem .5rem; vertical-align:middle;
  opacity:0; transition:opacity .4s;
}

/* KPI strip */
.kpi-strip {
  display:grid;
  grid-template-columns: repeat(auto-fit, minmax(140px,1fr));
  gap:var(--space-3); margin-bottom:var(--space-6);
}
.kpi-card {
  background:var(--color-surface); border:1px solid var(--color-border);
  border-radius:var(--radius-lg); padding:var(--space-4) var(--space-4) var(--space-3);
}
.kpi-label { font-size:var(--text-xs); font-weight:600; color:var(--color-text-muted);
  text-transform:uppercase; letter-spacing:.07em; margin-bottom:.35rem; }
.kpi-value { font-size:clamp(1.6rem,3vw,2.4rem); font-weight:800; line-height:1;
  font-variant-numeric:tabular-nums; }
.kpi-value.green  { color:var(--color-success); }
.kpi-value.blue   { color:var(--color-primary); }
.kpi-value.orange { color:var(--color-orange); }
.kpi-value.red    { color:var(--color-error); }
.kpi-sub { font-size:var(--text-xs); color:var(--color-text-muted); margin-top:.25rem; }

/* Presenze aree */
.presenze-grid {
  display:grid;
  grid-template-columns: repeat(auto-fit, minmax(160px,1fr));
  gap:var(--space-3); margin-bottom:var(--space-6);
}
.presenze-card {
  background:var(--color-surface); border:1px solid var(--color-border);
  border-radius:var(--radius-lg); padding:var(--space-4);
}
.presenze-card-header {
  display:flex; align-items:center; gap:.4rem;
  font-size:var(--text-xs); font-weight:700; color:var(--color-text-muted);
  text-transform:uppercase; letter-spacing:.07em; margin-bottom:var(--space-2);
}
.presenze-number {
  font-size:clamp(2rem,4vw,3rem); font-weight:800; line-height:1;
  color:var(--color-primary); font-variant-numeric:tabular-nums;
  transition: transform .1s ease;
}
.presenze-number.bump { transform:scale(1.08); }
.presenze-subrow {
  display:flex; gap:var(--space-3); margin-top:.4rem;
}
.presenze-sub {
  font-size:var(--text-xs); font-variant-numeric:tabular-nums;
}
.presenze-sub.in  { color:var(--color-success); }
.presenze-sub.out { color:var(--color-orange); }

/* Heatmap */
.heatmap-section { margin-bottom:var(--space-6); }
.heatmap-title {
  font-size:var(--text-sm); font-weight:700; margin-bottom:var(--space-3);
  color:var(--color-text);
}
.heatmap-bars {
  display:flex; align-items:flex-end; gap:3px; height:80px;
}
.heatmap-bar-wrap {
  flex:1; display:flex; flex-direction:column;
  align-items:center; gap:2px; height:100%;
  justify-content:flex-end;
}
.heatmap-bar {
  width:100%; background:var(--color-primary);
  border-radius:3px 3px 0 0; min-height:2px;
  opacity:.75; transition:height .4s ease, opacity .2s;
}
.heatmap-bar:hover { opacity:1; }
.heatmap-bar-label {
  font-size:.6rem; color:var(--color-text-muted);
  font-variant-numeric:tabular-nums;
}
.heatmap-empty {
  color:var(--color-text-muted); font-size:var(--text-sm);
  padding:var(--space-4) 0;
}

/* Alert banner */
.alert-closing-banner {
  background:color-mix(in oklab, var(--color-warning) 12%, var(--color-surface));
  border:1px solid var(--color-warning);
  border-radius:var(--radius-lg); padding:var(--space-3) var(--space-4);
  margin-bottom:var(--space-4);
  display:flex; align-items:flex-start; gap:var(--space-2);
  font-size:var(--text-sm);
}
.alert-closing-banner .alert-icon { font-size:1.2rem; flex-shrink:0; }
.alert-closing-banner strong { color:var(--color-warning); }

/* Scan anomali */
.scan-anomali-list { display:flex; flex-direction:column; gap:var(--space-2); }
.scan-anomali-item {
  background:color-mix(in oklab, var(--color-error) 8%, var(--color-surface));
  border:1px solid color-mix(in oklab, var(--color-error) 30%, transparent);
  border-radius:var(--radius-md); padding:var(--space-2) var(--space-3);
  display:flex; justify-content:space-between; align-items:center;
  font-size:var(--text-sm);
}
.scan-anomali-item .badge-red {
  background:var(--color-error); color:#fff;
  border-radius:9999px; padding:.1rem .5rem;
  font-size:var(--text-xs); font-weight:700;
}

/* Pass non consegnati */
.pass-nc-list { display:flex; flex-direction:column; gap:var(--space-2); margin-top:var(--space-2); }
.pass-nc-item {
  background:var(--color-surface-offset);
  border-radius:var(--radius-md); padding:var(--space-2) var(--space-3);
  display:flex; justify-content:space-between; align-items:center;
  font-size:var(--text-sm);
}
.pass-nc-item .badge-orange {
  background:var(--color-orange); color:#fff;
  border-radius:9999px; padding:.1rem .5rem;
  font-size:var(--text-xs); font-weight:700;
}

/* Alert gruppi (existing style enhanced) */
.alert-group-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(200px,1fr));
  gap:var(--space-2);
}
.alert-group-card {
  background:var(--color-surface); border:1px solid var(--color-border);
  border-radius:var(--radius-md); padding:var(--space-2) var(--space-3);
  font-size:var(--text-sm);
}
.alert-group-card .ag-name {
  font-weight:700; white-space:nowrap; overflow:hidden;
  text-overflow:ellipsis; max-width:180px;
}
.alert-group-card .ag-meta {
  font-size:var(--text-xs); color:var(--color-text-muted); margin-top:.15rem;
}
.progress-bar-wrap {
  margin-top:.35rem; background:var(--color-surface-offset);
  border-radius:9999px; height:5px; overflow:hidden;
}
.progress-bar-fill {
  height:100%; border-radius:9999px;
  background:var(--color-primary); transition:width .4s ease;
}
.progress-bar-fill.warn  { background:var(--color-warning); }
.progress-bar-fill.empty { background:var(--color-error); }

/* Activity feed */
.activity-feed { display:flex; flex-direction:column; gap:var(--space-2); }
.activity-item {
  display:flex; align-items:flex-start; gap:var(--space-2);
  font-size:var(--text-xs); color:var(--color-text-muted);
}
.activity-dot {
  width:6px; height:6px; border-radius:50%;
  background:var(--color-primary); flex-shrink:0; margin-top:.3rem;
}
.activity-time { flex-shrink:0; font-variant-numeric:tabular-nums; }

/* Section card wrapper */
.dash-section {
  background:var(--color-surface); border:1px solid var(--color-border);
  border-radius:var(--radius-lg); padding:var(--space-5);
  margin-bottom:var(--space-5);
}
.dash-section-title {
  font-size:var(--text-sm); font-weight:700; margin-bottom:var(--space-4);
  display:flex; align-items:center; gap:var(--space-2);
}
.dash-two-col {
  display:grid; grid-template-columns:1fr 1fr; gap:var(--space-5);
}
@media(max-width:700px){ .dash-two-col { grid-template-columns:1fr; } }
</style>

<h1 class="page-title">
  Dashboard
  <span id="dash-live-badge" class="dash-live-badge">● LIVE</span>
</h1>

<!-- ── ALERT CHIUSURA ── -->
<div id="alert-closing-banner" style="display:none"></div>

<!-- ── KPI STRIP ── -->
<div class="kpi-strip" id="kpi-strip">
  <div class="kpi-card">
    <div class="kpi-label">Partecipanti</div>
    <div class="kpi-value blue" id="kpi-partecipanti">–</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-label">Pass generati</div>
    <div class="kpi-value green" id="kpi-pass">–</div>
    <div class="kpi-sub" id="kpi-pass-sub"></div>
  </div>
  <div class="kpi-card">
    <div class="kpi-label">Senza pass</div>
    <div class="kpi-value orange" id="kpi-senza">–</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-label">Scan QR oggi</div>
    <div class="kpi-value blue" id="kpi-scan">–</div>
  </div>
</div>

<!-- ── PRESENZE LIVE ── -->
<div class="dash-section">
  <div class="dash-section-title">🎡 Presenze live per area</div>
  <div class="presenze-grid" id="presenze-grid">
    <% ['mariambini','palazzetto','la_perla','ludostria'].forEach(function(area){ %>
    <div class="presenze-card" id="presenze-card-<%= area %>">
      <div class="presenze-card-header">
        <%= area === 'mariambini' ? '🎡 Mariambini' :
            area === 'palazzetto' ? '🏟️ Palazzetto' :
            area === 'la_perla'   ? '🎬 La Perla' : '🎲 Ludostria' %>
      </div>
      <div class="presenze-number" id="pres-<%= area %>">–</div>
      <div class="presenze-subrow">
        <span class="presenze-sub in">↑ <span id="pres-in-<%= area %>">–</span></span>
        <span class="presenze-sub out">↓ <span id="pres-out-<%= area %>">–</span></span>
      </div>
    </div>
    <% }); %>
  </div>
</div>

<!-- ── HEATMAP + ALERT ── -->
<div class="dash-two-col">
  <div class="dash-section">
    <div class="dash-section-title">📊 Scan QR per ora — oggi</div>
    <div class="heatmap-section">
      <div class="heatmap-bars" id="heatmap-bars">
        <div class="heatmap-empty">Nessun dato ancora oggi</div>
      </div>
    </div>
  </div>

  <div class="dash-section">
    <div class="dash-section-title">⚠️ Alert intelligenti</div>
    <!-- Scan anomali -->
    <div id="scan-anomali-wrap" style="display:none">
      <div style="font-size:var(--text-xs);font-weight:700;color:var(--color-error);
                  text-transform:uppercase;letter-spacing:.07em;margin-bottom:var(--space-2)">
        Scan anomali (>3 scan in 2h)
      </div>
      <div class="scan-anomali-list" id="scan-anomali-list"></div>
    </div>
    <!-- Pass non consegnati (solo vicino chiusura) -->
    <div id="pass-nc-wrap" style="display:none">
      <div style="font-size:var(--text-xs);font-weight:700;color:var(--color-warning);
                  text-transform:uppercase;letter-spacing:.07em;margin-bottom:var(--space-2);
                  margin-top:var(--space-3)">
        Pass non ritirati
      </div>
      <div class="pass-nc-list" id="pass-nc-list"></div>
    </div>
    <div id="alert-empty" style="color:var(--color-text-muted);font-size:var(--text-sm);padding:var(--space-4) 0">
      ✅ Nessun alert attivo
    </div>
  </div>
</div>

<!-- ── ALERT GRUPPI ── -->
<div class="dash-section">
  <div class="dash-section-title">📋 Gruppi con pass incompleti</div>
  <div class="alert-group-grid" id="alert-groups-container">
    <% if(!alertGroups||alertGroups.length===0){ %>
      <span style="color:var(--color-text-muted);font-size:var(--text-sm)">✅ Tutti i gruppi sono a posto</span>
    <% }else{alertGroups.forEach(function(g){ %>
      <div class="alert-group-card">
        <div class="ag-name" title="<%= g.name %>"><%= g.name %></div>
        <% if(g.zone){ %><div class="ag-meta">📍 <%= g.zone %></div><% } %>
        <div class="ag-meta"><%= g.pass_count %> / <%= g.max_passes||'?' %> pass</div>
        <div class="progress-bar-wrap">
          <div class="progress-bar-fill <%= g.pass_count===0?'empty':(g.pass_count<g.max_passes?'warn':'') %>"
               style="width:<%= g.max_passes>0 ? Math.round(g.pass_count/g.max_passes*100) : 0 %>%"></div>
        </div>
      </div>
    <% });} %>
  </div>
</div>

<!-- ── ATTIVITÀ RECENTE ── -->
<div class="dash-section">
  <div class="dash-section-title">🕐 Attività recente</div>
  <div class="activity-feed" id="activity-feed">
    <% if(recentActivity&&recentActivity.length){ recentActivity.forEach(function(a){ %>
      <div class="activity-item">
        <div class="activity-dot"></div>
        <span class="activity-time"><%= a.created_at ? a.created_at.slice(11,16) : '' %></span>
        <span><strong><%= a.username||'sistema' %></strong> — <%= a.action %><% if(a.details){ %> <span style="opacity:.7"><%= a.details.slice(0,60) %></span><% } %></span>
      </div>
    <% });} %>
  </div>
</div>

<script>
// ── State ────────────────────────────────────────────────
const AREAS = {
  mariambini: '🎡 Mariambini',
  palazzetto: '🏟️ Palazzetto',
  la_perla:   '🎬 La Perla',
  ludostria:  '🎲 Ludostria'
};

function animNum(el, val) {
  el.classList.add('bump');
  el.textContent = val;
  setTimeout(() => el.classList.remove('bump'), 150);
}

// ── Render presenze ──────────────────────────────────────
function renderPresenze(presenze) {
  Object.keys(AREAS).forEach(area => {
    const d = presenze[area] || { ins:0, outs:0, presenti:0 };
    const el = document.getElementById('pres-' + area);
    const inEl  = document.getElementById('pres-in-'  + area);
    const outEl = document.getElementById('pres-out-' + area);
    if (el) {
      el.textContent = d.presenti;
      el.classList.add('bump');
      setTimeout(() => el.classList.remove('bump'), 150);
    }
    if (inEl)  inEl.textContent  = d.ins;
    if (outEl) outEl.textContent = d.outs;
  });
}

// ── Render heatmap ───────────────────────────────────────
function renderHeatmap(data) {
  const wrap = document.getElementById('heatmap-bars');
  if (!data || !data.length) {
    wrap.innerHTML = '<div class="heatmap-empty">Nessun dato ancora oggi</div>';
    return;
  }
  const max = Math.max(...data.map(d => d.count), 1);
  // Ore 8-22
  const hours = Array.from({length:15}, (_,i) => String(i+8).padStart(2,'0'));
  const byHour = {};
  data.forEach(d => { byHour[d.ora] = d.count; });
  wrap.innerHTML = hours.map(h => {
    const c = byHour[h] || 0;
    const pct = Math.round(c / max * 100);
    return `<div class="heatmap-bar-wrap">
      <div class="heatmap-bar" style="height:${Math.max(pct,2)}%" title="${h}:00 — ${c} scan"></div>
      <div class="heatmap-bar-label">${h}</div>
    </div>`;
  }).join('');
}

// ── Render alert ─────────────────────────────────────────
function renderAlerts(data) {
  const { scanAnomali, passNonConsegnati, alertPassNonRitirati, nextClosing } = data;

  // Banner chiusura
  const banner = document.getElementById('alert-closing-banner');
  if (nextClosing) {
    const h = Math.floor(nextClosing.diffMin / 60);
    const m = nextClosing.diffMin % 60;
    const timeLeft = h > 0 ? `${h}h ${m}m` : `${m} min`;
    banner.style.display = 'flex';
    banner.innerHTML = `<span class="alert-icon">⏰</span>
      <div><strong>Chiusura ${nextClosing.label} alle ${nextClosing.closing}</strong>
      — mancano <strong>${timeLeft}</strong></div>`;
  } else {
    banner.style.display = 'none';
  }

  let hasAlert = false;

  // Scan anomali
  const anomaliWrap = document.getElementById('scan-anomali-wrap');
  const anomaliList = document.getElementById('scan-anomali-list');
  if (scanAnomali && scanAnomali.length) {
    hasAlert = true;
    anomaliWrap.style.display = 'block';
    anomaliList.innerHTML = scanAnomali.map(s =>
      `<div class="scan-anomali-item">
        <span><strong>${s.participant_name||s.code}</strong>
          ${s.group_name ? `<span style="opacity:.7"> – ${s.group_name}</span>` : ''}
        </span>
        <span class="badge-red">${s.hits}×</span>
      </div>`
    ).join('');
  } else {
    anomaliWrap.style.display = 'none';
  }

  // Pass non consegnati (solo se siamo vicini alla chiusura ritiro)
  const ncWrap = document.getElementById('pass-nc-wrap');
  const ncList = document.getElementById('pass-nc-list');
  if (alertPassNonRitirati && passNonConsegnati && passNonConsegnati.length) {
    hasAlert = true;
    ncWrap.style.display = 'block';
    ncList.innerHTML = passNonConsegnati.map(g =>
      `<div class="pass-nc-item">
        <span>${g.group_name||'–'}${g.zone?` <small style="opacity:.6">📍${g.zone}</small>`:''}</span>
        <span class="badge-orange">${g.non_consegnati}</span>
      </div>`
    ).join('');
  } else {
    ncWrap.style.display = 'none';
  }

  document.getElementById('alert-empty').style.display = hasAlert ? 'none' : 'block';
}

// ── Render alert gruppi ──────────────────────────────────
function renderAlertGroups(groups) {
  const c = document.getElementById('alert-groups-container');
  if (!groups || !groups.length) {
    c.innerHTML = '<span style="color:var(--color-text-muted);font-size:var(--text-sm)">✅ Tutti i gruppi sono a posto</span>';
    return;
  }
  c.innerHTML = groups.map(g => {
    const pct = g.max_passes > 0 ? Math.round(g.pass_count / g.max_passes * 100) : 0;
    const cls = g.pass_count === 0 ? 'empty' : (g.pass_count < g.max_passes ? 'warn' : '');
    return `<div class="alert-group-card">
      <div class="ag-name" title="${g.name}">${g.name}</div>
      ${g.zone ? `<div class="ag-meta">📍 ${g.zone}</div>` : ''}
      <div class="ag-meta">${g.pass_count} / ${g.max_passes||'?'} pass</div>
      <div class="progress-bar-wrap">
        <div class="progress-bar-fill ${cls}" style="width:${pct}%"></div>
      </div>
    </div>`;
  }).join('');
}

// ── Render attività ──────────────────────────────────────
function renderActivity(items) {
  const feed = document.getElementById('activity-feed');
  if (!items || !items.length) { feed.innerHTML = '<span style="opacity:.5">Nessuna attività</span>'; return; }
  feed.innerHTML = items.map(a =>
    `<div class="activity-item">
      <div class="activity-dot"></div>
      <span class="activity-time">${(a.created_at||'').slice(11,16)}</span>
      <span><strong>${a.username||'sistema'}</strong> — ${a.action}${a.details?` <span style="opacity:.7">${a.details.slice(0,60)}</span>`:''}</span>
    </div>`
  ).join('');
}

// ── Render KPI ───────────────────────────────────────────
function renderKPI(stats) {
  const el = (id, val) => { const e=document.getElementById(id); if(e) e.textContent=val; };
  el('kpi-partecipanti', stats.totalParticipants ?? '–');
  el('kpi-pass', stats.totalPasses ?? '–');
  const consegnati = (stats.passesByStatus||{})['CONSEGNATO'] || 0;
  const pct = stats.totalPasses > 0 ? Math.round(consegnati/stats.totalPasses*100) : 0;
  el('kpi-pass-sub', `${consegnati} consegnati (${pct}%)`);
  el('kpi-senza', stats.senzaPass ?? '–');
  el('kpi-scan', stats.ingressiOggi ?? '–');
}

// ── Refresh principale ───────────────────────────────────
function refresh() {
  fetch('/api/dashboard-stats')
    .then(r => r.json())
    .then(d => {
      document.getElementById('dash-live-badge').style.opacity = '1';
      renderKPI(d.stats);
      renderPresenze(d.presenze || {});
      renderHeatmap(d.heatmapOre);
      renderAlerts(d);
      renderAlertGroups(d.alertGroups);
      renderActivity(d.recentActivity);
    })
    .catch(() => {
      document.getElementById('dash-live-badge').style.opacity = '0';
    });
}

refresh();
setInterval(refresh, 15000);
</script>

<%- include('partials/footer') %>
