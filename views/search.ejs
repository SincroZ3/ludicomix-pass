<%-include('partials/header') %>
<nav class="breadcrumb-bar">Sei in: <a href="/home">Home</a> <span class="sep">›</span> <strong>Ricerca Pass</strong></nav>
<h1 class="page-title">Ricerca Pass</h1>

<div class="card">
  <div class="card-title">Testo da ricercare</div>
  <form method="get" action="/search" style="display:flex;gap:0.75rem;align-items:flex-end;">
    <label style="flex:1;margin:0;">
      <input type="text" name="q" value="<%= q %>" placeholder="Nome assegnatario, tipologia, gruppo, stand, codice…" autofocus>
    </label>
    <button type="submit" class="primary">&#128269; Cerca</button>
  </form>
</div>

<% if (q && results.length === 0) { %>
  <div class="alert alert-warning"><span>&#9888;&#65039;</span> Nessun pass trovato per "<strong><%= q %></strong>".</div>
<% } %>

<% if (results.length > 0) { %>
<h2>Risultati &mdash; <span class="chip"><%= results.length %> trovati</span></h2>
<div class="table-wrapper">
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Assegnatario</th>
        <th>Tipologia</th>
        <th>Gruppo / Associazione</th>
        <th>Stand</th>
        <th>Codice</th>
        <th>Stato</th>
        <th>Data</th>
        <th>PDF</th>
      </tr>
    </thead>
    <tbody>
      <% results.forEach(function(r){ %>
        <tr>
          <td><span class="chip">#<%= r.id %></span></td>
          <td><strong><%= r.participant_name %></strong></td>
          <td><%= r.pass_type_name %></td>
          <td><%= r.group_name || '&mdash;' %></td>
          <td><%= r.stand_name || '&mdash;' %></td>
          <td style="font-family:monospace;font-size:0.78rem;"><%= r.code || '' %></td>
          <td><span class="chip"><%= r.status || '&mdash;' %></span></td>
          <td style="font-size:0.78rem;color:var(--text-muted);white-space:nowrap;"><%= r.created_at %></td>
          <td>
            <% if (r.pdf_file) { %>
              <a href="/passes/<%= r.id %>/download" target="_blank" class="link-action">&#11015; PDF</a>
            <% } else { %><span style="color:var(--text-muted);">n/d</span><% } %>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>
<% } %>
<%-include('partials/footer') %>
