<%- include('partials/header') %>
<nav class="breadcrumb-bar">
  Sei in: <a href="/home">Home</a> <span class="sep">›</span>
  <a href="/admin/settings">Impostazioni</a> <span class="sep">›</span>
  <strong>📣 Bacheca Comunicazioni</strong>
</nav>
<h1 class="page-title">📣 Bacheca Comunicazioni</h1>

<% if(saved==='1'){ %>
  <div class="alert alert-success" style="margin-bottom:1rem;">✅ Comunicazione pubblicata con successo.</div>
<% } else if(saved==='err'){ %>
  <div class="alert alert-danger" style="margin-bottom:1rem;">❌ Errore. Verifica titolo e messaggio.</div>
<% } %>

<div style="display:grid;grid-template-columns:1fr 380px;gap:1.5rem;align-items:start;">

  <!-- ── LISTA ANNUNCI ── -->
  <div>
    <div class="card" style="padding:0;overflow:hidden;">
      <div class="card-title" style="margin:0;padding:.75rem 1.1rem;border-radius:0;">
        Comunicazioni attive — visibili su tutti i portali espositore
        <span style="float:right;font-weight:400;font-size:.75rem;color:var(--text-muted);">
          Stand con portale abilitato: <strong><%= totalStands %></strong>
        </span>
      </div>

      <% if(!announcements || announcements.length===0){ %>
        <div style="padding:3rem 1.5rem;text-align:center;color:var(--text-muted);">
          <div style="font-size:2rem;margin-bottom:.5rem;">📭</div>
          <p style="font-size:.85rem;margin:0;">Nessuna comunicazione pubblicata.</p>
        </div>
      <% } else { %>
      <div id="ann-list">
        <% announcements.forEach(function(a){ %>
        <%
          var typeColor = {info:'#1d6fa4', warning:'#c9a227', urgent:'#c0392b'};
          var typeBg    = {info:'#dbeafe', warning:'#fef9c3', urgent:'#fde8e8'};
          var typeLabel = {info:'INFO', warning:'AVVISO', urgent:'URGENTE'};
          var tc = typeColor[a.type] || typeColor.info;
          var tb = typeBg[a.type]    || typeBg.info;
          var tl = typeLabel[a.type] || 'INFO';
          var readPct = totalStands > 0 ? Math.round((readMap[a.id]||0)/totalStands*100) : 0;
          var isExpired = a.expires_at && new Date(a.expires_at) < new Date();
        %>
        <div class="ann-row<%= a.is_pinned ? ' ann-pinned' : '' %><%= isExpired ? ' ann-expired' : '' %>"
             id="ann-<%= a.id %>" style="padding:1rem 1.2rem;border-bottom:1px solid var(--border-light);display:flex;gap:1rem;align-items:flex-start;">

          <!-- emoji + pin indicator -->
          <div style="font-size:1.6rem;line-height:1;flex-shrink:0;padding-top:.1rem;">
            <%= a.emoji || '📣' %>
          </div>

          <!-- main content -->
          <div style="flex:1;min-width:0;">
            <div style="display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;margin-bottom:.3rem;">
              <% if(a.is_pinned){ %>
                <span style="font-size:.65rem;background:#1e2d4e;color:#f5c842;padding:.15rem .5rem;border-radius:9999px;font-weight:800;letter-spacing:.3px;">📌 FISSATO</span>
              <% } %>
              <span style="font-size:.68rem;font-weight:800;padding:.15rem .55rem;border-radius:9999px;
                           background:<%= tb %>;color:<%= tc %>;letter-spacing:.3px;"><%= tl %></span>
              <% if(isExpired){ %>
                <span style="font-size:.65rem;background:#f3f4f6;color:#9ca3af;padding:.15rem .5rem;border-radius:9999px;font-weight:700;">SCADUTO</span>
              <% } %>
              <strong style="font-size:.88rem;"><%= a.title %></strong>
            </div>
            <p style="font-size:.82rem;color:var(--text-secondary);margin:0 0 .5rem;white-space:pre-wrap;"><%= a.message %></p>
            <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap;">
              <span style="font-size:.7rem;color:var(--text-muted);">
                👤 <%= a.author || 'admin' %> &nbsp;·&nbsp;
                🕐 <%= (a.created_at||'').substring(0,16).replace('T',' ') %>
                <% if(a.expires_at){ %> &nbsp;·&nbsp; ⏳ scade <%= a.expires_at.substring(0,10) %><% } %>
              <% if(a.target_group_name){ %> &nbsp;·&nbsp; <span style="background:#fef3c7;color:#92400e;font-size:.7rem;font-weight:700;padding:.1rem .45rem;border-radius:9999px;">🏷️ Solo: <%= a.target_group_name %></span><% } %>
              </span>
              <!-- read progress -->
              <div style="display:flex;align-items:center;gap:.4rem;">
                <div style="width:80px;height:5px;background:var(--border-light);border-radius:9999px;overflow:hidden;">
                  <div style="height:5px;width:<%= readPct %>%;background:#2d6a4f;border-radius:9999px;transition:width .4s;"></div>
                </div>
                <span style="font-size:.68rem;color:var(--text-muted);">
                  <strong style="color:#2d6a4f;"><%= readMap[a.id]||0 %></strong>/<%= totalStands %> letti
                </span>
              </div>
            </div>
          </div>

          <!-- actions -->
          <div style="display:flex;flex-direction:column;gap:.35rem;flex-shrink:0;">
            <button onclick="togglePin(<%= a.id %>)" title="<%= a.is_pinned ? 'Sblocca' : 'Fissa in cima' %>"
              style="background:none;border:1px solid var(--border);border-radius:var(--radius-sm);padding:.3rem .55rem;cursor:pointer;font-size:.78rem;transition:background .15s;"
              id="pin-btn-<%= a.id %>">
              <%= a.is_pinned ? '📌 Sblocca' : '📌 Fissa' %>
            </button>
            <button onclick="deleteAnn(<%= a.id %>)" class="btn-danger" style="font-size:.78rem;padding:.3rem .55rem;">
              🗑 Elimina
            </button>
          </div>
        </div>
        <% }); %>
      </div>
      <% } %>
    </div>
  </div>

  <!-- ── FORM NUOVO ANNUNCIO ── -->
  <div>
    <div class="card" style="position:sticky;top:1rem;">
      <div class="card-title">✏️ Nuova comunicazione</div>
      <form method="POST" action="/admin/bacheca">

        <label>Emoji <span class="req">*</span>
          <div style="display:flex;gap:.4rem;flex-wrap:wrap;margin-top:.35rem;" id="emoji-picker">
            <% ['📣','📍','⚠️','🚨','ℹ️','✅','🎉','🚗','⏰','📋'].forEach(function(e){ %>
              <button type="button" onclick="pickEmoji('<%= e %>')"
                style="font-size:1.3rem;background:none;border:2px solid transparent;border-radius:6px;padding:.15rem .25rem;cursor:pointer;line-height:1;transition:border-color .1s;"
                class="emoji-btn" data-e="<%= e %>"><%= e %></button>
            <% }); %>
          </div>
          <input type="hidden" name="emoji" id="emoji-val" value="📣">
        </label>

        <label style="margin-top:.75rem;">Tipo
          <select name="type" style="margin-top:.2rem;">
            <option value="info">ℹ️ Info (blu)</option>
            <option value="warning">⚠️ Avviso (giallo)</option>
            <option value="urgent">🚨 Urgente (rosso)</option>
          </select>
        </label>

        <label style="margin-top:.75rem;">Destinatari
          <select name="target_group_id" style="margin-top:.2rem;">
            <option value="">📢 Tutti gli espositori</option>
            <% allGroups.forEach(function(g){ %>
              <option value="<%= g.id %>">🏷️ <%= g.name %></option>
            <% }); %>
          </select>
        </label>

        <label style="margin-top:.75rem;">Titolo <span class="req">*</span>
          <input type="text" name="title" maxlength="100" placeholder="Es: Parcheggio riservato cambiato" required style="margin-top:.2rem;">
        </label>

        <label style="margin-top:.75rem;">Messaggio <span class="req">*</span>
          <textarea name="message" rows="4" maxlength="600" required
            placeholder="Scrivi il testo del messaggio..." style="margin-top:.2rem;resize:vertical;"></textarea>
          <span style="font-size:.7rem;color:var(--text-muted);" id="msg-counter">0/600</span>
        </label>

        <label style="margin-top:.75rem;">
          <input type="checkbox" name="is_pinned" value="1" style="width:auto;display:inline;margin-right:.35rem;">
          📌 Fissa in cima (visibile prima degli altri)
        </label>

        <label style="margin-top:.75rem;">Scadenza (opzionale)
          <input type="date" name="expires_at" style="margin-top:.2rem;">
          <span style="font-size:.7rem;color:var(--text-muted);">Lascia vuoto = nessuna scadenza</span>
        </label>

        <!-- ANTEPRIMA LIVE -->
        <div id="preview-box" style="margin-top:1rem;display:none;padding:.75rem 1rem;border-radius:var(--radius-sm);border:1px solid var(--border-light);background:var(--bg-section);">
          <div style="font-size:.65rem;font-weight:800;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);margin-bottom:.4rem;">ANTEPRIMA PORTALE</div>
          <div style="display:flex;gap:.65rem;align-items:flex-start;">
            <span id="pv-emoji" style="font-size:1.4rem;">📣</span>
            <div>
              <div style="display:flex;gap:.35rem;align-items:center;margin-bottom:.25rem;">
                <span id="pv-badge" style="font-size:.65rem;font-weight:800;padding:.12rem .45rem;border-radius:9999px;background:#dbeafe;color:#1d6fa4;">INFO</span>
                <strong id="pv-title" style="font-size:.85rem;"></strong>
              </div>
              <p id="pv-msg" style="font-size:.8rem;margin:0;color:#4a5568;white-space:pre-wrap;"></p>
            </div>
          </div>
        </div>

        <button type="submit" class="primary" style="width:100%;margin-top:1rem;justify-content:center;">
          📢 Pubblica su tutti i portali
        </button>
      </form>
    </div>
  </div>
</div>

<style>
.ann-pinned { background: #fffbeb; }
.ann-expired { opacity: .55; }
.ann-row { transition: background .15s; }
.ann-row:hover { background: #f7f8ff; }
</style>

<script>
// Emoji picker
var selEmoji = '📣';
function pickEmoji(e) {
  selEmoji = e;
  document.getElementById('emoji-val').value = e;
  document.querySelectorAll('.emoji-btn').forEach(function(b){
    b.style.borderColor = b.dataset.e === e ? '#1e2d4e' : 'transparent';
  });
  document.getElementById('pv-emoji').textContent = e;
}
pickEmoji('📣');

// Live preview
var typeColors = { info: ['#dbeafe','#1d6fa4','INFO'], warning: ['#fef9c3','#c9a227','AVVISO'], urgent: ['#fde8e8','#c0392b','URGENTE'] };
function updatePreview() {
  var t = document.querySelector('[name=title]').value;
  var m = document.querySelector('[name=message]').value;
  var tp = document.querySelector('[name=type]').value;
  var box = document.getElementById('preview-box');
  if (t || m) {
    box.style.display = 'block';
    document.getElementById('pv-title').textContent = t;
    document.getElementById('pv-msg').textContent = m;
    var c = typeColors[tp] || typeColors.info;
    var badge = document.getElementById('pv-badge');
    badge.style.background = c[0]; badge.style.color = c[1]; badge.textContent = c[2];
  } else { box.style.display = 'none'; }
}
document.querySelector('[name=title]').addEventListener('input', updatePreview);
document.querySelector('[name=message]').addEventListener('input', function(){
  updatePreview();
  document.getElementById('msg-counter').textContent = this.value.length + '/600';
});
document.querySelector('[name=type]').addEventListener('change', updatePreview);

// Toggle pin
function togglePin(id) {
  fetch('/admin/bacheca/'+id+'/pin', {method:'POST'})
    .then(function(r){ return r.json(); })
    .then(function(d) {
      var row = document.getElementById('ann-'+id);
      var btn = document.getElementById('pin-btn-'+id);
      if (d.pinned) {
        row.classList.add('ann-pinned');
        btn.textContent = '📌 Sblocca';
      } else {
        row.classList.remove('ann-pinned');
        btn.textContent = '📌 Fissa';
      }
    });
}

// Delete
function deleteAnn(id) {
  if (!confirm('Eliminare questa comunicazione? Scomparirà da tutti i portali.')) return;
  fetch('/admin/bacheca/'+id, {method:'DELETE'})
    .then(function(r){ return r.json(); })
    .then(function(){ document.getElementById('ann-'+id).remove(); });
}
</script>

<%- include('partials/footer') %>
