<%- include('partials/header') %>
<nav class="breadcrumb-bar">Sei in: <a href="/home">Home</a> <span class="sep">&rsaquo;</span> <strong>Import CSV/Excel</strong></nav>
<h1 class="page-title">&#128229; Import massivo assegnatari</h1>
<% if(result){ %>
  <div style="background:<%= result.errors&&result.errors.length?'#fdf0f0':'#f0fdf4' %>;border:1.5px solid <%= result.errors&&result.errors.length?'#c0392b':'#2d6a4f' %>;border-radius:8px;padding:.8rem 1rem;display:flex;gap:.75rem;margin-bottom:1rem;font-size:.85rem;">
    <span><%= result.errors&&result.errors.length?'&#9888;':'&#9989;' %></span>
    <div><strong>Import completato</strong><br>
      <span style="color:#2d6a4f;font-weight:700"><%= result.ok %> importati</span> &middot;
      <span style="color:#c9a227;font-weight:700"><%= result.skip %> saltati</span>
      <% if(result.errors&&result.errors.length){ %><ul style="margin:.3rem 0 0 1rem;font-size:.78rem;color:#c0392b;"><% result.errors.slice(0,10).forEach(function(e){ %><li><%= e %></li><% }); %></ul><% } %>
    </div></div>
<% } %>
<div class="card"><p style="font-size:.85rem;margin-bottom:.9rem;">Formato: <code>.csv</code> / <code>.xlsx</code> — Colonne: <code>cognome;nome;email;ruolo</code></p>
  <a href="/import/template.csv" class="secondary" style="font-size:.82rem;">&#11015; Scarica template CSV</a></div>
<div class="card"><div class="card-title">Carica file</div>
  <form method="post" action="/import" enctype="multipart/form-data" style="display:grid;gap:.85rem;max-width:480px;">
    <label style="font-weight:700;font-size:.88rem;">Gruppo <span style="color:#c0392b">*</span><br>
      <select name="group_id" required style="margin-top:.35rem;width:100%;"><option value="">— seleziona —</option>
        <% groups.forEach(function(g){ %><option value="<%= g.id %>"><%= g.cat?g.cat+' › ':'' %><%= g.name %></option><% }); %>
      </select></label>
    <label style="font-weight:700;font-size:.88rem;">File <span style="color:#c0392b">*</span><br>
      <input type="file" name="file" accept=".csv,.xlsx,.xls" required style="margin-top:.35rem;display:block;"></label>
    <div style="display:flex;gap:.75rem;"><button type="submit" class="primary">&#128228; Avvia import</button><a href="/participants" class="secondary">Annulla</a></div>
  </form></div>
<%- include('partials/footer') %>