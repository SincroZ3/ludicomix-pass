<%-include('partials/header') %>
<nav class="breadcrumb-bar">Sei in: <a href="/home">Home</a> <span class="sep">›</span> <strong>Assegnatari Pass</strong></nav>
<h1 class="page-title">Assegnatari Pass</h1>

<% const isViewer = currentUser && currentUser.role === 'viewer'; %>

<!-- BARRA RICERCA + FILTRO ZONA -->
<div class="card" style="margin-bottom:1rem;padding:0.85rem 1.1rem;">
  <div style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:flex-end;">
    <div style="flex:2;min-width:200px;">
      <label style="margin:0;font-size:0.78rem;">🔍 Ricerca testuale (nome gruppo, stand, codice, note…)<br>
        <input type="text" id="search-input" placeholder="Scrivi per filtrare…" oninput="applyFilters()" style="margin-top:0.25rem;">
      </label>
    </div>
    <div style="flex:1;min-width:160px;">
      <label style="margin:0;font-size:0.78rem;">📍 Filtra per Zona / Padiglione<br>
        <select id="zone-filter" onchange="applyFilters()" style="margin-top:0.25rem;">
          <option value="">— Tutte le zone —</option>
          <%
            const dbZoneNames = (typeof zones !== 'undefined' ? zones : []).map(function(z){ return z.name; });
            const legacyZones = [...new Set(assignmentGroups.map(function(ag){ return ag.zone; }).filter(function(z){ return z && z.trim() && !dbZoneNames.includes(z); }))].sort();
            const allZones    = dbZoneNames.concat(legacyZones).sort();
          %>
          <% allZones.forEach(function(z){ %><option value="<%= z %>"><%= z %></option><% }); %>
        </select>
      </label>
    </div>
    <button type="button" onclick="clearFilters()" class="secondary" style="height:38px;margin-bottom:1px;">✕ Azzera</button>
  </div>
  <div id="filter-count" style="font-size:0.78rem;color:var(--text-muted);margin-top:0.5rem;"></div>
</div>

<!-- TAB CATEGORIE -->
<div class="pill-tabs" id="cat-tabs">
  <% categories.forEach(function(c, idx){ %>
    <button type="button" class="pill-tab <%= idx === 0 ? 'active' : '' %>" data-cat-tab data-cat-id="<%= c.id %>"><%= c.name %></button>
  <% }); %>
</div>

<% categories.forEach(function(c, idx){ %>
  <% const catGroups = assignmentGroups.filter(ag => ag.group_id === c.id); %>
  <section class="category-panel" data-cat-panel data-cat-id="<%= c.id %>" style="<%= idx === 0 ? '' : 'display:none' %>">
    <div class="category-header">
      <h2 style="margin:0;">
        <%= c.name %>
        <span class="chip cat-count" data-cat-id="<%= c.id %>" style="margin-left:0.4rem;"><%= catGroups.length %> gruppi</span>
      </h2>
      <% if (!isViewer) { %>
        <button type="button" class="primary" onclick="openGroupModal(<%= c.id %>, '<%- c.name.replace(/'/g, "\\'") %>')">+ Nuovo gruppo / stand</button>
      <% } %>
    </div>

    <% if (catGroups.length === 0) { %>
      <div class="alert alert-info" style="margin-top:0.75rem;"><span>ℹ️</span> Nessun gruppo inserito per questa categoria.</div>
    <% } else { %>
      <div class="table-wrapper" style="margin-top:0.75rem;">
        <table id="table-cat-<%= c.id %>">
          <thead>
            <tr>
              <th>Gruppo / Associazione</th>
              <th>Nome stand</th>
              <th>Zona / Padiglione</th>
              <th>Codice stand</th>
              <th>N. assegnatari</th>
              <th>Max pass</th>
              <th>Note</th>
              <th>Gestione Pass</th>
              <% if (!isViewer) { %><th>Cancella</th><% } %>
            </tr>
          </thead>
          <tbody>
            <% catGroups.forEach(function(ag){ %>
              <tr class="group-row"
                  data-name="<%= (ag.name||'').toLowerCase() %>"
                  data-stand="<%= (ag.stand_name||'').toLowerCase() %>"
                  data-zone="<%= (ag.zone||'').toLowerCase() %>"
                  data-code="<%= (ag.stand_code||'').toLowerCase() %>"
                  data-notes="<%= (ag.notes||'').toLowerCase() %>">
                <td><strong><%= ag.name %></strong></td>
                <td><%= ag.stand_name || ag.name || '' %></td>
                <td><%= ag.zone || '—' %></td>
                <td><%= ag.stand_code || '—' %></td>
                <td><span class="chip"><%= ag.participants_count || 0 %></span></td>
                <td><%= ag.max_passes != null ? ag.max_passes : 'illimitati' %></td>
                <td style="font-size:0.78rem;color:var(--text-muted);max-width:180px;"><%= ag.notes || '' %></td>
                <td><a href="/assignment-groups/<%= ag.id %>" class="link-action">📋 Gestione Pass</a></td>
                <% if (!isViewer) { %>
                <td>
                  <button type="button" class="btn-danger"
                    onclick="openDeleteGroupModal(<%= ag.id %>, '<%- ag.name.replace(/'/g, "\\'") %>', <%= ag.participants_count || 0 %>)">
                    ✕ Cancella
                  </button>
                </td>
                <% } %>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <div class="no-results-msg" data-cat-id="<%= c.id %>" style="display:none;" class="alert alert-info">
        <div class="alert alert-info"><span>🔍</span> Nessun gruppo corrisponde ai filtri applicati.</div>
      </div>
    <% } %>
  </section>
<% }); %>

<!-- MODALE CANCELLAZIONE GRUPPO -->
<% if (!isViewer) { %>
<div class="modal-overlay" id="modal-delete-group" style="display:none">
  <div class="modal">
    <div class="modal-header danger">
      <h2>⚠️ Conferma cancellazione gruppo</h2>
      <button type="button" class="modal-close" onclick="closeModal('modal-delete-group')">×</button>
    </div>
    <div class="modal-body">
      <p style="margin:0 0 0.4rem;">Stai per cancellare definitivamente il gruppo:</p>
      <p><strong id="delete-group-name" style="font-size:1.05rem;"></strong></p>
      <p id="delete-group-warning" style="color:#922b21;font-weight:700;margin:0.25rem 0;"></p>
      <div class="alert alert-danger"><span>⚠️</span> Operazione <strong>irreversibile</strong>. Tutti i dati associati verranno eliminati.</div>
      <form method="post" id="delete-group-form">
        <div class="modal-actions">
          <button type="button" class="secondary" onclick="closeModal('modal-delete-group')">Annulla</button>
          <button type="submit" style="padding:0.45rem 1.1rem;background:#c0392b;color:#fff;border:none;border-radius:4px;font-weight:700;font-size:0.82rem;cursor:pointer;">Sì, cancella definitivamente</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- MODALE NUOVO GRUPPO -->
<div class="modal-overlay" id="modal-group" style="display:none">
  <div class="modal">
    <div class="modal-header">
      <h2 id="modal-group-title">Nuovo gruppo</h2>
      <button type="button" class="modal-close" onclick="closeModal('modal-group')">×</button>
    </div>
    <form method="post" action="/assignment-groups" class="modal-body">
      <input type="hidden" name="group_id" id="modal-group-id">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.6rem 1rem;">
        <label>Categoria<br><input type="text" id="modal-group-category" disabled></label>
        <label>Nome gruppo <span style="color:#c0392b">*</span><br><input type="text" name="name" required></label>
        <!-- Campi CRM: visibili solo per espositore / associazione -->
        <label class="crm-only-field">Nome stand / riferimento<br><input type="text" name="stand_name"></label>
        <label class="crm-only-field">Zona / Padiglione<br>
          <select name="zone">
            <option value="">&#8212; Nessuna &#8212;</option>
            <% (typeof zones !== 'undefined' ? zones : []).forEach(function(z){ %>
              <option value="<%= z.name %>"><%= z.name %></option>
            <% }); %>
          </select>
        </label>
        <label class="crm-only-field">Codice stand<br><input type="text" name="stand_code"></label>
        <label>Max pass (0 = illimitati)<br><input type="number" name="max_passes" min="0"></label>
        <label style="grid-column:1/-1;">Email di riferimento<br><input type="email" name="email" placeholder="email@esempio.it"></label>
      </div>
      <label>Note<br><textarea name="notes" rows="2"></textarea></label>
      <div class="modal-actions">
        <button type="button" class="secondary" onclick="closeModal('modal-group')">Annulla</button>
        <button type="submit" class="primary">+ Salva</button>
      </div>
    </form>
  </div>
</div>
<% } %>

<!-- MODALE CIUCHINO MARONNO — LIMITE SUPERATO -->
<div class="modal-overlay" id="modal-maronno" style="display:none">
  <div class="modal" style="max-width:520px;">
    <div class="modal-header" style="background:#fff8e1;border-bottom-color:#f6c343;">
      <h2 style="color:#7d5a00;">⚠️ Limite pass superato!</h2>
      <button type="button" class="modal-close" onclick="closeModal('modal-maronno')">×</button>
    </div>
    <div class="modal-body" style="text-align:center;">
      <img src="data:image/jpeg;base64," style="max-width:220px;width:100%;margin:0 auto 0.5rem;display:block;" alt="E se poi te ne penti?">
      <p id="maronno-msg" style="font-size:1rem;font-weight:700;color:#7d5a00;margin:0 0 0.25rem;"></p>
      <p id="maronno-sub" style="font-size:0.85rem;color:var(--text-secondary);margin:0 0 1rem;"></p>
      <div class="card" style="text-align:left;margin:0;">
        <div class="card-title">Vuoi aumentare il limite per procedere?</div>
        <label>Nuovo numero massimo di pass<br>
          <input type="number" id="maronno-new-max" min="1" style="max-width:140px;">
        </label>
        <label style="margin-top:0.5rem;">Password amministratore <span style="color:#c0392b">*</span><br>
          <input type="password" id="maronno-password">
        </label>
        <div id="maronno-error" style="color:#c0392b;font-size:0.82rem;margin-top:0.4rem;display:none;"></div>
      </div>
      <div class="modal-actions" style="margin-top:1rem;">
        <button type="button" class="secondary" onclick="closeModal('modal-maronno')">Annulla</button>
        <button type="button" class="primary" onclick="submitBulkForced()">Aumenta limite e inserisci</button>
      </div>
    </div>
  </div>
</div>

<script>
// ── Filtro + ricerca ──
function applyFilters() {
  const q = (document.getElementById('search-input').value || '').toLowerCase().trim();
  const zone = (document.getElementById('zone-filter').value || '').toLowerCase();
  let totalVisible = 0;

  document.querySelectorAll('[data-cat-panel]').forEach(panel => {
    const catId = panel.getAttribute('data-cat-id');
    const rows = panel.querySelectorAll('tr.group-row');
    let visibleInCat = 0;

    rows.forEach(row => {
      const text = (row.dataset.name + ' ' + row.dataset.stand + ' ' + row.dataset.code + ' ' + row.dataset.notes);
      const zoneMatch = !zone || row.dataset.zone === zone;
      const textMatch = !q || text.includes(q);
      const show = zoneMatch && textMatch;
      row.style.display = show ? '' : 'none';
      if (show) { visibleInCat++; totalVisible++; }
    });

    // Aggiorna counter chip
    const chip = document.querySelector(`.cat-count[data-cat-id="${catId}"]`);
    if (chip) chip.textContent = visibleInCat + ' gruppi';

    // Mostra messaggio nessun risultato
    const noRes = document.querySelector(`.no-results-msg[data-cat-id="${catId}"]`);
    const wrapper = panel.querySelector('.table-wrapper');
    if (noRes) noRes.style.display = (visibleInCat === 0 && rows.length > 0) ? '' : 'none';
  });

  const fc = document.getElementById('filter-count');
  if (q || zone) {
    fc.textContent = `${totalVisible} gruppo/i visibili con i filtri applicati.`;
  } else {
    fc.textContent = '';
  }
}

function clearFilters() {
  document.getElementById('search-input').value = '';
  document.getElementById('zone-filter').value = '';
  applyFilters();
}

// ── Tab categorie ──
(function(){
  const tabs = document.querySelectorAll('[data-cat-tab]');
  const panels = document.querySelectorAll('[data-cat-panel]');
  tabs.forEach(function(btn){
    btn.addEventListener('click', function(){
      const id = this.getAttribute('data-cat-id');
      tabs.forEach(b => b.classList.remove('active'));
      this.classList.add('active');
      panels.forEach(p => p.style.display = p.getAttribute('data-cat-id') === id ? '' : 'none');
    });
  });
})();

// ── Modali ──
function openDeleteGroupModal(groupId, groupName, cnt) {
  document.getElementById('delete-group-name').textContent = groupName;
  const w = document.getElementById('delete-group-warning');
  w.textContent = cnt > 0 ? 'Attenzione: contiene ' + cnt + ' assegnatario/i che verranno eliminati.' : 'Il gruppo non contiene assegnatari.';
  document.getElementById('delete-group-form').action = '/assignment-groups/' + groupId + '/delete';
  document.getElementById('modal-delete-group').style.display = 'flex';
}
function openGroupModal(groupId, categoryName){
  document.getElementById('modal-group-id').value = groupId;
  document.getElementById('modal-group-category').value = categoryName;
  const cat = (categoryName || '').toLowerCase().trim();
  const isCrm = cat.includes('espositore') || cat.includes('associazion');
  document.querySelectorAll('.crm-only-field').forEach(function(el){
    el.style.display = isCrm ? '' : 'none';
  });
  const titles = {
    'ospiti': '🎤 Nuovo gruppo ospiti',
    'espositore': '🏪 Nuovo espositore / stand',
    'associazione': '🤝 Nuova associazione'
  };
  document.getElementById('modal-group-title').textContent = titles[cat] || 'Nuovo gruppo';
  document.getElementById('modal-group').style.display = 'flex';
}
function closeModal(id){ document.getElementById(id).style.display = 'none'; }

// ── Bulk import (gestito da assignment_group_detail) ──
var _bulkPending = null;

function submitBulkForced() {
  if (!_bulkPending) return;
  const newMax = document.getElementById('maronno-new-max').value;
  const pwd = document.getElementById('maronno-password').value;
  const errEl = document.getElementById('maronno-error');

  if (!newMax || parseInt(newMax) < _bulkPending.total_after) {
    errEl.textContent = 'Il nuovo limite deve essere almeno ' + _bulkPending.total_after;
    errEl.style.display = '';
    return;
  }
  if (!pwd) {
    errEl.textContent = 'Inserisci la password amministratore';
    errEl.style.display = '';
    return;
  }
  errEl.style.display = 'none';

  const fd = new FormData(_bulkPending.form);
  fd.set('force_over_limit', '1');
  fd.set('new_max_passes', newMax);
  fd.set('admin_password', pwd);

  fetch('/participants/bulk-import', { method: 'POST', body: fd })
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        closeModal('modal-maronno');
        window.location.reload();
      } else {
        errEl.textContent = data.error || 'Errore';
        errEl.style.display = '';
      }
    })
    .catch(() => { errEl.textContent = 'Errore di rete'; errEl.style.display = ''; });
}
</script>
<%-include('partials/footer') %>
