<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Candidatura Volontario — <%= eventName %></title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --brand-dark:   #1e2d4e;
    --brand-yellow: #f5c842;
    --brand-gold:   #c9a227;
    --brand-violet: #6b3fa0;
    --teal:         #01696f;
    --bg:           #f0f2f5;
    --surface:      #ffffff;
    --border:       #d1d9e6;
    --muted:        #4a5568;
    --error:        #dc2626;
    --success:      #065f46;
    --radius-sm:    4px;
    --radius-md:    8px;
    --radius-lg:    12px;
  }
  body { font-family: -apple-system, 'Segoe UI', Arial, sans-serif; font-size: 14px; background: var(--bg); color: var(--brand-dark); min-height: 100dvh; }

  /* ── TOPBAR (identica al portale interno) ── */
  .topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 1.5rem;
    background: var(--brand-dark);
    min-height: 70px;
    border-bottom: 3px solid var(--brand-yellow);
  }
  .brand { display: flex; align-items: center; gap: 0.75rem; }
  .brand-logo-img { height: 54px; width: auto; display: block; filter: drop-shadow(0 1px 2px rgba(0,0,0,.3)); }
  .brand-ciuco { height: 62px; width: auto; display: block; margin-right: .25rem; filter: drop-shadow(0 2px 4px rgba(0,0,0,.4)); }
  .brand-text-block { display: flex; flex-direction: column; gap: .05rem; }
  .brand-name { font-size: 1.35rem; font-weight: 900; color: var(--brand-yellow); letter-spacing: -.02em; }
  .brand-sub { font-size: .75rem; color: #aec6e8; font-style: italic; letter-spacing: .2px; }
  .topbar-right { display: flex; align-items: center; gap: 1rem; }
  .topbar-badge {
    background: var(--brand-violet);
    color: #fff;
    font-size: .75rem;
    font-weight: 700;
    padding: .3rem .85rem;
    border-radius: 99px;
    letter-spacing: .03em;
  }

  /* ── LAYOUT ── */
  .page-wrap { max-width: 680px; margin: 2.5rem auto; padding: 0 1rem 3rem; }

  /* ── HERO IMMAGINE ── */
  .hero-mascot {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 1.5rem;
    gap: .5rem;
  }
  .hero-mascot img {
    height: 160px;
    width: auto;
    filter: drop-shadow(0 4px 12px rgba(30,45,78,.18));
    animation: bounceIn .5s cubic-bezier(.34,1.56,.64,1) both;
  }
  .hero-mascot .hero-caption {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--brand-dark);
    text-align: center;
  }
  .hero-mascot .hero-sub {
    font-size: .88rem;
    color: var(--muted);
    text-align: center;
    max-width: 380px;
    line-height: 1.5;
  }
  @keyframes bounceIn {
    from { opacity:0; transform:translateY(-20px) scale(.85) }
    to { opacity:1; transform:none }
  }

  /* ── CARD ── */
  .card {
    background: var(--surface);
    border-radius: 16px;
    box-shadow: 0 2px 16px rgba(30,45,78,.09);
    padding: 1.75rem 2rem;
  }

  /* ── FORM ── */
  .section-label {
    font-size: .7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .07em;
    color: var(--teal);
    margin: 1.5rem 0 .75rem;
    padding-bottom: .4rem;
    border-bottom: 2px solid #e8f4f4;
  }
  .section-label:first-of-type { margin-top: 0; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: .85rem; }
  .form-row.single { grid-template-columns: 1fr; }
  @media (max-width: 520px) {
    .form-row { grid-template-columns: 1fr; }
    .card { padding: 1.25rem 1rem; }
    .topbar { flex-direction: column; align-items: flex-start; gap: .5rem; padding: .75rem 1rem; }
  }
  .field { display: flex; flex-direction: column; gap: .35rem; }
  .field label { font-size: .8rem; font-weight: 700; color: var(--brand-dark); }
  .field label .req { color: var(--error); margin-left: .15rem; }
  .field label .opt { font-weight: 400; color: #94a3b8; font-size: .75rem; margin-left: .25rem; }
  input[type="text"], input[type="email"], input[type="tel"], input[type="date"], textarea {
    border: 1.5px solid var(--border);
    border-radius: var(--radius-md);
    padding: .6rem .85rem;
    font-size: .9rem;
    color: var(--brand-dark);
    background: #fafbfc;
    transition: border-color .15s, box-shadow .15s;
    width: 100%;
  }
  input:focus, textarea:focus {
    outline: none;
    border-color: var(--teal);
    box-shadow: 0 0 0 3px rgba(1,105,111,.12);
    background: #fff;
  }
  textarea { min-height: 90px; resize: vertical; }
  input.cf { text-transform: uppercase; font-family: monospace; letter-spacing: .06em; }

  /* Privacy */
  .privacy-box {
    background: #f8fafc;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-md);
    padding: .9rem 1rem;
    display: flex;
    align-items: flex-start;
    gap: .65rem;
    margin-top: 1.5rem;
    cursor: pointer;
  }
  .privacy-box input[type="checkbox"] { width: 18px; height: 18px; margin-top: .1rem; accent-color: var(--teal); cursor: pointer; flex-shrink: 0; }
  .privacy-box label { font-size: .82rem; color: var(--muted); line-height: 1.5; cursor: pointer; }

  /* Submit */
  .btn-submit {
    display: block; width: 100%; margin-top: 1.5rem;
    padding: .85rem;
    background: var(--brand-dark); color: var(--brand-yellow);
    font-size: 1rem; font-weight: 800;
    border: none; border-radius: var(--radius-md);
    cursor: pointer; letter-spacing: .02em;
    transition: background .15s;
  }
  .btn-submit:hover { background: #152240; }

  /* Alert */
  .alert { border-radius: var(--radius-md); padding: .85rem 1rem; font-size: .88rem; margin-bottom: 1.25rem; display: flex; align-items: flex-start; gap: .6rem; }
  .alert-error { background: #fef2f2; border: 1.5px solid #fecaca; color: var(--error); }
  .alert-success { background: #d1fae5; border: 1.5px solid #6ee7b7; color: var(--success); }
  .alert-success h3 { font-size: 1.05rem; font-weight: 800; margin-bottom: .3rem; }
  .page-footer { text-align: center; margin-top: 2rem; font-size: .78rem; color: #94a3b8; }
</style>
</head>
<body>

<!-- TOPBAR identica al portale interno -->
<header class="topbar">
  <div class="brand">
    <img src="data:image/png;base64," alt="Ciuchino mascotte Ludicomix" class="brand-ciuco">
    <img src="data:image/png;base64," alt="Ludicomix logo" class="brand-logo-img">
    <div class="brand-text-block">
      <span class="brand-name"><%= eventName %></span>
      <span class="brand-sub">Gestione Pass &amp; Volontari</span>
    </div>
  </div>
  <div class="topbar-right">
    <span class="topbar-badge">🙋 Candidatura Volontario</span>
  </div>
</header>

<div class="page-wrap">

  <% if (sent) {%>
    <div class="hero-mascot">
      <img src="data:image/jpeg;base64," alt="Ciuchino vuole te!">
      <div class="hero-caption">Candidatura inviata! 🎉</div>
      <div class="hero-sub">Grazie per esserti candidato/a. Riceverai una email di conferma e ti contatteremo presto!</div>
    </div>
    <div class="card" style="text-align:center">
      <a href="/candidatura-volontario" style="font-size:.9rem;color:var(--teal);font-weight:700;text-decoration:none">← Invia un'altra candidatura</a>
    </div>
  <%} else {%>

  <!-- HERO MASCOTTE -->
  <div class="hero-mascot">
    <img src="data:image/jpeg;base64," alt="Ciuchino vuole te!">
    <div class="hero-caption"><%= eventName %> ha bisogno di te!</div>
    <div class="hero-sub">Compila il modulo per candidarti come volontario. Gli organizzatori valuteranno la tua candidatura e ti risponderanno via email.</div>
  </div>

  <div class="card">
    <%if (error) {%>
      <div class="alert alert-error">⚠️ <%= error %></div>
    <%}%>

    <form method="post" action="/candidatura-volontario" novalidate>

      <div class="section-label">Dati personali</div>
      <div class="form-row">
        <div class="field">
          <label>Nome <span class="req">*</span></label>
          <input type="text" name="first_name" required placeholder="Mario" autocomplete="given-name">
        </div>
        <div class="field">
          <label>Cognome <span class="req">*</span></label>
          <input type="text" name="last_name" required placeholder="Rossi" autocomplete="family-name">
        </div>
      </div>
      <div class="form-row" style="margin-top:.85rem">
        <div class="field">
          <label>Email <span class="req">*</span></label>
          <input type="email" name="email" required placeholder="mario.rossi@email.it" autocomplete="email">
        </div>
        <div class="field">
          <label>Telefono <span class="opt">(facoltativo)</span></label>
          <input type="tel" name="phone" placeholder="+39 333 1234567" autocomplete="tel">
        </div>
      </div>

      <div class="section-label">Dati anagrafici <span style="font-weight:400;color:#94a3b8;font-size:.75rem;text-transform:none;letter-spacing:0">(facoltativi — utili a fini assicurativi)</span></div>
      <div class="form-row" style="margin-bottom:.85rem">
        <div class="field">
          <label>Data di nascita</label>
          <input type="date" name="birth_date">
        </div>
        <div class="field">
          <label>Luogo di nascita</label>
          <input type="text" name="birth_place" placeholder="Es. Roma (RM)">
        </div>
      </div>
      <div class="form-row single" style="margin-bottom:.85rem">
        <div class="field">
          <label>Codice fiscale</label>
          <input type="text" name="fiscal_code" class="cf" placeholder="RSSMRA80A01H501Z" maxlength="16">
        </div>
      </div>
      <div class="form-row single">
        <div class="field">
          <label>Luogo di residenza</label>
          <input type="text" name="residence" placeholder="Via Roma 1, 00100 Roma (RM)" autocomplete="street-address">
        </div>
      </div>

      <div class="section-label">Disponibilità e competenze</div>
      <div class="form-row single" style="margin-bottom:.85rem">
        <div class="field">
          <label>Competenze / esperienze <span class="opt">(facoltativo)</span></label>
          <input type="text" name="skills" placeholder="Es. accoglienza, logistica, giochi da tavolo, primo soccorso…">
        </div>
      </div>
      <div class="form-row single" style="margin-bottom:.85rem">
        <div class="field">
          <label>Disponibilità <span class="opt">(facoltativo)</span></label>
          <input type="text" name="availability" placeholder="Es. sabato mattina, tutta la domenica, entrambe le giornate…">
        </div>
      </div>
      <div class="form-row single">
        <div class="field">
          <label>Note aggiuntive <span class="opt">(facoltativo)</span></label>
          <textarea name="notes" placeholder="Qualcosa che vorresti farci sapere…"></textarea>
        </div>
      </div>

      <div class="privacy-box">
        <input type="checkbox" name="privacy" id="privacy" value="1">
        <label for="privacy">
          Acconsento al trattamento dei dati personali forniti ai sensi del
          <strong>Regolamento UE 2016/679 (GDPR)</strong>, per le finalità legate all'organizzazione
          dell'evento e alla gestione dei volontari. I dati non saranno ceduti a terzi.
        </label>
      </div>

      <button type="submit" class="btn-submit">Invia la mia candidatura →</button>
    </form>
  </div>

  <%}%>

  <div class="page-footer"><%= eventName %> &mdash; Portale Volontari</div>
</div>
</body>
</html>
