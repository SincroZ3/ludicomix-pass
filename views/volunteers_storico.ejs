<%- include('partials/header', { path: '/volunteers/storico', currentUser: currentUser }) %>
<div class="container" style="max-width:1100px;margin:1.5rem auto;padding:0 1.25rem 3rem">

  <!-- BREADCRUMB -->
  <div style="font-size:.78rem;color:#64748b;margin-bottom:1.25rem">
    <a href="/home" style="color:#1e2d4e;text-decoration:none">🏠 Home</a>
    <span style="margin:0 .4rem">›</span>
    <a href="/volunteers" style="color:#1e2d4e;text-decoration:none">🙋 Volontari</a>
    <span style="margin:0 .4rem">›</span>
    <span style="color:#64748b">📋 Storico candidature</span>
  </div>

  <!-- HEADER -->
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;flex-wrap:wrap;gap:.75rem">
    <div>
      <h1 style="font-size:1.35rem;font-weight:800;color:#1e2d4e;line-height:1.15">📋 Storico candidature</h1>
      <p style="font-size:.78rem;color:#64748b;margin-top:.15rem">Candidature accettate e rifiutate con data e operatore</p>
    </div>
    <a href="/volunteers" style="display:inline-flex;align-items:center;gap:.4rem;background:#f1f5f9;color:#1e2d4e;border:1.5px solid #d1d9e6;border-radius:8px;padding:.44rem 1rem;font-size:.83rem;font-weight:600;text-decoration:none">← Torna ai volontari</a>
  </div>

  <!-- FILTRO RAPIDO -->
  <div style="display:flex;gap:.5rem;margin-bottom:1.25rem;flex-wrap:wrap">
    <button onclick="filterHistory('all')" id="f-all" class="f-btn f-btn-active">Tutte (<%= history.length %>)</button>
    <button onclick="filterHistory('approved')" id="f-approved" class="f-btn">✅ Accettate (<%= history.filter(function(h){return h.status==='approved'}).length %>)</button>
    <button onclick="filterHistory('rejected')" id="f-rejected" class="f-btn">❌ Rifiutate (<%= history.filter(function(h){return h.status==='rejected'}).length %>)</button>
  </div>

  <% if(!history.length){ %>
  <div style="text-align:center;padding:4rem 1rem;color:#94a3b8">
    <div style="font-size:3rem;margin-bottom:.75rem">📭</div>
    <div style="font-weight:700;color:#64748b;font-size:1rem">Nessuna candidatura elaborata ancora</div>
    <div style="font-size:.83rem;margin-top:.35rem">Le candidature accettate o rifiutate appariranno qui.</div>
  </div>
  <% } else { %>
  <div style="background:#fff;border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;box-shadow:0 1px 4px rgba(30,45,78,.06)">
    <table style="width:100%;border-collapse:collapse;font-size:.85rem">
      <thead>
        <tr style="background:#f8fafc;border-bottom:2px solid #e2e8f0">
          <th style="padding:.75rem 1rem;text-align:left;font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.05em;color:#64748b">Candidato</th>
          <th style="padding:.75rem 1rem;text-align:left;font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.05em;color:#64748b">Contatti</th>
          <th style="padding:.75rem 1rem;text-align:left;font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.05em;color:#64748b">Esito</th>
          <th style="padding:.75rem 1rem;text-align:left;font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.05em;color:#64748b">Data elaborazione</th>
          <th style="padding:.75rem 1rem;text-align:left;font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.05em;color:#64748b">Elaborato da</th>
          <th style="padding:.75rem 1rem;text-align:left;font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.05em;color:#64748b">Note rifiuto</th>
        </tr>
      </thead>
      <tbody id="storico-tbody">
      <% history.forEach(function(h){ %>
        <tr class="storico-row" data-status="<%= h.status %>" style="border-bottom:1px solid #f1f5f9;transition:background .1s" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background=''">
          <td style="padding:.75rem 1rem">
            <div style="font-weight:700;color:#1e2d4e"><%= h.last_name %> <%= h.first_name %></div>
            <div style="font-size:.75rem;color:#94a3b8;margin-top:.1rem">#<%= h.id %> · inviata <%= h.created_at ? h.created_at.slice(0,10) : '—' %></div>
            <% if(h.skills){ %><div style="font-size:.75rem;color:#475569;margin-top:.2rem">🎯 <%= h.skills %></div><% } %>
            <% if(h.availability){ %><div style="font-size:.75rem;color:#475569">🕐 <%= h.availability %></div><% } %>
          </td>
          <td style="padding:.75rem 1rem;color:#475569">
            <% if(h.email){ %><div>✉️ <%= h.email %></div><% } %>
            <% if(h.phone){ %><div>📞 <%= h.phone %></div><% } %>
          </td>
          <td style="padding:.75rem 1rem">
            <% if(h.status === 'approved'){ %>
              <span style="display:inline-flex;align-items:center;gap:.3rem;background:#d1fae5;color:#065f46;border:1px solid #6ee7b7;border-radius:99px;padding:.2rem .7rem;font-size:.75rem;font-weight:700">✅ Accettata</span>
            <% } else { %>
              <span style="display:inline-flex;align-items:center;gap:.3rem;background:#fef2f2;color:#dc2626;border:1px solid #fecaca;border-radius:99px;padding:.2rem .7rem;font-size:.75rem;font-weight:700">❌ Rifiutata</span>
            <% } %>
          </td>
          <td style="padding:.75rem 1rem;color:#475569;font-size:.82rem;font-variant-numeric:tabular-nums">
            <%= h.reviewed_at ? h.reviewed_at.slice(0,16).replace('T',' ') : '—' %>
          </td>
          <td style="padding:.75rem 1rem">
            <% if(h.reviewed_by_name){ %>
              <span style="background:#e0e7ff;color:#3730a3;border-radius:6px;padding:.15rem .55rem;font-size:.78rem;font-weight:600"><%= h.reviewed_by_name %></span>
            <% } else { %>
              <span style="color:#94a3b8;font-size:.8rem">—</span>
            <% } %>
          </td>
          <td style="padding:.75rem 1rem;color:#64748b;font-size:.8rem;max-width:200px">
            <%= h.rejection_reason || '—' %>
          </td>
        </tr>
      <% }); %>
      </tbody>
    </table>
  </div>
  <% } %>

</div>

<style>
  .f-btn { background:#f1f5f9;color:#1e2d4e;border:1.5px solid #d1d9e6;border-radius:8px;padding:.35rem .9rem;font-size:.8rem;font-weight:600;cursor:pointer;font-family:inherit;transition:all .15s }
  .f-btn-active { background:#1e2d4e;color:#f5c842;border-color:#1e2d4e }
  .f-btn:hover:not(.f-btn-active) { background:#e2e8f0 }
</style>
<script>
  function filterHistory(status) {
    document.querySelectorAll('.storico-row').forEach(function(r){
      r.style.display = (status === 'all' || r.dataset.status === status) ? '' : 'none';
    });
    document.querySelectorAll('.f-btn').forEach(function(b){ b.classList.remove('f-btn-active'); });
    document.getElementById('f-' + status).classList.add('f-btn-active');
  }
</script>

<%- include('partials/footer') %>
