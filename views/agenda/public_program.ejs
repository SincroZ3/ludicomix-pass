<!DOCTYPE html>
<html lang="it" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Programma</title>
  <meta name="description" content="Scopri il programma completo di Ludicomix: panel, workshop, talk e tanto altro.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Work+Sans:wght@300..700&display=swap" rel="stylesheet">
  <style>
    /* ── TOKENS ────────────────────────────────────────────── */
    :root {
      --bg:           #f7f6f2;
      --surface:      #f9f8f5;
      --surface-2:    #ffffff;
      --border:       rgba(40,37,29,0.10);
      --divider:      #dcd9d5;
      --text:         #28251d;
      --text-muted:   #7a7974;
      --text-faint:   #bab9b4;
      --primary:      #01696f;
      --primary-h:    #0c4e54;
      --primary-hl:   #cedcd8;
      --accent:       #da7101;
      --error:        #a12c7b;
      --success:      #437a22;
      --shadow-sm:    0 1px 3px rgba(40,37,29,.07);
      --shadow-md:    0 4px 16px rgba(40,37,29,.09);
      --shadow-lg:    0 12px 40px rgba(40,37,29,.13);
      --r-sm: .375rem; --r-md: .5rem; --r-lg: .75rem; --r-xl: 1rem; --r-full: 9999px;
      --font-display: 'Instrument Serif', Georgia, serif;
      --font-body:    'Work Sans', system-ui, sans-serif;
      --trans:        180ms cubic-bezier(.16,1,.3,1);
      --content:      1100px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { -webkit-font-smoothing: antialiased; scroll-behavior: smooth; }
    body { font-family: var(--font-body); font-size: 1rem; color: var(--text); background: var(--bg); min-height: 100dvh; }
    img { display: block; max-width: 100%; height: auto; }
    a { color: inherit; text-decoration: none; }
    button { cursor: pointer; font: inherit; border: none; background: none; }
    ::selection { background: color-mix(in oklab, var(--primary) 20%, transparent); }

    /* ── LAYOUT ─────────────────────────────────────────────── */
    .container { max-width: var(--content); margin-inline: auto; padding-inline: 1.25rem; }

    /* ── TOPBAR ─────────────────────────────────────────────── */
    .topbar {
      background: var(--primary);
      color: #fff;
      padding: 1rem 0;
      position: sticky; top: 0; z-index: 100;
      box-shadow: var(--shadow-md);
    }
    .topbar-inner {
      display: flex; align-items: center; justify-content: space-between; gap: 1rem;
      flex-wrap: wrap;
    }
    .topbar-brand { display: flex; align-items: center; gap: .75rem; }
    .brand-logo {
      width: 36px; height: 36px; flex-shrink: 0;
    }
    .brand-title { font-family: var(--font-display); font-size: 1.35rem; color: #fff; line-height: 1.1; }
    .brand-sub  { font-size: .75rem; opacity: .8; letter-spacing: .04em; }
    .topbar-nav { display: flex; gap: .5rem; align-items: center; }
    .nav-tab {
      padding: .45rem .9rem; border-radius: var(--r-full);
      font-size: .875rem; font-weight: 500; color: rgba(255,255,255,.75);
      transition: background var(--trans), color var(--trans);
    }
    .nav-tab:hover, .nav-tab.active {
      background: rgba(255,255,255,.18); color: #fff;
    }
    .nav-tab.active { font-weight: 700; }
    .qr-btn {
      padding: .45rem .9rem; border-radius: var(--r-full);
      font-size: .8rem; font-weight: 600;
      background: rgba(255,255,255,.15); color: #fff;
      border: 1px solid rgba(255,255,255,.25);
      display: flex; align-items: center; gap: .4rem;
      transition: background var(--trans);
    }
    .qr-btn:hover { background: rgba(255,255,255,.25); }

    /* ── HERO ────────────────────────────────────────────────── */
    .hero {
      background: linear-gradient(135deg in oklab, var(--primary) 0%, #0c4e54 60%, #1a3a30 100%);
      color: #fff; padding: clamp(2.5rem,6vw,5rem) 0 clamp(2rem,4vw,3.5rem);
      text-align: center;
    }
    .hero-eyebrow {
      font-size: .8rem; letter-spacing: .12em; text-transform: uppercase;
      opacity: .7; margin-bottom: .75rem;
    }
    .hero-title {
      font-family: var(--font-display); font-size: clamp(2.4rem,5vw,4.2rem);
      line-height: 1.08; margin-bottom: .75rem;
    }
    .hero-sub { font-size: 1.05rem; opacity: .8; max-width: 44ch; margin-inline: auto; }

    /* ── FEATURED STRIP ─────────────────────────────────────── */
    .featured-strip { padding: 2rem 0 0; }
    .strip-label {
      font-size: .72rem; letter-spacing: .1em; text-transform: uppercase;
      color: var(--text-muted); font-weight: 600; margin-bottom: .9rem;
      display: flex; align-items: center; gap: .5rem;
    }
    .strip-label::after {
      content: ''; flex: 1; height: 1px; background: var(--divider);
    }
    .featured-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(min(300px,100%), 1fr));
      gap: 1rem;
    }
    .featured-card {
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: var(--r-xl);
      overflow: hidden;
      box-shadow: var(--shadow-sm);
      display: flex; flex-direction: column;
      transition: transform var(--trans), box-shadow var(--trans);
    }
    .featured-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
    .featured-img {
      width: 100%; aspect-ratio: 16/7; object-fit: cover;
      background: var(--primary-hl);
    }
    .featured-img-placeholder {
      width: 100%; aspect-ratio: 16/7;
      background: linear-gradient(135deg, var(--primary-hl), color-mix(in oklab, var(--primary) 15%, white));
      display: flex; align-items: center; justify-content: center;
      font-size: 2.5rem;
    }
    .featured-body { padding: 1rem 1.1rem 1.2rem; flex: 1; display: flex; flex-direction: column; }
    .event-meta-row { display: flex; gap: .5rem; align-items: center; flex-wrap: wrap; margin-bottom: .5rem; }
    .tag-type {
      font-size: .7rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase;
      padding: .2em .65em; border-radius: var(--r-full);
      background: var(--primary-hl); color: var(--primary);
    }
    .tag-space {
      font-size: .72rem; padding: .2em .65em; border-radius: var(--r-full);
      background: rgba(40,37,29,.07); color: var(--text-muted);
    }
    .tag-full {
      font-size: .7rem; padding: .2em .65em; border-radius: var(--r-full);
      background: #fce8e1; color: #c0392b; font-weight: 600;
    }
    .featured-title {
      font-family: var(--font-display); font-size: 1.2rem; line-height: 1.25;
      margin-bottom: .35rem;
    }
    .featured-time { font-size: .82rem; color: var(--text-muted); margin-bottom: .4rem; }
    .featured-speakers { font-size: .8rem; color: var(--text-muted); margin-bottom: .75rem; flex: 1; }
    .featured-speakers strong { color: var(--text); }
    .btn-register {
      display: inline-flex; align-items: center; gap: .4rem;
      padding: .55rem 1.1rem; border-radius: var(--r-full);
      background: var(--primary); color: #fff;
      font-size: .85rem; font-weight: 600;
      transition: background var(--trans);
      align-self: flex-start;
    }
    .btn-register:hover { background: var(--primary-h); }
    .btn-register.full { background: var(--text-muted); cursor: default; }

    /* ── FILTERS ─────────────────────────────────────────────── */
    .filters-bar {
      position: sticky; top: 64px; z-index: 50;
      background: var(--surface); border-bottom: 1px solid var(--divider);
      padding: .75rem 0;
    }
    .filters-inner {
      display: flex; gap: .5rem; flex-wrap: wrap; align-items: center;
    }
    .filter-select, .filter-input {
      padding: .45rem .75rem; border-radius: var(--r-full);
      border: 1px solid var(--border);
      background: var(--surface-2); color: var(--text);
      font: inherit; font-size: .85rem;
      transition: border-color var(--trans), box-shadow var(--trans);
    }
    .filter-select:focus, .filter-input:focus {
      outline: none; border-color: var(--primary);
      box-shadow: 0 0 0 3px color-mix(in oklab, var(--primary) 18%, transparent);
    }
    .filter-input { flex: 1; min-width: 160px; max-width: 260px; }
    .filter-btn {
      padding: .45rem .9rem; border-radius: var(--r-full);
      background: var(--primary); color: #fff;
      font-size: .85rem; font-weight: 600;
      transition: background var(--trans);
    }
    .filter-btn:hover { background: var(--primary-h); }
    .filter-reset {
      padding: .45rem .7rem; border-radius: var(--r-full); font-size: .8rem;
      color: var(--text-muted);
      transition: background var(--trans);
    }
    .filter-reset:hover { background: var(--border); }
    .results-count {
      margin-left: auto; font-size: .78rem; color: var(--text-muted);
    }

    /* ── DATE TABS ───────────────────────────────────────────── */
    .date-tabs {
      display: flex; gap: .4rem; flex-wrap: wrap;
      padding: 1.25rem 0 .5rem;
    }
    .date-tab {
      padding: .4rem .85rem; border-radius: var(--r-full);
      font-size: .82rem; font-weight: 500;
      border: 1px solid var(--border);
      color: var(--text-muted); background: var(--surface-2);
      transition: all var(--trans); cursor: pointer;
    }
    .date-tab:hover, .date-tab.active {
      background: var(--primary); color: #fff; border-color: var(--primary);
    }

    /* ── MAIN SECTIONS ───────────────────────────────────────── */
    #section-programma { padding: 1.5rem 0 4rem; }
    #section-ospiti    { padding: 2.5rem 0 4rem; display: none; }

    /* ── EVENT LIST ──────────────────────────────────────────── */
    .day-block { margin-bottom: 2.5rem; }
    .day-header {
      font-family: var(--font-display); font-size: 1.3rem;
      padding-bottom: .5rem; margin-bottom: 1rem;
      border-bottom: 2px solid var(--divider);
      display: flex; align-items: baseline; gap: .75rem;
    }
    .day-header .day-count { font-family: var(--font-body); font-size: .78rem; color: var(--text-muted); font-weight: 400; }
    .event-row {
      display: grid;
      grid-template-columns: 80px 1fr auto;
      gap: .75rem; align-items: start;
      padding: .9rem; border-radius: var(--r-lg);
      background: var(--surface-2); border: 1px solid var(--border);
      margin-bottom: .6rem;
      transition: box-shadow var(--trans), transform var(--trans);
    }
    .event-row:hover { box-shadow: var(--shadow-sm); transform: translateX(2px); }
    .event-time-col {
      text-align: right; padding-right: .75rem;
      border-right: 2px solid var(--divider);
    }
    .event-start { font-weight: 700; font-size: 1rem; color: var(--primary); line-height: 1; }
    .event-end   { font-size: .75rem; color: var(--text-muted); margin-top: .15rem; }
    .event-main-col { display: flex; flex-direction: column; gap: .25rem; }
    .event-title-row {
      display: flex; align-items: flex-start; gap: .5rem; flex-wrap: wrap;
    }
    .event-title { font-weight: 600; font-size: .98rem; line-height: 1.3; }
    .space-dot {
      display: inline-block; width: 10px; height: 10px;
      border-radius: 50%; flex-shrink: 0; margin-top: .3rem;
    }
    .event-info { font-size: .8rem; color: var(--text-muted); display: flex; gap: .5rem; flex-wrap: wrap; }
    .event-speakers { font-size: .82rem; color: var(--text-muted); }
    .event-speakers strong { color: var(--text); }
    .event-action-col { display: flex; flex-direction: column; align-items: flex-end; gap: .4rem; }
    .seats-badge {
      font-size: .72rem; padding: .2em .6em; border-radius: var(--r-full);
      background: rgba(67,122,34,.1); color: var(--success); white-space: nowrap;
    }
    .seats-badge.full { background: rgba(161,44,123,.1); color: var(--error); }
    .btn-iscriviti {
      padding: .4rem .85rem; border-radius: var(--r-full);
      background: var(--primary); color: #fff;
      font-size: .78rem; font-weight: 600;
      transition: background var(--trans); white-space: nowrap;
    }
    .btn-iscriviti:hover { background: var(--primary-h); }

    /* ── EMPTY STATE ─────────────────────────────────────────── */
    .empty-state {
      text-align: center; padding: 4rem 1rem;
      color: var(--text-muted);
    }
    .empty-state .icon { font-size: 3rem; margin-bottom: 1rem; }
    .empty-state h3 { font-size: 1.15rem; color: var(--text); margin-bottom: .5rem; }

    /* ── GUESTS GRID ─────────────────────────────────────────── */
    .section-title {
      font-family: var(--font-display); font-size: clamp(1.6rem,3vw,2.2rem);
      margin-bottom: .5rem;
    }
    .section-sub { color: var(--text-muted); margin-bottom: 2rem; font-size: .95rem; }
    .guests-filter-row { display: flex; gap: .5rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
    .cat-pill {
      padding: .35rem .85rem; border-radius: var(--r-full); font-size: .8rem; font-weight: 500;
      border: 1px solid var(--border); color: var(--text-muted); cursor: pointer;
      transition: all var(--trans); background: var(--surface-2);
    }
    .cat-pill:hover, .cat-pill.active {
      background: var(--primary); color: #fff; border-color: var(--primary);
    }
    .guests-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(min(220px,100%), 1fr));
      gap: 1.2rem;
    }
    .guest-card {
      background: var(--surface-2); border: 1px solid var(--border);
      border-radius: var(--r-xl); overflow: hidden;
      box-shadow: var(--shadow-sm);
      transition: transform var(--trans), box-shadow var(--trans);
      display: flex; flex-direction: column;
    }
    .guest-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
    .guest-photo {
      width: 100%; aspect-ratio: 3/2; object-fit: cover;
      background: var(--primary-hl);
    }
    .guest-photo-placeholder {
      width: 100%; aspect-ratio: 3/2;
      background: linear-gradient(135deg, var(--primary-hl), color-mix(in oklab, var(--primary) 10%, white));
      display: flex; align-items: center; justify-content: center;
      font-size: 3rem; color: var(--primary);
    }
    .guest-body { padding: .9rem 1rem 1.1rem; flex: 1; display: flex; flex-direction: column; }
    .guest-cat {
      font-size: .7rem; letter-spacing: .07em; text-transform: uppercase;
      color: var(--primary); font-weight: 700; margin-bottom: .35rem;
    }
    .guest-name { font-weight: 700; font-size: 1rem; line-height: 1.2; margin-bottom: .3rem; }
    .guest-stand { font-size: .78rem; color: var(--text-muted); margin-bottom: .5rem; }
    .guest-bio {
      font-size: .82rem; color: var(--text-muted); line-height: 1.5; flex: 1;
      display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
    }
    .guest-links { display: flex; gap: .5rem; margin-top: .75rem; flex-wrap: wrap; }
    .guest-link {
      font-size: .75rem; color: var(--primary); font-weight: 500;
      padding: .2rem .55rem; border-radius: var(--r-full);
      border: 1px solid var(--primary-hl);
      transition: background var(--trans);
    }
    .guest-link:hover { background: var(--primary-hl); }
    .featured-star {
      display: inline-block; margin-left: .3rem; font-size: .8rem;
    }

    /* ── QR MODAL ────────────────────────────────────────────── */
    .modal-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,.5);
      display: none; align-items: center; justify-content: center;
      z-index: 1000; padding: 1rem;
    }
    .modal-overlay.open { display: flex; }
    .modal-box {
      background: var(--surface-2); border-radius: var(--r-xl);
      padding: 2rem; text-align: center; max-width: 320px; width: 100%;
      box-shadow: var(--shadow-lg);
    }
    .modal-box h3 { font-family: var(--font-display); font-size: 1.3rem; margin-bottom: .5rem; }
    .modal-box p  { font-size: .85rem; color: var(--text-muted); margin-bottom: 1.25rem; }
    .modal-box img { width: 200px; height: 200px; margin-inline: auto; border-radius: var(--r-md); }
    .modal-close {
      margin-top: 1.25rem; padding: .5rem 1.25rem; border-radius: var(--r-full);
      background: var(--primary); color: #fff; font-size: .85rem; font-weight: 600;
    }

    /* ── FOOTER ──────────────────────────────────────────────── */
    .prog-footer {
      background: #1c1b19; color: rgba(255,255,255,.55);
      padding: 2rem 0; text-align: center; font-size: .8rem;
    }
    .prog-footer a { color: rgba(255,255,255,.75); }

    /* ── MOBILE ──────────────────────────────────────────────── */
    @media (max-width: 640px) {
      .topbar-brand .brand-sub { display: none; }
      .event-row { grid-template-columns: 68px 1fr; }
      .event-action-col { display: none; }
      .filter-input { min-width: 120px; }
      .results-count { display: none; }
      .hero-title { font-size: 2rem; }
    }
    @media (max-width: 480px) {
      .event-row { grid-template-columns: 1fr; }
      .event-time-col { text-align: left; padding-right: 0; border-right: none; border-bottom: 1px solid var(--divider); padding-bottom: .4rem; display: flex; gap: .5rem; align-items: baseline; }
    }
  </style>
</head>
<body>

<!-- ── TOPBAR ─────────────────────────────────────────── -->
<header class="topbar" role="banner">
  <div class="container topbar-inner">
    <div class="topbar-brand">
      <svg class="brand-logo" viewBox="0 0 36 36" fill="none" aria-hidden="true">
        <rect width="36" height="36" rx="8" fill="rgba(255,255,255,.15)"/>
        <path d="M8 26 L18 10 L28 26 M13 20 H23" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="18" cy="28" r="2" fill="white"/>
      </svg>
      <div>
        <div class="brand-title">Ludicomix</div>
        <div class="brand-sub">Programma ufficiale</div>
      </div>
    </div>
    <nav class="topbar-nav" role="navigation" aria-label="Sezioni programma">
      <a href="#" class="nav-tab active" onclick="showSection('programma',this);return false;">📅 Programma</a>
      <% if (guests && guests.length > 0) { %>
      <a href="#" class="nav-tab" onclick="showSection('ospiti',this);return false;">🧑‍🎤 Ospiti</a>
      <% } %>
      <button class="qr-btn" onclick="document.getElementById('qrModal').classList.add('open')" aria-label="Mostra QR code">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><path d="M14 14h3v3m0 4h4m-4-4v4m-3-4h-1"/></svg>
        QR
      </button>
    </nav>
  </div>
</header>

<!-- ── HERO ──────────────────────────────────────────── -->
<section class="hero" role="banner">
  <div class="container">
    <p class="hero-eyebrow">📍 Ludicomix — Edizione 2026</p>
    <h1 class="hero-title">Il Programma</h1>
    <p class="hero-sub">Panel, workshop, talk, ospiti speciali e tanto altro — tutto in un posto solo.</p>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════ -->
<!-- SEZIONE PROGRAMMA                                      -->
<!-- ══════════════════════════════════════════════════════ -->
<div id="section-programma">
  <div class="container">

    <!-- ── FEATURED ─────────────────────────────────────── -->
    <% if (featured && featured.length > 0) { %>
    <section class="featured-strip" aria-label="In evidenza">
      <p class="strip-label">⭐ In evidenza</p>
      <div class="featured-grid">
        <% featured.forEach(ev => { %>
        <article class="featured-card">
          <% if (ev.image_url) { %>
          <img src="<%= ev.image_url %>" alt="<%= ev.title %>" class="featured-img" loading="lazy" width="400" height="175">
          <% } else { %>
          <div class="featured-img-placeholder" aria-hidden="true">
            <%= ev.event_type === 'panel' ? '🎙️' : ev.event_type === 'workshop' ? '🛠️' : ev.event_type === 'talk' ? '💬' : ev.event_type === 'gaming' ? '🎮' : ev.event_type === 'mostra' ? '🖼️' : '✨' %>
          </div>
          <% } %>
          <div class="featured-body">
            <div class="event-meta-row">
              <span class="tag-type"><%= ev.event_type %></span>
              <span class="tag-space"><%= ev.space_name %></span>
              <% if (ev.availability === 'full') { %><span class="tag-full">Sold out</span><% } %>
            </div>
            <h3 class="featured-title"><%= ev.title %></h3>
            <p class="featured-time">
              📅 <%= ev.date %> &nbsp;·&nbsp; 🕐 <%= ev.start_time %>–<%= ev.end_time %>
            </p>
            <% if (ev.speakers_list) { %>
            <p class="featured-speakers"><strong><%= ev.speakers_list %></strong></p>
            <% } %>
            <% if (ev.registrations_open) { %>
            <a href="/programma/iscriviti/<%= ev.id %>"
               class="btn-register<%= ev.availability === 'full' ? ' full' : '' %>"
               <%= ev.availability === 'full' ? 'aria-disabled="true"' : '' %>>
              🎟️ <%= ev.availability === 'full' ? 'Sold out' : 'Iscriviti' %>
            </a>
            <% } %>
          </div>
        </article>
        <% }); %>
      </div>
    </section>
    <% } %>

    <!-- ── FILTERS ────────────────────────────────────────── -->
    <form class="filters-bar" method="GET" action="/programma" role="search" aria-label="Filtri programma">
      <div class="container filters-inner">
        <select name="date" class="filter-select" aria-label="Filtra per data">
          <option value="">Tutte le date</option>
          <% (dates||[]).forEach(d => { %>
          <option value="<%= d.date %>" <%= filters.date === d.date ? 'selected' : '' %>>
            📅 <%= d.date %>
          </option>
          <% }); %>
        </select>
        <select name="space" class="filter-select" aria-label="Filtra per sala">
          <option value="">Tutte le sale</option>
          <% (spaces||[]).forEach(s => { %>
          <option value="<%= s.name %>" <%= filters.space === s.name ? 'selected' : '' %>>
            🏛️ <%= s.name %>
          </option>
          <% }); %>
        </select>
        <select name="type" class="filter-select" aria-label="Filtra per tipo">
          <option value="">Tutti i tipi</option>
          <% ['panel','workshop','talk','mostra','firma copie','gaming','altro'].forEach(t => { %>
          <option value="<%= t %>" <%= filters.type === t ? 'selected' : '' %>><%= t.charAt(0).toUpperCase()+t.slice(1) %></option>
          <% }); %>
        </select>
        <input type="text" name="q" class="filter-input"
               placeholder="🔍 Cerca evento o ospite…"
               value="<%= filters.q || '' %>" aria-label="Cerca">
        <button type="submit" class="filter-btn">Filtra</button>
        <% if (filters.date || filters.space || filters.type || filters.q) { %>
        <a href="/programma" class="filter-reset" aria-label="Rimuovi filtri">✕ Reset</a>
        <% } %>
        <span class="results-count"><%= events.length %> event<%= events.length===1?'o':'i' %></span>
      </div>
    </form>

    <!-- ── DATE TABS (rapidi) ────────────────────────────── -->
    <% if (dates && dates.length > 1 && !filters.q) { %>
    <div class="date-tabs" role="tablist" aria-label="Selezione rapida data">
      <a href="/programma" class="date-tab <%= !filters.date ? 'active' : '' %>" role="tab">Tutti</a>
      <% dates.forEach(d => { %>
      <a href="/programma?date=<%= d.date %><%= filters.space ? '&space='+encodeURIComponent(filters.space) : '' %><%= filters.type ? '&type='+filters.type : '' %>"
         class="date-tab <%= filters.date === d.date ? 'active' : '' %>" role="tab">
        <%= d.date %>
      </a>
      <% }); %>
    </div>
    <% } %>

    <!-- ── EVENTS LIST ───────────────────────────────────── -->
    <% if (!events || events.length === 0) { %>
    <div class="empty-state" role="status">
      <div class="icon">📭</div>
      <h3>Nessun evento pubblicato<%= filters.date ? ' per questa data' : '' %>.</h3>
      <p>Torna presto — il programma si aggiorna costantemente!</p>
    </div>
    <% } else {
      // Raggruppa per data
      const grouped = {};
      events.forEach(ev => {
        if (!grouped[ev.date]) grouped[ev.date] = [];
        grouped[ev.date].push(ev);
      });
      Object.keys(grouped).sort().forEach(date => {
        const dayEvents = grouped[date];
    %>
    <section class="day-block" aria-label="Programma del <%= date %>">
      <% if (!filters.date || Object.keys(grouped).length > 1) { %>
      <h2 class="day-header">
        📅 <%= date %>
        <span class="day-count"><%= dayEvents.length %> event<%= dayEvents.length===1?'o':'i' %></span>
      </h2>
      <% } %>
      <% dayEvents.forEach(ev => {
           const isFull = ev.availability === 'full';
           const hasSeats = ev.max_seats > 0;
      %>
      <article class="event-row" role="article" aria-label="<%= ev.title %>">
        <div class="event-time-col" aria-label="Orario">
          <div class="event-start"><%= ev.start_time %></div>
          <div class="event-end"><%= ev.end_time %></div>
        </div>
        <div class="event-main-col">
          <div class="event-title-row">
            <span class="space-dot" style="background:<%= ev.space_color %>" title="<%= ev.space_name %>"></span>
            <span class="event-title"><%= ev.title %></span>
            <% if (ev.featured) { %><span class="featured-star" aria-label="In evidenza">⭐</span><% } %>
          </div>
          <div class="event-info">
            <span class="tag-type" style="font-size:.68rem"><%= ev.event_type %></span>
            <span>🏛️ <%= ev.space_name %></span>
            <% if (ev.tags) { %><span>🏷️ <%= ev.tags %></span><% } %>
          </div>
          <% if (ev.speakers_list) { %>
          <div class="event-speakers"><strong>🎤 <%= ev.speakers_list %></strong></div>
          <% } %>
        </div>
        <div class="event-action-col">
          <% if (hasSeats) { %>
          <span class="seats-badge<%= isFull ? ' full' : '' %>">
            <%= isFull ? '🔴 Sold out' : '🟢 ' + ev.seats_taken + '/' + ev.max_seats %>
          </span>
          <% } %>
          <% if (ev.registrations_open && !isFull) { %>
          <a href="/programma/iscriviti/<%= ev.id %>" class="btn-iscriviti">🎟️ Iscriviti</a>
          <% } else if (ev.registrations_open && isFull) { %>
          <span class="btn-iscriviti" style="background:var(--text-muted);cursor:default">Sold out</span>
          <% } %>
        </div>
      </article>
      <% }); %>
    </section>
    <% }); } %>

  </div><!-- /.container -->
</div><!-- /#section-programma -->

<!-- ══════════════════════════════════════════════════════ -->
<!-- SEZIONE OSPITI                                         -->
<!-- ══════════════════════════════════════════════════════ -->
<% if (guests && guests.length > 0) { %>
<div id="section-ospiti" style="display:none">
  <div class="container">
    <h2 class="section-title">Gli Ospiti</h2>
    <p class="section-sub">Scopri gli ospiti speciali di questa edizione di Ludicomix.</p>

    <!-- Filtri per categoria -->
    <% const cats = [...new Set(guests.map(g => g.category))]; %>
    <% if (cats.length > 1) { %>
    <div class="guests-filter-row" role="group" aria-label="Filtra per categoria">
      <button class="cat-pill active" onclick="filterGuests('',this)">Tutti</button>
      <% cats.forEach(c => { %>
      <button class="cat-pill" onclick="filterGuests('<%= c %>',this)">
        <%= c.charAt(0).toUpperCase()+c.slice(1) %>
      </button>
      <% }); %>
    </div>
    <% } %>

    <div class="guests-grid" id="guestsGrid">
      <% guests.forEach(g => { %>
      <article class="guest-card" data-category="<%= g.category %>">
        <% if (g.photo_url) { %>
        <img src="<%= g.photo_url %>" alt="<%= g.name %>" class="guest-photo" loading="lazy" width="300" height="200">
        <% } else { %>
        <div class="guest-photo-placeholder" aria-hidden="true">
          <%= g.category === 'autore' ? '✍️' : g.category === 'artista' ? '🎨' : g.category === 'cosplayer' ? '🦸' : g.category === 'youtuber' || g.category === 'streamer' ? '📹' : '🧑‍🎤' %>
        </div>
        <% } %>
        <div class="guest-body">
          <p class="guest-cat"><%= g.category %><%= g.featured ? '<span class="featured-star">⭐</span>' : '' %></p>
          <h3 class="guest-name"><%- g.name %></h3>
          <% if (g.stand_location) { %>
          <p class="guest-stand">📍 <%= g.stand_location %></p>
          <% } %>
          <% if (g.bio) { %>
          <p class="guest-bio"><%= g.bio %></p>
          <% } %>
          <% if (g.website_url || g.social_url) { %>
          <div class="guest-links">
            <% if (g.website_url) { %><a href="<%= g.website_url %>" target="_blank" rel="noopener" class="guest-link">🌐 Sito</a><% } %>
            <% if (g.social_url) { %><a href="<%= g.social_url %>" target="_blank" rel="noopener" class="guest-link">📱 Social</a><% } %>
          </div>
          <% } %>
        </div>
      </article>
      <% }); %>
    </div>

  </div>
</div>
<% } %>

<!-- ── QR MODAL ────────────────────────────────────────── -->
<div class="modal-overlay" id="qrModal" role="dialog" aria-modal="true" aria-label="QR Code programma"
     onclick="if(event.target===this)this.classList.remove('open')">
  <div class="modal-box">
    <h3>📱 QR Code</h3>
    <p>Scansiona per condividere il programma.</p>
    <img src="/programma/qr" alt="QR code del programma" width="200" height="200" loading="lazy">
    <br>
    <button class="modal-close" onclick="document.getElementById('qrModal').classList.remove('open')">
      Chiudi
    </button>
  </div>
</div>

<!-- ── FOOTER ─────────────────────────────────────────── -->
<footer class="prog-footer" role="contentinfo">
  <div class="container">
    <p>Programma aggiornato in tempo reale &nbsp;·&nbsp; <%= title %></p>
    <p style="margin-top:.4rem">
      <a href="/programma/qr">Scarica QR</a>
    </p>
  </div>
</footer>

<script>
// ── TAB SWITCHING ────────────────────────────────────────
function showSection(name, el) {
  document.getElementById('section-programma').style.display = name === 'programma' ? '' : 'none';
  const ospiti = document.getElementById('section-ospiti');
  if (ospiti) ospiti.style.display = name === 'ospiti' ? '' : 'none';
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  if (el) el.classList.add('active');
}

// ── GUEST CATEGORY FILTER ────────────────────────────────
function filterGuests(cat, el) {
  const cards = document.querySelectorAll('#guestsGrid .guest-card');
  cards.forEach(c => {
    c.style.display = (!cat || c.dataset.category === cat) ? '' : 'none';
  });
  document.querySelectorAll('.cat-pill').forEach(p => p.classList.remove('active'));
  if (el) el.classList.add('active');
}

// ── ESC closes modal ────────────────────────────────────
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') document.getElementById('qrModal').classList.remove('open');
});
</script>
</body>
</html>
