<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    :root {
      --brand-dark:   #1e2d4e;
      --brand-yellow: #f5c842;
      --brand-gold:   #c9a227;
      --brand-violet: #6b3fa0;
      --accent-blue:  #1d6fa4;
      --bg:           #f0f2f5;
      --white:        #ffffff;
      --border:       #d1d9e6;
      --border-light: #e8ecf3;
      --text:         #1a2744;
      --muted:        #718096;
      --radius-sm:    4px;
      --radius-md:    8px;
      --radius-lg:    12px;
      --shadow-sm:    0 1px 3px rgba(30,45,78,.10);
      --shadow-md:    0 3px 10px rgba(30,45,78,.15);
    }
    *, *::before, *::after { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: -apple-system, 'Segoe UI', Arial, sans-serif;
      font-size: 15px;
      background: var(--bg);
      color: var(--text);
      line-height: 1.55;
    }
    a { color: var(--accent-blue); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* ── TOPBAR ── */
    .topbar {
      background: var(--brand-dark);
      border-bottom: 3px solid var(--brand-yellow);
      padding: 0 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: .5rem;
      min-height: 70px;
      isolation: isolate;
    }
    .brand { display: flex; align-items: center; gap: .65rem; }
    .brand-ciuco {
      height: 62px; width: auto; display: block;
      margin-right: .2rem;
      filter: drop-shadow(0 2px 4px rgba(0,0,0,.4));
    }
    .brand-logo-img {
      height: 54px; width: auto; display: block;
      mix-blend-mode: lighten;
      filter: drop-shadow(0 1px 2px rgba(0,0,0,.3));
    }
    .brand-text-block { display: flex; flex-direction: column; gap: .05rem; }
    .brand-name { font-size: 1.05rem; font-weight: 800; color: #fff; letter-spacing: .3px; }
    .brand-sub  { font-size: .73rem; color: #aec6e8; font-style: italic; letter-spacing: .2px; }
    .topbar-right { font-size: .8rem; color: rgba(255,255,255,.5); text-align: right; white-space: nowrap; }
    @media (max-width: 600px) {
      .topbar { padding: 0 .9rem; }
      .brand-ciuco { height: 44px; }
      .brand-logo-img { height: 36px; }
    }

    /* ── CONTAINER ── */
    .container { max-width: 1100px; margin: 0 auto; padding: 1.5rem 1rem 3rem; }

    /* ── DATE FILTER ── */
    .date-filter {
      display: flex; gap: .5rem; flex-wrap: wrap;
      margin-bottom: 1.5rem;
      border-bottom: 2px solid var(--border);
      padding-bottom: 1rem;
    }
    .date-btn {
      padding: .4rem 1.1rem;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: var(--white);
      font-size: .8rem; font-weight: 700;
      cursor: pointer; text-decoration: none; color: var(--text);
      transition: background .15s;
    }
    .date-btn:hover { background: var(--border-light); text-decoration: none; }
    .date-btn.active {
      background: var(--brand-dark);
      color: var(--brand-yellow);
      border-color: var(--brand-dark);
    }

    /* ── DAY SECTION ── */
    .day-section { margin-bottom: 2.5rem; }
    .day-label {
      font-size: .75rem; font-weight: 800;
      text-transform: uppercase; letter-spacing: .5px;
      color: var(--muted);
      margin-bottom: 1rem;
      padding-bottom: .4rem;
      border-bottom: 1px solid var(--border-light);
    }

    /* ── EVENT CARD ── */
    .event-card {
      background: var(--white);
      border-radius: var(--radius-md);
      border: 1px solid var(--border);
      box-shadow: var(--shadow-sm);
      padding: 1rem 1.25rem;
      margin-bottom: .75rem;
      display: grid;
      grid-template-columns: 90px 1fr auto;
      gap: 1rem;
      align-items: start;
      cursor: pointer;
      transition: box-shadow .15s, transform .1s;
    }
    .event-card:hover { box-shadow: var(--shadow-md); transform: translateY(-1px); }
    .event-time {
      font-weight: 700; font-size: .9rem;
      color: var(--brand-dark);
      text-align: center; padding-top: .1rem;
    }
    .event-time .end-time { font-size: .75rem; font-weight: 400; color: var(--muted); }
    .event-space {
      display: inline-block; font-size: .72rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .4px;
      padding: .1rem .5rem; border-radius: 999px;
      background: var(--bg); border: 1px solid var(--border);
      color: var(--muted); margin-bottom: .35rem;
    }
    .event-title { font-size: 1rem; font-weight: 700; margin: 0 0 .3rem; color: var(--brand-dark); }
    .event-type {
      display: inline-block; font-size: .7rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .3px;
      padding: .1rem .4rem; border-radius: 3px;
      background: #e8edf8; color: var(--brand-dark); margin-right: .4rem;
    }
    .event-desc { font-size: .83rem; color: var(--muted); margin: .4rem 0; }
    .event-speakers { font-size: .8rem; color: #4a5568; margin-top: .3rem; }
    .event-speakers strong { color: var(--brand-violet); }
    .seats-badge { text-align: right; font-size: .78rem; font-weight: 700; white-space: nowrap; }
    .seats-badge.full      { color: #c0392b; }
    .seats-badge.available { color: #1d6a39; }
    .seats-bar {
      display: block; height: 5px; border-radius: 9999px;
      background: var(--border-light); overflow: hidden;
      margin-top: .3rem; width: 80px; margin-left: auto;
    }
    .seats-bar-fill { height: 100%; background: var(--brand-dark); display: block; }
    .btn-iscriviti {
      display: inline-block; margin-top: .6rem;
      padding: .4rem .9rem;
      background: var(--brand-yellow); color: var(--brand-dark);
      font-weight: 700; font-size: .78rem;
      text-transform: uppercase; letter-spacing: .4px;
      border-radius: var(--radius-sm);
      transition: background .15s; text-decoration: none;
    }
    .btn-iscriviti:hover { background: #ffe066; text-decoration: none; }
    .btn-iscriviti.full { background: var(--border); color: var(--muted); cursor: not-allowed; pointer-events: none; }
    @media (max-width: 600px) {
      .event-card { grid-template-columns: 1fr; gap: .5rem; }
      .seats-badge { text-align: left; }
      .seats-bar { margin-left: 0; }
    }

    /* ── FOOTER ── */
    .footer {
      text-align: center; padding: 2rem 1rem;
      color: var(--muted); font-size: .78rem;
      border-top: 1px solid var(--border-light); margin-top: 2rem;
    }

    /* ── MODAL ── */
    .modal-overlay {
      position: fixed; inset: 0;
      background: rgba(20,28,50,.6);
      backdrop-filter: blur(3px);
      z-index: 1000;
      display: flex; align-items: center; justify-content: center;
      padding: 1rem;
      opacity: 0; pointer-events: none;
      transition: opacity .2s;
    }
    .modal-overlay.open { opacity: 1; pointer-events: all; }
    .modal {
      background: var(--white);
      border-radius: var(--radius-lg);
      box-shadow: 0 20px 60px rgba(20,28,50,.3);
      width: 100%; max-width: 680px; max-height: 90vh;
      overflow-y: auto;
      transform: translateY(20px) scale(.97);
      transition: transform .2s;
    }
    .modal-overlay.open .modal { transform: translateY(0) scale(1); }
    .modal-banner { width: 100%; max-height: 240px; object-fit: cover; border-radius: var(--radius-lg) var(--radius-lg) 0 0; display: block; }
    .modal-banner-placeholder {
      background: linear-gradient(135deg, var(--brand-dark) 0%, #253660 100%);
      height: 110px;
      border-radius: var(--radius-lg) var(--radius-lg) 0 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 2.5rem;
    }
    .modal-body { padding: 1.5rem 1.75rem 1.75rem; }
    .modal-meta { display: flex; flex-wrap: wrap; gap: .6rem; margin-bottom: 1rem; font-size: .8rem; }
    .modal-meta span {
      display: inline-flex; align-items: center; gap: .3rem;
      padding: .25rem .65rem; border-radius: 999px;
      background: var(--bg); border: 1px solid var(--border);
      color: var(--text); font-weight: 600;
    }
    .modal-title { font-size: 1.4rem; font-weight: 700; color: var(--brand-dark); margin: 0 0 .35rem; line-height: 1.25; }
    .modal-type {
      display: inline-block; font-size: .7rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .3px;
      padding: .15rem .5rem; border-radius: 3px;
      background: #e8edf8; color: var(--brand-dark); margin-bottom: .85rem;
    }
    .modal-desc { font-size: .93rem; color: #4a5568; line-height: 1.65; margin-bottom: 1rem; white-space: pre-line; }
    .modal-speakers {
      background: #f4f0fa; border-left: 3px solid var(--brand-violet);
      border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
      padding: .75rem 1rem; margin-bottom: 1rem;
      font-size: .88rem; color: var(--brand-violet); font-weight: 600;
    }
    .modal-tags { display: flex; flex-wrap: wrap; gap: .4rem; margin-bottom: 1.25rem; }
    .modal-tag {
      font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .3px;
      padding: .2rem .6rem; border-radius: 999px;
      background: #e8edf8; color: var(--brand-dark); border: 1px solid var(--border);
    }
    .modal-seats { display: flex; align-items: center; gap: .75rem; margin-bottom: 1.25rem; font-size: .85rem; }
    .modal-seats-bar { flex: 1; height: 6px; border-radius: 9999px; background: var(--border-light); overflow: hidden; }
    .modal-seats-fill { height: 100%; border-radius: 9999px; background: var(--brand-dark); transition: width .4s; }
    .modal-footer {
      display: flex; align-items: center; justify-content: space-between;
      gap: 1rem; padding-top: 1rem; border-top: 1px solid var(--border-light);
    }
    .btn-modal-close {
      padding: .4rem .9rem; border: 1px solid var(--border);
      border-radius: var(--radius-sm); font-size: .82rem; font-weight: 700;
      color: var(--muted); cursor: pointer; background: var(--white); transition: background .15s;
    }
    .btn-modal-close:hover { background: var(--bg); }
    .btn-modal-iscriviti {
      display: inline-block; padding: .5rem 1.25rem;
      background: var(--brand-yellow); color: var(--brand-dark);
      font-weight: 700; font-size: .85rem;
      text-transform: uppercase; letter-spacing: .4px;
      border-radius: var(--radius-sm); transition: background .15s; text-decoration: none;
    }
    .btn-modal-iscriviti:hover { background: #ffe066; text-decoration: none; }
    .btn-modal-iscriviti.full { background: var(--border); color: var(--muted); cursor: not-allowed; pointer-events: none; }
    @media (max-width: 600px) {
      .modal-body { padding: 1.25rem 1.1rem 1.25rem; }
      .modal-title { font-size: 1.15rem; }
    }
  </style>
</head>
<body>

<!-- TOPBAR con loghi Ludicomix -->
<div class="topbar">
  <div class="brand">
    <img src="/img/ciuchino.png" class="brand-ciuco" alt="Ciuchino Ludicomix"
         onerror="this.style.display='none'">
    <img src="/img/logo.png" class="brand-logo-img" alt="Logo Ludicomix"
         onerror="this.style.display='none'">
    <div class="brand-text-block">
      <span class="brand-name">Ludicomix</span>
      <span class="brand-sub">Programma eventi</span>
    </div>
  </div>
  <div class="topbar-right">
    Aggiornato<br>
    <strong style="color:#fff"><%= new Date().toLocaleDateString('it-IT') %></strong>
  </div>
</div>

<div class="container">

  <!-- Filtri data -->
  <% if(dates && dates.length > 1) { %>
  <div class="date-filter">
    <a href="/programma" class="date-btn <%= !filters.date ? 'active' : '' %>">Tutte le date</a>
    <% dates.forEach(function(d){ %>
      <a href="/programma?date=<%= d.date %>"
         class="date-btn <%= filters.date === d.date ? 'active' : '' %>">
        <%= new Date(d.date + 'T12:00:00').toLocaleDateString('it-IT', {weekday:'short', day:'2-digit', month:'short'}) %>
      </a>
    <% }) %>
  </div>
  <% } %>

  <!-- Lista eventi -->
  <% if (!events || events.length === 0) { %>
    <div style="text-align:center;padding:4rem 1rem;color:var(--muted)">
      <div style="font-size:3rem;margin-bottom:.75rem">&#128525;</div>
      <p>Nessun evento pubblicato<%= filters && filters.date ? ' per questa data' : '' %>.</p>
    </div>
  <% } else { %>
    <%
      var byDay = {};
      events.forEach(function(e) {
        if (!byDay[e.date]) byDay[e.date] = [];
        byDay[e.date].push(e);
      });
      var sortedDays = Object.keys(byDay).sort();
    %>
    <% sortedDays.forEach(function(day) { %>
      <div class="day-section">
        <div class="day-label">
          <%= new Date(day + 'T12:00:00').toLocaleDateString('it-IT', {weekday:'long', day:'2-digit', month:'long', year:'numeric'}) %>
        </div>
        <% byDay[day].forEach(function(e) { %>
          <% var isFull = e.availability === 'full'; %>
          <div class="event-card" onclick="openModal(<%= e.id %>)" role="button" tabindex="0">
            <div class="event-time">
              <%= e.starttime %><br>
              <span class="end-time">&ndash; <%= e.endtime %></span>
            </div>
            <div>
              <div>
                <span class="event-space" style="border-color:<%= e.spacecolor || '#d1d9e6' %>"><%= e.spacename %></span>
                <span class="event-type"><%= e.eventtype %></span>
              </div>
              <div class="event-title"><%= e.title %></div>
              <% if (e.description) { %>
                <div class="event-desc"><%= e.description.slice(0, 180) %><%= e.description.length > 180 ? '&hellip;' : '' %></div>
              <% } %>
              <% if (e.speakerslist) { %>
                <div class="event-speakers"><strong><%= e.speakerslist %></strong></div>
              <% } %>
              <% if (e.registrationsopen) { %>
                <% if (isFull) { %>
                  <span class="btn-iscriviti full" onclick="event.stopPropagation()">Posti esauriti</span>
                <% } else { %>
                  <a href="/programma/iscriviti/<%= e.id %>" class="btn-iscriviti" onclick="event.stopPropagation()">Iscriviti &rarr;</a>
                <% } %>
              <% } %>
            </div>
            <div class="seats-badge <%= e.maxseats > 0 ? (isFull ? 'full' : 'available') : '' %>">
              <% if (e.maxseats > 0) { %>
                <%= e.seatstaken %> / <%= e.maxseats %>
                <% if (isFull) { %><br><span>ESAURITO</span><% } %>
                <span class="seats-bar">
                  <span class="seats-bar-fill" style="width:<%= Math.min(100, Math.round(e.seatstaken / e.maxseats * 100)) %>%"></span>
                </span>
              <% } else { %>
                <span style="color:var(--muted);font-weight:400;font-size:.75rem">Ingresso<br>libero</span>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% }) %>
  <% } %>

</div>

<div class="footer">
  <p>Programma aggiornato in tempo reale &middot; <%= title %></p>
</div>

<!-- MODAL dettaglio evento -->
<div class="modal-overlay" id="modal-overlay" onclick="if(event.target===this)closeModal()">
  <div class="modal" role="dialog" aria-modal="true">
    <div id="modal-banner-area"></div>
    <div class="modal-body">
      <div class="modal-meta" id="modal-meta"></div>
      <div id="modal-type-badge" class="modal-type"></div>
      <h2 class="modal-title" id="modal-title"></h2>
      <div class="modal-desc" id="modal-desc"></div>
      <div class="modal-speakers" id="modal-speakers" style="display:none"></div>
      <div class="modal-tags" id="modal-tags" style="display:none"></div>
      <div class="modal-seats" id="modal-seats" style="display:none">
        <span id="modal-seats-label"></span>
        <div class="modal-seats-bar">
          <div class="modal-seats-fill" id="modal-seats-fill"></div>
        </div>
        <span id="modal-seats-pct"></span>
      </div>
      <div class="modal-footer">
        <button class="btn-modal-close" onclick="closeModal()">&#10005; Chiudi</button>
        <span id="modal-iscriviti-wrap"></span>
      </div>
    </div>
  </div>
</div>

<script>
function safeJSON(v) {
  var s = JSON.stringify(v == null ? '' : v);
  return s.replace(/</g, '\u003c').replace(/>/g, '\u003e');
}

var EVENTSDATA = {};
<% if(events && events.length) { events.forEach(function(e) { %>
EVENTSDATA[<%= e.id %>] = {
  id:          <%= e.id %>,
  title:       <%- JSON.stringify(e.title       || '') %>,
  description: <%- JSON.stringify(e.description || '') %>,
  date:        <%- JSON.stringify(e.date        || '') %>,
  starttime:   <%- JSON.stringify(e.starttime   || '') %>,
  endtime:     <%- JSON.stringify(e.endtime     || '') %>,
  spacename:   <%- JSON.stringify(e.spacename   || '') %>,
  spacecolor:  <%- JSON.stringify(e.spacecolor  || '#d1d9e6') %>,
  eventtype:   <%- JSON.stringify(e.eventtype   || '') %>,
  imageurl:    <%- JSON.stringify(e.imageurl    || '') %>,
  tags:        <%- JSON.stringify(e.tags        || '') %>,
  speakers:    <%- JSON.stringify(e.speakerslist|| '') %>,
  maxseats:    <%= e.maxseats   || 0 %>,
  seatstaken:  <%= e.seatstaken || 0 %>,
  regopen:     <%= e.registrationsopen ? 1 : 0 %>,
  isfull:      <%= e.availability === 'full' ? 'true' : 'false' %>
};
<% }) } %>

function openModal(id) {
  var e = EVENTSDATA[id];
  if (!e) return;

  /* banner */
  var ba = document.getElementById('modal-banner-area');
  ba.innerHTML = e.imageurl
    ? '<img src="' + e.imageurl + '" class="modal-banner" alt="">'
    : '<div class="modal-banner-placeholder">&#128197;</div>';

  /* meta pills */
  var dateStr = e.date
    ? new Date(e.date + 'T12:00:00').toLocaleDateString('it-IT', {weekday:'long', day:'2-digit', month:'long', year:'numeric'})
    : '';
  document.getElementById('modal-meta').innerHTML =
    '<span>&#128197; ' + dateStr + '</span>' +
    '<span>&#128336; ' + e.starttime + ' &ndash; ' + e.endtime + '</span>' +
    '<span style="border-color:' + e.spacecolor + '">&#128205; ' + e.spacename + '</span>';

  document.getElementById('modal-type-badge').textContent = e.eventtype;
  document.getElementById('modal-title').textContent = e.title;

  var descEl = document.getElementById('modal-desc');
  descEl.textContent = e.description;
  descEl.style.display = e.description ? '' : 'none';

  var spkEl = document.getElementById('modal-speakers');
  if (e.speakers) {
    spkEl.innerHTML = '&#127908; <strong>' + e.speakers + '</strong>';
    spkEl.style.display = '';
  } else {
    spkEl.style.display = 'none';
  }

  var tagsEl = document.getElementById('modal-tags');
  if (e.tags) {
    var html = e.tags.split(',').map(function(t) {
      return t.trim() ? '<span class="modal-tag">' + t.trim() + '</span>' : '';
    }).join('');
    tagsEl.innerHTML = html;
    tagsEl.style.display = html ? '' : 'none';
  } else {
    tagsEl.style.display = 'none';
  }

  var seatsEl = document.getElementById('modal-seats');
  if (e.maxseats > 0) {
    var pct = Math.min(100, Math.round(e.seatstaken / e.maxseats * 100));
    document.getElementById('modal-seats-label').textContent = e.seatstaken + ' / ' + e.maxseats + ' iscritti';
    document.getElementById('modal-seats-fill').style.width = pct + '%';
    document.getElementById('modal-seats-fill').style.background = e.isfull ? '#c0392b' : 'var(--brand-dark)';
    document.getElementById('modal-seats-pct').textContent = pct + '%';
    seatsEl.style.display = '';
  } else {
    seatsEl.style.display = 'none';
  }

  var wrapEl = document.getElementById('modal-iscriviti-wrap');
  if (e.regopen) {
    wrapEl.innerHTML = e.isfull
      ? '<span class="btn-modal-iscriviti full">Posti esauriti</span>'
      : '<a href="/programma/iscriviti/' + e.id + '" class="btn-modal-iscriviti">Iscriviti gratuitamente &rarr;</a>';
  } else {
    wrapEl.innerHTML = '';
  }

  document.getElementById('modal-overlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

/* FIX: closeModal semplice, nessun controllo su event.target qui */
function closeModal() {
  document.getElementById('modal-overlay').classList.remove('open');
  document.body.style.overflow = '';
}

document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeModal();
});

document.querySelectorAll('.event-card').forEach(function(card) {
  card.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); card.click(); }
  });
});
</script>
</body>
</html>
