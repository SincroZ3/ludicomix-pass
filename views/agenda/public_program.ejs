<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Programma <%= title %></title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, 'Segoe UI', Arial, sans-serif; font-size: 15px; background: #f0ede8; color: #1a2744; line-height: 1.55; }
    a { color: inherit; text-decoration: none; }

    /* ── NAVBAR ── */
    .navbar {
      background: #1e2d4e;
      padding: .6rem 1.5rem;
      display: flex; align-items: center; justify-content: space-between;
      border-bottom: 3px solid #f5c842;
    }
    .navbar-brand { display: flex; align-items: center; gap: .75rem; }
    .navbar-brand img { height: auto; width: auto; object-fit: contain; }
    .navbar-brand .brand-name { font-size: 1.15rem; font-weight: 800; color: #fff; letter-spacing: .2px; line-height: 1; }
    .navbar-brand .brand-sub  { font-size: .68rem; color: #aec6e8; letter-spacing: .5px; text-transform: uppercase; margin-top: 2px; }
    .navbar-actions { display: flex; gap: .5rem; }
    .navbar-actions a {
      display: inline-flex; align-items: center; gap: .35rem;
      padding: .35rem .85rem; border-radius: 999px;
      background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.2);
      color: #fff; font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .4px;
      transition: background .15s;
    }
    .navbar-actions a:hover { background: rgba(255,255,255,.2); }
    .navbar-actions a.active-nav { background: #f5c842; color: #1e2d4e; border-color: #f5c842; }

    /* ── HERO ── */
    .hero {
      background: linear-gradient(175deg, #1e2d4e 0%, #162240 100%);
      padding: 3rem 1rem 3.5rem;
      text-align: center;
      color: #fff;
    }
    .hero-eyebrow {
      display: flex; align-items: center; justify-content: center; gap: .75rem;
      font-size: .72rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase;
      color: #aec6e8; margin-bottom: 1.1rem;
    }
    .hero-eyebrow::before, .hero-eyebrow::after {
      content: ''; display: block; height: 1px; width: 60px; background: rgba(174,198,232,.4);
    }
    .hero h1 {
      font-size: clamp(2.6rem, 7vw, 5rem);
      font-style: italic;
      font-weight: 800;
      color: #f5f0e8;
      letter-spacing: -.5px;
      line-height: 1.05;
      margin-bottom: .9rem;
    }
    .hero-sub {
      font-size: .95rem; color: #aec6e8; max-width: 500px; margin: 0 auto; line-height: 1.6;
    }

    /* ── CONTAINER ── */
    .container { max-width: 1100px; margin: 0 auto; padding: 0 1rem; }

    /* ── FILTER CARD ── */
    .filter-wrap { padding: 1.5rem 0 .75rem; }
    .filter-card {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 2px 12px rgba(30,45,78,.10);
      padding: 1.1rem 1.4rem 1rem;
    }
    .filter-row {
      display: flex; align-items: flex-end; flex-wrap: wrap; gap: .6rem;
    }
    .filter-group { display: flex; flex-direction: column; gap: .3rem; flex: 1; min-width: 140px; }
    .filter-group label {
      font-size: .63rem; font-weight: 800; text-transform: uppercase; letter-spacing: .6px; color: #8896ab;
    }
    .filter-group select,
    .filter-group input {
      padding: .42rem .7rem; border: 1px solid #d1d9e6; border-radius: 6px;
      font-size: .82rem; color: #1a2744; background: #f8f9fc;
      appearance: none; -webkit-appearance: none;
      outline: none; transition: border-color .15s;
      width: 100%;
    }
    .filter-group select:focus, .filter-group input:focus { border-color: #1e2d4e; }
    .filter-group.search { flex: 2; min-width: 200px; }
    .filter-actions { display: flex; gap: .4rem; align-items: flex-end; padding-bottom: 1px; }
    .btn-filtra {
      padding: .44rem 1.2rem; background: #1e2d4e; color: #f5c842;
      border: none; border-radius: 6px; font-size: .8rem; font-weight: 700;
      cursor: pointer; text-transform: uppercase; letter-spacing: .4px; transition: background .15s;
    }
    .btn-filtra:hover { background: #162240; }
    .btn-reset {
      padding: .44rem 1rem; background: transparent; color: #8896ab;
      border: 1px solid #d1d9e6; border-radius: 6px; font-size: .8rem; font-weight: 600;
      cursor: pointer; text-decoration: none; display: inline-block; transition: border-color .15s;
    }
    .btn-reset:hover { border-color: #8896ab; color: #1a2744; }
    .events-count {
      margin-top: .75rem; font-size: .78rem; font-weight: 700; color: #8896ab;
      text-transform: uppercase; letter-spacing: .4px;
    }

    /* ── DAY GROUP ── */
    .events-wrap { padding: .75rem 0 2.5rem; }
    .day-group { margin-bottom: 2.2rem; }
    .day-header {
      display: flex; align-items: center; gap: 1rem;
      margin-bottom: 1rem;
    }
    .day-badge {
      background: #1e2d4e; color: #fff; border-radius: 8px;
      min-width: 58px; height: 58px;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .day-badge .d-num { font-size: 1.7rem; font-weight: 800; line-height: 1; }
    .day-badge .d-mon { font-size: .58rem; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: #aec6e8; }
    .day-info { flex: 1; border-bottom: 2px solid #d1d9e6; padding-bottom: .5rem; }
    .day-info .d-label { font-size: .82rem; font-weight: 800; text-transform: uppercase; letter-spacing: .4px; color: #1a2744; }
    .day-info .d-count { font-size: .72rem; color: #8896ab; font-weight: 600; margin-left: .6rem; }

    /* ── EVENT CARD ── */
    .event-card {
      background: #fff;
      border-radius: 10px;
      border: 1px solid #e2e8f0;
      box-shadow: 0 1px 4px rgba(30,45,78,.07);
      padding: .9rem 1.1rem;
      margin-bottom: .65rem;
      display: grid;
      grid-template-columns: 76px 1fr auto;
      gap: .9rem;
      align-items: start;
      cursor: pointer;
      transition: box-shadow .15s, transform .1s;
    }
    .event-card:hover { box-shadow: 0 4px 16px rgba(30,45,78,.13); transform: translateY(-1px); }
    .event-card.hidden { display: none; }

    /* Time column */
    .ev-time { display: flex; flex-direction: column; align-items: center; padding-top: .1rem; }
    .ev-time .t-start { font-size: 1.1rem; font-weight: 800; color: #1e2d4e; line-height: 1; }
    .ev-time .t-end   { font-size: .75rem; font-weight: 400; color: #8896ab; margin-top: .15rem; }
    .ev-dot { width: 9px; height: 9px; border-radius: 50%; margin-top: auto; margin-top: .9rem; flex-shrink: 0; }

    /* Body column */
    .ev-body { min-width: 0; }
    .ev-tags { display: flex; flex-wrap: wrap; gap: .3rem; margin-bottom: .45rem; }
    .tag {
      display: inline-block; padding: .12rem .45rem;
      border-radius: 4px; font-size: .66rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: .3px; white-space: nowrap;
    }
    .tag-type  { background: #dbe8f7; color: #1d6fa4; }
    .tag-space { background: #dbe8f7; color: #1d6fa4; border: 1px solid #b8d1ed; }
    .tag-other { background: #e8edf8; color: #2d4a7a; }
    .tag-full  { background: #fee2e2; color: #c0392b; }
    .ev-title { font-size: 1rem; font-weight: 700; color: #1a2744; margin-bottom: .2rem; }
    .ev-desc  { font-size: .8rem; color: #718096; margin-top: .3rem; }
    .ev-speakers { font-size: .78rem; color: #4a5568; margin-top: .3rem; }
    .ev-speakers strong { color: #6b3fa0; }

    /* Seats column */
    .ev-seats { text-align: right; white-space: nowrap; padding-top: .1rem; }
    .ev-seats .s-count { font-size: .82rem; font-weight: 700; }
    .ev-seats .s-count.full  { color: #c0392b; }
    .ev-seats .s-count.avail { color: #1d6a39; }
    .ev-seats .s-bar { display: block; height: 5px; border-radius: 9999px; background: #e8ecf3; overflow: hidden; margin-top: .3rem; width: 80px; margin-left: auto; }
    .ev-seats .s-fill { height: 100%; background: #1e2d4e; display: block; }
    .ev-seats .free-label { color: #1d6a39; font-size: .78rem; font-weight: 700; }
    .btn-iscriviti {
      display: inline-block; margin-top: .5rem;
      padding: .35rem .85rem; background: #1e2d4e; color: #f5c842;
      font-size: .72rem; font-weight: 800; text-transform: uppercase; letter-spacing: .4px;
      border-radius: 5px; border: none; cursor: pointer; text-decoration: none;
      transition: background .15s;
    }
    .btn-iscriviti:hover { background: #162240; }
    .btn-iscriviti.disabled { background: #e2e8f0; color: #8896ab; cursor: default; }

    /* ── EMPTY STATE ── */
    .empty-state { text-align: center; padding: 4rem 1rem; color: #8896ab; }
    .empty-state .empty-icon { font-size: 3rem; margin-bottom: .75rem; }

    /* ── FOOTER ── */
    .footer {
      text-align: center; padding: 1.5rem 1rem;
      color: #8896ab; font-size: .75rem;
      border-top: 1px solid #e2e8f0; margin-top: 1rem;
    }

    /* ── OSPITI IN EVIDENZA — CAROUSEL ── */
    .guests-featured-wrap { padding: 1rem 0 .5rem; }
    .guest-carousel-outer { position:relative; }
    .guest-viewport { overflow:hidden; border-radius:12px; }
    .guest-cards-grid {
      display:flex; gap:1rem; margin-top:.8rem;
      transition:transform .4s cubic-bezier(.25,.46,.45,.94);
      will-change:transform;
    }
    .guest-fc {
      flex: 0 0 calc(25% - .75rem);
      background:#fff;
      border-radius:14px;
      box-shadow:0 2px 10px rgba(30,45,78,.09);
      overflow:hidden;
      display:flex;
      flex-direction:column;
      transition:transform .18s,box-shadow .18s;
    }
    .guest-fc:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(30,45,78,.15); }
    .guest-fc-img { width:100%; aspect-ratio:1/1; object-fit:cover; background:#f1f1f1; }
    .guest-fc-img-placeholder { width:100%; aspect-ratio:1/1; background:linear-gradient(135deg,#e8eaf6,#c5cae9); display:flex; align-items:center; justify-content:center; font-size:2.5rem; }
    .guest-fc-body { padding:.75rem .9rem .9rem; flex:1; display:flex; flex-direction:column; gap:.25rem; }
    .guest-fc-name { font-weight:700; font-size:.97rem; color:#1e2d4e; }
    .guest-fc-cat  { font-size:.75rem; color:#6b7280; font-weight:600; text-transform:uppercase; letter-spacing:.4px; }
    .guest-fc-bio  { font-size:.8rem; color:#4b5563; line-height:1.45; margin-top:.25rem; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden; }
    @media(max-width:900px) { .guest-fc { flex: 0 0 calc(50% - .5rem); } }
    @media(max-width:600px) { .guest-fc { flex: 0 0 100%; } }
    .guest-dots { display:flex; justify-content:center; gap:.45rem; margin-top:.75rem; }

    /* ── MODALE OSPITI ── */
    #guestModal .modal-box { max-width: 420px; }
    .guest-modal-photo { width: 120px; height: 120px; border-radius: 50%; object-fit: cover; display: block; margin: 0 auto 1rem; border: 3px solid #e8ecf3; }
    .guest-modal-photo-placeholder { width: 120px; height: 120px; border-radius: 50%; background: linear-gradient(135deg,#e8eaf6,#c5cae9); display: flex; align-items: center; justify-content: center; font-size: 2.8rem; margin: 0 auto 1rem; }
    .guest-modal-name { text-align: center; font-size: 1.2rem; font-weight: 700; color: #1a2744; margin-bottom: .3rem; }
    .guest-modal-cat  { text-align: center; font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .6px; color: #6b3fa0; margin-bottom: .8rem; }
    .guest-modal-bio  { font-size: .87rem; color: #4a5568; line-height: 1.6; }
    .guest-modal-links { display: flex; gap: .6rem; justify-content: center; flex-wrap: wrap; margin-top: .9rem; }
    .guest-modal-link { display: inline-flex; align-items: center; gap: .3rem; font-size: .8rem; color: #6b3fa0; text-decoration: none; background: #f3eeff; border-radius: 99px; padding: .3rem .8rem; }
    .guest-modal-link:hover { background: #e4d5ff; }

    /* ── SHARE BUTTON ── */
    .share-btn { display:inline-flex; align-items:center; gap:.35rem; background:none; border:1px solid #d1d9e8; border-radius:99px; padding:.32rem .85rem; font-size:.78rem; color:#6b7280; cursor:pointer; transition:background .15s,color .15s; }
    .share-btn:hover { background:#f0f4ff; color:#1a2744; }
    .share-toast { position:fixed; bottom:1.5rem; left:50%; transform:translateX(-50%) translateY(80px); background:#1a2744; color:#fff; padding:.6rem 1.2rem; border-radius:99px; font-size:.85rem; opacity:0; transition:opacity .25s,transform .25s; z-index:9999; pointer-events:none; }
    .share-toast.show { opacity:1; transform:translateX(-50%) translateY(0); }

    /* card ospiti cliccabile */
    .guest-fc { cursor: pointer; }
    /* ── IN EVIDENZA CAROUSEL ── */
    .featured-wrap { padding: 1.2rem 0 .5rem; }
    .featured-header { display:flex; align-items:center; gap:.5rem; margin-bottom:.9rem; }
    .featured-label { font-size:.68rem; font-weight:800; text-transform:uppercase; letter-spacing:.8px; color:#92400e; }
    .featured-carousel-outer { position:relative; }
    .featured-viewport { overflow:hidden; border-radius:12px; }
    .featured-track {
      display:flex; gap:1rem;
      transition:transform .4s cubic-bezier(.25,.46,.45,.94);
      will-change:transform;
    }
    .featured-card {
      flex: 0 0 calc(33.333% - .67rem);
      background:#fff; border-radius:12px; overflow:hidden;
      border:1px solid #e2e8f0;
      box-shadow:0 3px 14px rgba(30,45,78,.10);
      cursor:pointer;
      transition:box-shadow .15s, transform .15s;
    }
    .featured-card:hover { box-shadow:0 6px 22px rgba(30,45,78,.16); transform:translateY(-2px); }
    @media(max-width:900px) { .featured-card { flex: 0 0 calc(50% - .5rem); } }
    @media(max-width:600px) { .featured-card { flex: 0 0 100%; } }
    .fc-img-wrap { width:100%; height:190px; background:#111; overflow:hidden; }
    .fc-img { width:100%; height:100%; object-fit:cover; display:block; }
    .fc-img-placeholder { width:100%; height:100%; display:flex; align-items:center; justify-content:center; background:#1a1a2e; }
    .fc-body { padding:.9rem 1.1rem 1.1rem; }
    .fc-tags { display:flex; flex-wrap:wrap; gap:.35rem; margin-bottom:.5rem; }
    .fc-tag-type  { font-size:.65rem; font-weight:700; text-transform:uppercase; letter-spacing:.3px; padding:.15rem .5rem; border-radius:999px; background:#dbe8f7; color:#1d6fa4; }
    .fc-tag-space { font-size:.65rem; font-weight:600; padding:.15rem .6rem; border-radius:999px; background:transparent; border:1px solid #d1d9e6; color:#4a5568; }
    .fc-title { font-size:1.15rem; font-weight:800; color:#1a2744; margin-bottom:.5rem; line-height:1.25; }
    .fc-meta  { font-size:.75rem; color:#8896ab; margin-bottom:.75rem; line-height:1.5; }
    .fc-btn {
      display:inline-block; padding:.45rem 1.2rem;
      background:#0f8080; color:#fff;
      font-size:.8rem; font-weight:700; letter-spacing:.3px;
      border-radius:999px; text-decoration:none; border:none; cursor:pointer;
      transition:background .15s;
    }
    .fc-btn:hover { background:#0a6060; text-decoration:none; }
    .fc-btn.disabled { background:#d1d9e6; color:#8896ab; cursor:default; }
    /* Arrow buttons */
    .carousel-btn {
      position:absolute; top:50%; transform:translateY(-50%);
      width:38px; height:38px; border-radius:50%;
      background:#fff; border:2px solid #e2e8f0;
      box-shadow:0 2px 10px rgba(0,0,0,.15);
      cursor:pointer; display:flex; align-items:center; justify-content:center;
      font-size:1.1rem; color:#1e2d4e; z-index:10;
      transition:background .15s, color .15s, box-shadow .15s;
    }
    .carousel-btn:hover:not(:disabled) { background:#1e2d4e; color:#f5c842; box-shadow:0 4px 14px rgba(30,45,78,.3); }
    .carousel-btn:disabled { opacity:.3; cursor:default; }
    .carousel-btn.prev { left:-19px; }
    .carousel-btn.next { right:-19px; }
    /* Dots */
    .carousel-dots { display:flex; justify-content:center; gap:.45rem; margin-top:.75rem; }
    .c-dot { width:8px; height:8px; border-radius:50%; background:#d1d9e6; transition:background .2s, transform .2s; cursor:pointer; border:none; padding:0; }
    .c-dot.active { background:#1e2d4e; transform:scale(1.25); }

    /* ── MODAL ── */

    .modal-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,.5); z-index: 999;
      justify-content: center; align-items: center; padding: 1rem;
    }
    .modal-overlay.open { display: flex; }
    .modal-box {
      background: #fff; border-radius: 12px;
      box-shadow: 0 8px 32px rgba(0,0,0,.2);
      max-width: 520px; width: 100%; max-height: 88vh; overflow-y: auto;
    }
    .modal-head { padding: 1.1rem 1.4rem .8rem; border-bottom: 1px solid #e8ecf3; position: relative; }
    .modal-head .mtype { font-size: .65rem; font-weight: 800; text-transform: uppercase; letter-spacing: .5px; color: #6b3fa0; margin-bottom: .3rem; }
    .modal-head h3 { margin: 0; font-size: 1.1rem; color: #1a2744; padding-right: 2rem; }
    .modal-close { position: absolute; top: .9rem; right: 1rem; background: none; border: none; font-size: 1.2rem; cursor: pointer; color: #8896ab; }
    .modal-body { padding: 1rem 1.4rem; font-size: .88rem; }
    .modal-meta { color: #8896ab; margin-bottom: .75rem; font-size: .82rem; }
    .modal-foot { padding: .8rem 1.4rem 1.1rem; border-top: 1px solid #e8ecf3; text-align: right; }

    /* ── RESPONSIVE ── */
    /* ── DAY TABS STICKY ── */
    .day-tabs-wrap {
      position: sticky; top: 0; z-index: 100;
      background: #f0ede8;
      padding: .5rem 0 .4rem;
      border-bottom: 1px solid #e2e8f0;
      margin-bottom: .5rem;
    }
    .day-tabs-scroll {
      display: flex; gap: .45rem;
      overflow-x: auto; -webkit-overflow-scrolling: touch;
      scrollbar-width: none; padding: 0 1rem;
    }
    .day-tabs-scroll::-webkit-scrollbar { display: none; }
    .day-tab {
      flex-shrink: 0;
      padding: .38rem .9rem;
      border-radius: 999px;
      border: 1.5px solid #d1d9e6;
      background: #fff;
      font-size: .78rem; font-weight: 700;
      color: #4a5568; cursor: pointer;
      white-space: nowrap;
      transition: background .15s, color .15s, border-color .15s;
    }
    .day-tab:hover  { border-color: #1e2d4e; color: #1e2d4e; }
    .day-tab.active { background: #1e2d4e; color: #f5c842; border-color: #1e2d4e; }

    /* ── FILTRI COLLASSABILI ── */
    .filter-toggle-btn {
      display: none; /* visibile solo mobile */
      width: 100%; padding: .65rem 1rem;
      background: #fff; border: 1px solid #d1d9e6; border-radius: 10px;
      font-size: .9rem; font-weight: 700; color: #1e2d4e;
      cursor: pointer; text-align: left;
      box-shadow: 0 1px 4px rgba(30,45,78,.07);
      justify-content: space-between; align-items: center; gap: .5rem;
    }
    .filter-toggle-btn .ftb-arrow { transition: transform .2s; }
    .filter-toggle-btn.open .ftb-arrow { transform: rotate(180deg); }
    .filter-collapsible {
      overflow: hidden;
      max-height: 1000px;
      transition: max-height .3s ease, opacity .25s ease;
      opacity: 1;
    }
    .filter-collapsible.collapsed { max-height: 0; opacity: 0; }

    /* ── MOBILE: event card verticale ── */
    @media (max-width: 640px) {
      /* filtri collassabili */
      .filter-toggle-btn { display: flex; margin-bottom: .5rem; }
      .filter-collapsible.collapsed { max-height: 0; opacity: 0; }

      /* card eventi: layout verticale a 2 colonne (tempo | body) senza colonna posti */
      .event-card {
        grid-template-columns: 58px 1fr;
        grid-template-rows: auto auto;
        gap: .5rem .75rem;
        padding: .8rem .9rem;
      }
      .ev-time {
        grid-column: 1; grid-row: 1;
        align-items: flex-start; padding-top: .05rem;
      }
      .ev-time .t-start { font-size: 1.05rem; }
      .ev-body {
        grid-column: 2; grid-row: 1;
      }
      /* posti: va sotto, full-width, inline orizzontale */
      .ev-seats {
        grid-column: 1 / -1; grid-row: 2;
        display: flex; align-items: center; gap: .6rem;
        text-align: left; padding-top: 0; padding-left: 0;
        border-top: 1px solid #f0f2f7; margin-top: .2rem; padding-top: .5rem;
      }
      .ev-seats .s-count { font-size: .8rem; white-space: nowrap; }
      .ev-seats .s-bar   { width: 60px; margin-left: 0; margin-top: 0; flex-shrink: 0; }
      .ev-seats .free-label { font-size: .78rem; }
      .btn-iscriviti { margin-top: 0; padding: .28rem .7rem; font-size: .7rem; }

      /* day tabs: visibili su mobile */
      .day-tabs-wrap { display: block; }

      /* hero più compatto */
      .hero { padding: 2rem 1rem 2.2rem; }
      .hero h1 { font-size: clamp(2rem, 9vw, 3rem); }

      /* navbar più compatta */
      .navbar { padding: .4rem .9rem; }
    }
    @media (min-width: 641px) {
      /* Day tabs nascosti su desktop (si usa la select) */
      .day-tabs-wrap { display: none; }
    }
  </style>
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar">
  <div class="navbar-brand">
    <img src="/ciuco.png" alt="Ludicomix" style="height:60px;width:auto;max-width:64px;object-fit:contain;mix-blend-mode:screen">
    <img src="/logo-ludi.png" alt="Ludicomix" style="height:52px;width:auto;object-fit:contain;margin-left:.4rem;mix-blend-mode:screen">
  </div>
  <div class="navbar-actions">
    <a href="/programma" class="active-nav">📅 Programma</a>
    <a href="/ospiti">🎤 Ospiti</a>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-eyebrow">Ludicomix &mdash; Edizione 2026</div>
  <h1>Il Programma</h1>
  <p class="hero-sub">Panel, workshop, talk, ospiti speciali e tanto altro &mdash; tutto in un posto solo.</p>
</section>

<!-- FILTERS -->
<div class="container">
  <div class="filter-wrap">
    <button class="filter-toggle-btn" id="filterToggleBtn" onclick="toggleFilters()" aria-expanded="false" aria-controls="filterCollapsible">
      <span>🔍 Filtra &amp; Cerca</span>
      <span class="ftb-arrow">▼</span>
    </button>
    <div class="filter-collapsible collapsed" id="filterCollapsible">
    <div class="filter-card">
      <form class="filter-row" method="GET" action="/programma" id="filterForm">
        <div class="filter-group">
          <label>Tutte le date</label>
          <select name="date">
            <option value="">Tutte le date</option>
            <% dates.forEach(d => { %>
            <option value="<%= d.date %>" <%= filters.date === d.date ? 'selected' : '' %>>
              <%= new Date(d.date + 'T12:00:00').toLocaleDateString('it-IT',{weekday:'short',day:'2-digit',month:'long'}) %>
            </option>
            <% }); %>
          </select>
        </div>
        <div class="filter-group">
          <label>Tutte le sale</label>
          <select name="space">
            <option value="">Tutte le sale</option>
            <% spaces.forEach(s => { %>
            <option value="<%= s.name %>" <%= filters.space === s.name ? 'selected' : '' %>><%= s.name %></option>
            <% }); %>
          </select>
        </div>
        <div class="filter-group">
          <label>Tutti i tipi</label>
          <select id="filterType" onchange="applyClientFilter()">
            <option value="">Tutti i tipi</option>
          </select>
        </div>
        <div class="filter-group search">
          <label>Cerca evento o ospite&hellip;</label>
          <input type="text" id="filterSearch" placeholder="Cerca evento o ospite..." oninput="applyClientFilter()">
        </div>
        <div class="filter-actions">
          <button type="submit" class="btn-filtra">Filtra</button>
          <a href="/programma" class="btn-reset">Reset</a>
        </div>
      </form>
      <div class="events-count" id="eventsCount"><%= events.length %> eventi</div>
    </div>
    </div><!-- /filter-collapsible -->
  </div>
</div>


<!-- DAY TABS STICKY (mobile) -->
<% if (dates && dates.length > 1) { %>
<div class="day-tabs-wrap" id="dayTabsWrap">
  <div class="day-tabs-scroll" id="dayTabsScroll">
    <button class="day-tab<%= !filters.date ? ' active' : '' %>" onclick="setDayTab('', this)">Tutti</button>
    <% dates.forEach(function(d) {
         var label = new Date(d.date + 'T12:00:00').toLocaleDateString('it-IT',{weekday:'short',day:'2-digit',month:'short'});
         label = label.charAt(0).toUpperCase() + label.slice(1);
    %>
    <button class="day-tab<%= filters.date === d.date ? ' active' : '' %>"
            onclick="setDayTab('<%= d.date %>', this)"
            data-date="<%= d.date %>"><%= label %></button>
    <% }); %>
  </div>
</div>
<% } %>

<!-- OSPITI IN EVIDENZA -->
<% if (typeof featuredGuests !== 'undefined' && featuredGuests.length > 0) { %>
<div class="container">
  <div class="guests-featured-wrap">
    <div class="featured-header">
      <span class="featured-label">🎤 Ospiti in evidenza</span>
    </div>
    <div class="guest-carousel-outer" id="guestOuter">
      <button class="carousel-btn prev" id="guestPrev" onclick="guestSlide(-1)" aria-label="Precedente">&#8592;</button>
      <div class="guest-viewport" id="guestViewport">
        <div class="guest-cards-grid" id="guestTrack">
          <% featuredGuests.forEach(function(g) { %>
          <div class="guest-fc" onclick="openGuestModal(<%= g.assignment_group_id %>)" data-gid="<%= g.assignment_group_id %>">
            <% if (g.photo_url) { %>
              <img src="<%= g.photo_url %>" alt="<%= g.group_name %>" class="guest-fc-img" loading="lazy">
            <% } else { %>
              <div class="guest-fc-img-placeholder">🎤</div>
            <% } %>
            <div class="guest-fc-body">
              <div class="guest-fc-name"><%= g.group_name %></div>
              <% if (g.category) { %><div class="guest-fc-cat"><%= g.category %></div><% } %>
              <% if (g.bio) { %><div class="guest-fc-bio"><%= g.bio %></div><% } %>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
      <button class="carousel-btn next" id="guestNext" onclick="guestSlide(1)" aria-label="Successivo">&#8594;</button>
    </div>
    <div class="guest-dots" id="guestDots"></div>
  </div>
</div>
<% } %>

<!-- IN EVIDENZA -->
<%
  const featured = events.filter(e => e.featured == 1);
%>
<% if (featured.length > 0) { %>
<div class="container">
  <div class="featured-wrap">
    <div class="featured-header">
      <span class="featured-label">⭐ In evidenza</span>
    </div>
    <div class="featured-carousel-outer" id="featuredOuter">
      <button class="carousel-btn prev" id="featPrev" onclick="featSlide(-1)" aria-label="Precedente">&#8592;</button>
      <div class="featured-viewport" id="featViewport">
        <div class="featured-track" id="featTrack">
          <% featured.forEach((ev, fi) => {
               const evImg = ev.imageurl || ev.image_url || '';
               const isFull = ev.availability === 'full';
               const canReg = ev.registrations_open == 1;
          %>
          <div class="featured-card" data-fi="<%= fi %>" onclick="openModal(<%= ev.id %>)" style="cursor:pointer" role="button" tabindex="0" onkeydown="if(event.key==='Enter')openModal(<%= ev.id %>)">
            <div class="fc-img-wrap">
              <% if (evImg) { %>
                <img src="<%= evImg %>" alt="<%= ev.title %>" class="fc-img">
              <% } else { %>
                <div class="fc-img-placeholder">
                  <img src="/ciuco.png" alt="" style="height:100%;object-fit:contain;opacity:.25">
                </div>
              <% } %>
            </div>
            <div class="fc-body">
              <div class="fc-tags">
                <span class="fc-tag-type"><%= ev.event_type || 'evento' %></span>
                <span class="fc-tag-space"><%= ev.space_name %></span>
              </div>
              <div class="fc-title"><%= ev.title %></div>
              <div class="fc-meta">
                📅 <%= new Date(ev.date + 'T12:00:00').toLocaleDateString('it-IT',{day:'2-digit',month:'long',year:'numeric'}) %>
                &nbsp;·&nbsp;
                🕐 <%= ev.start_time %>–<%= ev.end_time %>
              </div>
              <% if (canReg && !isFull) { %>
                <a href="/programma/iscriviti/<%= ev.id %>" class="fc-btn" onclick="event.stopPropagation()">🎫 Iscriviti</a>
              <% } else if (isFull) { %>
                <span class="fc-btn disabled">Posti esauriti</span>
              <% } %>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
      <button class="carousel-btn next" id="featNext" onclick="featSlide(1)" aria-label="Successivo">&#8594;</button>
    </div>
    <div class="carousel-dots" id="featDots"></div>
  </div>
</div>
<% } %>

<!-- EVENTS -->
<div class="container">
  <div class="events-wrap">

  <% if (events.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">📭</div>
      <p>Nessun evento pubblicato per la data selezionata.</p>
    </div>
  <% } else { %>

    <%
      const byDay = {};
      events.forEach(e => { if (!byDay[e.date]) byDay[e.date] = []; byDay[e.date].push(e); });
    %>

    <% Object.entries(byDay).sort((a,b) => a[0].localeCompare(b[0])).forEach(([date, dayEvs]) => {
         const dayDate = new Date(date + 'T12:00:00');
         const dayNum  = dayDate.getDate();
         const dayMon  = dayDate.toLocaleDateString('it-IT',{month:'short'}).toUpperCase().replace('.','');
         const dayFull = dayDate.toLocaleDateString('it-IT',{weekday:'long',day:'2-digit',month:'long',year:'numeric'}).toUpperCase();
    %>
    <div class="day-group" data-date="<%= date %>">
      <div class="day-header">
        <div class="day-badge">
          <span class="d-num"><%= dayNum %></span>
          <span class="d-mon"><%= dayMon %></span>
        </div>
        <div class="day-info">
          <span class="d-label"><%= dayFull %></span>
          <span class="d-count"><%= dayEvs.length %> EVENTO<%= dayEvs.length !== 1 ? 'I' : '' %></span>
        </div>
      </div>

      <% dayEvs.sort((a,b) => a.start_time.localeCompare(b.start_time)).forEach(e => {
           const isFull      = e.availability === 'full';
           const canRegister = e.registrations_open == 1;
           const dotColor    = e.space_color ? '#' + e.space_color.replace('#','') : '#1e2d4e';
           const pct         = (e.max_seats > 0) ? Math.min(100, Math.round((e.seats_taken||0) / e.max_seats * 100)) : 0;
      %>
      <div class="event-card"
           data-type="<%= (e.event_type||'').toLowerCase() %>"
           data-title="<%= e.title.toLowerCase() %>"
           data-speakers="<%= (e.speakers_list||'').toLowerCase() %>"
           onclick="openModal(<%= e.id %>)">

        <!-- Colonna tempo -->
        <div class="ev-time">
          <span class="t-start"><%= e.start_time %></span>
          <span class="t-end"><%= e.end_time %></span>
          <span class="ev-dot" style="background:<%- dotColor %>"></span>
        </div>

        <!-- Colonna body -->
        <div class="ev-body">
          <div class="ev-tags">
            <span class="tag tag-type"><%= e.event_type || 'evento' %></span>
            <span class="tag tag-space">📍 <%= e.space_name %></span>
            <% if (e.tags) { e.tags.split(',').forEach(t => { t = t.trim(); if (t) { %><span class="tag tag-other"><%= t %></span><% } }); } %>
            <% if (isFull) { %><span class="tag tag-full">⊗ Esaurito</span><% } %>
          </div>
          <div class="ev-title"><%= e.title %></div>
          <% if (e.description) { %><div class="ev-desc"><%= e.description.slice(0,200) %><%= e.description.length > 200 ? '…' : '' %></div><% } %>
          <% if (e.speakers_list) { %><div class="ev-speakers">con <strong><%= e.speakers_list %></strong></div><% } %>
        </div>

        <!-- Colonna posti -->
        <div class="ev-seats">
          <% if (e.max_seats > 0) { %>
            <div class="s-count <%= isFull ? 'full' : 'avail' %>"><%= e.seats_taken || 0 %> / <%= e.max_seats %></div>
            <span class="s-bar"><span class="s-fill" style="width:<%= pct %>%"></span></span>
            <% if (canRegister && !isFull) { %>
              <a href="/programma/iscriviti/<%= e.id %>" class="btn-iscriviti" onclick="event.stopPropagation()">Iscriviti →</a>
            <% } else if (isFull) { %>
              <button class="btn-iscriviti disabled" disabled>Posti esauriti</button>
            <% } %>
          <% } else { %>
            <div class="free-label">✓ Ingresso<br>libero</div>
          <% } %>
        </div>

      </div>
      <% }); %>
    </div>
    <% }); %>

  <% } %>
  </div>
</div>

<div class="footer">Programma aggiornato in tempo reale &middot; <%= title %></div>

<!-- MODALE OSPITI -->
<div class="modal-overlay" id="guestModal" onclick="if(event.target===this)closeGuestModal()">
  <div class="modal-box">
    <div class="modal-head">
      <div class="mtype" id="gmType"></div>
      <h3 id="gmTitle"></h3>
      <button class="modal-close" onclick="closeGuestModal()">&#x2715;</button>
    </div>
    <div class="modal-body">
      <div id="gmPhoto"></div>
      <div class="guest-modal-name" id="gmName"></div>
      <div class="guest-modal-cat"  id="gmCat"></div>
      <div class="guest-modal-bio"  id="gmBio"></div>
      <div class="guest-modal-links" id="gmLinks"></div>
    </div>
  </div>
</div>

<!-- SHARE TOAST -->
<div class="share-toast" id="shareToast">🔗 Link copiato!</div>

<!-- MODAL -->
<div class="modal-overlay" id="evModal" onclick="if(event.target===this)closeModal()">
  <div class="modal-box">
    <div class="modal-head">
      <div class="mtype" id="mType"></div>
      <h3 id="mTitle"></h3>
      <button class="modal-close" onclick="closeModal()">&#x2715;</button>
    </div>
    <div class="modal-body">
      <div class="modal-meta" id="mMeta"></div>
      <div id="mDesc"></div>
      <div id="mSpk" style="margin-top:.6rem;font-size:.85rem;color:#4a5568"></div>
      <div id="mSeats" style="margin-top:.6rem;font-size:.82rem;color:#8896ab"></div>
    </div>
    <div class="modal-foot" id="mFoot" style="display:flex;align-items:center;justify-content:space-between;gap:.5rem;"></div>
  </div>
</div>

<script>
/* ── DATI OSPITI (embed server-side) ── */
var GUESTDATA = {};
<% if (typeof featuredGuests !== 'undefined') { featuredGuests.forEach(function(g) { %>
GUESTDATA[<%= g.assignment_group_id %>] = <%- JSON.stringify({
  id: g.assignment_group_id,
  name: g.group_name || '',
  photo: g.photo_url || '',
  bio: g.bio || '',
  category: g.category || '',
  website: g.website || '',
  instagram: g.social_instagram || ''
}) %>;
<% }); } %>

/* ── DATI EVENTI (embed server-side) ── */
var EVDATA = {};
<% events.forEach(e => { %>
EVDATA[<%= e.id %>] = <%- JSON.stringify({
  id: e.id, title: e.title,
  description: e.description || '',
  event_type: e.event_type || '',
  date: e.date, start_time: e.start_time, end_time: e.end_time,
  space_name: e.space_name,
  max_seats: e.max_seats || 0,
  seats_taken: e.seats_taken || 0,
  availability: e.availability || '',
  registrations_open: e.registrations_open || 0,
  speakers_list: e.speakers_list || ''
}) %>;
<% }); %>

/* ── MODAL ── */
function openModal(id) {
  var ev = EVDATA[id]; if (!ev) return;
  var isFull = ev.availability === 'full';
  document.getElementById('mType').textContent = (ev.event_type || '').toUpperCase();
  document.getElementById('mTitle').textContent = ev.title;
  var dateStr = '';
  try { dateStr = new Date(ev.date + 'T12:00:00').toLocaleDateString('it-IT',{weekday:'long',day:'2-digit',month:'long'}); } catch(x) {}
  document.getElementById('mMeta').textContent = '📅 ' + dateStr + '   🕐 ' + ev.start_time + '–' + ev.end_time + '   📍 ' + ev.space_name;
  var desc = document.getElementById('mDesc');
  desc.textContent = ev.description;
  desc.style.display = ev.description ? '' : 'none';
  document.getElementById('mSpk').innerHTML = ev.speakers_list
    ? 'con <strong style="color:#6b3fa0">' + ev.speakers_list + '</strong>' : '';
  document.getElementById('mSeats').textContent = ev.max_seats > 0
    ? (isFull ? '⚠️ Posti esauriti (' + ev.seats_taken + '/' + ev.max_seats + ')'
              : '🪑 ' + (ev.max_seats - ev.seats_taken) + ' posti disponibili su ' + ev.max_seats)
    : '🎟 Ingresso libero';
  var foot = document.getElementById('mFoot');
  var shareBtn = '<button class="share-btn" data-share-id="' + ev.id + '" onclick="shareEvent(this)">🔗 Condividi</button>';
  if (ev.registrations_open && !isFull) {
    foot.innerHTML = '<a href="/programma/iscriviti/' + ev.id + '" class="btn-iscriviti">Iscriviti →</a>' + shareBtn;
  } else if (ev.registrations_open && isFull) {
    foot.innerHTML = '<button class="btn-iscriviti disabled" disabled>Posti esauriti</button>' + shareBtn;
  } else { foot.innerHTML = shareBtn; }
  document.getElementById('evModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeModal() {
  document.getElementById('evModal').classList.remove('open');
  document.body.style.overflow = '';
}
document.addEventListener('keydown', function(e) { if (e.key === 'Escape') { closeModal(); closeGuestModal(); } });

/* ── FEATURED CAROUSEL ── */
(function() {
  var track    = document.getElementById('featTrack');
  var viewport = document.getElementById('featViewport');
  var dotsWrap = document.getElementById('featDots');
  var btnPrev  = document.getElementById('featPrev');
  var btnNext  = document.getElementById('featNext');
  if (!track) return;

  var cards    = track.querySelectorAll('.featured-card');
  var total    = cards.length;
  var current  = 0;
  var autoTimer = null;

  function getVisible() {
    var w = viewport ? viewport.offsetWidth : window.innerWidth;
    if (w <= 600)  return 1;
    if (w <= 900)  return 2;
    return 3;
  }

  function getCardWidth() {
    if (!cards[0]) return 0;
    return cards[0].offsetWidth + 16;
  }

  function maxIndex() { return Math.max(0, total - getVisible()); }

  function update() {
    var vis = getVisible();
    var max = maxIndex();
    current = Math.max(0, Math.min(current, max));
    track.style.transform = 'translateX(-' + (current * getCardWidth()) + 'px)';
    if (btnPrev) btnPrev.disabled = current === 0;
    if (btnNext) btnNext.disabled = current >= max;
    var needArrows = total > vis;
    if (btnPrev) btnPrev.style.display = needArrows ? '' : 'none';
    if (btnNext) btnNext.style.display = needArrows ? '' : 'none';
    if (dotsWrap) {
      dotsWrap.innerHTML = '';
      if (needArrows) {
        for (var i = 0; i <= max; i++) {
          (function(idx) {
            var d = document.createElement('button');
            d.className = 'c-dot' + (idx === current ? ' active' : '');
            d.setAttribute('aria-label', 'Vai a ' + (idx+1));
            d.onclick = function() { current = idx; update(); resetAuto(); };
            dotsWrap.appendChild(d);
          })(i);
        }
      }
    }
  }

  function startAuto() {
    if (autoTimer) clearInterval(autoTimer);
    autoTimer = setInterval(function() {
      current = (current >= maxIndex()) ? 0 : current + 1;
      update();
    }, 5000);
  }

  function resetAuto() { startAuto(); }

  window.featSlide = function(dir) {
    current += dir;
    update();
    resetAuto();
  };

  /* Pausa su hover/touch */
  var outer = document.getElementById('featuredOuter');
  if (outer) {
    outer.addEventListener('mouseenter', function() { if (autoTimer) clearInterval(autoTimer); });
    outer.addEventListener('mouseleave', startAuto);
    outer.addEventListener('touchstart', function() { if (autoTimer) clearInterval(autoTimer); }, { passive: true });
    outer.addEventListener('touchend', function() { resetAuto(); }, { passive: true });
  }

  cards.forEach(function(card) {
    card.addEventListener('click', function(e) {
      if (e.target.tagName === 'A' || e.target.tagName === 'BUTTON') return;
    });
  });

  window.addEventListener('resize', function() { update(); });
  update();
  startAuto();
})();

/* ── GUEST CAROUSEL ── */
(function() {
  var track    = document.getElementById('guestTrack');
  var viewport = document.getElementById('guestViewport');
  var dotsWrap = document.getElementById('guestDots');
  var btnPrev  = document.getElementById('guestPrev');
  var btnNext  = document.getElementById('guestNext');
  if (!track) return;

  var cards    = track.querySelectorAll('.guest-fc');
  var total    = cards.length;
  var current  = 0;
  var autoTimer = null;

  function getVisible() {
    var w = viewport ? viewport.offsetWidth : window.innerWidth;
    if (w <= 600)  return 1;
    if (w <= 900)  return 2;
    return 4;
  }

  function getCardWidth() {
    if (!cards[0]) return 0;
    return cards[0].offsetWidth + 16;
  }

  function maxIndex() { return Math.max(0, total - getVisible()); }

  function update() {
    var vis = getVisible();
    var max = maxIndex();
    current = Math.max(0, Math.min(current, max));
    track.style.transform = 'translateX(-' + (current * getCardWidth()) + 'px)';
    if (btnPrev) btnPrev.disabled = current === 0;
    if (btnNext) btnNext.disabled = current >= max;
    var needArrows = total > vis;
    if (btnPrev) btnPrev.style.display = needArrows ? '' : 'none';
    if (btnNext) btnNext.style.display = needArrows ? '' : 'none';
    if (dotsWrap) {
      dotsWrap.innerHTML = '';
      if (needArrows) {
        for (var i = 0; i <= max; i++) {
          (function(idx) {
            var d = document.createElement('button');
            d.className = 'c-dot' + (idx === current ? ' active' : '');
            d.setAttribute('aria-label', 'Vai a ospite ' + (idx+1));
            d.onclick = function() { current = idx; update(); resetAuto(); };
            dotsWrap.appendChild(d);
          })(i);
        }
      }
    }
  }

  function startAuto() {
    if (autoTimer) clearInterval(autoTimer);
    autoTimer = setInterval(function() {
      current = (current >= maxIndex()) ? 0 : current + 1;
      update();
    }, 4000);
  }

  function resetAuto() { startAuto(); }

  window.guestSlide = function(dir) {
    current += dir;
    update();
    resetAuto();
  };

  /* Pausa su hover/touch */
  var outer = document.getElementById('guestOuter');
  if (outer) {
    outer.addEventListener('mouseenter', function() { if (autoTimer) clearInterval(autoTimer); });
    outer.addEventListener('mouseleave', startAuto);
    outer.addEventListener('touchstart', function() { if (autoTimer) clearInterval(autoTimer); }, { passive: true });
    outer.addEventListener('touchend', function() { resetAuto(); }, { passive: true });
  }

  window.addEventListener('resize', function() { update(); });
  update();
  startAuto();
})();

/* ── FILTRO TIPO (client-side) ── */
(function() {
  var cards = document.querySelectorAll('.event-card');
  var types = {};
  cards.forEach(function(c) { var t = c.dataset.type; if (t && t !== '') types[t] = true; });
  var sel = document.getElementById('filterType');
  Object.keys(types).sort().forEach(function(t) {
    var o = document.createElement('option');
    o.value = t; o.textContent = t.charAt(0).toUpperCase() + t.slice(1);
    sel.appendChild(o);
  });
})();

function applyClientFilter() {
  var typeVal   = document.getElementById('filterType').value.toLowerCase();
  var searchVal = document.getElementById('filterSearch').value.toLowerCase().trim();
  var cards     = document.querySelectorAll('.event-card');
  var visible   = 0;
  cards.forEach(function(c) {
    var matchType   = !typeVal   || c.dataset.type === typeVal;
    var matchSearch = !searchVal || c.dataset.title.includes(searchVal) || c.dataset.speakers.includes(searchVal);
    if (matchType && matchSearch) { c.classList.remove('hidden'); visible++; }
    else                          { c.classList.add('hidden'); }
  });
  document.getElementById('eventsCount').textContent = visible + ' eventi';
}

/* ── FILTRI COLLASSABILI ── */
function toggleFilters() {
  var btn  = document.getElementById('filterToggleBtn');
  var wrap = document.getElementById('filterCollapsible');
  if (!btn || !wrap) return;
  var isOpen = !wrap.classList.contains('collapsed');
  if (isOpen) {
    wrap.classList.add('collapsed');
    btn.classList.remove('open');
    btn.setAttribute('aria-expanded', 'false');
  } else {
    wrap.classList.remove('collapsed');
    btn.classList.add('open');
    btn.setAttribute('aria-expanded', 'true');
  }
}

/* ── DAY TABS STICKY ── */
function setDayTab(dateVal, btnEl) {
  /* aggiorna stato active delle pill */
  document.querySelectorAll('.day-tab').forEach(function(b) { b.classList.remove('active'); });
  if (btnEl) btnEl.classList.add('active');

  /* scroll la pill attiva al centro */
  if (btnEl) {
    var scroll = document.getElementById('dayTabsScroll');
    if (scroll) {
      var btnLeft   = btnEl.offsetLeft;
      var btnWidth  = btnEl.offsetWidth;
      var scrollW   = scroll.offsetWidth;
      scroll.scrollTo({ left: btnLeft - scrollW / 2 + btnWidth / 2, behavior: 'smooth' });
    }
  }

  /* filtra i day-group e gli event-card */
  var groups = document.querySelectorAll('.day-group');
  groups.forEach(function(g) {
    if (!dateVal || g.dataset.date === dateVal) {
      g.style.display = '';
    } else {
      g.style.display = 'none';
    }
  });

  /* aggiorna contatore visibile */
  var visible = 0;
  document.querySelectorAll('.event-card:not(.hidden)').forEach(function(c) {
    var grp = c.closest('.day-group');
    if (!grp || grp.style.display !== 'none') visible++;
  });
  var countEl = document.getElementById('eventsCount');
  if (countEl) countEl.textContent = visible + ' eventi';
}

/* ── MODALE OSPITI ── */
function openGuestModal(id) {
  var g = GUESTDATA[id]; if (!g) return;
  document.getElementById('gmType').textContent = 'OSPITE';
  document.getElementById('gmTitle').textContent = '';
  var photoEl = document.getElementById('gmPhoto');
  if (g.photo) {
    photoEl.innerHTML = '<img src="' + g.photo + '" alt="' + g.name + '" class="guest-modal-photo" loading="lazy">';
  } else {
    photoEl.innerHTML = '<div class="guest-modal-photo-placeholder">🎤</div>';
  }
  document.getElementById('gmName').textContent = g.name;
  document.getElementById('gmCat').textContent  = g.category || '';
  document.getElementById('gmBio').textContent  = g.bio || '';
  var links = document.getElementById('gmLinks');
  links.innerHTML = '';
  if (g.website) {
    links.innerHTML += '<a href="' + g.website + '" target="_blank" rel="noopener" class="guest-modal-link">🌐 Sito web</a>';
  }
  if (g.instagram) {
    var ig = g.instagram.replace(/^@/, '');
    links.innerHTML += '<a href="https://instagram.com/' + ig + '" target="_blank" rel="noopener" class="guest-modal-link">📷 @' + ig + '</a>';
  }
  document.getElementById('guestModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeGuestModal() {
  document.getElementById('guestModal').classList.remove('open');
  document.body.style.overflow = '';
}

/* ── SHARE EVENTO ── */
function shareEvent(btn) {
  var id = btn.dataset.shareId;
  var ev = EVDATA[parseInt(id, 10)];
  var title = ev ? ev.title : '';
  var url = window.location.origin + '/programma#evento-' + id;
  var toast = document.getElementById('shareToast');
  if (navigator.share) {
    navigator.share({ title: title, url: url }).catch(function(){});
  } else if (navigator.clipboard) {
    navigator.clipboard.writeText(url).then(function() {
      toast.classList.add('show');
      setTimeout(function(){ toast.classList.remove('show'); }, 2200);
    });
  } else {
    var ta = document.createElement('textarea');
    ta.value = url; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); document.body.removeChild(ta);
    toast.classList.add('show');
    setTimeout(function(){ toast.classList.remove('show'); }, 2200);
  }
}

</script>

