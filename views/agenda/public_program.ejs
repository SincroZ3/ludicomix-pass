<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>Programma — <%= eventName %></title>
  <style>
    :root {
      --brand-dark:   #1e2d4e;
      --brand-yellow: #f5c842;
      --brand-gold:   #c9a227;
      --brand-violet: #6b3fa0;
      --accent-blue:  #1d6fa4;
      --bg:           #f0f2f5;
      --white:        #ffffff;
      --border:       #d1d9e6;
      --border-light: #e8ecf3;
      --text:         #1a2744;
      --muted:        #718096;
      --radius-sm:    4px;
      --radius-md:    8px;
      --radius-lg:    12px;
      --shadow-sm:    0 1px 3px rgba(30,45,78,.10);
      --shadow-md:    0 3px 10px rgba(30,45,78,.15);
    }
    *, *::before, *::after { box-sizing: border-box; }
    body { margin:0; font-family: -apple-system,'Segoe UI',Arial,sans-serif; font-size:15px; background:var(--bg); color:var(--text); line-height:1.55; }
    a { color:var(--accent-blue); text-decoration:none; }
    a:hover { text-decoration:underline; }

    .topbar {
      background: var(--brand-dark);
      border-bottom: 3px solid var(--brand-yellow);
      padding: .75rem 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .topbar h1 { margin:0; font-size:1.2rem; color:#fff; letter-spacing:.3px; }
    .topbar .brand-sub { font-size:.78rem; color:#aec6e8; }

    .container { max-width:1100px; margin:0 auto; padding:1.5rem 1rem; }

    /* Filtri data */
    .date-filter {
      display:flex; gap:.5rem; flex-wrap:wrap; margin-bottom:1.5rem;
      border-bottom:2px solid var(--border); padding-bottom:1rem;
    }
    .date-btn {
      padding:.4rem 1.1rem; border:1px solid var(--border);
      border-radius: 999px; background:var(--white);
      font-size:.8rem; font-weight:700; cursor:pointer;
      text-decoration:none; color:var(--text); transition:background .15s;
    }
    .date-btn:hover { background:var(--border-light); text-decoration:none; }
    .date-btn.active { background:var(--brand-dark); color:var(--brand-yellow); border-color:var(--brand-dark); }

    /* Day section */
    .day-section { margin-bottom:2.5rem; }
    .day-label {
      font-size:.75rem; font-weight:800; text-transform:uppercase; letter-spacing:.5px;
      color:var(--muted); margin-bottom:1rem; padding-bottom:.4rem; border-bottom:1px solid var(--border-light);
    }

    /* Event card */
    .event-card {
      background:var(--white); border-radius:var(--radius-md); border:1px solid var(--border);
      box-shadow:var(--shadow-sm); padding:1rem 1.25rem; margin-bottom:.75rem;
      display:grid; grid-template-columns:90px 1fr auto; gap:1rem; align-items:start;
    }
    .event-card:hover { box-shadow:var(--shadow-md); }

    .event-time {
      font-weight:700; font-size:.9rem; color:var(--brand-dark); text-align:center;
      padding-top:.1rem;
    }
    .event-time .end-time { font-size:.75rem; font-weight:400; color:var(--muted); }

    .event-space {
      display:inline-block; font-size:.72rem; font-weight:700; text-transform:uppercase;
      letter-spacing:.4px; padding:.1rem .5rem; border-radius:999px;
      background: var(--bg); border:1px solid var(--border); color:var(--muted);
      margin-bottom:.35rem;
    }

    .event-title { font-size:1rem; font-weight:700; margin:0 0 .3rem; color:var(--brand-dark); }
    .event-type { display:inline-block; font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.3px;
      padding:.1rem .4rem; border-radius:3px; background:#e8edf8; color:var(--brand-dark); margin-right:.4rem; }
    .event-desc { font-size:.83rem; color:var(--muted); margin:.4rem 0; }
    .event-speakers { font-size:.8rem; color:#4a5568; margin-top:.3rem; }
    .event-speakers strong { color:var(--brand-violet); }

    .seats-badge {
      text-align:right; font-size:.78rem; font-weight:700; white-space:nowrap;
    }
    .seats-badge.full { color:#c0392b; }
    .seats-badge.available { color:#1d6a39; }
    .seats-badge .seats-bar {
      display:block; height:5px; border-radius:9999px; background:var(--border-light);
      overflow:hidden; margin-top:.3rem; width:80px; margin-left:auto;
    }
    .seats-bar-fill { height:100%; background:var(--brand-dark); display:block; }

    .btn-iscriviti {
      display:inline-block; margin-top:.6rem; padding:.4rem .9rem;
      background:var(--brand-yellow); color:var(--brand-dark);
      font-weight:700; font-size:.78rem; text-transform:uppercase; letter-spacing:.4px;
      border-radius:var(--radius-sm); transition:background .15s; text-decoration:none;
      font-family:'Arial Narrow',Arial,sans-serif;
    }
    .btn-iscriviti:hover { background:#ffe066; text-decoration:none; }
    .btn-iscriviti.full { background:var(--border); color:var(--muted); cursor:not-allowed; }

    .footer { text-align:center; padding:2rem 1rem; color:var(--muted); font-size:.78rem; border-top:1px solid var(--border-light); margin-top:2rem; }

    @media(max-width:600px) {
      .event-card { grid-template-columns:1fr; gap:.5rem; }
      .seats-badge { text-align:left; }
      .seats-badge .seats-bar { margin-left:0; }
    }
  </style>
</head>
<body>

  <div class="topbar">
    <div>
      <h1>📅 Programma <%= eventName %></h1>
      <div class="brand-sub">Tutti gli eventi e le attività</div>
    </div>
    <div style="font-size:.82rem;color:#aec6e8;">Ultimo aggiornamento: <%= new Date().toLocaleDateString('it-IT') %></div>
  </div>

  <div class="container">

    <!-- Filtri data -->
    <% if (dates.length > 1) { %>
      <div class="date-filter">
        <a href="/programma" class="date-btn <%= !selectedDate ? 'active' : '' %>">Tutte le date</a>
        <% dates.forEach(d => { %>
          <a href="/programma?date=<%= d.date %>" class="date-btn <%= selectedDate === d.date ? 'active' : '' %>">
            <%= new Date(d.date).toLocaleDateString('it-IT',{weekday:'short',day:'2-digit',month:'short'}) %>
          </a>
        <% }); %>
      </div>
    <% } %>

    <% if (events.length === 0) { %>
      <div style="text-align:center;padding:4rem 1rem;color:var(--muted);">
        <div style="font-size:3rem;margin-bottom:.75rem;">📭</div>
        <p>Nessun evento pubblicato per la data selezionata.</p>
      </div>
    <% } else { %>
      <% const featured = events.filter(e => e.is_featured); %>
<% if (featured.length > 0) { %>
<div style="margin:0 0 1.8rem;padding:1.2rem 1.4rem;background:linear-gradient(135deg,#fffbe6,#fff7cc);border:2px solid #f5c842;border-radius:12px;">
  <div style="font-size:.68rem;font-weight:800;text-transform:uppercase;letter-spacing:.8px;color:#92400e;margin-bottom:.9rem;">⭐ In evidenza</div>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:.7rem;">
    <% featured.forEach(ev => { %>
    <div style="background:#fff;border-left:4px solid <%- ev.space_color||'#6b3fa0' %>;border-radius:8px;padding:.8rem 1rem;box-shadow:0 2px 8px rgba(30,45,78,.09);">
      <div style="font-size:.63rem;font-weight:800;text-transform:uppercase;letter-spacing:.5px;color:#6b3fa0;margin-bottom:.25rem;"><%= ev.event_type||'evento' %></div>
      <div style="font-size:.9rem;font-weight:700;color:#1a2744;margin-bottom:.45rem;line-height:1.3;"><%= ev.title %></div>
      <div style="display:flex;flex-wrap:wrap;gap:.35rem;font-size:.7rem;color:#64748b;">
        <span>📅 <%= new Date(ev.date).toLocaleDateString('it-IT',{weekday:'short',day:'2-digit',month:'short'}) %></span>
        <span>🕐 <%= ev.start_time %>–<%= ev.end_time %></span>
        <span>📍 <%= ev.space_name %></span>
      </div>
    </div>
    <% }) %>
  </div>
</div>
<% } %>
<% const featured = events.filter(e => e.is_featured); %>
<% if (featured.length > 0) { %>
<div style="margin:0 0 1.8rem;padding:1.2rem 1.4rem;background:linear-gradient(135deg,#fffbe6,#fff7cc);border:2px solid #f5c842;border-radius:12px;">
  <div style="font-size:.68rem;font-weight:800;text-transform:uppercase;letter-spacing:.8px;color:#92400e;margin-bottom:.9rem;">⭐ In evidenza</div>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:.7rem;">
    <% featured.forEach(ev => { %>
    <div style="background:#fff;border-left:4px solid <%- ev.space_color||'#6b3fa0' %>;border-radius:8px;padding:.8rem 1rem;box-shadow:0 2px 8px rgba(30,45,78,.09);">
      <div style="font-size:.63rem;font-weight:800;text-transform:uppercase;letter-spacing:.5px;color:#6b3fa0;margin-bottom:.25rem;"><%= ev.event_type||'evento' %></div>
      <div style="font-size:.9rem;font-weight:700;color:#1a2744;margin-bottom:.45rem;line-height:1.3;"><%= ev.title %></div>
      <div style="display:flex;flex-wrap:wrap;gap:.35rem;font-size:.7rem;color:#64748b;">
        <span>📅 <%= new Date(ev.date).toLocaleDateString('it-IT',{weekday:'short',day:'2-digit',month:'short'}) %></span>
        <span>🕐 <%= ev.start_time %>–<%= ev.end_time %></span>
        <span>📍 <%= ev.space_name %></span>
      </div>
    </div>
    <% }) %>
  </div>
</div>
<% } %>
<% const byDay = {}; events.forEach(e => { if(!byDay[e.date]) byDay[e.date]=[]; byDay[e.date].push(e); }); %>
      <% Object.entries(byDay).sort((a,b)=>a[0].localeCompare(b[0])).forEach(([date, evs]) => { %>
        <div class="day-section">
          <div class="day-label">
            <%= new Date(date).toLocaleDateString('it-IT',{weekday:'long',day:'2-digit',month:'long',year:'numeric'}) %>
          </div>
          <% evs.sort((a,b)=>a.start_time.localeCompare(b.start_time)).forEach(e => { %>
            <div class="event-card">
              <div class="event-time">
                <%= e.start_time %><br>
                <span class="end-time">– <%= e.end_time %></span>
              </div>
              <div>
                <div>
                  <span class="event-space" style="border-color:<%= e.space_color %>;"><%= e.space_name %></span>
                  <span class="event-type"><%= e.event_type %></span>
                </div>
                <div class="event-title"><%= e.title %></div>
                <% if(e.description) { %><div class="event-desc"><%= e.description.slice(0,200) %><%= e.description.length>200?'…':'' %></div><% } %>
                <% if(e.speakers_list) { %>
                  <div class="event-speakers">🎤 <strong><%= e.speakers_list %></strong></div>
                <% } %>
                <% if(e.max_seats > 0 && !e.is_full) { %>
                  <a href="/programma/iscriviti/<%= e.id %>" class="btn-iscriviti">Iscriviti →</a>
                <% } else if(e.max_seats > 0 && e.is_full) { %>
                  <span class="btn-iscriviti full">Posti esauriti</span>
                <% } %>
              </div>
              <div class="seats-badge <%= e.max_seats > 0 ? (e.is_full ? 'full' : 'available') : '' %>">
                <% if(e.max_seats > 0) { %>
                  <%= e.seats_taken %> / <%= e.max_seats %>
                  <% if(e.is_full) { %><br><span>ESAURITO</span><% } %>
                  <span class="seats-bar"><span class="seats-bar-fill" style="width:<%= Math.min(100, Math.round(e.seats_taken/e.max_seats*100)) %>%"></span></span>
                <% } else { %>
                  <span style="color:var(--muted);font-weight:400;font-size:.75rem;">Ingresso<br>libero</span>
                <% } %>
              </div>
            </div>
          <% }); %>
        </div>
      <% }); %>
    <% } %>

  </div>

  <div class="footer">
    <p>Programma aggiornato in tempo reale · <%= eventName %></p>
  </div>

</body>
</html>
