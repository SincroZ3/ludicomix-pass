<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title><%= title %></title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root{
  --navy:     #1e2d4e;
  --navy-d:   #14203a;
  --navy-m:   #243460;
  --gold:     #c9a227;
  --gold-l:   #e8c14a;
  --cream:    #e8dfc8;
  --bg:       #f0ede6;
  --surface:  #ffffff;
  --border:   #dbd4c4;
  --text:     #1a1a2e;
  --muted:    #6b6660;
  --violet:   #6b3fa0;
  --red:      #c0392b;
  --green:    #1d6a39;
  --r6:6px; --r10:10px; --r14:14px; --r20:20px;
  --sh1:0 2px 8px rgba(26,26,46,.09);
  --sh2:0 8px 28px rgba(26,26,46,.16);
  --tr:.18s cubic-bezier(.16,1,.3,1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:16px}
body{font-family:'Inter',system-ui,sans-serif;background:var(--bg);color:var(--text);line-height:1.55;min-height:100dvh}
a{text-decoration:none;color:inherit}
img{display:block;max-width:100%;height:auto}
button{cursor:pointer;font:inherit;color:inherit;background:none;border:none}

/* ───── TOPBAR ───── */
.topbar{
  background:var(--navy);
  border-bottom:3px solid var(--gold);
  padding:0 1.75rem;
  display:flex;align-items:center;justify-content:space-between;gap:1rem;
  height:68px;position:sticky;top:0;z-index:300;
}
.tb-brand{display:flex;align-items:center;gap:.6rem}
.tb-ciuco{height:58px;width:auto;flex-shrink:0;filter:drop-shadow(0 2px 8px rgba(0,0,0,.55))}
.tb-logo{height:44px;width:auto;flex-shrink:0;filter:drop-shadow(0 1px 4px rgba(0,0,0,.4))}
.tb-name{display:flex;flex-direction:column;line-height:1.15}
.tb-name strong{font-size:.98rem;font-weight:800;color:var(--cream)}
.tb-name span{font-size:.65rem;text-transform:uppercase;letter-spacing:.9px;color:var(--gold);font-weight:700}
.tb-right{display:flex;align-items:center;gap:.5rem}
.tb-pill{
  display:inline-flex;align-items:center;gap:.3rem;
  padding:.3rem .75rem;border:1px solid rgba(201,162,39,.35);border-radius:999px;
  color:var(--cream);font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;
  background:rgba(255,255,255,.06);transition:background var(--tr);
}
.tb-pill:hover{background:rgba(255,255,255,.13)}
.tb-pill.active{background:rgba(201,162,39,.18);border-color:var(--gold);color:var(--gold)}
@media(max-width:540px){
  .topbar{padding:0 1rem;height:58px}
  .tb-ciuco{height:44px}.tb-logo{height:34px}
  .tb-name strong{font-size:.84rem}.tb-pill span{display:none}
}

/* ───── HERO ───── */
.hero{
  background:linear-gradient(160deg, var(--navy-d) 0%, var(--navy) 55%, var(--navy-m) 100%);
  padding:3.5rem 2rem 3rem;text-align:center;position:relative;overflow:hidden;
}
.hero::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse 70% 60% at 50% 0%,rgba(201,162,39,.08),transparent);
  pointer-events:none;
}
.hero-kicker{
  display:inline-flex;align-items:center;gap:.4rem;
  font-size:.68rem;font-weight:800;text-transform:uppercase;letter-spacing:1.2px;
  color:var(--gold);margin-bottom:1.1rem;
}
.hero-kicker::before,.hero-kicker::after{content:'';width:24px;height:1px;background:var(--gold);opacity:.5}
.hero h1{
  font-family:'Playfair Display',Georgia,serif;
  font-size:clamp(2.5rem,6vw,5rem);font-weight:900;
  color:var(--cream);line-height:1.05;margin-bottom:.85rem;
}
.hero-sub{
  font-size:clamp(.84rem,1.5vw,1rem);color:rgba(232,223,200,.6);
  max-width:52ch;margin:0 auto;
}

/* ───── MAIN WRAP ───── */
.wrap{max-width:1140px;margin:0 auto;padding:2rem 1.75rem 5rem}
@media(max-width:640px){.wrap{padding:1.25rem 1rem 3rem}}

/* ───── IN EVIDENZA ───── */
.s-label{
  display:flex;align-items:center;gap:.55rem;
  font-size:.78rem;font-weight:800;text-transform:uppercase;letter-spacing:.8px;
  color:var(--muted);margin-bottom:1.2rem;
}
.s-label::after{content:'';flex:1;height:1px;background:var(--border)}
.feat-grid{
  display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));
  gap:1rem;margin-bottom:2.5rem;
}
.feat-card{
  background:var(--surface);border:1px solid var(--border);border-radius:var(--r14);
  overflow:hidden;box-shadow:var(--sh1);cursor:pointer;
  transition:box-shadow var(--tr),transform var(--tr);
}
.feat-card:hover{box-shadow:var(--sh2);transform:translateY(-3px)}
.feat-img{aspect-ratio:16/9;overflow:hidden;background:var(--navy)}
.feat-img img{width:100%;height:100%;object-fit:cover;
  transition:transform .4s cubic-bezier(.16,1,.3,1)}
.feat-card:hover .feat-img img{transform:scale(1.06)}
.feat-body{padding:.9rem 1rem 1rem}
.feat-tags{display:flex;flex-wrap:wrap;gap:.3rem;margin-bottom:.5rem}
.feat-title{font-size:.96rem;font-weight:800;color:var(--navy);line-height:1.3;margin-bottom:.45rem}
.feat-meta{font-size:.74rem;color:var(--muted);display:flex;align-items:center;gap:.6rem;flex-wrap:wrap}
.feat-meta b{color:var(--navy)}
.feat-cta{
  display:inline-flex;align-items:center;gap:.3rem;
  margin-top:.8rem;padding:.38rem .9rem;
  background:var(--navy);color:var(--cream);
  border-radius:999px;font-size:.75rem;font-weight:700;
  transition:background var(--tr);
}
.feat-cta:hover{background:var(--navy-d)}

/* ───── FILTERS ───── */
.filter-wrap{
  background:var(--surface);border:1px solid var(--border);border-radius:var(--r14);
  padding:.85rem 1.1rem;margin-bottom:.85rem;box-shadow:var(--sh1);
  display:flex;flex-wrap:wrap;align-items:flex-end;gap:.6rem;
}
.fg{display:flex;flex-direction:column;gap:.2rem;min-width:130px}
.fg label{font-size:.61rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--muted)}
.fg select,.fg input[type=text]{
  padding:.38rem .7rem;border:1px solid var(--border);border-radius:var(--r6);
  font-size:.82rem;background:var(--bg);color:var(--text);outline:none;
  transition:border-color var(--tr);
}
.fg select:focus,.fg input:focus{border-color:var(--navy)}
.fg-search{flex:1;min-width:160px}
.btn-filtra{
  padding:.4rem 1.1rem;background:var(--navy);color:var(--cream);
  border-radius:var(--r6);font-size:.82rem;font-weight:700;
  transition:background var(--tr);white-space:nowrap;
}
.btn-filtra:hover{background:var(--navy-d)}
.btn-reset-sm{
  padding:.38rem .8rem;border:1px solid var(--border);border-radius:var(--r6);
  font-size:.8rem;font-weight:600;color:var(--muted);background:var(--surface);
  transition:background var(--tr);text-decoration:none;display:inline-block;
}
.btn-reset-sm:hover{background:var(--bg)}

/* ───── RESULT ROW ───── */
.result-row{
  display:flex;align-items:center;justify-content:space-between;
  flex-wrap:wrap;gap:.5rem;margin-bottom:1.1rem;
}
.res-count{font-size:.78rem;color:var(--muted);font-weight:600}

/* ───── DATE SEPARATOR ───── */
.date-sep{
  display:flex;align-items:center;gap:.55rem;
  font-size:.73rem;font-weight:800;text-transform:uppercase;letter-spacing:.6px;
  color:var(--muted);margin:1.5rem 0 .7rem;
}
.date-sep .ds-ico{
  width:36px;height:36px;background:var(--navy);color:var(--gold);
  border-radius:var(--r6);display:flex;flex-direction:column;
  align-items:center;justify-content:center;font-weight:900;flex-shrink:0;line-height:1;
}
.ds-ico .d-day{font-size:.85rem}.ds-ico .d-mon{font-size:.5rem;text-transform:uppercase;letter-spacing:.4px}
.date-sep::after{content:'';flex:1;height:1px;background:var(--border)}
.date-sep .ds-cnt{color:var(--muted);font-weight:500}

/* ───── EVENT ROW ───── */
.ev-list{display:flex;flex-direction:column;gap:.55rem}
.ev-row{
  background:var(--surface);border:1px solid var(--border);border-radius:var(--r10);
  display:grid;grid-template-columns:88px 1fr auto;
  overflow:hidden;box-shadow:var(--sh1);cursor:pointer;
  transition:box-shadow var(--tr),transform var(--tr);
}
.ev-row:hover{box-shadow:var(--sh2);transform:translateY(-1px)}
.ev-row.is-featured{border-left:3px solid var(--gold)}

.ev-time{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:.75rem .5rem;background:var(--navy);gap:.1rem;position:relative;
}
.et-start{font-size:1.05rem;font-weight:900;color:var(--cream);line-height:1}
.et-end{font-size:.64rem;color:rgba(232,223,200,.45);line-height:1}
.et-dot{
  position:absolute;bottom:10px;left:50%;transform:translateX(-50%);
  width:8px;height:8px;border-radius:50%;
}

.ev-body{padding:.7rem 1rem;min-width:0}
.ev-tags{display:flex;flex-wrap:wrap;gap:.28rem;margin-bottom:.4rem}
.ev-title{font-size:.95rem;font-weight:800;color:var(--navy);line-height:1.3}
.ev-star{color:var(--gold);font-size:.85rem;margin-left:.3rem}
.ev-sub{font-size:.76rem;color:var(--muted);margin-top:.25rem;line-height:1.4}

.ev-right{
  display:flex;flex-direction:column;align-items:flex-end;justify-content:center;
  gap:.5rem;padding:.7rem .8rem;border-left:1px solid var(--border);min-width:110px;
}
.ev-seats{font-size:.72rem;font-weight:700}
.ev-seats.ok{color:var(--green)}.ev-seats.full{color:var(--red)}
.ev-bar{width:70px;height:4px;border-radius:999px;background:var(--border);overflow:hidden}
.ev-fill{height:100%;border-radius:999px}
.ev-btn{
  display:inline-flex;align-items:center;gap:.25rem;
  padding:.35rem .8rem;background:var(--navy);color:var(--cream);
  border-radius:999px;font-size:.7rem;font-weight:700;
  transition:background var(--tr);white-space:nowrap;text-decoration:none;
}
.ev-btn:hover{background:var(--navy-d)}
.ev-btn.full{background:var(--border);color:var(--muted);pointer-events:none}
.ev-free{font-size:.7rem;color:var(--muted);text-align:right;font-weight:600}

/* ───── TAGS ───── */
.tag{display:inline-block;padding:.1rem .42rem;border-radius:999px;
  font-size:.61rem;font-weight:800;text-transform:uppercase;letter-spacing:.3px}
.t-type{background:#ede8f8;color:var(--violet)}
.t-space{background:var(--bg);border:1px solid var(--border);color:var(--muted)}
.t-tags{background:#fdf4d8;color:#7d5200}
.t-star{color:var(--gold)}
.t-full{background:#fde8e8;color:var(--red)}
.t-open{background:#d4efde;color:var(--green)}

/* ───── EMPTY ───── */
.empty{text-align:center;padding:4rem 1rem;color:var(--muted)}
.empty-ico{font-size:3rem;margin-bottom:.75rem;display:block}

/* ───── MODAL ───── */
.moverlay{
  position:fixed;inset:0;background:rgba(20,26,46,.7);backdrop-filter:blur(5px);
  z-index:400;display:flex;align-items:center;justify-content:center;padding:1rem;
  opacity:0;pointer-events:none;transition:opacity .22s;
}
.moverlay.open{opacity:1;pointer-events:all}
.mdialog{
  background:var(--surface);border-radius:var(--r20);
  box-shadow:0 32px 80px rgba(20,26,46,.35);
  width:100%;max-width:660px;max-height:90vh;overflow-y:auto;
  transform:translateY(20px) scale(.97);transition:transform .24s cubic-bezier(.16,1,.3,1);
}
.moverlay.open .mdialog{transform:none}
.m-head{
  background:var(--navy);border-radius:var(--r20) var(--r20) 0 0;
  padding:1.5rem 1.6rem 1.2rem;
  display:flex;align-items:flex-start;gap:1rem;
}
.m-head-txt{flex:1;min-width:0}
.m-kicker{font-size:.67rem;font-weight:800;text-transform:uppercase;letter-spacing:.6px;
  color:var(--gold);margin-bottom:.3rem}
.m-title{font-family:'Playfair Display',Georgia,serif;font-size:1.4rem;font-weight:900;
  color:var(--cream);line-height:1.2}
.m-x{width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,.1);
  color:var(--cream);font-size:1rem;display:flex;align-items:center;justify-content:center;
  flex-shrink:0;transition:background var(--tr)}
.m-x:hover{background:rgba(255,255,255,.2)}
.m-pills{
  display:flex;flex-wrap:wrap;gap:.4rem;
  padding:.85rem 1.6rem;background:var(--bg);border-bottom:1px solid var(--border);
}
.mpill{
  display:inline-flex;align-items:center;gap:.22rem;
  padding:.22rem .6rem;background:var(--surface);border:1px solid var(--border);
  border-radius:999px;font-size:.74rem;font-weight:600;color:var(--text);
}
.m-body{padding:1.4rem 1.6rem}
.mb-sec{margin-bottom:1.1rem}
.mb-lbl{font-size:.62rem;font-weight:800;text-transform:uppercase;letter-spacing:.6px;
  color:var(--muted);margin-bottom:.35rem}
.mb-text{font-size:.92rem;color:#3a3a5c;line-height:1.72}
.mb-spk{
  background:#f4f0fa;border-left:3px solid var(--violet);
  border-radius:0 var(--r6) var(--r6) 0;padding:.7rem .9rem;
  font-size:.88rem;color:var(--violet);font-weight:700;
}
.mb-seats{display:flex;align-items:center;gap:1rem}
.mb-sbar{flex:1;height:6px;border-radius:999px;background:var(--border);overflow:hidden}
.mb-sfill{height:100%;border-radius:999px;transition:width .4s}
.m-foot{
  display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.8rem;
  padding:1rem 1.6rem;border-top:1px solid var(--border);
}
.m-close-btn{
  padding:.44rem .95rem;border:1px solid var(--border);border-radius:var(--r6);
  font-size:.82rem;font-weight:700;color:var(--muted);background:var(--surface);
  transition:background var(--tr);
}
.m-close-btn:hover{background:var(--bg)}
.m-iscr-btn{
  display:inline-block;padding:.5rem 1.3rem;
  background:var(--gold);color:var(--navy);border-radius:var(--r6);
  font-size:.85rem;font-weight:800;text-transform:uppercase;letter-spacing:.4px;
  transition:background var(--tr);
}
.m-iscr-btn:hover{background:var(--gold-l)}
.m-iscr-btn.full{background:var(--border);color:var(--muted);pointer-events:none}

/* ───── FOOTER ───── */
.footer{
  background:var(--navy);border-top:3px solid var(--gold);
  text-align:center;padding:1.4rem;
  font-size:.75rem;color:rgba(232,223,200,.4);
}
.footer strong{color:var(--gold)}

/* ───── RESPONSIVE ───── */
@media(max-width:700px){
  .ev-row{grid-template-columns:72px 1fr}
  .ev-right{display:none}
}
@media(max-width:420px){
  .feat-grid{grid-template-columns:1fr}
  .ev-row{grid-template-columns:64px 1fr}
  .ev-time{padding:.6rem .35rem}
  .et-start{font-size:.9rem}
}
</style>
</head>
<body>
<%
/* ── helpers ── */
var allEvs  = events || [];
var allDates = dates  || [];
var allSpaces= spaces || [];
var f       = filters || {};

/* Calcola tipi evento dai dati */
var _types = [];
allEvs.forEach(function(e){
  if(e.eventtype && _types.indexOf(e.eventtype)===-1) _types.push(e.eventtype);
});
_types.sort();

/* Featured */
var featured = allEvs.filter(function(e){ return e.featured || e.inevidenza; });

/* Raggruppa per giorno */
var byDay = {};
allEvs.forEach(function(e){
  if(!byDay[e.date]) byDay[e.date]=[];
  byDay[e.date].push(e);
});
var sortedDays = Object.keys(byDay).sort();

function isoToIt(d,opts){
  try{ return new Date(d+'T12:00:00').toLocaleDateString('it-IT',opts); }
  catch(x){ return d||''; }
}
%>

<!-- TOPBAR -->
<header class="topbar">
  <a href="/programma" class="tb-brand">
    <img src="/img/ciuchino.png" class="tb-ciuco" alt=""
         onerror="this.onerror=null;this.src='';this.style.display='none'">
    <img src="/img/logo.png" class="tb-logo" alt="Ludicomix"
         onerror="this.onerror=null;this.src='';this.style.display='none'">
    <div class="tb-name">
      <strong>Ludicomix</strong>
      <span>Programma ufficiale</span>
    </div>
  </a>
  <div class="tb-right">
    <a href="/programma" class="tb-pill active">
      &#128197; <span>Programma</span>
    </a>
    <a href="/programma/qr" class="tb-pill" target="_blank">
      &#9638; <span>QR</span>
    </a>
  </div>
</header>

<!-- HERO -->
<section class="hero">
  <div class="hero-kicker">Ludicomix &mdash; Edizione 2026</div>
  <h1>Il Programma</h1>
  <p class="hero-sub">Panel, workshop, talk, ospiti speciali e tanto altro &mdash; tutto in un posto solo.</p>
</section>

<!-- MAIN -->
<main class="wrap">

  <!-- IN EVIDENZA -->
  <% if(featured.length > 0){ %>
  <div class="s-label">&#11088; In evidenza</div>
  <div class="feat-grid">
    <% featured.forEach(function(e){ %>
    <div class="feat-card" onclick="openModal(<%= e.id %>)" role="button" tabindex="0">
      <div class="feat-img">
        <% if(e.imageurl){ %>
          <img src="<%= e.imageurl %>" alt="<%= e.title %>" loading="lazy">
        <% } else { %>
          <img src="/img/ciuchino.png" alt="" style="object-fit:contain;padding:1rem;opacity:.3"
               onerror="this.style.display='none'">
        <% } %>
      </div>
      <div class="feat-body">
        <div class="feat-tags">
          <% if(e.eventtype){ %><span class="tag t-type"><%= e.eventtype %></span><% } %>
          <% if(e.spacename){ %><span class="tag t-space"><%= e.spacename %></span><% } %>
        </div>
        <div class="feat-title"><%= e.title %></div>
        <div class="feat-meta">
          <span>&#128197; <b><%= isoToIt(e.date,{day:'2-digit',month:'2-digit',year:'numeric'}) %></b></span>
          <span>&#128336; <%= e.starttime %>&ndash;<%= e.endtime %></span>
        </div>
        <% if(e.registrationsopen){ %>
        <a href="/programma/iscriviti/<%= e.id %>" class="feat-cta" onclick="event.stopPropagation()">
          &#127914; Iscriviti
        </a>
        <% } %>
      </div>
    </div>
    <% }); %>
  </div>
  <% } %>

  <!-- FILTRI -->
  <form class="filter-wrap" method="GET" action="/programma" id="fform">
    <% if(f.date){ %><input type="hidden" name="date" value="<%= f.date %>"><% } %>

    <div class="fg">
      <label>Tutte le date</label>
      <select name="date" onchange="this.form.submit()">
        <option value="">Tutte le date</option>
        <% allDates.forEach(function(d){ %>
          <option value="<%= d.date %>" <%= f.date===d.date?'selected':'' %>>
            <%= isoToIt(d.date,{weekday:'short',day:'2-digit',month:'short'}) %>
          </option>
        <% }); %>
      </select>
    </div>

    <div class="fg">
      <label>Tutte le sale</label>
      <select name="space" onchange="this.form.submit()">
        <option value="">Tutte le sale</option>
        <% allSpaces.forEach(function(s){ %>
          <option value="<%= s.name %>" <%= f.space===s.name?'selected':'' %>><%= s.name %></option>
        <% }); %>
      </select>
    </div>

    <% if(_types.length > 0){ %>
    <div class="fg">
      <label>Tutti i tipi</label>
      <select id="sel-type" onchange="clientFilter()">
        <option value="">Tutti i tipi</option>
        <% _types.forEach(function(t){ %><option value="<%= t %>"><%= t %></option><% }); %>
      </select>
    </div>
    <% } %>

    <div class="fg fg-search">
      <label>Cerca evento o ospite&hellip;</label>
      <input type="text" id="q" placeholder="Cerca evento o ospite&hellip;" oninput="clientFilter()">
    </div>

    <button type="submit" class="btn-filtra">Filtra</button>
    <a href="/programma" class="btn-reset-sm">Reset</a>
  </form>

  <!-- CONTATORE -->
  <div class="result-row">
    <span class="res-count" id="ev-count"><%= allEvs.length %> event<%= allEvs.length===1?'o':'i' %></span>
  </div>

  <!-- NESSUN RISULTATO (client-side) -->
  <div id="no-res" style="display:none" class="empty">
    <span class="empty-ico">&#128270;</span>
    <p style="font-weight:700;font-size:.96rem">Nessun risultato</p>
    <p style="font-size:.82rem;margin-top:.3rem">Prova a modificare la ricerca.</p>
  </div>

  <!-- EVENTI PER GIORNO -->
  <% if(allEvs.length === 0){ %>
    <div class="empty">
      <span class="empty-ico">&#128525;</span>
      <p style="font-size:.96rem;font-weight:700;margin-bottom:.35rem">Nessun evento pubblicato</p>
    </div>
  <% } else { %>

  <div id="evwrap">
  <% sortedDays.forEach(function(day){ %>
  <%
    var dtObj = new Date(day+'T12:00:00');
    var dDay  = dtObj.toLocaleDateString('it-IT',{day:'2-digit'});
    var dMon  = dtObj.toLocaleDateString('it-IT',{month:'short'});
    var dLong = dtObj.toLocaleDateString('it-IT',{weekday:'long',day:'2-digit',month:'long',year:'numeric'});
    var dayEvs= byDay[day];
  %>
  <div class="day-sec" data-day="<%= day %>">
    <div class="date-sep">
      <div class="ds-ico">
        <div class="d-day"><%= dDay %></div>
        <div class="d-mon"><%= dMon %></div>
      </div>
      <%= dLong %>
      <span class="ds-cnt" id="cnt-<%= day %>"><%= dayEvs.length %> event<%= dayEvs.length===1?'o':'i' %></span>
    </div>
    <div class="ev-list">
    <% dayEvs.forEach(function(e){ %>
    <%
      var isFull = e.maxseats > 0 && e.seatstaken >= e.maxseats;
      var pct    = e.maxseats > 0 ? Math.min(100,Math.round(e.seatstaken/e.maxseats*100)) : 0;
    %>
    <div class="ev-row<%= (e.featured||e.inevidenza)?' is-featured':'' %>"
         data-t="<%= (e.title||'').toLowerCase() %>"
         data-s="<%= (e.speakerslist||'').toLowerCase() %>"
         data-tp="<%= e.eventtype||'' %>"
         onclick="openModal(<%= e.id %>)" role="button" tabindex="0">

      <div class="ev-time">
        <div class="et-start"><%= e.starttime %></div>
        <div class="et-end"><%= e.endtime %></div>
        <% if(e.spacecolor){ %>
          <div class="et-dot" style="background:#<%= e.spacecolor.replace('#','') %>"></div>
        <% } %>
      </div>

      <div class="ev-body">
        <div class="ev-tags">
          <% if(e.eventtype){ %><span class="tag t-type"><%= e.eventtype %></span><% } %>
          <% if(e.spacename){ %><span class="tag t-space">&#128205; <%= e.spacename %></span><% } %>
          <% if(e.tags){ e.tags.split(',').forEach(function(tg){ tg=tg.trim(); if(tg){ %><span class="tag t-tags"><%= tg %></span><% }}); } %>
          <% if(isFull){ %><span class="tag t-full">&#128683; Esaurito</span><% } %>
        </div>
        <div class="ev-title">
          <%= e.title %>
          <% if(e.featured||e.inevidenza){ %><span class="ev-star">&#11088;</span><% } %>
        </div>
        <% if(e.speakerslist){ %>
          <div class="ev-sub">&#127908; <%= e.speakerslist %></div>
        <% } %>
      </div>

      <div class="ev-right">
        <% if(e.maxseats > 0){ %>
          <div class="ev-seats <%= isFull?'full':'ok' %>">
            <%= e.seatstaken %> / <%= e.maxseats %>
          </div>
          <div class="ev-bar">
            <div class="ev-fill" style="width:<%= pct %>%;background:<%= isFull?'#c0392b':'#1d6a39' %>"></div>
          </div>
          <% if(e.registrationsopen){ %>
            <a href="/programma/iscriviti/<%= e.id %>"
               class="ev-btn<%= isFull?' full':'' %>"
               onclick="event.stopPropagation()">
              &#127914; <%= isFull?'Esaurito':'Iscriviti' %>
            </a>
          <% } %>
        <% } else { %>
          <div class="ev-free">&#10003; Ingresso<br>libero</div>
        <% } %>
      </div>
    </div>
    <% }); %>
    </div>
  </div>
  <% }); %>
  </div>
  <% } %>

</main>

<footer class="footer">
  <p>Programma aggiornato in tempo reale &middot; <strong><%= title %></strong></p>
</footer>

<!-- MODAL -->
<div class="moverlay" id="mov" onclick="if(event.target===this)closeM()">
  <div class="mdialog" role="dialog" aria-modal="true" aria-labelledby="m-ttl">
    <div class="m-head">
      <div class="m-head-txt">
        <div class="m-kicker" id="m-kick"></div>
        <h2 class="m-title" id="m-ttl"></h2>
      </div>
      <button class="m-x" onclick="closeM()" aria-label="Chiudi">&#10005;</button>
    </div>
    <div class="m-pills" id="m-pills"></div>
    <div class="m-body">
      <div class="mb-sec" id="mb-desc-w">
        <div class="mb-lbl">Descrizione</div>
        <div class="mb-text" id="mb-desc"></div>
      </div>
      <div class="mb-sec" id="mb-spk-w" style="display:none">
        <div class="mb-lbl">Ospiti / Speaker</div>
        <div class="mb-spk" id="mb-spk"></div>
      </div>
      <div class="mb-sec" id="mb-seats-w" style="display:none">
        <div class="mb-lbl">Disponibilità posti</div>
        <div class="mb-seats">
          <span id="mb-stxt" style="font-size:.82rem;font-weight:700"></span>
          <div class="mb-sbar"><div class="mb-sfill" id="mb-sfill"></div></div>
          <span id="mb-spct" style="font-size:.78rem;color:var(--muted)"></span>
        </div>
      </div>
    </div>
    <div class="m-foot">
      <button class="m-close-btn" onclick="closeM()">&#10005; Chiudi</button>
      <span id="m-cta"></span>
    </div>
  </div>
</div>

<script>
/* ── Event data ── */
var ED={};
<% allEvs.forEach(function(e){ var f2=e.maxseats>0&&e.seatstaken>=e.maxseats; %>
ED[<%= e.id %>]={
  id:<%= e.id %>,
  title:<%- JSON.stringify(e.title||'') %>,
  desc:<%- JSON.stringify(e.description||'') %>,
  date:<%- JSON.stringify(e.date||'') %>,
  start:<%- JSON.stringify(e.starttime||'') %>,
  end:<%- JSON.stringify(e.endtime||'') %>,
  space:<%- JSON.stringify(e.spacename||'') %>,
  sc:<%- JSON.stringify(e.spacecolor||'') %>,
  type:<%- JSON.stringify(e.eventtype||'') %>,
  spk:<%- JSON.stringify(e.speakerslist||'') %>,
  max:<%= e.maxseats||0 %>,
  taken:<%= e.seatstaken||0 %>,
  reg:<%= e.registrationsopen?1:0 %>,
  full:<%= f2?'true':'false' %>
};
<% }); %>

function fmt(d){
  try{return new Date(d+'T12:00:00').toLocaleDateString('it-IT',{weekday:'long',day:'2-digit',month:'long',year:'numeric'});}
  catch(x){return d||'';}
}

function openModal(id){
  var e=ED[id]; if(!e) return;
  document.getElementById('m-kick').textContent=fmt(e.date);
  document.getElementById('m-ttl').textContent=e.title;

  var pills='<span class="mpill">&#128336; '+e.start+'&ndash;'+e.end+'</span>';
  if(e.space) pills+='<span class="mpill" style="border-color:'+(e.sc||'var(--border)')+'">&#128205; '+e.space+'</span>';
  if(e.type)  pills+='<span class="mpill">&#127914; '+e.type+'</span>';
  document.getElementById('m-pills').innerHTML=pills;

  var dw=document.getElementById('mb-desc-w');
  document.getElementById('mb-desc').textContent=e.desc;
  dw.style.display=e.desc?'':'none';

  var sw=document.getElementById('mb-spk-w');
  if(e.spk){document.getElementById('mb-spk').textContent='🎤 '+e.spk;sw.style.display='';}
  else sw.style.display='none';

  var seatW=document.getElementById('mb-seats-w');
  if(e.max>0){
    var pct=Math.min(100,Math.round(e.taken/e.max*100));
    document.getElementById('mb-stxt').textContent=e.taken+' / '+e.max+' iscritti';
    var sf=document.getElementById('mb-sfill');
    sf.style.width=pct+'%';
    sf.style.background=e.full?'#c0392b':'#1d6a39';
    document.getElementById('mb-spct').textContent=pct+'%';
    seatW.style.display='';
  } else seatW.style.display='none';

  var cta=document.getElementById('m-cta');
  if(e.reg){
    cta.innerHTML=e.full
      ?'<span class="m-iscr-btn full">&#128683; Posti esauriti</span>'
      :'<a href="/programma/iscriviti/'+e.id+'" class="m-iscr-btn">&#127914; Iscriviti gratuitamente &rarr;</a>';
  } else cta.innerHTML='';

  document.getElementById('mov').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeM(){
  document.getElementById('mov').classList.remove('open');
  document.body.style.overflow='';
}
document.addEventListener('keydown',function(e){if(e.key==='Escape')closeM();});

/* Accessibilità keyboard */
document.querySelectorAll('[role="button"]').forEach(function(el){
  el.addEventListener('keydown',function(e){
    if(e.key==='Enter'||e.key===' '){e.preventDefault();el.click();}
  });
});

/* ── CLIENT-SIDE FILTER ── */
function clientFilter(){
  var q=(document.getElementById('q').value||'').toLowerCase().trim();
  var ts=document.getElementById('sel-type');
  var tp=ts?ts.value:'';
  var tot=0;
  document.querySelectorAll('.day-sec').forEach(function(ds){
    var n=0;
    ds.querySelectorAll('.ev-row').forEach(function(r){
      var ok=(!q||(r.dataset.t+' '+r.dataset.s).includes(q))&&(!tp||r.dataset.tp===tp);
      r.style.display=ok?'':'none';
      if(ok)n++;
    });
    ds.style.display=n>0?'':'none';
    var c=ds.querySelector('[id^="cnt-"]');
    if(c)c.textContent=n+' event'+(n===1?'o':'i');
    tot+=n;
  });
  var cc=document.getElementById('ev-count');
  if(cc)cc.textContent=tot+' event'+(tot===1?'o':'i');
  var nr=document.getElementById('no-res');
  if(nr)nr.style.display=tot===0?'':'none';
}
</script>
</body>
</html>
