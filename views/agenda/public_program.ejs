<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Programma <%= title %></title>
  <style>
    :root {
      --brand-dark: #1e2d4e; --brand-yellow: #f5c842; --brand-gold: #c9a227;
      --brand-violet: #6b3fa0; --accent-blue: #1d6fa4;
      --bg: #f0f2f5; --white: #ffffff; --border: #d1d9e6; --border-light: #e8ecf3;
      --text: #1a2744; --muted: #718096;
      --radius-sm: 4px; --radius-md: 8px; --radius-lg: 12px;
      --shadow-sm: 0 1px 3px rgba(30,45,78,.10); --shadow-md: 0 3px 10px rgba(30,45,78,.15);
    }
    *, *::before, *::after { box-sizing: border-box; }
    body { margin:0; font-family:-apple-system,Segoe UI,Arial,sans-serif; font-size:15px; background:var(--bg); color:var(--text); line-height:1.55; }
    a { color:var(--accent-blue); text-decoration:none; }
    a:hover { text-decoration:underline; }
    .topbar { background:var(--brand-dark); border-bottom:3px solid var(--brand-yellow); padding:.75rem 1.5rem; display:flex; justify-content:space-between; align-items:center; }
    .topbar h1 { margin:0; font-size:1.2rem; color:#fff; letter-spacing:.3px; }
    .topbar .brand-sub { font-size:.78rem; color:#aec6e8; }
    .container { max-width:1100px; margin:0 auto; padding:1.5rem 1rem; }
    .date-filter { display:flex; gap:.5rem; flex-wrap:wrap; margin-bottom:1.5rem; border-bottom:2px solid var(--border); padding-bottom:1rem; }
    .date-btn { padding:.4rem 1.1rem; border:1px solid var(--border); border-radius:999px; background:var(--white); font-size:.8rem; font-weight:700; cursor:pointer; text-decoration:none; color:var(--text); transition:background .15s; }
    .date-btn:hover { background:var(--border-light); text-decoration:none; }
    .date-btn.active { background:var(--brand-dark); color:var(--brand-yellow); border-color:var(--brand-dark); }
    .day-section { margin-bottom:2.5rem; }
    .day-label { font-size:.75rem; font-weight:800; text-transform:uppercase; letter-spacing:.5px; color:var(--muted); margin-bottom:1rem; padding-bottom:.4rem; border-bottom:1px solid var(--border-light); }
    .event-card { background:var(--white); border-radius:var(--radius-md); border:1px solid var(--border); box-shadow:var(--shadow-sm); padding:1rem 1.25rem; margin-bottom:.75rem; display:grid; grid-template-columns:90px 1fr auto; gap:1rem; align-items:start; cursor:pointer; }
    .event-card:hover { box-shadow:var(--shadow-md); }
    .event-time { font-weight:700; font-size:.9rem; color:var(--brand-dark); text-align:center; padding-top:.1rem; }
    .event-time .end-time { font-size:.75rem; font-weight:400; color:var(--muted); }
    .event-space { display:inline-block; font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.4px; padding:.1rem .5rem; border-radius:999px; background:var(--bg); border:1px solid var(--border); color:var(--muted); margin-bottom:.35rem; }
    .event-title { font-size:1rem; font-weight:700; margin:0 0 .3rem; color:var(--brand-dark); }
    .event-type { display:inline-block; font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.3px; padding:.1rem .4rem; border-radius:3px; background:#e8edf8; color:var(--brand-dark); margin-right:.4rem; }
    .event-desc { font-size:.83rem; color:var(--muted); margin:.4rem 0; }
    .event-speakers { font-size:.8rem; color:#4a5568; margin-top:.3rem; }
    .event-speakers strong { color:var(--brand-violet); }
    .seats-badge { text-align:right; font-size:.78rem; font-weight:700; white-space:nowrap; }
    .seats-badge.full { color:#c0392b; }
    .seats-badge.available { color:#1d6a39; }
    .seats-bar { display:block; height:5px; border-radius:9999px; background:var(--border-light); overflow:hidden; margin-top:.3rem; width:80px; margin-left:auto; }
    .seats-bar-fill { height:100%; background:var(--brand-dark); display:block; }
    .btn-iscriviti { display:inline-block; margin-top:.6rem; padding:.4rem .9rem; background:var(--brand-yellow); color:var(--brand-dark); font-weight:700; font-size:.78rem; text-transform:uppercase; letter-spacing:.4px; border-radius:var(--radius-sm); transition:background .15s; text-decoration:none; font-family:'Arial Narrow',Arial,sans-serif; }
    .btn-iscriviti:hover { background:#ffe066; text-decoration:none; }
    .btn-iscriviti.full { background:var(--border); color:var(--muted); cursor:not-allowed; }
    .footer { text-align:center; padding:2rem 1rem; color:var(--muted); font-size:.78rem; border-top:1px solid var(--border-light); margin-top:2rem; }
    @media(max-width:600px) {
      .event-card { grid-template-columns:1fr; gap:.5rem; }
      .seats-badge { text-align:left; }
      .seats-badge .seats-bar { margin-left:0; }
    }
    /* Modal — aggiunto solo per il fix, stile coerente con la UI esistente */
    .modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.5); z-index:999; justify-content:center; align-items:center; padding:1rem; }
    .modal-overlay.open { display:flex; }
    .modal-box { background:#fff; border-radius:var(--radius-lg); box-shadow:0 8px 32px rgba(0,0,0,.2); max-width:520px; width:100%; max-height:88vh; overflow-y:auto; }
    .modal-head { padding:1.1rem 1.4rem .8rem; border-bottom:1px solid var(--border-light); position:relative; }
    .modal-head h3 { margin:0; font-size:1.1rem; color:var(--brand-dark); padding-right:2rem; }
    .modal-head .mtype { font-size:.68rem; font-weight:800; text-transform:uppercase; letter-spacing:.4px; color:var(--brand-violet); margin-bottom:.3rem; }
    .modal-close { position:absolute; top:.9rem; right:1rem; background:none; border:none; font-size:1.2rem; cursor:pointer; color:var(--muted); }
    .modal-body { padding:1rem 1.4rem; font-size:.88rem; }
    .modal-meta { color:var(--muted); margin-bottom:.75rem; font-size:.82rem; }
    .modal-foot { padding:.8rem 1.4rem 1.1rem; border-top:1px solid var(--border-light); text-align:right; }
  </style>
</head>
<body>

<div class="topbar">
  <div>
    <h1>📅 Programma <%= title %></h1>
    <div class="brand-sub">Tutti gli eventi e le attività</div>
  </div>
  <div style="font-size:.82rem;color:#aec6e8">Ultimo aggiornamento: <%= new Date().toLocaleDateString('it-IT') %></div>
</div>

<div class="container">

  <% if (dates.length > 1) { %>
  <div class="date-filter">
    <a href="/programma" class="date-btn <%= !filters.date ? 'active' : '' %>">Tutte le date</a>
    <% dates.forEach(d => { %>
      <a href="/programma?date=<%= d.date %>"
         class="date-btn <%= filters.date === d.date ? 'active' : '' %>">
        <%/* FIX: T12:00:00 evita bug timezone UTC→locale */%>
        <%= new Date(d.date + 'T12:00:00').toLocaleDateString('it-IT',{weekday:'short',day:'2-digit',month:'short'}) %>
      </a>
    <% }); %>
  </div>
  <% } %>

  <% if (events.length === 0) { %>
    <div style="text-align:center;padding:4rem 1rem;color:var(--muted)">
      <div style="font-size:3rem;margin-bottom:.75rem">📭</div>
      <p>Nessun evento pubblicato per la data selezionata.</p>
    </div>
  <% } else { %>

    <%
      // FIX #1 — "In evidenza": era e.is_featured (undefined), ora e.featured == 1
      const featured = events.filter(e => e.featured == 1);
    %>
    <% if (featured.length > 0) { %>
    <div style="margin:0 0 1.8rem;padding:1.2rem 1.4rem;background:linear-gradient(135deg,#fffbe6,#fff7cc);border:2px solid #f5c842;border-radius:12px">
      <div style="font-size:.68rem;font-weight:800;text-transform:uppercase;letter-spacing:.8px;color:#92400e;margin-bottom:.9rem">⭐ In evidenza</div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:.7rem">
        <% featured.forEach(ev => { %>
          <div style="background:#fff;border-left:4px solid #<%- ev.space_color || '6b3fa0' %>;border-radius:8px;padding:.8rem 1rem;box-shadow:0 2px 8px rgba(30,45,78,.09);cursor:pointer"
               onclick="openModal(<%= ev.id %>)">
            <div style="font-size:.63rem;font-weight:800;text-transform:uppercase;letter-spacing:.5px;color:#6b3fa0;margin-bottom:.25rem"><%= ev.event_type || 'evento' %></div>
            <div style="font-size:.9rem;font-weight:700;color:#1a2744;margin-bottom:.45rem;line-height:1.3"><%= ev.title %></div>
            <div style="display:flex;flex-wrap:wrap;gap:.35rem;font-size:.7rem;color:#64748b">
              <span>📅 <%= new Date(ev.date + 'T12:00:00').toLocaleDateString('it-IT',{weekday:'short',day:'2-digit',month:'short'}) %></span>
              <span>🕐 <%= ev.start_time %>–<%= ev.end_time %></span>
              <span>📍 <%= ev.space_name %></span>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <%
      const byDay = {};
      events.forEach(e => { if(!byDay[e.date]) byDay[e.date]=[]; byDay[e.date].push(e); });
    %>

    <% Object.entries(byDay).sort((a,b)=>a[0].localeCompare(b[0])).forEach(([date, evs]) => { %>
    <div class="day-section">
      <div class="day-label">
        <%= new Date(date + 'T12:00:00').toLocaleDateString('it-IT',{weekday:'long',day:'2-digit',month:'long',year:'numeric'}) %>
      </div>

      <% evs.sort((a,b)=>a.start_time.localeCompare(b.start_time)).forEach(e => {
           // FIX #2 — is_full non esiste nella view, usare availability
           const isFull = e.availability === 'full';
           // FIX #3 — Iscriviti: era max_seats>0, ora registrations_open==1
           const canRegister = e.registrations_open == 1;
      %>
        <div class="event-card" onclick="openModal(<%= e.id %>)">

          <div class="event-time">
            <%= e.start_time %><br>
            <span class="end-time">– <%= e.end_time %></span>
          </div>

          <div>
            <div>
              <span class="event-space" style="border-color:<%- e.space_color %>"><%= e.space_name %></span>
              <span class="event-type"><%= e.event_type %></span>
            </div>
            <div class="event-title"><%= e.title %></div>
            <% if(e.description) { %>
              <div class="event-desc"><%= e.description.slice(0,200) %><%= e.description.length>200?'…':'' %></div>
            <% } %>
            <% if(e.speakers_list) { %>
              <div class="event-speakers">con <strong><%= e.speakers_list %></strong></div>
            <% } %>
            <% if(canRegister && !isFull) { %>
              <a href="/programma/iscriviti/<%= e.id %>" class="btn-iscriviti" onclick="event.stopPropagation()">Iscriviti →</a>
            <% } else if(canRegister && isFull) { %>
              <span class="btn-iscriviti full">Posti esauriti</span>
            <% } %>
          </div>

          <div class="seats-badge <%= isFull ? 'full' : (e.max_seats > 0 ? 'available' : '') %>">
            <% if(e.max_seats > 0) { %>
              <%= e.seats_taken %> / <%= e.max_seats %>
              <% if(isFull) { %><br><span>ESAURITO</span><% } %>
              <span class="seats-bar"><span class="seats-bar-fill" style="width:<%= Math.min(100,Math.round(e.seats_taken/e.max_seats*100)) %>%"></span></span>
            <% } else { %>
              <span style="color:var(--muted);font-weight:400;font-size:.75rem">Ingresso<br>libero</span>
            <% } %>
          </div>

        </div>
      <% }); %>
    </div>
    <% }); %>

  <% } %>

</div>

<div class="footer">
  <p>Programma aggiornato in tempo reale · <%= title %></p>
</div>

<!-- Modal (fix #3) -->
<div class="modal-overlay" id="evModal" onclick="if(event.target===this)closeModal()">
  <div class="modal-box">
    <div class="modal-head">
      <div class="mtype" id="mType"></div>
      <h3 id="mTitle"></h3>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body">
      <div class="modal-meta" id="mMeta"></div>
      <div id="mDesc"></div>
      <div id="mSpk" style="margin-top:.6rem;font-size:.85rem;color:#4a5568"></div>
      <div id="mSeats" style="margin-top:.6rem;font-size:.82rem;color:var(--muted)"></div>
    </div>
    <div class="modal-foot" id="mFoot"></div>
  </div>
</div>

<%# Embed events data — fix: niente JSON inline negli onclick, si usa lookup by id %>
<script>
var EVDATA = {};
<% events.forEach(e => { %>
EVDATA[<%= e.id %>] = <%- JSON.stringify({
  id: e.id,
  title: e.title,
  description: e.description || '',
  event_type: e.event_type || '',
  date: e.date,
  start_time: e.start_time,
  end_time: e.end_time,
  space_name: e.space_name,
  max_seats: e.max_seats,
  seats_taken: e.seats_taken,
  availability: e.availability,
  registrations_open: e.registrations_open,
  speakers_list: e.speakers_list || ''
}) %>;
<% }); %>

function openModal(id) {
  var ev = EVDATA[id];
  if (!ev) return;
  var isFull = ev.availability === 'full';
  document.getElementById('mType').textContent = (ev.event_type || '').toUpperCase();
  document.getElementById('mTitle').textContent = ev.title;
  var dateStr = '';
  try { dateStr = new Date(ev.date + 'T12:00:00').toLocaleDateString('it-IT', {weekday:'long',day:'2-digit',month:'long'}); } catch(x){}
  document.getElementById('mMeta').textContent = '📅 ' + dateStr + '   🕐 ' + ev.start_time + '–' + ev.end_time + '   📍 ' + ev.space_name;
  var desc = document.getElementById('mDesc');
  desc.textContent = ev.description || '';
  desc.style.display = ev.description ? '' : 'none';
  var spk = document.getElementById('mSpk');
  spk.innerHTML = ev.speakers_list ? 'con <strong style="color:#6b3fa0">' + ev.speakers_list + '</strong>' : '';
  var seats = document.getElementById('mSeats');
  seats.textContent = ev.max_seats > 0
    ? (isFull ? '⚠️ Posti esauriti (' + ev.seats_taken + '/' + ev.max_seats + ')' : '🪑 ' + (ev.max_seats - ev.seats_taken) + ' posti disponibili su ' + ev.max_seats)
    : '🎟 Ingresso libero';
  var foot = document.getElementById('mFoot');
  if (ev.registrations_open == 1 && !isFull) {
    foot.innerHTML = '<a href="/programma/iscriviti/' + ev.id + '" class="btn-iscriviti">Iscriviti →</a>';
  } else if (ev.registrations_open == 1 && isFull) {
    foot.innerHTML = '<span class="btn-iscriviti full">Posti esauriti</span>';
  } else {
    foot.innerHTML = '';
  }
  document.getElementById('evModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeModal() {
  document.getElementById('evModal').classList.remove('open');
  document.body.style.overflow = '';
}
document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeModal(); });
</script>

</body>
</html>
