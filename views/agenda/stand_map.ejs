<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <title>Mappa Stand — <%= zone.name %> · Ludicomix</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html,body{height:100%;width:100%;overflow:hidden;
      font-family:-apple-system,'Segoe UI',Arial,sans-serif;
      background:#1e2d4e;}

    /* ── Header ─────────────────────────────────────────────────────── */
    .sm-header{
      position:fixed;top:0;left:0;right:0;z-index:500;
      display:flex;align-items:center;justify-content:space-between;
      padding:.55rem .9rem;
      background:linear-gradient(to bottom,rgba(30,45,78,.95) 60%,transparent);
      pointer-events:none;
    }
    .sm-header>*{pointer-events:auto}
    .sm-title{color:#f5c842;font-size:.82rem;font-weight:800;text-transform:uppercase;letter-spacing:.5px}
    .sm-subtitle{color:rgba(255,255,255,.7);font-size:.68rem;font-weight:600}
    .sm-back{
      display:flex;align-items:center;gap:.4rem;
      padding:.45rem .85rem;border-radius:10px;
      background:rgba(255,255,255,.1);border:1.5px solid rgba(245,200,66,.4);
      color:#f5c842;font-size:.78rem;font-weight:700;
      cursor:pointer;text-decoration:none;
    }
    .sm-back:active{background:rgba(255,255,255,.2)}

    /* ── Leaflet map container ───────────────────────────────────────── */
    #mapWrap{position:fixed;inset:0;width:100%;height:100%;}
    /* Nasconde attribution Leaflet (mappa non geografica) */
    .leaflet-control-attribution{display:none!important}
    /* Nasconde zoom control Leaflet (usiamo i nostri bottoni .sm-ctrl) */
    .leaflet-control-zoom{display:none!important}
    /* Stand come DivIcon Leaflet */
    .leaflet-div-icon{background:none!important;border:none!important;}

    /*
     * #mapBg è l'immagine di sfondo come un vero <img> — occupa esattamente
     * le dimensioni naturali (areaW × areaH) e serve solo come sfondo visivo.
     *
     * #mapArea è sovrapposto a #mapBg con position:absolute inset:0.
     * CRUCIALE: #mapArea ha esattamente le stesse dimensioni del div .map-area
     * della pagina admin al momento del drop, cioè:
     *   width  = ADMIN_W  (larghezza del .map-area nell'admin — sconosciuta)
     *   height = ADMIN_H  (max(520, width * imgH/imgW) se contain verticale)
     *
     * Poiché non conosciamo ADMIN_W, usiamo la logica inversa:
     * Il div admin usa background-size:contain e background-position:center top.
     * Con contain, l'immagine viene scalata in modo che entrambe le dimensioni
     * stiano dentro il div. Se imgAR > divAR (immagine più larga) → limitata da width.
     * Se imgAR < divAR (immagine più alta) → limitata da height.
     *
     * La posizione dell'immagine nel div admin:
     *   imgRenderedW = min(divW, divH * imgAR)
     *   imgRenderedH = min(divH, divW / imgAR)
     *   imgOffsetX   = (divW - imgRenderedW) / 2  ← con center
     *   imgOffsetY   = 0                           ← con top
     *
     * Le coordinate % degli stand sono relative al div (0,0)→(divW,divH).
     * Un punto a left:X%, top:Y% si trova in pixel a:
     *   px = X/100 * divW
     *   py = Y/100 * divH
     *
     * Per allinearsi, il nostro #mapArea deve avere le stesse divW e divH.
     * Poi usiamo <img> posizionato con left=imgOffsetX, top=0.
     *
     * STIMA di divW: la pagina admin ha width ~100vw, senza sidebar.
     * Dal codice: .map-area-wrap{width:100%}, .map-wrap{display:block}.
     * Usiamo una larghezza di riferimento fissa pari a quella che tipicamente
     * aveva il browser admin quando gli stand sono stati posizionati.
     * Dal DB/mappa: refW e refH vengono passati con ogni drop ma non salvati.
     * → Usiamo l'approccio più robusto: esponiamo refW dal backend se disponibile,
     *   altrimenti usiamo 1400px come stima ragionevole per un desktop admin.
     *
     * In questo file accettiamo dal template EJS la variabile `zone.map_ref_w`
     * (se salvata) oppure usiamo il default 1400.
     */

    /* #mapArea e #mapBgImg gestiti da Leaflet ImageOverlay */

    /* ── Stand SVG layer ─────────────────────────────────────────────── */
    .sm-stand-svg { cursor:pointer; }
    .sm-stand-svg:hover > rect,
    .sm-stand-svg:hover > polygon,
    .sm-stand-svg.active > rect,
    .sm-stand-svg.active > polygon {
      filter: brightness(1.35);
      stroke: #f5c842;
      stroke-width: 2.5px;
    }
    .leaflet-overlay-pane { pointer-events: none; }
    .leaflet-overlay-pane svg { overflow: visible; }

    /* ── Tooltip ─────────────────────────────────────────────────────── */
    .sm-tip{
      position:fixed;z-index:900;
      background:#1e2d4e;color:#fff;
      border:1.5px solid #f5c842;border-radius:10px;
      padding:.5rem .75rem;
      pointer-events:none;opacity:0;transition:opacity .15s;
      max-width:220px;min-width:130px;
      box-shadow:0 4px 18px rgba(0,0,0,.45);font-size:.77rem;
    }
    .sm-tip.show{opacity:1}
    .sm-tip-code{font-size:.63rem;color:#f5c842;font-weight:800;margin-bottom:.15rem}
    .sm-tip-name{font-weight:700;line-height:1.2}
    .sm-tip-ev{font-size:.63rem;color:#a0aec0;margin-top:.2rem}

    /* ── Sheet ───────────────────────────────────────────────────────── */
    .sm-overlay{position:fixed;inset:0;z-index:700;pointer-events:none}
    .sm-overlay.open{pointer-events:auto}
    .sm-sheet{
      position:fixed;bottom:0;left:0;right:0;z-index:750;
      background:#fff;border-radius:20px 20px 0 0;
      box-shadow:0 -4px 32px rgba(0,0,0,.25);
      transform:translateY(100%);
      transition:transform .32s cubic-bezier(.16,1,.3,1);
      padding-bottom:env(safe-area-inset-bottom,16px);
      max-height:72vh;overflow-y:auto;
    }
    .sm-sheet.open{transform:translateY(0)}
    .sm-handle{width:38px;height:4px;background:#d1d9e6;border-radius:2px;margin:.7rem auto .4rem}
    .sm-body{padding:.5rem 1.2rem 1.4rem}
    .sm-shead{display:flex;align-items:flex-start;gap:.75rem;margin-bottom:.7rem}
    .sm-badge{
      flex-shrink:0;min-width:44px;height:44px;border-radius:10px;
      background:#1e2d4e;color:#f5c842;font-weight:900;font-size:.84rem;
      display:flex;align-items:center;justify-content:center;
      padding:0 .5rem;
    }
    .sm-sname{font-size:1rem;font-weight:800;color:#1a2744;line-height:1.2}
    .sm-scat{font-size:.72rem;color:#718096;margin-top:.15rem}
    .sm-noev{font-size:.8rem;color:#a0aec0;text-align:center;padding:.75rem 0;font-style:italic}
    .sm-link-open-btn{display:block;width:100%;margin-top:1rem;padding:.55rem 1rem;border-radius:8px;
      border:1.5px dashed #4f98a3;background:none;color:#4f98a3;font-size:.8rem;font-weight:700;
      cursor:pointer;text-align:center;transition:background .14s,color .14s}
    .sm-link-open-btn:hover{background:#4f98a3;color:#fff}

    /* ── Controlli (bottom-right, NON sovrapposti all'header) ─────────── */
    .sm-ctrl{
      position:fixed;
      right:12px;
      bottom:calc(env(safe-area-inset-bottom,0px) + 12px);
      z-index:500;
      display:flex;flex-direction:column;gap:6px;
    }
    .sm-btn{
      width:44px;height:44px;border-radius:11px;
      background:#fff;border:1.5px solid #e2e8f0;
      font-size:1.3rem;cursor:pointer;color:#1a2744;
      display:flex;align-items:center;justify-content:center;
      box-shadow:0 2px 8px rgba(0,0,0,.18);
    }
    .sm-btn:active{background:#f0f4ff}
    .sm-btn.reset{background:#1e2d4e;border-color:#f5c842;color:#f5c842}

    /* ── Legend (bottom-left) ────────────────────────────────────────── */
    .sm-legend{
      position:fixed;
      left:12px;
      bottom:calc(env(safe-area-inset-bottom,0px) + 12px);
      z-index:500;
      background:rgba(30,45,78,.88);border:1px solid rgba(245,200,66,.3);
      border-radius:10px;padding:.45rem .7rem;
      font-size:.62rem;color:#cbd5e0;display:none;
    }
    .sm-leg-row{display:flex;align-items:center;gap:.4rem;margin-bottom:.18rem}
    .sm-leg-row:last-child{margin-bottom:0}
    .sm-leg-sq{width:10px;height:10px;border-radius:2px;flex-shrink:0;
      background:#1e2d4e;border:1.5px solid rgba(245,200,66,.7);}

    /* ── Drawer lista stand ──────────────────────────────────────────── */
    .sm-drawer-overlay{
      position:fixed;inset:0;z-index:600;
      background:rgba(0,0,0,.45);
      opacity:0;pointer-events:none;
      transition:opacity .28s ease;
    }
    .sm-drawer-overlay.open{opacity:1;pointer-events:auto}
    .sm-drawer{
      position:fixed;right:0;top:0;bottom:0;z-index:650;
      width:min(300px,88vw);
      background:#1e2d4e;
      border-left:1.5px solid rgba(245,200,66,.3);
      display:flex;flex-direction:column;
      transform:translateX(100%);
      transition:transform .3s cubic-bezier(.16,1,.3,1);
      box-shadow:-4px 0 32px rgba(0,0,0,.35);
    }
    .sm-drawer.open{transform:translateX(0)}
    .sm-drawer-head{
      display:flex;align-items:center;justify-content:space-between;
      padding:.75rem 1rem .6rem;
      border-bottom:1px solid rgba(255,255,255,.1);
      flex-shrink:0;
    }
    .sm-drawer-title{color:#f5c842;font-size:.82rem;font-weight:800;text-transform:uppercase;letter-spacing:.5px}
    .sm-drawer-close{
      width:30px;height:30px;border-radius:7px;
      background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);
      color:#fff;font-size:1.1rem;cursor:pointer;
      display:flex;align-items:center;justify-content:center;
    }
    .sm-drawer-close:active{background:rgba(255,255,255,.18)}
    .sm-drawer-body{flex:1;overflow-y:auto;padding:.4rem 0;}
    .sm-drawer-item{
      display:flex;align-items:center;gap:.65rem;
      padding:.55rem 1rem;cursor:pointer;
      border-bottom:1px solid rgba(255,255,255,.05);
      transition:background .12s;
    }
    .sm-drawer-item:active,.sm-drawer-item:hover{background:rgba(245,200,66,.1)}
    .sm-drawer-dot{
      width:10px;height:10px;border-radius:2px;flex-shrink:0;
      background:#4f98a3;border:1.5px solid rgba(245,200,66,.5);
    }
    .sm-drawer-code{font-size:.68rem;font-weight:800;color:#f5c842;min-width:36px;flex-shrink:0}
    .sm-drawer-name{font-size:.78rem;color:#e2e8f0;line-height:1.2}
    .sm-drawer-loc{font-size:.65rem;color:#718096;margin-top:.08rem}
    .sm-drawer-evbadge{
      margin-left:auto;flex-shrink:0;
      background:rgba(245,200,66,.18);color:#f5c842;
      font-size:.6rem;font-weight:800;border-radius:9999px;
      padding:.1rem .38rem;
    }
    /* Evento nella sheet */
    .sm-ev-item{
      display:flex;gap:.6rem;align-items:flex-start;
      padding:.55rem 0;border-bottom:1px solid #e8ecf3;
    }
    .sm-ev-item:last-child{border-bottom:none}
    .sm-ev-time{
      flex-shrink:0;min-width:52px;
      font-size:.68rem;font-weight:800;color:#1e2d4e;
      background:#f0f4ff;border-radius:5px;
      padding:.2rem .35rem;text-align:center;line-height:1.3;
    }
    .sm-ev-title{font-size:.8rem;font-weight:700;color:#1a2744;line-height:1.25}
    .sm-ev-space{font-size:.65rem;color:#718096;margin-top:.1rem}
    .sm-ev-link{display:block;text-decoration:none;color:inherit;border-radius:6px;
      transition:background .12s;margin:0 -.4rem;padding:0 .4rem;flex:1}
    .sm-ev-link:active,.sm-ev-link:hover{background:#f0f4ff}
    .sm-ev-arrow{font-size:.65rem;color:#4f98a3;margin-top:.18rem}
    .sm-ev-excl{flex-shrink:0;margin-left:.4rem;align-self:flex-start;margin-top:.3rem;
      width:20px;height:20px;border-radius:4px;border:1px solid #e2e8f0;
      background:none;cursor:pointer;color:#a0aec0;font-size:.7rem;
      display:flex;align-items:center;justify-content:center;
      transition:background .12s,color .12s}
    .sm-ev-excl:hover{background:#fff1f1;color:#e53e3e;border-color:#fed7d7}
    .sm-excl-section{margin-top:.85rem;border-top:1px dashed #e2e8f0;padding-top:.6rem}
    .sm-excl-toggle{font-size:.68rem;color:#a0aec0;cursor:pointer;
      display:flex;align-items:center;gap:.3rem;background:none;border:none;padding:0}
    .sm-excl-toggle:hover{color:#718096}
    .sm-excl-list{margin-top:.5rem;display:none}
    .sm-excl-list.open{display:block}
    .sm-excl-item{display:flex;align-items:center;gap:.5rem;padding:.35rem 0;
      border-bottom:1px solid #f0f4ff;font-size:.75rem;color:#a0aec0}
    .sm-excl-item:last-child{border-bottom:none}
    .sm-excl-name{flex:1;font-style:italic}
    .sm-excl-restore{font-size:.65rem;color:#4f98a3;background:none;
      border:1px solid #bee3f8;border-radius:4px;padding:.1rem .4rem;
      cursor:pointer;white-space:nowrap;transition:background .12s}
    .sm-excl-restore:hover{background:#ebf8ff}
    /* Modale aggancio manuale */
    .sm-link-modal{position:fixed;inset:0;z-index:9999;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.45);opacity:0;pointer-events:none;transition:opacity .18s}
    .sm-link-modal.open{opacity:1;pointer-events:auto}
    .sm-link-box{background:#fff;border-radius:14px;width:min(420px,92vw);max-height:80vh;display:flex;flex-direction:column;box-shadow:0 8px 40px rgba(0,0,0,.22);overflow:hidden}
    .sm-link-head{display:flex;align-items:center;justify-content:space-between;padding:.85rem 1rem .7rem;border-bottom:1px solid #e2e8f0;flex-shrink:0}
    .sm-link-title{font-size:.95rem;font-weight:800;color:#1a2744}
    .sm-link-close{width:28px;height:28px;border-radius:50%;border:none;background:#f0f4ff;color:#4a5568;cursor:pointer;font-size:.9rem;display:flex;align-items:center;justify-content:center}
    .sm-link-close:hover{background:#e2e8f0}
    .sm-link-search{padding:.65rem 1rem;border-bottom:1px solid #e2e8f0;flex-shrink:0}
    .sm-link-search input{width:100%;padding:.45rem .75rem;border-radius:8px;border:1px solid #cbd5e0;font-size:.85rem;outline:none;color:#1a2744}
    .sm-link-search input:focus{border-color:#4f98a3;box-shadow:0 0 0 2px rgba(79,152,163,.15)}
    .sm-link-list{overflow-y:auto;flex:1;padding:.5rem 0}
    .sm-link-item{display:flex;align-items:center;gap:.7rem;padding:.6rem 1rem;cursor:pointer;transition:background .12s}
    .sm-link-item:hover{background:#f7fafc}
    .sm-link-item-info{flex:1;min-width:0}
    .sm-link-item-title{font-size:.82rem;font-weight:700;color:#1a2744;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .sm-link-item-meta{font-size:.7rem;color:#718096;margin-top:.1rem}
    .sm-link-btn{flex-shrink:0;padding:.3rem .75rem;border-radius:6px;border:none;background:#4f98a3;color:#fff;font-size:.75rem;font-weight:700;cursor:pointer;transition:background .12s}
    .sm-link-btn:hover{background:#3a7f8a}
    .sm-link-btn:disabled{background:#a0aec0;cursor:not-allowed}
    .sm-link-empty{text-align:center;color:#a0aec0;font-size:.82rem;padding:2rem 1rem}
    .sm-ev-link{display:block;text-decoration:none;color:inherit;border-radius:6px;
      transition:background .12s;margin:0 -.4rem;padding:0 .4rem}
    .sm-ev-link:active,.sm-ev-link:hover{background:#f0f4ff}
    .sm-ev-arrow{font-size:.65rem;color:#4f98a3;margin-top:.18rem}

    /* ── Loading ─────────────────────────────────────────────────────── */
    #smLoad{position:fixed;inset:0;z-index:9999;background:#1e2d4e;
      display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;}
    .spin{width:40px;height:40px;border-radius:50%;
      border:3px solid rgba(245,200,66,.2);border-top-color:#f5c842;
      animation:spin .8s linear infinite;}
    @keyframes spin{to{transform:rotate(360deg)}}
    #smLoad p{color:#a0aec0;font-size:.85rem}

    @media(min-width:769px){
      .sm-sheet{left:auto;right:16px;bottom:16px;width:320px;
        border-radius:16px;max-height:calc(100vh - 80px);
        transform:translateX(calc(100% + 20px));}
      .sm-sheet.open{transform:translateX(0)}
    }
  </style>
</head>
<body>

<div id="smLoad"><div class="spin"></div><p>Caricamento mappa…</p></div>

<header class="sm-header">
  <div style="display:flex;align-items:center;gap:.55rem">
    <img src="/img/logo.png" alt="Ludicomix" height="36"
         style="object-fit:contain" onerror="this.style.display='none'">
    <div>
      <div class="sm-subtitle">Mappa Stand</div>
      <div class="sm-title"><%= zone.name %></div>
    </div>
  </div>
  <a href="/mappa-pubblica" class="sm-back">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2.5">
      <path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/>
    </svg>
    Mappa
  </a>
</header>

<div id="mapWrap"></div>
<% if (zone.background_image) { %>
<script>var BG_URL = "/zone-bg/<%= zone.background_image %>";</script>
<% } else { %>
<script>var BG_URL = null;</script>
<% } %>

<div class="sm-tip" id="smTip">
  <div class="sm-tip-code" id="tipCode"></div>
  <div class="sm-tip-name" id="tipName"></div>
  <div class="sm-tip-ev"   id="tipEv"></div>
</div>

<div class="sm-overlay" id="smOverlay" onclick="closeSheet()"></div>
<div class="sm-sheet" id="smSheet">
  <div class="sm-handle"></div>
  <div class="sm-body" id="smBody"></div>
</div>

<div class="sm-ctrl">
  <button class="sm-btn" onclick="openDrawer()" aria-label="Lista stand" title="Lista stand">
    <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2.5">
      <line x1="8" y1="6"  x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/>
      <line x1="8" y1="18" x2="21" y2="18"/>
      <circle cx="3" cy="6" r="1.2" fill="currentColor"/>
      <circle cx="3" cy="12" r="1.2" fill="currentColor"/>
      <circle cx="3" cy="18" r="1.2" fill="currentColor"/>
    </svg>
  </button>
  <button class="sm-btn reset" onclick="resetView()" title="Centra mappa" aria-label="Centra mappa">
    <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2.5">
      <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
      <path d="M3 3v5h5"/>
    </svg>
  </button>
  <button class="sm-btn" onclick="doZoom(1.25)" aria-label="Zoom in">+</button>
  <button class="sm-btn" onclick="doZoom(0.8)"  aria-label="Zoom out">−</button>
</div>

<!-- Drawer lista stand -->
<div class="sm-drawer-overlay" id="smDrawerOverlay" onclick="closeDrawer()"></div>
<div class="sm-drawer" id="smDrawer">
  <div class="sm-drawer-head">
    <span class="sm-drawer-title">Stand in zona</span>
    <button class="sm-drawer-close" onclick="closeDrawer()" aria-label="Chiudi">✕</button>
  </div>
  <div style="padding:.5rem .75rem .3rem;flex-shrink:0;border-bottom:1px solid rgba(255,255,255,.08)">
    <input type="search" id="smDrawerSearch" placeholder="Cerca stand…"
      oninput="filterDrawer(this.value)"
      style="width:100%;padding:.42rem .7rem;border-radius:7px;border:1px solid rgba(255,255,255,.15);
             background:rgba(255,255,255,.08);color:#e2e8f0;font-size:.8rem;outline:none;
             -webkit-appearance:none">
  </div>
  <div class="sm-drawer-body" id="smDrawerBody"></div>
</div>

<div class="sm-legend" id="smLegend">
  <div class="sm-leg-row"><div class="sm-leg-sq"></div>Stand</div>
  <div class="sm-leg-row">
    <div class="sm-leg-sq" style="position:relative">
      <div style="position:absolute;top:-3px;right:-3px;width:6px;height:6px;
           border-radius:50%;background:#f5c842"></div>
    </div>
    Ha eventi
  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
// ── Configurazione ────────────────────────────────────────────────────────────
const ZONE_ID   = <%= zoneId %>;
const isMobile  = window.innerWidth <= 768;
const ADMIN_REF_W = <%= (zone.map_ref_w || 1400) %>;
const ADMIN_MIN_H = 520;
const IS_AUTH   = <%- typeof isAuthenticated !== 'undefined' && isAuthenticated ? 'true' : 'false' %>;

let stands  = [];
let areaW   = 0, areaH = 0;
let leafMap = null;       // istanza Leaflet
let imgBounds = null;     // bounds [[0,0],[areaH,areaW]] in CRS.Simple
let standMarkers = {};    // id → L.marker

// ── Carica stands ─────────────────────────────────────────────────────────────
fetch('/api/mappa-stand/' + ZONE_ID)
  .then(r => r.json())
  .then(d => {
    stands = d.stands || [];
    if (leafMap) renderStands();
  })
  .catch(() => {
    document.getElementById('smLoad').innerHTML =
      '<p style="color:#fc8181">Errore caricamento mappa.</p>';
  });

// ── Inizializza Leaflet dopo che conosciamo dimensioni immagine ───────────────
function initLeaflet(natW, natH) {
  if (!natW || !natH) { natW = 1200; natH = 800; }

  // Stessa logica di calcolo dell'admin per replicare esattamente
  // il posizionamento degli stand (background-size:contain, center top)
  const imgAR = natW / natH;
  const divAR = ADMIN_REF_W / ADMIN_MIN_H;
  let renderedH;
  if (imgAR > divAR) {
    renderedH = ADMIN_REF_W / imgAR;
  } else {
    renderedH = ADMIN_MIN_H;
  }
  areaW = ADMIN_REF_W;
  areaH = Math.max(ADMIN_MIN_H, renderedH);

  // In CRS.Simple y cresce verso il basso → bounds [y1,x1],[y2,x2]
  // ma Leaflet ha y che cresce verso l'alto per default.
  // Usiamo bounds con y invertito: [[-areaH,0],[0,areaW]]
  // così il punto [0,0] dell'immagine corrisponde a lat=0,lng=0 in basso a sinistra
  // e il punto [areaH,areaW] corrisponde a lat=-areaH,lng=areaW.
  // Più semplice: usiamo [0,0] come top-left con transformation personalizzata
  // → convenzione standard: bounds = [[0,0],[areaH,areaW]] con maxBounds simmetrico

  imgBounds = [[0, 0], [areaH, areaW]];

  leafMap = L.map('mapWrap', {
    crs: L.CRS.Simple,
    minZoom: -3,
    maxZoom: 3,
    zoomSnap: 0.1,
    zoomDelta: 0.5,
    scrollWheelZoom: true,
    doubleClickZoom: false,
    attributionControl: false,
    zoomControl: false,
  });

  if (BG_URL) {
    L.imageOverlay(BG_URL, imgBounds).addTo(leafMap);
  } else {
    // Nessuna immagine: sfondo scuro
    document.getElementById('mapWrap').style.background = '#1e2d4e';
  }

  // Centra la mappa sull'immagine con padding
  leafMap.fitBounds(imgBounds, { padding: [24, 24] });

  // Chiudi sheet cliccando sulla mappa (non su uno stand)
  leafMap.on('click', closeSheet);

  document.getElementById('smLoad').style.display = 'none';
  document.getElementById('smLegend').style.display = 'block';

  if (stands.length) renderStands();
}

// Carica l'immagine per ottenere le dimensioni naturali
// Nota: su Safari iOS con immagini in cache, .onload non si triggera se src
// viene impostato prima del listener → assegniamo src per ultimi,
// poi controlliamo .complete per gestire la cache
(function() {
  if (!BG_URL) { initLeaflet(1200, 800); return; }
  const probe = new Image();
  probe.onload  = function() { initLeaflet(probe.naturalWidth, probe.naturalHeight); };
  probe.onerror = function() { initLeaflet(1200, 800); };
  probe.src = BG_URL;
  // Gestisce il caso in cui l'immagine è già in cache (Safari iOS)
  if (probe.complete && probe.naturalWidth) {
    initLeaflet(probe.naturalWidth, probe.naturalHeight);
  }
})();

// ── Render stands — SVG layer su overlayPane, aggiornato da Leaflet ──────────
// Usiamo un singolo <svg> fisso nell'overlayPane di Leaflet.
// Su ogni 'viewreset'/'zoom'/'move' ricalcoliamo le posizioni con
// map.latLngToLayerPoint() → gli stand restano solidali alla mappa al 100%.

let standsSvgRoot = null;  // il <svg> globale nel pane

function renderStands() {
  // Crea (o svuota) il root SVG nel pane di Leaflet
  const pane = leafMap.getPanes().overlayPane;
  if (standsSvgRoot) {
    standsSvgRoot.remove();
  }
  const svgNS = 'http://www.w3.org/2000/svg';
  standsSvgRoot = document.createElementNS(svgNS, 'svg');
  standsSvgRoot.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;overflow:visible;pointer-events:none;';
  pane.appendChild(standsSvgRoot);

  standMarkers = {};   // id → { s, gEl, cx_crs, cy_crs, sw_crs, sh_crs, gr }

  stands.forEach(s => {
    if (s.map_x == null || s.map_y == null) return;

    const gw    = parseFloat(s.map_w  || 8);
    const gh    = parseFloat(s.map_h  || 5);
    const gr    = parseFloat(s.map_rot || 0);
    const color = s.color || '#1e2d4e';
    const hasEv = Array.isArray(s.events) && s.events.length > 0;
    const label = s.stand_code || s.name || '';

    // Coordinate centro in pixel admin (y verso il basso)
    const cx_px = parseFloat(s.map_x) / 100 * areaW;
    const cy_px = parseFloat(s.map_y) / 100 * areaH;
    const sw_px = gw / 100 * areaW;
    const sh_px = gh / 100 * areaH;

    // Punto centro in CRS.Simple (lat = areaH - cy perché Leaflet ha y verso l'alto)
    const crs_lat = areaH - cy_px;
    const crs_lng = cx_px;

    // Costruiamo il <g> SVG per questo stand (in coordinate "virtuale" - scalato da updateStands)
    const g = document.createElementNS(svgNS, 'g');
    g.setAttribute('id', 'smst-' + s.id);
    g.setAttribute('class', 'sm-stand-svg' + (hasEv ? ' has-events' : ''));
    g.style.cursor = 'pointer';
    g.style.pointerEvents = 'all';

    // Shape: rect o polygon custom
    let shapeEl;
    if (s.map_shape) {
      try {
        const sp = JSON.parse(s.map_shape);
        if (Array.isArray(sp) && sp.length >= 3) {
          // sp è in % del bounding box 0-100, convertiamo in pixel relativi al centro
          const ptsList = sp.map(p => {
            const px_ = (p[0]/100 - 0.5) * sw_px;
            const py_ = (0.5 - p[1]/100) * sh_px;  // y invertita per SVG
            return px_ + ',' + py_;
          }).join(' ');
          shapeEl = document.createElementNS(svgNS, 'polygon');
          shapeEl.setAttribute('points', ptsList);
          shapeEl.setAttribute('fill', color);
        }
      } catch(e) {}
    }
    if (!shapeEl) {
      shapeEl = document.createElementNS(svgNS, 'rect');
      shapeEl.setAttribute('x', -sw_px/2);
      shapeEl.setAttribute('y', -sh_px/2);
      shapeEl.setAttribute('width', sw_px);
      shapeEl.setAttribute('height', sh_px);
      shapeEl.setAttribute('fill', color);
      shapeEl.setAttribute('rx', Math.min(3, sw_px * 0.04));
    }
    g.appendChild(shapeEl);

    // Dot eventi (angolo top-right)
    if (hasEv) {
      const dot = document.createElementNS(svgNS, 'circle');
      const r = Math.max(4, Math.min(8, sw_px * 0.08));
      dot.setAttribute('cx', sw_px/2 - r);
      dot.setAttribute('cy', -sh_px/2 + r);
      dot.setAttribute('r', r);
      dot.setAttribute('fill', '#f5c842');
      dot.setAttribute('stroke', 'rgba(255,255,255,0.9)');
      dot.setAttribute('stroke-width', '1.5');
      dot.style.pointerEvents = 'none';
      g.appendChild(dot);
    }

    // Label testo
    if (label) {
      const txt = document.createElementNS(svgNS, 'text');
      txt.setAttribute('x', '0');
      txt.setAttribute('y', '0');
      txt.setAttribute('text-anchor', 'middle');
      txt.setAttribute('dominant-baseline', 'middle');
      const fs = Math.max(8, Math.min(sw_px * 0.18, sh_px * 0.35, 20));
      txt.setAttribute('font-size', fs);
      txt.setAttribute('font-weight', '900');
      txt.setAttribute('fill', '#fff');
      txt.setAttribute('font-family', '-apple-system,sans-serif');
      txt.style.pointerEvents = 'none';
      txt.style.filter = 'drop-shadow(0 1px 2px rgba(0,0,0,0.8))';
      txt.textContent = label;
      g.appendChild(txt);
    }

    // Rotazione attorno al centro
    if (gr) g.setAttribute('transform', 'rotate(' + gr + ')');

    standsSvgRoot.appendChild(g);

    // Click / hover
    g.addEventListener('click', function(e) {
      e.stopPropagation();
      document.querySelectorAll('.sm-stand-svg').forEach(el => el.classList.remove('active'));
      g.classList.add('active');
      openSheet(s);
    });
    if (!isMobile) {
      g.addEventListener('mouseenter', function(e) { showTip(e, s); });
      g.addEventListener('mousemove',  function(e) { moveTip(e); });
      g.addEventListener('mouseleave', function()  { hideTip(); });
    }

    standMarkers[s.id] = { s, g, crs_lat, crs_lng, sw_px, sh_px, gr };
  });

  // Primo posizionamento
  updateStandPositions();

  // Aggiorna posizioni ad ogni zoom/pan/resize
  leafMap.off('viewreset zoom move', updateStandPositions);
  leafMap.on('viewreset zoom move',  updateStandPositions);
}

function updateStandPositions() {
  if (!standsSvgRoot || !leafMap) return;
  // Offset del pane (Leaflet muove il pane durante il pan per efficienza)
  const panePos = L.DomUtil.getPosition(leafMap.getPanes().overlayPane);
  Object.values(standMarkers).forEach(function(m) {
    // Converte coordinate CRS nel punto pixel del pane
    const pt = leafMap.latLngToLayerPoint([m.crs_lat, m.crs_lng]);
    // Sottrae l'offset del pane perché il SVG è già figlio del pane
    const x = pt.x - (panePos ? panePos.x : 0);
    const y = pt.y - (panePos ? panePos.y : 0);
    // Calcola scala corrente rispetto alle dimensioni native degli stand
    // (sw_px e sh_px sono in pixel admin; ora dobbiamo scalare al zoom corrente)
    const p1 = leafMap.latLngToLayerPoint([m.crs_lat - m.sh_px/2, m.crs_lng - m.sw_px/2]);
    const p2 = leafMap.latLngToLayerPoint([m.crs_lat + m.sh_px/2, m.crs_lng + m.sw_px/2]);
    const scaleX = Math.abs(p2.x - p1.x) / m.sw_px;
    const scaleY = Math.abs(p2.y - p1.y) / m.sh_px;
    // Aggiorna transform del <g>: translate al centro, scala, poi rotazione
    const rot = m.gr ? ' rotate(' + m.gr + ')' : '';
    m.g.setAttribute('transform',
      'translate(' + x + ',' + y + ') scale(' + scaleX + ',' + scaleY + ')' + rot);
  });
}

// ── Tooltip ───────────────────────────────────────────────────────────────────
const tip = document.getElementById('smTip');
function showTip(e, s) {
  document.getElementById('tipCode').textContent = s.stand_code || s.name || '';
  const tName = (s.stand_name && s.stand_name !== s.stand_code) ? s.stand_name : (s.name && s.name !== s.stand_code ? s.name : '');
  document.getElementById('tipName').textContent = tName;
  document.getElementById('tipEv').textContent   =
    Array.isArray(s.events) && s.events.length
      ? '🗓 ' + s.events.length + (s.events.length === 1 ? ' evento' : ' eventi') : '';
  tip.classList.add('show');
  moveTip(e);
}
function moveTip(e) {
  let x = e.clientX + 14, y = e.clientY - 10;
  if (x + 230 > window.innerWidth)  x = e.clientX - 234;
  if (y + 80  > window.innerHeight) y = e.clientY - 90;
  tip.style.left = x + 'px';
  tip.style.top  = y + 'px';
}
function hideTip() { tip.classList.remove('show'); }

// ── Sheet ──────────────────────────────────────────────────────────────────────
function openSheet(s) {
  hideTip();
  closeDrawer();
  document.querySelectorAll('.sm-stand-svg').forEach(el => el.classList.remove('active'));
  const el = document.getElementById('smst-' + s.id);
  if (el) el.classList.add('active');

  // Header: solo codice e nome stand (senza gruppo/associazione)
  let html =
    '<div class="sm-shead">' +
      '<div class="sm-badge">' + esc(s.stand_code || '') + '</div>' +
      '<div>' +
        '<div class="sm-sname">' + esc((s.stand_name && s.stand_name !== s.stand_code) ? s.stand_name : (s.name && s.name !== s.stand_code ? s.name : '')) + '</div>' +
        (s.zone ? '<div class="sm-scat">🗺 ' + esc(s.zone) + '</div>' : '') +
      '</div>' +
    '</div>';

  // Sezione eventi
  const evs = Array.isArray(s.events) ? s.events : [];
  if (evs.length === 0) {
    html += '<div class="sm-noev">Nessun evento in programma per questo stand.</div>';
  } else {
    html += '<div style="font-size:.72rem;font-weight:800;color:#4a5568;text-transform:uppercase;letter-spacing:.4px;margin:.6rem 0 .35rem">📅 Programma</div>';
    evs.forEach(ev => {
      const orario = ev.start_time
        ? ev.start_time.substring(0,5) + (ev.end_time ? ' – ' + ev.end_time.substring(0,5) : '')
        : '';
      const evUrl = '/programma#evento-' + ev.id;
      html +=
        '<div style="display:flex;align-items:flex-start;gap:.2rem">' +
          '<a class="sm-ev-link" href="' + evUrl + '" target="_blank" rel="noopener noreferrer">' +
            '<div class="sm-ev-item">' +
              (orario ? '<div class="sm-ev-time">' + esc(ev.date ? ev.date.substring(5).replace('-','/') : '') + '<br>' + esc(orario) + '</div>' : '') +
              '<div style="min-width:0;flex:1">' +
                '<div class="sm-ev-title">' + esc(ev.title || '') + '</div>' +
                (ev.space_name ? '<div class="sm-ev-space">🏛 ' + esc(ev.space_name) + '</div>' : '') +
                '<div class="sm-ev-arrow">Vai al programma →</div>' +
              '</div>' +
            '</div>' +
          '</a>' +
          (IS_AUTH ? '<button class="sm-ev-excl" title="Scollega evento" onclick="excludeEvent('+s.id+','+ev.id+',this)">✕</button>' : '') +
        '</div>';
    });
  }
  if (IS_AUTH && Array.isArray(s.excluded_events) && s.excluded_events.length > 0) {
    const excl = s.excluded_events;
    html += '<div class="sm-excl-section"><button class="sm-excl-toggle" onclick="this.nextElementSibling.classList.toggle(\'open\')">🚫 ' + excl.length + ' scollegat' + (excl.length===1?'o':'i') + ' ▼</button><div class="sm-excl-list">';
    excl.forEach(ev => {
      html += '<div class="sm-excl-item"><span class="sm-excl-name">' + esc(ev.title||'') + '</span><button class="sm-excl-restore" onclick="unexcludeEvent('+s.id+','+ev.id+',this)">↩ Ripristina</button></div>';
    });
    html += '</div></div>';
  }

  // Pulsante aggancio manuale (solo utenti autenticati)
  if (IS_AUTH) {
    html += '<button class="sm-link-open-btn" onclick="openLinkModal(' + s.id + ',\'' + esc(s.stand_code || s.name || '') + '\')">' +
            '➕ Collega evento</button>';
  }

  document.getElementById('smBody').innerHTML = html;
  document.getElementById('smSheet').classList.add('open');
  document.getElementById('smOverlay').classList.add('open');
}

function esc(str) {
  return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function closeSheet() {
  document.getElementById('smSheet').classList.remove('open');
  document.getElementById('smOverlay').classList.remove('open');
  document.querySelectorAll('.sm-stand-svg').forEach(el => el.classList.remove('active'));
}

// ── Drawer lista stand ─────────────────────────────────────────────────────────
function openDrawer() {
  closeSheet();
  // Costruisce lista alfabetica degli stand con dati già in memoria
  const sorted = [...stands].sort((a, b) => {
    const ca = (a.stand_code || a.name || '').toLowerCase();
    const cb = (b.stand_code || b.name || '').toLowerCase();
    return ca.localeCompare(cb, 'it');
  });
  let html = '';
  if (sorted.length === 0) {
    html = '<div style="color:#718096;font-size:.8rem;text-align:center;padding:2rem 1rem">Nessuno stand posizionato</div>';
  } else {
    sorted.forEach(s => {
      const evCount = Array.isArray(s.events) ? s.events.length : 0;
      const color   = '#1e2d4e';
      html +=
        '<div class="sm-drawer-item" onclick="focusStand(' + s.id + ')">' +
          '<div class="sm-drawer-dot"></div>' +
          '<div style="min-width:0;flex:1">' +
            '<div style="display:flex;align-items:center;gap:.35rem">' +
              (s.stand_code ? '<span class="sm-drawer-code">' + esc(s.stand_code) + '</span>' : '') +
              '<span class="sm-drawer-name">' + esc((s.stand_name && s.stand_name !== s.stand_code) ? s.stand_name : (s.name && s.name !== s.stand_code ? s.name : '')) + '</span>' +
            '</div>' +
            (s.zone ? '<div class="sm-drawer-loc">🗺 ' + esc(s.zone) + '</div>' : '') +
          '</div>' +
          (evCount > 0 ? '<span class="sm-drawer-evbadge">' + evCount + ' 🗓</span>' : '') +
        '</div>';
    });
  }
  document.getElementById('smDrawerBody').innerHTML = html;
  document.getElementById('smDrawer').classList.add('open');
  document.getElementById('smDrawerOverlay').classList.add('open');
}

function closeDrawer() {
  document.getElementById('smDrawer').classList.remove('open');
  document.getElementById('smDrawerOverlay').classList.remove('open');
}

function filterDrawer(q) {
  const term = (q || '').trim().toLowerCase();
  const body = document.getElementById('smDrawerBody');
  if (!body) return;
  const items = body.querySelectorAll('.sm-drawer-item');
  items.forEach(item => {
    const text = item.textContent.toLowerCase();
    item.style.display = (!term || text.includes(term)) ? '' : 'none';
  });
}

function excludeEvent(groupId, eventId, btn) {
  if (!confirm('Scollega questo evento dallo stand?')) return;
  btn.disabled = true;
  fetch('/api/stand-event-exclude', {
    method: 'POST', headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ group_id: groupId, event_id: eventId })
  })
  .then(r => r.json())
  .then(data => {
    if (data.ok) {
      const st = stands.find(x => x.id === groupId);
      if (st) {
        const ev = (st.events || []).find(e => e.id === eventId);
        st.events = (st.events || []).filter(e => e.id !== eventId);
        if (ev) { if (!st.excluded_events) st.excluded_events = []; st.excluded_events.push(ev); }
        openSheet(st);
      }
    } else { btn.disabled = false; alert('Errore: ' + (data.error || '')); }
  })
  .catch(() => { btn.disabled = false; alert('Errore di rete.'); });
}

function unexcludeEvent(groupId, eventId, btn) {
  btn.disabled = true;
  fetch('/api/stand-event-unexclude', {
    method: 'POST', headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ group_id: groupId, event_id: eventId })
  })
  .then(r => r.json())
  .then(data => {
    if (data.ok) {
      const st = stands.find(x => x.id === groupId);
      if (st) {
        const ev = (st.excluded_events || []).find(e => e.id === eventId);
        st.excluded_events = (st.excluded_events || []).filter(e => e.id !== eventId);
        if (ev) { if (!st.events) st.events = []; st.events.push(ev); st.events.sort((a,b) => (a.date+a.start_time).localeCompare(b.date+b.start_time)); }
        openSheet(st);
      }
    } else { btn.disabled = false; alert('Errore: ' + (data.error || '')); }
  })
  .catch(() => { btn.disabled = false; alert('Errore di rete.'); });
}

// ── Aggancio manuale ──────────────────────────────────────────────────────────
let _linkGroupId   = null;
let _linkAllEvents = [];

function openLinkModal(groupId, standCode) {
  _linkGroupId = groupId;
  document.getElementById('smLinkStandName').textContent = standCode;
  document.getElementById('smLinkSearch').value = '';
  document.getElementById('smLinkList').innerHTML = '<div class="sm-link-empty">Caricamento…</div>';
  document.getElementById('smLinkModal').classList.add('open');

  fetch('/api/stand-eventi-disponibili/' + groupId)
    .then(r => r.json())
    .then(data => {
      if (!data.ok) { document.getElementById('smLinkList').innerHTML = '<div class="sm-link-empty">Errore caricamento.</div>'; return; }
      _linkAllEvents = data.events || [];
      renderLinkList(_linkAllEvents);
    })
    .catch(() => { document.getElementById('smLinkList').innerHTML = '<div class="sm-link-empty">Errore di rete.</div>'; });
}

function closeLinkModal() {
  document.getElementById('smLinkModal').classList.remove('open');
  _linkGroupId = null;
  _linkAllEvents = [];
}

function filterLinkModal(q) {
  const term = (q || '').trim().toLowerCase();
  const filtered = !term ? _linkAllEvents : _linkAllEvents.filter(ev =>
    (ev.title || '').toLowerCase().includes(term) ||
    (ev.date  || '').includes(term) ||
    (ev.space_name || '').toLowerCase().includes(term)
  );
  renderLinkList(filtered);
}

function renderLinkList(events) {
  const list = document.getElementById('smLinkList');
  if (!events || events.length === 0) {
    list.innerHTML = '<div class="sm-link-empty">Nessun evento disponibile da collegare.</div>';
    return;
  }
  list.innerHTML = events.map(ev => {
    const date  = ev.date  ? ev.date.substring(5).replace('-', '/') : '';
    const time  = ev.start_time ? ev.start_time.substring(0,5) : '';
    const meta  = [date, time, ev.space_name].filter(Boolean).join(' · ');
    return '<div class="sm-link-item">' +
      '<div class="sm-link-item-info">' +
        '<div class="sm-link-item-title">' + esc(ev.title || '') + '</div>' +
        (meta ? '<div class="sm-link-item-meta">' + esc(meta) + '</div>' : '') +
      '</div>' +
      '<button class="sm-link-btn" onclick="linkEvent(' + ev.id + ',this)">Collega</button>' +
    '</div>';
  }).join('');
}

function linkEvent(eventId, btn) {
  if (!_linkGroupId) return;
  btn.disabled = true;
  btn.textContent = '…';
  fetch('/api/stand-event-link', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({ group_id: _linkGroupId, event_id: eventId })
  })
  .then(r => r.json())
  .then(data => {
    if (data.ok) {
      // Aggiorna stand in memoria
      const st = stands.find(x => x.id === _linkGroupId);
      if (st) {
        const ev = _linkAllEvents.find(e => e.id === eventId);
        if (ev) {
          if (!st.events) st.events = [];
          st.events.push(ev);
          st.events.sort((a,b) => ((a.date||'')+(a.start_time||'')).localeCompare((b.date||'')+(b.start_time||'')));
          // Aggiorna dot sulla mappa
          // Ridisegna tutti gli stand per aggiornare il dot
          renderStands();
        }
      }
      // Rimuovi dall'elenco disponibili e aggiorna la lista
      _linkAllEvents = _linkAllEvents.filter(e => e.id !== eventId);
      renderLinkList(_linkAllEvents);
      // Riapri la scheda per aggiornare
      if (st) openSheet(st);
    } else {
      btn.disabled = false; btn.textContent = 'Collega';
      alert('Errore: ' + (data.error || ''));
    }
  })
  .catch(() => { btn.disabled = false; btn.textContent = 'Collega'; alert('Errore di rete.'); });
}

// Chiudi modale cliccando fuori
document.getElementById('smLinkModal').addEventListener('click', function(e) {
  if (e.target === this) closeLinkModal();
});

function focusStand(id) {
  closeDrawer();
  const s = stands.find(x => x.id === id);
  if (!s || s.map_x == null || !leafMap) return;
  const px = parseFloat(s.map_x) / 100 * areaW;
  const py = parseFloat(s.map_y) / 100 * areaH;
  leafMap.setView([areaH - py, px], Math.max(leafMap.getZoom(), 0.5), { animate: true });
  setTimeout(() => openSheet(s), 380);
}
(function(){
  const sh = document.getElementById('smSheet');
  let sy = 0;
  sh.addEventListener('touchstart', e => { sy = e.touches[0].clientY; }, {passive:true});
  sh.addEventListener('touchmove',  e => {
    if (e.touches[0].clientY - sy > 60) closeSheet();
  }, {passive:true});
})();
// click su mappa → closeSheet gestito da leafMap.on('click') in initLeaflet

// ── Pan & Zoom — gestiti da Leaflet ──────────────────────────────────────────
// Leaflet gestisce nativamente touch (iOS Safari incluso), mouse, trackpad e wheel.
// resetView e doZoom sono wrapper sui metodi Leaflet usati dai bottoni .sm-ctrl.
function resetView() {
  if (!leafMap || !imgBounds) return;
  leafMap.fitBounds(imgBounds, { padding: [24, 24], animate: true });
}
function doZoom(f) {
  if (!leafMap) return;
  if (f > 1) leafMap.zoomIn(0.5);
  else       leafMap.zoomOut(0.5);
}

</script>
<!-- Modale aggancio manuale eventi -->
<div class="sm-link-modal" id="smLinkModal">
  <div class="sm-link-box">
    <div class="sm-link-head">
      <span class="sm-link-title">➕ Collega evento a <span id="smLinkStandName"></span></span>
      <button class="sm-link-close" onclick="closeLinkModal()">✕</button>
    </div>
    <div class="sm-link-search">
      <input type="search" id="smLinkSearch" placeholder="Cerca per titolo o data…" oninput="filterLinkModal(this.value)">
    </div>
    <div class="sm-link-list" id="smLinkList"></div>
  </div>
</div>
</body>
</html>
