<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mappa <%= title %></title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; font-family: -apple-system, 'Segoe UI', Arial, sans-serif; background: #f0ede8; color: #1a2744; }

    /* ── NAVBAR ── */
    .navbar {
      background: #1e2d4e; padding: .6rem 1.5rem;
      display: flex; align-items: center; justify-content: space-between;
      border-bottom: 3px solid #f5c842; position: relative; z-index: 1000;
    }
    .navbar-brand { display: flex; align-items: center; gap: .75rem; }
    .navbar-brand img { height: 52px; width: auto; object-fit: contain; mix-blend-mode: screen; }
    .navbar-actions { display: flex; gap: .5rem; }
    .navbar-actions a {
      display: inline-flex; align-items: center; gap: .35rem;
      padding: .35rem .85rem; border-radius: 999px;
      background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.2);
      color: #fff; font-size: .75rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: .4px; transition: background .15s; text-decoration: none;
    }
    .navbar-actions a:hover { background: rgba(255,255,255,.2); }
    .navbar-actions a.active-nav { background: #f5c842; color: #1e2d4e; border-color: #f5c842; }

    /* ── LAYOUT ── */
    .app-wrap { display: flex; height: calc(100vh - 67px); }

    /* ── SIDEBAR ── */
    .sidebar {
      width: 320px; flex-shrink: 0;
      background: #fff; border-right: 1px solid #e2e8f0;
      display: flex; flex-direction: column; overflow: hidden; z-index: 500;
    }
    .sidebar-header { background: #1e2d4e; padding: 1rem 1.2rem .8rem; color: #fff; flex-shrink: 0; }
    .sidebar-header h2 { font-size: .95rem; font-weight: 800; margin-bottom: .5rem; }
    .search-wrap { position: relative; }
    .search-input {
      width: 100%; padding: .5rem .5rem .5rem 2.2rem;
      border: none; border-radius: 8px;
      font-size: .85rem; outline: none; color: #1a2744; background: rgba(255,255,255,.95);
    }
    .search-icon { position: absolute; left: .6rem; top: 50%; transform: translateY(-50%); font-size: .9rem; opacity: .5; pointer-events: none; }

    .filter-tabs {
      display: flex; gap: .35rem; padding: .65rem 1rem .55rem;
      border-bottom: 1px solid #f0f2f7; overflow-x: auto; scrollbar-width: none; flex-shrink: 0;
    }
    .filter-tabs::-webkit-scrollbar { display: none; }
    .ftab {
      flex-shrink: 0; padding: .28rem .75rem; border-radius: 999px;
      border: 1.5px solid #d1d9e6; background: #f8f9fc;
      font-size: .72rem; font-weight: 700; color: #4a5568; cursor: pointer; white-space: nowrap; transition: all .15s;
    }
    .ftab:hover { border-color: #1e2d4e; color: #1e2d4e; }
    .ftab.active { background: #1e2d4e; color: #f5c842; border-color: #1e2d4e; }

    .zone-list { overflow-y: auto; flex: 1; }
    .zone-item {
      display: flex; align-items: flex-start; gap: .75rem;
      padding: .8rem 1rem; border-bottom: 1px solid #f0f2f7;
      cursor: pointer; transition: background .12s;
    }
    .zone-item:hover { background: #f8f9ff; }
    .zone-item.active { background: #eef2ff; border-left: 3px solid #1e2d4e; }
    .zone-item.hidden { display: none; }
    .zone-badge {
      flex-shrink: 0; width: 32px; height: 32px; border-radius: 50%;
      font-weight: 900; font-size: .8rem;
      display: flex; align-items: center; justify-content: center;
      border: 2px solid #fff; box-shadow: 0 1px 4px rgba(0,0,0,.25); margin-top: 2px;
      color: #fff;
    }
    .zone-info { min-width: 0; }
    .zone-name { font-size: .85rem; font-weight: 800; color: #1a2744; line-height: 1.2; }
    .zone-sub  { font-size: .73rem; color: #718096; margin-top: .12rem; line-height: 1.4; }
    .zone-tags { display: flex; flex-wrap: wrap; gap: .3rem; margin-top: .35rem; }
    .zone-tag {
      font-size: .58rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: .3px; padding: .13rem .45rem; border-radius: 999px;
      background: #f0f2f7; color: #4a5568;
    }

    /* ── MAPPA ── */
    #map { flex: 1; z-index: 1; }

    /* Marker */
    .ludi-marker {
      width: 34px; height: 34px; border-radius: 50%;
      color: #fff; font-weight: 900; font-size: .82rem;
      display: flex; align-items: center; justify-content: center;
      border: 2.5px solid #fff;
      box-shadow: 0 2px 8px rgba(0,0,0,.35);
      cursor: pointer; transition: transform .15s, box-shadow .15s;
    }
    .ludi-marker:hover { transform: scale(1.18); box-shadow: 0 4px 14px rgba(0,0,0,.4); }
    .ludi-marker.active-marker { transform: scale(1.22); box-shadow: 0 4px 18px rgba(0,0,0,.5); }

    /* Popup */
    .leaflet-popup-content-wrapper { border-radius: 12px; box-shadow: 0 8px 30px rgba(0,0,0,.18); border: none; padding: 0; overflow: hidden; }
    .leaflet-popup-content { margin: 0; width: 270px !important; }
    .popup-header { padding: .8rem 1rem .6rem; display: flex; align-items: center; gap: .7rem; }
    .popup-badge {
      flex-shrink: 0; width: 36px; height: 36px; border-radius: 50%;
      color: #fff; font-weight: 900; font-size: .88rem;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 2px 6px rgba(0,0,0,.2);
    }
    .popup-title-wrap .popup-title { font-weight: 800; font-size: .92rem; color: #1a2744; line-height: 1.2; }
    .popup-title-wrap .popup-loc   { font-size: .72rem; color: #718096; margin-top: .1rem; }
    .popup-body { padding: 0 1rem .9rem; }
    .popup-desc { font-size: .8rem; color: #4a5568; line-height: 1.55; }
    .popup-tags { display: flex; flex-wrap: wrap; gap: .3rem; margin-top: .55rem; }
    .popup-tag { font-size: .58rem; font-weight: 700; text-transform: uppercase; letter-spacing: .3px; padding: .13rem .45rem; border-radius: 999px; background: #f0f2f7; color: #4a5568; }
    .leaflet-popup-tip { background: #fff; }
    .leaflet-popup-close-button { color: #718096 !important; font-size: 1rem !important; top: 8px !important; right: 10px !important; }

    /* ── EMPTY STATE ── */
    .no-zones { text-align: center; padding: 3rem 1rem; color: #8896ab; }
    .no-zones .no-icon { font-size: 2.5rem; margin-bottom: .5rem; }
    .no-zones a { color: #1e2d4e; font-weight: 700; }

    /* ── MOBILE ── */
    .mobile-detail {
      display: none; position: fixed; bottom: 0; left: 0; right: 0;
      background: #fff; border-radius: 16px 16px 0 0;
      box-shadow: 0 -4px 24px rgba(0,0,0,.18); z-index: 900;
      padding: 1.1rem 1.2rem 2rem;
      transform: translateY(100%); transition: transform .3s cubic-bezier(.16,1,.3,1);
    }
    .mobile-detail.open { transform: translateY(0); }
    .mobile-detail-handle { width: 36px; height: 4px; background: #d1d9e6; border-radius: 2px; margin: 0 auto .85rem; }
    .mobile-detail-close { position: absolute; top: 1rem; right: 1rem; background: #f0f2f7; border: none; border-radius: 50%; width: 30px; height: 30px; font-size: 1rem; cursor: pointer; color: #4a5568; display: flex; align-items: center; justify-content: center; }

    @media (max-width: 768px) {
      .app-wrap { flex-direction: column; height: calc(100vh - 55px); }
      .sidebar { width: 100%; height: 42vh; border-right: none; border-bottom: 1px solid #e2e8f0; }
      #map { flex: 1; min-height: 180px; }
      .navbar { padding: .4rem .9rem; }
      .navbar-brand img { height: 38px; }
      .navbar-actions a { font-size: .65rem; padding: .28rem .6rem; }
    }
    @media (min-width: 769px) { .mobile-detail { display: none !important; } }
  </style>
</head>
<body>

<nav class="navbar">
  <div class="navbar-brand">
    <img src="/ciuco.png" alt="Ludicomix">
    <img src="/logo-ludi.png" alt="Ludicomix" style="margin-left:.4rem">
  </div>
  <div class="navbar-actions">
    <a href="/mappa" class="active-nav">🗺️ Mappa</a>
    <a href="/programma">📅 Programma</a>
    <a href="/ospiti">🎤 Ospiti</a>
  </div>
</nav>

<div class="app-wrap">
  <aside class="sidebar">
    <div class="sidebar-header">
      <h2>📍 Le Location dell'Evento</h2>
      <div class="search-wrap">
        <span class="search-icon">🔍</span>
        <input class="search-input" id="sidebarSearch" type="text" placeholder="Cerca zona…" oninput="filterZones()">
      </div>
    </div>
    <div class="filter-tabs" id="filterTabs">
      <button class="ftab active" onclick="setFilter('all',this)">Tutte</button>
      <button class="ftab" data-filter="area"    onclick="setFilter('area',this)">🎪 Aree</button>
      <button class="ftab" data-filter="mostra"  onclick="setFilter('mostra',this)">🖼️ Mostre</button>
      <button class="ftab" data-filter="extra"   onclick="setFilter('extra',this)">⭐ Extra</button>
      <button class="ftab" data-filter="parking" onclick="setFilter('parking',this)">🅿️ Parcheggi</button>
    </div>
    <div class="zone-list" id="zoneList">
      <% if (!zones || zones.length === 0) { %>
      <div class="no-zones">
        <div class="no-icon">🗺️</div>
        <p>Nessuna zona configurata.<br>
        <a href="/admin/mappa-pubblica">Configura le zone dall'area admin →</a></p>
      </div>
      <% } %>
    </div>
  </aside>
  <div id="map"></div>
</div>

<div class="mobile-detail" id="mobileDetail">
  <div class="mobile-detail-handle"></div>
  <button class="mobile-detail-close" onclick="closeMobileDetail()">✕</button>
  <div id="mobileDetailContent"></div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
var ZONES = <%- zonesJson %>;

/* ── colori per tipo ── */
var TYPE_COLORS = {
  area:    '#e8372a',
  mostra:  '#1e2d4e',
  extra:   '#6b3fa0',
  parking: '#1e7ed4',
  default: '#555'
};
function zoneColor(z) {
  if (z.map_color) return z.map_color;
  return TYPE_COLORS[z.map_type] || TYPE_COLORS.default;
}

/* ── MAPPA ── */
var mapCenter = ZONES.length
  ? [ZONES.reduce(function(s,z){return s+z.map_lat;},0)/ZONES.length,
     ZONES.reduce(function(s,z){return s+z.map_lng;},0)/ZONES.length]
  : [43.7183, 10.9488];

var map = L.map('map', { center: mapCenter, zoom: 16 });
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
  attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>', maxZoom: 19
}).addTo(map);

/* ── MARKER ── */
var markers = {}, activeId = null, activeFilter = 'all';

function makeIcon(z, isActive) {
  var color = zoneColor(z);
  var lbl = z.map_label || z.name.substring(0,3);
  var cls = 'ludi-marker' + (isActive ? ' active-marker' : '');
  return L.divIcon({
    className: '',
    html: '<div class="' + cls + '" style="background:' + color + '">' + lbl + '</div>',
    iconSize: [34,34], iconAnchor: [17,17], popupAnchor: [0,-22]
  });
}

function popupHtml(z) {
  var color = zoneColor(z);
  var lbl = z.map_label || z.name.substring(0,3);
  var tags = z.map_tags ? z.map_tags.split(',').map(function(t){
    return '<span class="popup-tag">'+t.trim()+'</span>';
  }).join('') : '';
  return '<div class="popup-header">' +
    '<div class="popup-badge" style="background:'+color+'">'+lbl+'</div>' +
    '<div class="popup-title-wrap">' +
      '<div class="popup-title">'+z.name+'</div>' +
      (z.map_address ? '<div class="popup-loc">📍 '+z.map_address+'</div>' : '') +
    '</div></div>' +
    '<div class="popup-body">' +
      (z.map_desc ? '<div class="popup-desc">'+z.map_desc+'</div>' : '') +
      (tags ? '<div class="popup-tags">'+tags+'</div>' : '') +
    '</div>';
}

ZONES.forEach(function(z) {
  if (!z.map_lat || !z.map_lng) return;
  var m = L.marker([z.map_lat, z.map_lng], { icon: makeIcon(z, false) })
    .addTo(map).bindPopup(popupHtml(z), { maxWidth: 290 });
  m.on('click', function() { activateZone(z.id); });
  markers[z.id] = m;
});

/* ── SIDEBAR ── */
function renderSidebar() {
  var list = document.getElementById('zoneList');
  if (ZONES.length === 0) return;
  list.innerHTML = '';
  ZONES.forEach(function(z) {
    var color = zoneColor(z);
    var lbl = z.map_label || z.name.substring(0,3);
    var tags = z.map_tags ? z.map_tags.split(',').map(function(t){
      return '<span class="zone-tag">'+t.trim()+'</span>';
    }).join('') : '';
    var div = document.createElement('div');
    div.className = 'zone-item';
    div.setAttribute('data-id', z.id);
    div.setAttribute('data-type', z.map_type || 'area');
    div.setAttribute('data-search', (z.name+' '+(z.map_address||'')+' '+(z.map_desc||'')).toLowerCase());
    div.innerHTML =
      '<div class="zone-badge" style="background:'+color+'">'+lbl+'</div>' +
      '<div class="zone-info">' +
        '<div class="zone-name">'+z.name+'</div>' +
        (z.map_address ? '<div class="zone-sub">'+z.map_address+'</div>' : '') +
        (tags ? '<div class="zone-tags">'+tags+'</div>' : '') +
      '</div>';
    div.addEventListener('click', function() { focusZone(z.id); });
    list.appendChild(div);
  });
}
renderSidebar();

function focusZone(id) {
  var z = ZONES.find(function(x){ return x.id===id; });
  if (!z || !z.map_lat) return;
  activateZone(id);
  map.setView([z.map_lat, z.map_lng], Math.max(z.map_zoom||16, 17), { animate: true });
  if (markers[id]) markers[id].openPopup();
  if (window.innerWidth <= 768) openMobileDetail(z);
}

function activateZone(id) {
  if (activeId && markers[activeId]) {
    var old = ZONES.find(function(x){return x.id===activeId;});
    if (old) markers[activeId].setIcon(makeIcon(old, false));
  }
  activeId = id;
  var z = ZONES.find(function(x){return x.id===id;});
  if (z && markers[id]) markers[id].setIcon(makeIcon(z, true));
  document.querySelectorAll('.zone-item').forEach(function(el){
    var act = parseInt(el.getAttribute('data-id'))===id;
    el.classList.toggle('active', act);
    if (act) el.scrollIntoView({ behavior:'smooth', block:'nearest' });
  });
}

function setFilter(f, btn) {
  activeFilter = f;
  document.querySelectorAll('.ftab').forEach(function(b){ b.classList.remove('active'); });
  btn.classList.add('active');
  filterZones();
}

function filterZones() {
  var search = (document.getElementById('sidebarSearch').value||'').toLowerCase().trim();
  document.querySelectorAll('.zone-item').forEach(function(el) {
    var type   = el.getAttribute('data-type');
    var sText  = el.getAttribute('data-search');
    var okF    = activeFilter==='all' || type===activeFilter;
    var okS    = !search || sText.includes(search);
    el.classList.toggle('hidden', !(okF && okS));
  });
  // nascondi/mostra marker
  ZONES.forEach(function(z) {
    if (!markers[z.id]) return;
    var type   = z.map_type || 'area';
    var sText  = (z.name+' '+(z.map_address||'')).toLowerCase();
    var show   = (activeFilter==='all' || type===activeFilter) && (!search || sText.includes(search));
    if (show) { if (!map.hasLayer(markers[z.id])) markers[z.id].addTo(map); }
    else      { if (map.hasLayer(markers[z.id]))  map.removeLayer(markers[z.id]); }
  });
}

/* ── MOBILE DETAIL ── */
function openMobileDetail(z) {
  var color = zoneColor(z);
  var lbl = z.map_label || z.name.substring(0,3);
  var tags = z.map_tags ? z.map_tags.split(',').map(function(t){
    return '<span class="popup-tag" style="background:#f0f2f7;color:#4a5568;font-size:.65rem;padding:.15rem .5rem;border-radius:999px;font-weight:700;text-transform:uppercase">'+t.trim()+'</span>';
  }).join('') : '';
  document.getElementById('mobileDetailContent').innerHTML =
    '<div style="display:flex;gap:.75rem;align-items:flex-start;margin-bottom:.7rem">' +
      '<div class="popup-badge" style="background:'+color+';flex-shrink:0;width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:900">'+lbl+'</div>' +
      '<div><div style="font-weight:800;font-size:.95rem;color:#1a2744">'+z.name+'</div>' +
      (z.map_address ? '<div style="font-size:.75rem;color:#718096;margin-top:.1rem">📍 '+z.map_address+'</div>' : '') +
      '</div></div>' +
      (z.map_desc ? '<div style="font-size:.82rem;color:#4a5568;line-height:1.55;margin-bottom:.6rem">'+z.map_desc+'</div>' : '') +
      (tags ? '<div style="display:flex;flex-wrap:wrap;gap:.3rem">'+tags+'</div>' : '');
  document.getElementById('mobileDetail').classList.add('open');
}
function closeMobileDetail() { document.getElementById('mobileDetail').classList.remove('open'); }
map.on('click', function(){ closeMobileDetail(); });
</script>
</body>
</html>