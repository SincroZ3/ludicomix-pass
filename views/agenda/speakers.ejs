<%- include('../partials/header') %>
<main class="content">

  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;margin-bottom:1.2rem;">
    <h1 class="page-title" style="margin:0;border:none;">🎤 Ospiti e Speaker</h1>
    <div style="display:flex;gap:.5rem;">
      <button class="primary" onclick="document.getElementById('modal-new-spk').style.display='flex'">+ Nuovo Speaker</button>
      <a href="/agenda" class="secondary">← Agenda</a>
    </div>
  </div>

  <% if (flash) { %>
    <div class="alert alert-<%= flash.type === 'error' ? 'danger' : 'success' %>">
      <span><%= flash.type === 'error' ? '⚠️' : '✅' %></span>
      <span><%- flash.msg %></span>
    </div>
  <% } %>

  <% if (speakers.length === 0) { %>
    <div class="card" style="text-align:center;padding:3rem;color:var(--text-muted);">
      <div style="font-size:2.5rem;margin-bottom:.75rem;">🎤</div>
      <p>Nessun ospite o speaker registrato.</p>
    </div>
  <% } else { %>
    <div class="table-wrapper">
      <table>
        <thead><tr>
          <th>Nome</th><th>Email</th><th>Telefono</th><th>Link</th><th>Eventi</th><th>Stato</th><th>Azioni</th>
        </tr></thead>
        <tbody>
        <% speakers.forEach(s => { %>
          <tr>
            <td>
              <div style="display:flex;align-items:center;gap:.6rem;">
                <% if(s.photo_url) { %>
                  <img src="<%= s.photo_url %>" alt="<%= s.name %>"
                       style="width:36px;height:36px;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid #e2e8f0;">
                <% } else { %>
                  <div style="width:36px;height:36px;border-radius:50%;background:#e8ecf3;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1rem;">🎤</div>
                <% } %>
                <div>
                  <strong><%= s.name %></strong>
                  <% if(s.bio) { %>
                    <br><small style="color:var(--text-muted)"><%= s.bio.slice(0,60) %><%= s.bio.length > 60 ? '…' : '' %></small>
                  <% } %>
                </div>
              </div>
            </td>
            <td><%= s.email || '—' %></td>
            <td><%= s.phone || '—' %></td>
            <td>
              <% if(s.social_url) { %>
                <a href="<%= s.social_url %>" target="_blank" class="link-action">↗</a>
              <% } else { %>—<% } %>
            </td>
            <td><%= s.event_count %></td>
            <td>
              <% if(s.active) { %>
                <span style="color:#1d6a39;font-weight:700;">Attivo</span>
              <% } else { %>
                <span style="color:var(--text-muted)">Disabilitato</span>
              <% } %>
            </td>
            <td style="white-space:nowrap;">
              <button class="secondary btn-edit-spk"
                style="padding:.25rem .6rem;font-size:.76rem;"
                data-id="<%= s.id %>"
                data-name="<%= encodeURIComponent(s.name || '') %>"
                data-bio="<%= encodeURIComponent(s.bio || '') %>"
                data-email="<%= encodeURIComponent(s.email || '') %>"
                data-phone="<%= encodeURIComponent(s.phone || '') %>"
                data-social="<%= encodeURIComponent(s.social_url || '') %>"
                data-notes="<%= encodeURIComponent(s.notes || '') %>"
                data-active="<%= s.active ? '1' : '0' %>"
                data-photo="<%= encodeURIComponent(s.photo_url || '') %>">
                Modifica
              </button>
              <form method="POST" action="/agenda/speakers/<%= s.id %>/delete" style="display:inline;"
                onsubmit="return confirm('Eliminare questo speaker?')">
                <button class="btn-danger">Elimina</button>
              </form>
            </td>
          </tr>
        <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>

</main>

<!-- Modal: Nuovo Speaker -->
<div id="modal-new-spk" class="modal-overlay" onclick="if(event.target===this)this.style.display='none'">
  <div class="modal" style="max-width:560px;">
    <div class="modal-header">
      <h2>Nuovo Ospite / Speaker</h2>
      <button class="modal-close" onclick="document.getElementById('modal-new-spk').style.display='none'">✕</button>
    </div>
    <form method="POST" action="/agenda/speakers">
      <div class="modal-body">
        <div>
          <label>Nome <span class="req">*</span></label>
          <input type="text" name="name" required placeholder="Nome e cognome">
        </div>
        <div>
          <label>Bio / Presentazione</label>
          <textarea name="bio" rows="3" placeholder="Breve presentazione…"></textarea>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
          <div>
            <label>Email</label>
            <input type="email" name="email">
          </div>
          <div>
            <label>Telefono</label>
            <input type="text" name="phone">
          </div>
        </div>
        <div>
          <label>URL Foto (opzionale)</label>
          <input type="url" name="photo_url" placeholder="https://… (link immagine profilo)">
        </div>
        <div>
          <label>Link / Social</label>
          <input type="url" name="social_url" placeholder="https://…">
        </div>
        <div>
          <label>Note interne</label>
          <textarea name="notes" rows="2"></textarea>
        </div>
        <div class="modal-actions">
          <button type="button" class="secondary" onclick="document.getElementById('modal-new-spk').style.display='none'">Annulla</button>
          <button type="submit" class="primary">Aggiungi</button>
        </div>
      </div>
    </form>
  </div>
</div>

<!-- Modal: Modifica Speaker -->
<div id="modal-edit-spk" class="modal-overlay" onclick="if(event.target===this)this.style.display='none'">
  <div class="modal" style="max-width:560px;">
    <div class="modal-header">
      <h2>Modifica Speaker</h2>
      <button class="modal-close" onclick="document.getElementById('modal-edit-spk').style.display='none'">✕</button>
    </div>
    <form method="POST" id="form-edit-spk">
      <div class="modal-body">
        <div><label>Nome <span class="req">*</span></label><input type="text" name="name" id="espk-name" required></div>
        <div><label>Bio</label><textarea name="bio" id="espk-bio" rows="3"></textarea></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
          <div><label>Email</label><input type="email" name="email" id="espk-email"></div>
          <div><label>Telefono</label><input type="text" name="phone" id="espk-phone"></div>
        </div>
        <div><label>URL Foto (opzionale)</label><input type="url" name="photo_url" id="espk-photo" placeholder="https://… (link immagine profilo)"></div>
        <div><label>Link / Social</label><input type="url" name="social_url" id="espk-social"></div>
        <div><label>Note interne</label><textarea name="notes" id="espk-notes" rows="2"></textarea></div>
        <div>
          <label>
            <input type="checkbox" name="active" id="espk-active" value="1">
            Speaker attivo
          </label>
        </div>
        <div class="modal-actions">
          <button type="button" class="secondary" onclick="document.getElementById('modal-edit-spk').style.display='none'">Annulla</button>
          <button type="submit" class="primary">Salva</button>
        </div>
      </div>
    </form>
  </div>
</div>

<script>
document.querySelectorAll('.btn-edit-spk').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var d = btn.dataset;
    document.getElementById('form-edit-spk').action    = '/agenda/speakers/' + d.id;
    document.getElementById('espk-name').value         = decodeURIComponent(d.name);
    document.getElementById('espk-bio').value          = decodeURIComponent(d.bio);
    document.getElementById('espk-email').value        = decodeURIComponent(d.email);
    document.getElementById('espk-phone').value        = decodeURIComponent(d.phone);
    document.getElementById('espk-photo').value        = decodeURIComponent(d.photo || '');
    document.getElementById('espk-social').value       = decodeURIComponent(d.social);
    document.getElementById('espk-notes').value        = decodeURIComponent(d.notes);
    document.getElementById('espk-active').checked     = d.active === '1';
    document.getElementById('modal-edit-spk').style.display = 'flex';
  });
});
</script>

<%- include('../partials/footer') %>
