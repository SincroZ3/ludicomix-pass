<%- include('../partials/header', { path: '/agenda', currentUser: currentUser }) %>

<style>
  /* ── KPI CARDS ── */
  .kpi-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:1rem;margin-bottom:1.5rem}
  .kpi-card{background:#fff;border:1px solid #e2e8f0;border-radius:12px;box-shadow:0 1px 4px rgba(30,45,78,.06);padding:1rem 1.2rem;display:flex;flex-direction:column;align-items:center;text-align:center;gap:.3rem}
  .kpi-icon{font-size:1.8rem}
  .kpi-value{font-size:1.6rem;font-weight:800;color:#1e2d4e;line-height:1}
  .kpi-label{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:#94a3b8}
  .kpi-link{color:#1e2d4e;font-weight:700;font-size:.88rem;text-decoration:none}
  .kpi-link:hover{text-decoration:underline}

  /* ── TOOLBAR ── */
  .agenda-toolbar{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem;margin-bottom:1.25rem}
  .btn-toolbar{display:inline-flex;align-items:center;gap:.4rem;padding:.44rem .95rem;border-radius:8px;font-size:.82rem;font-weight:700;cursor:pointer;text-decoration:none;border:1.5px solid transparent;font-family:inherit;transition:all .15s}
  .btn-primary{background:#f5c842;color:#1e2d4e;border-color:#f5c842}
  .btn-primary:hover{background:#e6b800;border-color:#e6b800}
  .btn-ghost{background:#fff;color:#1e2d4e;border-color:#d1d9e6}
  .btn-ghost:hover{background:#f1f5f9}
  .btn-ghost.active{background:#1e2d4e;color:#f5c842;border-color:#1e2d4e}

  /* ── CALENDAR ── */
  .cal-wrap{background:#fff;border:1px solid #e2e8f0;border-radius:12px;box-shadow:0 1px 4px rgba(30,45,78,.06);overflow:hidden}
  .cal-grid{display:grid;gap:0}
  /* Navigazione giorni */
  .day-nav{display:flex;align-items:center;justify-content:space-between;gap:.75rem;background:#1e2d4e;border-radius:10px;padding:.5rem .75rem;margin-bottom:.5rem}
  .day-nav-btn{display:inline-flex;align-items:center;gap:.35rem;background:rgba(255,255,255,.1);color:#f5c842;border:1.5px solid rgba(255,255,255,.15);border-radius:99px;padding:.35rem .9rem;font-size:.8rem;font-weight:700;cursor:pointer;font-family:inherit;transition:all .15s;text-decoration:none}
  .day-nav-btn:hover{background:rgba(255,255,255,.2);border-color:rgba(255,255,255,.35)}
  .day-nav-btn.disabled{opacity:.3;cursor:not-allowed;pointer-events:none}
  .day-nav-center{text-align:center;flex:1}
  .day-nav-label{font-size:1.05rem;font-weight:800;color:#fff;line-height:1.2}
  .day-nav-date{font-size:.75rem;color:#aec6e8;font-weight:500;margin-top:.1rem}
  .day-nav-dots{display:flex;gap:.35rem;justify-content:center;margin-top:.4rem}
  .day-dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.25);cursor:pointer;transition:background .15s}
  .day-dot.active{background:#f5c842}
  .cal-col-head{background:#1e2d4e;color:#fff;padding:.65rem .5rem;text-align:center;font-size:.78rem;font-weight:800;letter-spacing:.04em;border-left:1px solid rgba(255,255,255,.12)}
  .cal-col-head:first-child{background:#162038;border-left:none}
  .cal-col-head .day-label{font-size:.65rem;font-weight:600;opacity:.75;text-transform:uppercase;letter-spacing:.06em}
  .cal-col-head .day-date{font-size:1rem;font-weight:800;margin-top:.1rem}
  .cal-time-label{font-size:.67rem;color:#94a3b8;padding:.15rem .3rem 0;text-align:right;font-variant-numeric:tabular-nums;border-top:1px solid #f1f5f9;border-right:1px solid #e8ecf0;background:#fafbfc;line-height:1}
  .cal-time-label.hour{color:#475569;font-weight:600;border-top:1px solid #e2e8f0}
  .cal-cell{border-top:1px solid #f1f5f9;border-left:1px solid #e8ecf0;position:relative;background:#fff}
  .cal-cell.hour{border-top:1px solid #e2e8f0}
  .cal-event{position:absolute;border-radius:5px;padding:.2rem .4rem;font-size:.7rem;font-weight:700;color:#fff;overflow:hidden;cursor:pointer;transition:opacity .15s;z-index:1;box-shadow:0 1px 3px rgba(0,0,0,.18);box-sizing:border-box;left:1px;right:1px}
  .cal-event:hover{opacity:.88;z-index:10}
  .cal-event .ev-title{font-size:.72rem;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .cal-event .ev-meta{font-size:.63rem;opacity:.88;margin-top:.05rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .cal-empty-msg{display:flex;align-items:center;justify-content:center;min-height:200px;color:#cbd5e1;font-size:.82rem}

  /* ── TOOLTIP evento ── */
  #ev-tooltip{position:fixed;z-index:9999;background:#1e2d4e;color:#fff;border-radius:10px;padding:.75rem 1rem;font-size:.82rem;max-width:260px;box-shadow:0 8px 24px rgba(0,0,0,.22);pointer-events:none;display:none;line-height:1.4}
  #ev-tooltip .tt-title{font-weight:800;font-size:.9rem;margin-bottom:.3rem}
  #ev-tooltip .tt-row{font-size:.78rem;opacity:.85;margin-top:.15rem}

  /* ── FLASH ── */
  .flash{padding:.65rem 1rem;border-radius:8px;font-size:.85rem;font-weight:600;margin-bottom:1rem}
  .flash.success{background:#d1fae5;color:#065f46;border:1px solid #6ee7b7}
  .flash.error{background:#fef2f2;color:#dc2626;border:1px solid #fecaca}

  @media(max-width:700px){
    .kpi-grid{grid-template-columns:1fr 1fr}
    .agenda-toolbar{flex-direction:column;align-items:stretch}
  }
</style>

<div class="container" style="max-width:1200px;margin:1.5rem auto;padding:0 1.25rem 3rem">

  <!-- BREADCRUMB -->
  <div style="font-size:.78rem;color:#64748b;margin-bottom:1rem">
    <a href="/home" style="color:#1e2d4e;text-decoration:none">🏠 Home</a>
    <span style="margin:0 .4rem">›</span>
    <span>📅 Agenda Palinsesto</span>
  </div>

  <% if(typeof flash !== 'undefined' && flash){ %>
    <div class="flash <%= flash.type %>"><%= flash.msg %></div>
  <% } %>

  <!-- TITOLO + AZIONI -->
  <div class="agenda-toolbar">
    <h1 style="font-size:1.35rem;font-weight:800;color:#1e2d4e;line-height:1.15">📅 Agenda Palinsesto</h1>
    <div style="display:flex;gap:.5rem;flex-wrap:wrap">
      <a href="/agenda/events/new" class="btn-toolbar btn-primary">+ NUOVO EVENTO</a>
      <a href="/agenda/events" class="btn-toolbar btn-ghost">TUTTI GLI EVENTI</a>
      <a href="/agenda/spaces" class="btn-toolbar btn-ghost">🏛 SALE</a>
      <a href="/agenda/speakers" class="btn-toolbar btn-ghost">🎤 SPEAKER</a>
      <a href="/agenda/registrations" class="btn-toolbar btn-ghost">📋 ISCRIZIONI</a>
    </div>
  </div>

  <!-- KPI -->
  <div class="kpi-grid">
    <div class="kpi-card">
      <span class="kpi-icon">📅</span>
      <span class="kpi-value"><%= totalEvents %></span>
      <span class="kpi-label">Totale eventi</span>
    </div>
    <div class="kpi-card">
      <span class="kpi-icon">👥</span>
      <span class="kpi-value"><%= totalRegistrations %></span>
      <span class="kpi-label">Iscrizioni confermate</span>
    </div>
    <div class="kpi-card">
      <span class="kpi-icon">🏛</span>
      <span class="kpi-value"><%= spaces.length %></span>
      <span class="kpi-label">Sale attive</span>
    </div>
    <div class="kpi-card" style="cursor:default">
      <span class="kpi-icon">📡</span>
      <a href="/programma" target="_blank" class="kpi-link">Programma Pubblico ↗</a>
      <a href="/programma/qr" target="_blank" class="btn-toolbar btn-ghost" style="font-size:.72rem;padding:.25rem .65rem;margin-top:.2rem">■ QR Code</a>
    </div>
  </div>

  <!-- FILTRO SALE -->
  <% if(spaces && spaces.length){ %>
  <div style="display:flex;flex-wrap:wrap;gap:.4rem;margin-bottom:.85rem;align-items:center">
    <span style="font-size:.75rem;font-weight:700;color:#64748b;margin-right:.25rem">FILTRA:</span>
    <button class="space-filter-btn active" data-space="all"
      style="display:inline-flex;align-items:center;gap:.35rem;background:#1e2d4e;color:#f5c842;border:1.5px solid #1e2d4e;border-radius:99px;padding:.25rem .85rem;font-size:.76rem;font-weight:700;cursor:pointer;font-family:inherit;transition:all .15s">
      Tutte le sale
    </button>
    <% spaces.forEach(function(sp){ %>
    <button class="space-filter-btn" data-space="<%= sp.id %>"
      style="display:inline-flex;align-items:center;gap:.35rem;background:#fff;color:#1e2d4e;border:1.5px solid #d1d9e6;border-radius:99px;padding:.25rem .85rem;font-size:.76rem;font-weight:700;cursor:pointer;font-family:inherit;transition:all .15s"
      data-color="<%= sp.color||'#4f98a3' %>">
      <span style="width:9px;height:9px;border-radius:50%;background:<%= sp.color||'#4f98a3' %>;flex-shrink:0;display:inline-block"></span>
      <%= sp.name %>
    </button>
    <% }); %>
  </div>
  <% } %>

  <!-- CALENDARIO -->
  <div class="cal-wrap">
    <%

      // ── Ricava i giorni disponibili dagli eventi ──
      var FIERA_DAYS_FULL = ['Domenica','Lunedì','Martedì','Mercoledì','Giovedì','Venerdì','Sabato'];

      // Prendi tutti i giorni distinti presenti negli eventi, mostra solo Sabato+Domenica se disponibili
      // altrimenti tutti i giorni con eventi
      var allDates = {};
      (allEvents||[]).forEach(function(e){ if(e.date) allDates[e.date] = true; });
      var sortedDates = Object.keys(allDates).sort();

      // Filtra solo Sab+Dom se presenti, altrimenti usa tutti i giorni (max 3)
      var satSun = sortedDates.filter(function(d){
        var day = new Date(d+'T12:00:00').getDay();
        return day === 6 || day === 0;
      });
      var CAL_DAYS = satSun.length >= 2 ? satSun.slice(0,3) : sortedDates.slice(0,3);

      // Fallback: se non ci sono eventi mostriamo sabato e domenica di default (fiera)
      if(!CAL_DAYS.length){
        CAL_DAYS = ['2026-05-16','2026-05-17'];
      }

      var CAL_LABELS = CAL_DAYS.map(function(d){
        var dt = new Date(d+'T12:00:00');
        return FIERA_DAYS_FULL[dt.getDay()];
      });

      // ── Fascia oraria: 09:00–23:00 step 15 min ──
      var CAL_START = 9;
      var CAL_END   = 23;
      var SLOT_MIN  = 15;          // minuti per slot
      var SLOT_H    = 14;          // px per slot da 15 min
      var SLOTS_PER_HOUR = 60 / SLOT_MIN;  // = 4

      var slots = [];
      for(var h = CAL_START; h < CAL_END; h++){
        for(var m = 0; m < 60; m += SLOT_MIN){
          slots.push({ h: h, m: m });
        }
      }

      // ── Raggruppa eventi per giorno ──
      var eventsByDay = {};
      CAL_DAYS.forEach(function(d){ eventsByDay[d] = []; });
      (allEvents||[]).forEach(function(e){
        if(eventsByDay[e.date]) eventsByDay[e.date].push(e);
      });

      function timeToMin(tStr){
        if(!tStr) return 0;
        var parts = tStr.split(':');
        return parseInt(parts[0]||0)*60 + parseInt(parts[1]||0);
      }

      // ── Calcolo colonne per eventi sovrapposti ──
      var colPos = {};
      CAL_DAYS.forEach(function(day){
        var dayEvents = eventsByDay[day]||[];
        if(!dayEvents.length) return;
        var sorted = dayEvents.slice().sort(function(a,b){
          return timeToMin(a.start_time) - timeToMin(b.start_time);
        });
        var clusters = [];
        sorted.forEach(function(ev){
          var eStart = timeToMin(ev.start_time);
          var eEnd   = timeToMin(ev.end_time);
          var placed = false;
          for(var ci=0;ci<clusters.length;ci++){
            var ok = clusters[ci].some(function(c){
              return eStart < timeToMin(c.end_time) && eEnd > timeToMin(c.start_time);
            });
            if(ok){ clusters[ci].push(ev); placed=true; break; }
          }
          if(!placed) clusters.push([ev]);
        });
        clusters.forEach(function(cluster){
          var n = cluster.length;
          if(n===1){ colPos[cluster[0].id]={col:0,total:1}; return; }
          var cols=[];
          cluster.forEach(function(ev){
            var eStart=timeToMin(ev.start_time), eEnd=timeToMin(ev.end_time);
            var placed=false;
            for(var ci=0;ci<cols.length;ci++){
              if(cols[ci]<=eStart){ cols[ci]=eEnd; colPos[ev.id]={col:ci,total:n}; placed=true; break; }
            }
            if(!placed){ colPos[ev.id]={col:cols.length,total:n}; cols.push(eEnd); }
          });
          var realCols=cols.length;
          cluster.forEach(function(ev){ if(colPos[ev.id]) colPos[ev.id].total=realCols; });
        });
      });

      var numDays = CAL_DAYS.length;
      var gridCols = '56px repeat(' + numDays + ', 1fr)';
    %>

    <% if(!(allEvents && allEvents.length)){ %>
      <div class="cal-empty-msg">
        <div style="text-align:center">
          <div style="font-size:2.5rem;margin-bottom:.5rem">📭</div>
          <div style="font-weight:700;color:#64748b">Nessun evento programmato</div>
          <div style="font-size:.8rem;color:#94a3b8;margin-top:.3rem;margin-bottom:1rem">Crea il primo evento per vederlo nel calendario</div>
          <a href="/agenda/events/new" class="btn-toolbar btn-primary" style="display:inline-flex">+ CREA IL PRIMO EVENTO</a>
        </div>
      </div>
    <% } else { %>

    <!-- NAVIGAZIONE GIORNO SINGOLO -->
    <div class="day-nav" id="dayNav">
      <button class="day-nav-btn" id="btnPrevDay" onclick="changeDay(-1)">&#8592; Prec.</button>
      <div class="day-nav-center">
        <div class="day-nav-label" id="dayNavLabel"></div>
        <div class="day-nav-date" id="dayNavDate"></div>
        <div class="day-nav-dots" id="dayNavDots"></div>
      </div>
      <button class="day-nav-btn" id="btnNextDay" onclick="changeDay(+1)">Succ. &#8594;</button>
    </div>

    <!-- HEADER GIORNO ATTIVO (sticky) -->
    <div style="display:grid;grid-template-columns:56px 1fr;position:sticky;top:0;z-index:20" id="calDayHeader">
      <div class="cal-col-head" style="background:#162038;padding:.65rem .3rem;font-size:.65rem;color:#94a3b8;text-align:right"></div>
      <div class="cal-col-head" id="calDayHeaderCell">
        <div class="day-label" id="hdrDayLabel"></div>
        <div class="day-date"><span id="hdrDayDate" style="font-size:.72rem;font-weight:600;opacity:.75"></span></div>
        <div style="font-size:.65rem;opacity:.6;margin-top:.1rem" id="hdrDayCount"></div>
      </div>
    </div>

    <!-- GRIGLIA ORARIA -->
    <div style="overflow-y:auto;max-height:75vh" id="calScrollWrap">
      <div class="cal-grid" style="grid-template-columns:56px 1fr" id="calGrid">

        <% slots.forEach(function(slot, si){
          var isHour = slot.m === 0;
          var isQuarter = slot.m === 15 || slot.m === 45;
        %>

          <!-- Etichetta ora -->
          <div class="cal-time-label <%= isHour ? 'hour' : '' %>" style="height:<%= SLOT_H %>px;line-height:<%= SLOT_H %>px;padding:0 4px 0 0">
            <% if(isHour){ %><%= String(slot.h).padStart(2,'0') %>:00<% } else if(slot.m===30){ %><span style="opacity:.5"><%= String(slot.h).padStart(2,'0') %>:30</span><% } %>
          </div>

          <!-- Celle per ogni giorno (tutte renderizzate, nascoste via JS) -->
          <% CAL_DAYS.forEach(function(day, di){
            var dayEvs = eventsByDay[day]||[];
            var slotMin = slot.h*60 + slot.m;
          %>
            <div class="cal-cell <%= isHour ? 'hour' : '' %>" style="height:<%= SLOT_H %>px" data-day="<%= day %>">
              <%
                // Renderizza gli eventi che iniziano in questo slot
                dayEvs.forEach(function(ev){
                  var evStartMin = timeToMin(ev.start_time);
                  var evEndMin   = timeToMin(ev.end_time);
                  if(evStartMin !== slotMin) return;   // solo dove iniziano

                  var durationMin = evEndMin - evStartMin;
                  if(durationMin <= 0) durationMin = SLOT_MIN;
                  var heightPx = Math.round((durationMin / SLOT_MIN) * SLOT_H) - 2;
                  var cp = colPos[ev.id] || {col:0,total:1};
                  var pct = 100 / cp.total;
                  var leftPct = cp.col * pct;

                  // Colore: usa space_color se disponibile, altrimenti colori predefiniti
                  var bgColor = ev.space_color || '#1e2d4e';
              %>
              <a href="/agenda/events/<%= ev.id %>/edit"
                 class="cal-event"
                 style="top:1px;height:<%= heightPx %>px;left:calc(<%= leftPct %>% + 1px);width:calc(<%= pct %>% - 3px);background:<%= bgColor %>"
                 data-title="<%= (ev.title||'').replace(/"/g,'&quot;') %>"
                 data-space="<%= (ev.space_name||'').replace(/"/g,'&quot;') %>"
                 data-time="<%= ev.start_time ? ev.start_time.slice(0,5) : '' %>–<%= ev.end_time ? ev.end_time.slice(0,5) : '' %>"
                 data-seats="<%= ev.seats_taken||0 %>/<%= ev.space_capacity||'?' %>"
                 data-space-id="<%= ev.space_id %>"
                 data-cell="<%= day %>-<%= slotMin %>"
                 data-start="<%= evStartMin %>"
                 data-end="<%= evEndMin %>"
                 data-day="<%= day %>"
                 onmouseenter="showEvTooltip(event,this)"
                 onmouseleave="hideEvTooltip()">
                <div class="ev-title"><%= ev.title %></div>
                <% if(heightPx > 30){ %>
                <div class="ev-meta"><%= ev.space_name %> · <%= ev.start_time ? ev.start_time.slice(0,5) : '' %>–<%= ev.end_time ? ev.end_time.slice(0,5) : '' %></div>
                <% } %>
              </a>
              <% }); %>
            </div>
          <% }); %>

        <% }); %>
      </div><!-- /cal-grid -->
    </div><!-- /scroll -->
    <% } %>
  </div><!-- /cal-wrap -->

  <!-- LEGENDA SALE -->
  <% if(spaces && spaces.length){ %>
  <div style="display:flex;flex-wrap:wrap;gap:.5rem;margin-top:.85rem">
    <% spaces.forEach(function(sp){ %>
      <span style="display:inline-flex;align-items:center;gap:.35rem;background:#f8fafc;border:1px solid #e2e8f0;border-radius:99px;padding:.2rem .75rem;font-size:.75rem;font-weight:600;color:#1e2d4e">
        <span style="width:10px;height:10px;border-radius:50%;background:<%= sp.color||'#4f98a3' %>;flex-shrink:0"></span>
        <%= sp.name %> <span style="opacity:.55;font-weight:400">(cap. <%= sp.capacity %>)</span>
      </span>
    <% }); %>
  </div>
  <% } %>

</div><!-- /container -->

<!-- TOOLTIP -->
<div id="ev-tooltip">
  <div class="tt-title" id="tt-title"></div>
  <div class="tt-row" id="tt-time">🕐 </div>
  <div class="tt-row" id="tt-space">🏛 </div>
  <div class="tt-row" id="tt-seats">👥 </div>
</div>

<script>
function showEvTooltip(e, el) {
  var t = document.getElementById('ev-tooltip');
  document.getElementById('tt-title').textContent  = el.dataset.title;
  document.getElementById('tt-time').textContent   = '🕐 ' + el.dataset.time;
  document.getElementById('tt-space').textContent  = '🏛 '  + el.dataset.space;
  document.getElementById('tt-seats').textContent  = '👥 ' + el.dataset.seats + ' iscritti';
  t.style.display = 'block';
  posTooltip(e, t);
}
function posTooltip(e, t) {
  var x = e.clientX + 14, y = e.clientY - 10;
  if(x + 270 > window.innerWidth) x = e.clientX - 280;
  if(y + 140 > window.innerHeight) y = e.clientY - 150;
  t.style.left = x + 'px';
  t.style.top  = y + 'px';
}
function hideEvTooltip() {
  document.getElementById('ev-tooltip').style.display = 'none';
}
document.addEventListener('mousemove', function(e){
  var t = document.getElementById('ev-tooltip');
  if(t.style.display !== 'none') posTooltip(e, t);
});

// ── FILTRO SALE ──
function recalcEventPositions(spaceId) {
  // Raccoglie eventi visibili filtrati per sala
  var visibleEvs = [];
  document.querySelectorAll('.cal-event').forEach(function(ev) {
    if (spaceId !== 'all' && ev.dataset.spaceId !== spaceId) return;
    if (ev.style.display === 'none') return;
    visibleEvs.push(ev);
  });
  if (!visibleEvs.length) return;

  // Ordina per ora di inizio
  visibleEvs.sort(function(a, b) {
    return (parseInt(a.dataset.start) || 0) - (parseInt(b.dataset.start) || 0);
  });

  // Raggruppa in cluster di eventi sovrapposti temporalmente (stesso giorno)
  var clusters = [];
  visibleEvs.forEach(function(ev) {
    var eStart = parseInt(ev.dataset.start) || 0;
    var eEnd   = parseInt(ev.dataset.end)   || 0;
    var eDay   = ev.dataset.day || '';
    var placed = false;
    for (var ci = 0; ci < clusters.length; ci++) {
      var overlaps = clusters[ci].some(function(other) {
        return other.dataset.day === eDay &&
               eStart < (parseInt(other.dataset.end) || 0) &&
               eEnd   > (parseInt(other.dataset.start) || 0);
      });
      if (overlaps) { clusters[ci].push(ev); placed = true; break; }
    }
    if (!placed) clusters.push([ev]);
  });

  // Per ogni cluster: assegna colonne con greedy, poi applica larghezza
  clusters.forEach(function(cluster) {
    if (cluster.length === 1) {
      cluster[0].style.left  = 'calc(0% + 1px)';
      cluster[0].style.width = 'calc(100% - 3px)';
      return;
    }
    var cols = []; // cols[i] = minuto fine ultimo evento in colonna i
    cluster.forEach(function(ev) {
      var eStart = parseInt(ev.dataset.start) || 0;
      var eEnd   = parseInt(ev.dataset.end)   || 0;
      var c = -1;
      for (var ci = 0; ci < cols.length; ci++) {
        if (cols[ci] <= eStart) { c = ci; cols[ci] = eEnd; break; }
      }
      if (c === -1) { c = cols.length; cols.push(eEnd); }
      ev._assignedCol = c;
    });
    var totalCols = cols.length;
    var pct = 100 / totalCols;
    cluster.forEach(function(ev) {
      var leftPct = (ev._assignedCol || 0) * pct;
      ev.style.left  = 'calc(' + leftPct + '% + 1px)';
      ev.style.width = 'calc(' + pct + '% - 3px)';
      delete ev._assignedCol;
    });
  });
}

function resetEventPositions() {
  // Ripristina le posizioni originali salvate in data-orig-*
  document.querySelectorAll('.cal-event').forEach(function(ev) {
    if (ev.dataset.origLeft !== undefined) ev.style.left  = ev.dataset.origLeft;
    if (ev.dataset.origWidth !== undefined) ev.style.width = ev.dataset.origWidth;
  });
}



// ── DATI GIORNI (passati da EJS) ──
var CAL_DAYS_JS  = <%- JSON.stringify(CAL_DAYS) %>;
var CAL_LABELS_JS = <%- JSON.stringify(CAL_LABELS) %>;
var eventsByDayCount = <%- JSON.stringify(
  (function(){
    var obj={};
    CAL_DAYS.forEach(function(d){ obj[d] = eventsByDay[d] ? eventsByDay[d].length : 0; });
    return obj;
  })()
) %>;
var FIERA_DAYS_FULL_JS = ['Domenica','Lunedì','Martedì','Mercoledì','Giovedì','Venerdì','Sabato'];

// ── NAVIGAZIONE GIORNO ──
var activeDayIdx = 0;

function renderDayNav() {
  var day   = CAL_DAYS_JS[activeDayIdx];
  var label = CAL_LABELS_JS[activeDayIdx];
  var dp    = day.split('-');
  var dateStr = dp[2] + '/' + dp[1] + '/' + dp[0];
  var count   = eventsByDayCount[day] || 0;

  // Barra nav
  document.getElementById('dayNavLabel').textContent = label;
  document.getElementById('dayNavDate').textContent  = dateStr + ' · ' + count + ' eventi';

  // Header sticky
  document.getElementById('hdrDayLabel').textContent = label;
  document.getElementById('hdrDayDate').textContent  = dateStr;
  document.getElementById('hdrDayCount').textContent = count + ' eventi';

  // Dots
  var dotsEl = document.getElementById('dayNavDots');
  dotsEl.innerHTML = '';
  CAL_DAYS_JS.forEach(function(d, i) {
    var dot = document.createElement('span');
    dot.className = 'day-dot' + (i === activeDayIdx ? ' active' : '');
    dot.title = CAL_LABELS_JS[i];
    dot.addEventListener('click', function() { activeDayIdx = i; renderDayNav(); showActiveDay(); });
    dotsEl.appendChild(dot);
  });

  // Pulsanti prev/next
  document.getElementById('btnPrevDay').classList.toggle('disabled', activeDayIdx === 0);
  document.getElementById('btnNextDay').classList.toggle('disabled', activeDayIdx === CAL_DAYS_JS.length - 1);
}

function showActiveDay() {
  var activeDay = CAL_DAYS_JS[activeDayIdx];
  // Mostra/nascondi celle della griglia
  document.querySelectorAll('.cal-cell[data-day]').forEach(function(cell) {
    cell.style.display = cell.dataset.day === activeDay ? '' : 'none';
  });
  // Scroll in cima alla griglia
  var wrap = document.getElementById('calScrollWrap');
  if (wrap) wrap.scrollTop = 0;
  renderDayNav();
}

function changeDay(delta) {
  var next = activeDayIdx + delta;
  if (next < 0 || next >= CAL_DAYS_JS.length) return;
  activeDayIdx = next;
  showActiveDay();
}

// Supporto swipe touch per mobile
(function() {
  var wrap = document.getElementById('calScrollWrap');
  if (!wrap) return;
  var startX = 0, startY = 0;
  wrap.addEventListener('touchstart', function(e) {
    startX = e.touches[0].clientX;
    startY = e.touches[0].clientY;
  }, { passive: true });
  wrap.addEventListener('touchend', function(e) {
    var dx = e.changedTouches[0].clientX - startX;
    var dy = e.changedTouches[0].clientY - startY;
    if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 50) {
      changeDay(dx < 0 ? 1 : -1);
    }
  }, { passive: true });
})();

// Init al caricamento: salva posizioni originali + mostra primo giorno
document.addEventListener('DOMContentLoaded', function() {
  // Salva posizioni originali per il filtro sale
  document.querySelectorAll('.cal-event').forEach(function(ev) {
    ev.dataset.origLeft  = ev.style.left;
    ev.dataset.origWidth = ev.style.width;
  });
  // Mostra il primo giorno
  if (CAL_DAYS_JS.length > 0) {
    showActiveDay();
  }
});

document.querySelectorAll('.space-filter-btn').forEach(function(btn){
  btn.addEventListener('click', function(){
    var spaceId = this.dataset.space;

    // Aggiorna stile bottoni
    document.querySelectorAll('.space-filter-btn').forEach(function(b){
      b.style.background  = '#fff';
      b.style.color       = '#1e2d4e';
      b.style.borderColor = '#d1d9e6';
    });
    if(spaceId === 'all'){
      this.style.background  = '#1e2d4e';
      this.style.color       = '#f5c842';
      this.style.borderColor = '#1e2d4e';
    } else {
      var col = this.dataset.color || '#1e2d4e';
      this.style.background  = col;
      this.style.color       = '#fff';
      this.style.borderColor = col;
    }

    // Mostra/nascondi eventi
    document.querySelectorAll('.cal-event').forEach(function(ev){
      ev.style.display = (spaceId === 'all' || ev.dataset.spaceId === spaceId) ? '' : 'none';
    });

    // Ricalcola posizioni: espandi se filtro singola sala, ripristina se "tutti"
    if (spaceId === 'all') {
      resetEventPositions();
    } else {
      recalcEventPositions(spaceId);
    }
  });
});
</script>

