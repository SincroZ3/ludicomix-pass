<%- include('../partials/header') %>

<main class="content">
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;margin-bottom:1.2rem">
    <h1 class="page-title" style="margin:0;border:none"><%= title %></h1>
    <a href="/agenda/events" class="secondary">← Tutti gli eventi</a>
  </div>

  <% if (flash) { %>
    <div class="alert alert-<%= flash.type === 'error' ? 'danger' : 'success' %>">
      <span><%= flash.type === 'error' ? '❌' : '✅' %></span>
      <span><%= flash.msg %></span>
    </div>
  <% } %>

  <form method="POST" action="<%= event.id ? `/agenda/events/${event.id}` : '/agenda/events' %>">
    <div style="display:grid;grid-template-columns:2fr 1fr;gap:1.5rem;align-items:start">

      <!-- ── Colonna sinistra ── -->
      <div>

        <!-- Informazioni evento -->
        <div class="card">
          <div class="card-title">Informazioni evento</div>

          <div style="margin-bottom:.85rem">
            <label>Titolo <span class="req">*</span></label>
            <input type="text" name="title" required value="<%= event.title || '' %>" placeholder="Titolo dell'evento">
          </div>

          <div style="margin-bottom:.85rem">
            <label>Descrizione</label>
            <textarea name="description" rows="4" placeholder="Descrizione pubblica dell'evento"><%= event.description || '' %></textarea>
          </div>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-bottom:.85rem">
            <div>
              <label>Tipo evento</label>
              <select name="event_type">
                <% ['panel','workshop','talk','mostra','firma copie','gaming','meet&greet','proiezione','torneo','tcg','cosplay','quiz','altro'].forEach(t => { %>
                  <option value="<%= t %>" <%= event.event_type === t ? 'selected' : '' %>>
                    <%= t.charAt(0).toUpperCase() + t.slice(1) %>
                  </option>
                <% }) %>
              </select>
            </div>
            <div>
              <label>Tag / Categorie</label>
              <input type="text" name="tags" value="<%= event.tags || '' %>" placeholder="fumetto, gaming, cosplay">
              <span class="help-text">Separati da virgola</span>
            </div>
          </div>

          <div style="margin-bottom:.85rem">
            <label>Immagine URL</label>
            <input type="url" name="image_url" value="<%= event.image_url || '' %>" placeholder="https://...">
          </div>

          <div style="margin-bottom:.85rem">
            <label>Note interne</label>
            <textarea name="notes" rows="2" placeholder="Note visibili solo agli admin"><%= event.notes || '' %></textarea>
          </div>
        </div>

        <!-- Ospiti e Speaker -->
        <div class="card">
          <div class="card-title">Ospiti e Speaker</div>
          <% if (speakers.length === 0) { %>
            <p style="color:var(--text-muted);font-size:.85rem">
              Nessuno speaker registrato.
              <a href="/agenda/speakers" class="link-action">Aggiungine uno</a>.
            </p>
          <% } else { %>
            <p class="help-text" style="margin-bottom:.75rem">Seleziona uno o più speaker e assegna loro un ruolo.</p>
            <div style="display:grid;gap:.5rem">
              <% speakers.forEach((s, i) => {
                   const sel = selectedSpeakers.find(ss => ss.speaker_id === s.id);
              %>
                <div style="display:flex;align-items:center;gap:.75rem;padding:.5rem .75rem;background:var(--bg-section);border-radius:var(--radius-sm);border:1px solid var(--border)">
                  <input type="checkbox"
                         name="speaker_ids"
                         value="<%= s.id %>"
                         id="spk-<%= s.id %>"
                         <%= sel ? 'checked' : '' %>
                         onchange="toggleRole(<%= s.id %>, this.checked)">
                  <label for="spk-<%= s.id %>" style="margin:0;font-weight:600;flex:1;cursor:pointer"><%= s.name %></label>
                  <select name="speaker_roles" id="role-<%= s.id %>"
                          style="width:130px;padding:.25rem .4rem;font-size:.78rem;<%= sel ? '' : 'opacity:.4' %>">
                    <% ['speaker','moderatore','ospite','autore','giurato'].forEach(r => { %>
                      <option value="<%= r %>" <%= sel && sel.role === r ? 'selected' : '' %>>
                        <%= r.charAt(0).toUpperCase() + r.slice(1) %>
                      </option>
                    <% }) %>
                  </select>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>

      </div><!-- /colonna sinistra -->

      <!-- ── Colonna destra ── -->
      <div>

        <!-- Programmazione -->
        <div class="card">
          <div class="card-title">Programmazione</div>

          <!-- Tipo luogo -->
          <div style="margin-bottom:.85rem">
            <label>Tipo luogo <span class="req">*</span></label>
            <select name="location_type" id="locationTypeSelect" onchange="toggleLocationUI()">
              <option value="sala"          <%= (!event.location_text) ? 'selected' : '' %>>🏛 Sala / Spazio</option>
              <option value="espositore"    <%= (event.location_text && event.location_type === 'espositore') ? 'selected' : '' %>>🏪 Espositore / Stand</option>
              <option value="associazione"  <%= (event.location_text && event.location_type === 'associazione') ? 'selected' : '' %>>🎲 Associazione</option>
            </select>
          </div>

          <!-- Sala (default) -->
          <div style="margin-bottom:.85rem" id="salaBlock">
            <label>Sala / Spazio <span class="req">*</span></label>
            <select name="space_id" id="space_id_select">
              <option value="">Seleziona sala</option>
              <% spaces.forEach(s => { %>
                <option value="<%= s.id %>" <%= event.space_id === s.id ? 'selected' : '' %>>
                  <%= s.name %> (cap. <%= s.capacity %>)
                </option>
              <% }) %>
            </select>
          </div>

          <!-- Espositore / Stand / Associazione -->
          <div style="margin-bottom:.85rem;display:none" id="espositoreBlock">
            <label id="espositoreLabel">Nome espositore / luogo <span class="req">*</span></label>
            <input type="text" name="location_text" id="location_text_input"
                   value="<%= event.location_text || '' %>"
                   placeholder="Es. Stand B12 / Nome Associazione…">
            <span class="help-text">Mostrato al posto della sala nel programma pubblico.</span>
            <!-- space_id nascosto con primo valore valido (soddisfa NOT NULL) -->
            <input type="hidden" name="space_id" id="space_id_hidden"
                   value="<%= spaces[0] ? spaces[0].id : '' %>">
          </div>

          <div style="margin-bottom:.85rem">
            <label>Data <span class="req">*</span></label>
            <input type="date" name="date" required value="<%= event.date || '' %>">
          </div>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-bottom:.85rem">
            <div>
              <label>Inizio <span class="req">*</span></label>
              <input type="time" name="start_time" required value="<%= event.start_time || '' %>">
            </div>
            <div>
              <label>Fine <span class="req">*</span></label>
              <input type="time" name="end_time" required value="<%= event.end_time || '' %>">
            </div>
          </div>

          <div style="margin-bottom:.85rem">
            <label>Posti massimi (iscrizioni)</label>
            <input type="number" name="max_seats" min="0" value="<%= event.max_seats || 0 %>">
            <span class="help-text">0 = nessun limite</span>
          </div>
        </div>

        <!-- Pubblicazione -->
        <div class="card">
          <div class="card-title">Pubblicazione</div>

          <%# BUG FIX #2 — confronto esplicito == 1 su tutti i checkbox
              così funziona correttamente sia con integer SQLite (0/1)
              sia con eventuali string "0"/"1" restituite dal driver %>

          <div style="margin-bottom:.75rem">
            <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer">
              <input type="checkbox" name="is_public" value="1"
                     <%= event.id ? (event.is_public == 1 ? 'checked' : '') : 'checked' %>>
              <span>Visibile nel programma pubblico</span>
            </label>
          </div>

          <div style="margin-bottom:.75rem">
            <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer">
              <input type="checkbox" name="published" value="1"
                     <%= event.published == 1 ? 'checked' : '' %>>
              <span>Pubblicato / attivo nel sito</span>
            </label>
          </div>

          <div style="margin-bottom:.75rem">
            <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer">
              <input type="checkbox" name="featured" value="1"
                     <%= event.featured == 1 ? 'checked' : '' %>>
              <span>⭐ In evidenza nel programma</span>
            </label>
            <span class="help-text" style="margin-left:1.5rem">Gli eventi in evidenza appaiono in cima alla pagina pubblica.</span>
          </div>

          <!-- Toggle iscrizioni -->
          <div style="margin-bottom:1rem;padding:.85rem;background:#f7f8fb;border-radius:4px;border:1px solid var(--border)">
            <div style="font-size:.73rem;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--text-secondary,#718096);margin-bottom:.65rem">
              Iscrizioni pubbliche
            </div>
            <label style="display:flex;align-items:center;justify-content:space-between;gap:.75rem;cursor:pointer;user-select:none">
              <div>
                <div style="font-size:.88rem;font-weight:600">Abilita pulsante "Iscriviti"</div>
                <div style="font-size:.78rem;color:var(--text-muted,#718096);margin-top:.15rem">
                  Se attivo, il pulsante Iscriviti sarà visibile sulla pagina pubblica dell'evento.
                </div>
              </div>
              <div style="position:relative;display:inline-block;width:44px;height:24px;flex-shrink:0">
                <input type="checkbox" name="registrations_open" value="1"
                       id="chk-reg-open"
                       <%= event.registrations_open == 1 ? 'checked' : '' %>
                       style="position:absolute;opacity:0;width:0;height:0">
                <span id="toggle-reg-slider"
                      style="position:absolute;cursor:pointer;inset:0;background:<%= event.registrations_open == 1 ? '#437a22' : '#cbd5e0' %>;border-radius:9999px;transition:background .2s"></span>
                <span id="toggle-reg-knob"
                      style="position:absolute;width:18px;height:18px;border-radius:50%;background:#fff;top:3px;left:<%= event.registrations_open == 1 ? '23px' : '3px' %>;transition:left .2s;box-shadow:0 1px 3px rgba(0,0,0,.2);pointer-events:none"></span>
              </div>
            </label>
          </div>

          <!-- Toggle accesso evento -->
          <div style="margin-bottom:1rem;padding:.85rem;background:#f7f8fb;border-radius:4px;border:1px solid var(--border)">
            <div style="font-size:.73rem;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--text-secondary,#718096);margin-bottom:.65rem">
              Accesso all'evento
            </div>

            <!-- Toggle: Ingresso libero -->
            <label style="display:flex;align-items:center;justify-content:space-between;gap:.75rem;cursor:pointer;user-select:none;margin-bottom:.75rem">
              <div>
                <div style="font-size:.88rem;font-weight:600">🎟 Ingresso libero</div>
                <div style="font-size:.78rem;color:var(--text-muted,#718096);margin-top:.15rem">
                  Zona non soggetta a bigliettazione, accesso gratuito.
                </div>
              </div>
              <div style="position:relative;display:inline-block;width:44px;height:24px;flex-shrink:0">
                <input type="checkbox" name="free_entry" value="1"
                       id="chk-free-entry"
                       <%= event.free_entry == 1 ? 'checked' : '' %>
                       style="position:absolute;opacity:0;width:0;height:0">
                <span id="toggle-free-slider"
                      style="position:absolute;cursor:pointer;inset:0;background:<%= event.free_entry == 1 ? '#437a22' : '#cbd5e0' %>;border-radius:9999px;transition:background .2s"></span>
                <span id="toggle-free-knob"
                      style="position:absolute;width:18px;height:18px;border-radius:50%;background:#fff;top:3px;left:<%= event.free_entry == 1 ? '23px' : '3px' %>;transition:left .2s;box-shadow:0 1px 3px rgba(0,0,0,.2);pointer-events:none"></span>
              </div>
            </label>

            <!-- Toggle: Area a biglietto -->
            <label style="display:flex;align-items:center;justify-content:space-between;gap:.75rem;cursor:pointer;user-select:none">
              <div>
                <div style="font-size:.88rem;font-weight:600">🎫 Area a biglietto</div>
                <div style="font-size:.78rem;color:var(--text-muted,#718096);margin-top:.15rem">
                  Zona soggetta a bigliettazione, accesso a pagamento.
                </div>
              </div>
              <div style="position:relative;display:inline-block;width:44px;height:24px;flex-shrink:0">
                <input type="checkbox" name="ticketed_area" value="1"
                       id="chk-ticketed"
                       <%= event.ticketed_area == 1 ? 'checked' : '' %>
                       style="position:absolute;opacity:0;width:0;height:0">
                <span id="toggle-ticketed-slider"
                      style="position:absolute;cursor:pointer;inset:0;background:<%= event.ticketed_area == 1 ? '#006494' : '#cbd5e0' %>;border-radius:9999px;transition:background .2s"></span>
                <span id="toggle-ticketed-knob"
                      style="position:absolute;width:18px;height:18px;border-radius:50%;background:#fff;top:3px;left:<%= event.ticketed_area == 1 ? '23px' : '3px' %>;transition:left .2s;box-shadow:0 1px 3px rgba(0,0,0,.2);pointer-events:none"></span>
              </div>
            </label>
          </div>

          <div style="display:flex;flex-direction:column;gap:.5rem">
            <button type="submit" class="primary" style="width:100%;justify-content:center">
              <%= event.id ? 'Salva modifiche' : 'Crea evento' %>
            </button>
            <a href="/agenda/events" class="secondary" style="width:100%;justify-content:center;text-align:center">Annulla</a>
          </div>
        </div>

        <!-- Azioni rapide (solo su edit) -->
        <% if (event.id) { %>
          <div class="card">
            <div class="card-title">Azioni rapide</div>
            <div style="display:flex;flex-direction:column;gap:.5rem">
              <a href="/agenda/events/<%= event.id %>/registrations" class="secondary"
                 style="width:100%;justify-content:center;text-align:center">
                👥 Visualizza iscritti
              </a>
              <form method="POST" action="/agenda/events/<%= event.id %>/publish">
                <button class="secondary" style="width:100%;justify-content:center">
                  <%= event.published ? '📥 Rimetti in bozza' : '📤 Pubblica ora' %>
                </button>
              </form>
              <form method="POST" action="/agenda/events/<%= event.id %>/delete"
                    onsubmit="return confirm('Eliminare definitivamente questo evento?')">
                <button class="btn-danger" style="width:100%;justify-content:center">🗑 Elimina evento</button>
              </form>
            </div>
          </div>
        <% } %>

      </div><!-- /colonna destra -->
    </div>
    <input type="hidden" name="force" id="force-conflict" value="0">
  </form>
</main>


<!-- MODALE CONFLITTO -->
<div id="conflict-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:9999;align-items:center;justify-content:center">
  <div style="background:#fff;border-radius:14px;padding:2rem 2.2rem;max-width:460px;width:92%;box-shadow:0 20px 60px rgba(0,0,0,.25);text-align:center">
    <img src="/ciuchino_stop.png" alt="Attenzione" style="width:90px;height:auto;margin-bottom:1rem;display:block;margin-left:auto;margin-right:auto" onerror="this.style.display='none'">
    <h2 style="font-size:1.1rem;font-weight:800;color:#1e2d4e;margin:0 0 .5rem">&#9888; Conflitto di orario</h2>
    <p style="font-size:.88rem;color:#475569;margin:0 0 1rem">Nello stesso spazio &egrave; gi&agrave; presente:</p>
    <div id="conflict-list" style="background:#fef9ec;border:1.5px solid #fbbf24;border-radius:8px;padding:.75rem 1rem;margin-bottom:1.2rem;text-align:left;font-size:.84rem;color:#92400e"></div>
    <p style="font-size:.82rem;color:#64748b;margin:0 0 1.3rem">Vuoi aggiungere l'evento <strong>in contemporanea</strong>?</p>
    <div style="display:flex;gap:.75rem;justify-content:center">
      <button type="button" onclick="closeConflictModal()" style="padding:.55rem 1.4rem;border:1.5px solid #d1d9e6;border-radius:8px;background:#fff;font-size:.88rem;font-weight:600;cursor:pointer;color:#475569">&#10007; Annulla</button>
      <button type="button" onclick="confirmConflict()" style="padding:.55rem 1.4rem;border:none;border-radius:8px;background:#1e2d4e;color:#fff;font-size:.88rem;font-weight:700;cursor:pointer">&#10003; Aggiungi comunque</button>
    </div>
  </div>
</div>
<script>
// ── Gestione conflitto orario ────────────────────────────────────────────
var _conflictOk = false;

function getMainForm() {
  var forms = document.querySelectorAll('form[method="POST"]');
  for (var i = 0; i < forms.length; i++) {
    var a = forms[i].getAttribute('action') || '';
    if (/\/agenda\/events(\/[0-9]+)?$/.test(a)) return forms[i];
  }
  return null;
}

document.addEventListener('DOMContentLoaded', function() {
  var mainForm = getMainForm();
  if (!mainForm) return;

  mainForm.addEventListener('submit', function(e) {
    if (_conflictOk) return;

    var salaBlock     = document.getElementById('salaBlock');
    var spaceIdSelect = document.getElementById('space_id_select');
    var spaceIdHidden = document.getElementById('space_id_hidden');
    var spaceId = '';
    if (salaBlock && salaBlock.style.display !== 'none' && spaceIdSelect) {
      spaceId = spaceIdSelect.value;
    } else if (spaceIdHidden) {
      spaceId = spaceIdHidden.value;
    }
    if (!spaceId && spaceIdSelect) spaceId = spaceIdSelect.value;

    var date      = (mainForm.querySelector('[name="date"]')       || {}).value || '';
    var startTime = (mainForm.querySelector('[name="start_time"]') || {}).value || '';
    var endTime   = (mainForm.querySelector('[name="end_time"]')   || {}).value || '';

    if (!spaceId || !date || !startTime || !endTime) return;

    e.preventDefault();

    var action    = mainForm.getAttribute('action') || '';
    var excludeId = '';
    var m = action.match(/\/agenda\/events\/([0-9]+)$/);
    if (m) excludeId = m[1];

    var url = '/api/agenda/check-conflict'
            + '?space_id='   + encodeURIComponent(spaceId)
            + '&date='       + encodeURIComponent(date)
            + '&start_time=' + encodeURIComponent(startTime)
            + '&end_time='   + encodeURIComponent(endTime)
            + (excludeId ? '&exclude_id=' + excludeId : '');

    fetch(url, { credentials: 'same-origin' })
      .then(function(r) {
        var ct = r.headers.get('content-type') || '';
        if (!ct.includes('application/json')) {
          _conflictOk = true;
          mainForm.submit();
          return null;
        }
        return r.json();
      })
      .then(function(data) {
        if (!data) return;
        if (!data.conflict) {
          _conflictOk = true;
          mainForm.submit();
          return;
        }
        var list = document.getElementById('conflict-list');
        list.innerHTML = (data.conflicts || []).map(function(c) {
          return '<div style="padding:.3rem 0;border-bottom:1px solid #fde68a">'
               + '<strong>' + (c.title || '') + '</strong><br>'
               + '<span>' + (c.start_time || '') + '&ndash;' + (c.end_time || '') + '</span>'
               + (c.space_name ? ' <span style="color:#94a3b8;font-size:.76rem">&middot; ' + c.space_name + '</span>' : '')
               + '</div>';
        }).join('');
        document.getElementById('conflict-modal').style.display = 'flex';
      })
      .catch(function() {
        _conflictOk = true;
        mainForm.submit();
      });
  });

  document.getElementById('conflict-modal').addEventListener('click', function(e) {
    if (e.target === this) closeConflictModal();
  });
});

function closeConflictModal() {
  document.getElementById('conflict-modal').style.display = 'none';
  _conflictOk = false;
  var ff = document.getElementById('force-conflict');
  if (ff) ff.value = '0';
}

function confirmConflict() {
  document.getElementById('conflict-modal').style.display = 'none';
  _conflictOk = true;
  var f = getMainForm();
  if (!f) return;
  var old = f.querySelector('input[name="force"]');
  if (old) old.parentNode.removeChild(old);
  var inp = document.createElement('input');
  inp.type = 'hidden';
  inp.name = 'force';
  inp.value = '1';
  f.appendChild(inp);
  f.submit();
}

function toggleRole(id, checked) {
  var sel = document.getElementById('role-' + id);
  if (sel) sel.style.opacity = checked ? 1 : .4;
}
</script>


