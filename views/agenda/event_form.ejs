<%- include('../partials/header') %>

<nav class="breadcrumb-bar">
  Sei in <a href="/agenda/events">&#128197; Agenda</a> &rsaquo; <strong><%= event ? 'Modifica Evento' : 'Nuovo Evento' %></strong>
</nav>

<h1 class="page-title"><%= event ? '&#9998; Modifica Evento' : '&#128197; Nuovo Evento' %></h1>

<style>
  /* ---- SEZIONI FORM ---- */
  .ev-section{background:var(--bg-white,#fff);border:1px solid var(--border,#d1d9e6);border-radius:var(--radius-md,10px);box-shadow:var(--shadow-sm,0 1px 3px rgba(30,45,78,.07));margin-bottom:1.1rem;overflow:hidden}
  .ev-section-hd{display:flex;align-items:center;gap:.45rem;padding:.6rem 1.1rem;background:var(--bg-section,#f0f2f5);border-bottom:1px solid var(--border-light,#e8ecf3);font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted,#64748b)}
  .ev-section-body{padding:.9rem 1.1rem}

  /* ---- FIELD ---- */
  .fg{display:flex;flex-direction:column;gap:.26rem}
  .fg label{font-size:.69rem;font-weight:700;color:var(--text-muted,#64748b);text-transform:uppercase;letter-spacing:.45px}
  .fg input,.fg select,.fg textarea{width:100%;padding:.42rem .68rem;border:1.5px solid var(--border,#d1d9e6);border-radius:var(--radius-xs,6px);font-size:.83rem;font-family:inherit;color:var(--text-primary,#1a2744);background:var(--bg-white,#fff);transition:border-color .15s,box-shadow .15s}
  .fg input:focus,.fg select:focus,.fg textarea:focus{outline:none;border-color:var(--accent,#6b3fa0);box-shadow:0 0 0 3px rgba(107,63,160,.1)}
  .fg textarea{resize:vertical;min-height:68px}
  .fg-hint{font-size:.7rem;color:var(--text-muted,#64748b)}

  /* ---- GRIGLIE ---- */
  .fgrid-2{display:grid;grid-template-columns:1fr 1fr;gap:.7rem;margin-bottom:.7rem}
  .fgrid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:.7rem;margin-bottom:.7rem}
  .fspan{grid-column:1/-1;margin-bottom:.7rem}

  /* ---- CHECKBOX ROW ---- */
  .cb-row{display:flex;align-items:center;gap:.5rem;padding-top:.3rem}
  .cb-row input[type=checkbox]{width:16px;height:16px;accent-color:var(--accent,#6b3fa0);cursor:pointer}
  .cb-row label{font-size:.83rem;color:var(--text-primary,#1a2744);text-transform:none;letter-spacing:0;font-weight:600;cursor:pointer}

  /* ---- COLOR PICKER ---- */
  .color-wrap{display:flex;gap:.5rem;align-items:center}
  .color-swatch{width:36px;height:34px;padding:2px;border-radius:6px;border:1.5px solid var(--border,#d1d9e6);cursor:pointer;flex-shrink:0}

  /* ---- CTA BUTTONS ---- */
  .ev-cta-top{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.65rem;margin-bottom:1rem;padding:.75rem 1.1rem;background:var(--bg-white,#fff);border:1px solid var(--border,#d1d9e6);border-radius:var(--radius-md,10px);box-shadow:var(--shadow-sm)}
  .ev-cta-bottom{position:sticky;bottom:0;z-index:50;background:var(--bg-white,#fff);border-top:2px solid var(--border,#d1d9e6);padding:.8rem 1.1rem;display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;box-shadow:0 -4px 16px rgba(30,45,78,.09)}

  /* tasto SALVA / CREA - grande e prominente */
  .btn-ev-save{
    display:inline-flex;align-items:center;gap:.45rem;
    padding:.68rem 2rem;color:#fff;border:none;border-radius:var(--radius-xs,6px);
    font-size:.95rem;font-weight:800;cursor:pointer;font-family:inherit;
    transition:background .15s,transform .1s,box-shadow .15s;white-space:nowrap;
    background:var(--accent,#6b3fa0);box-shadow:0 2px 10px rgba(107,63,160,.35);
  }
  .btn-ev-save.save-blue{background:var(--accent-blue,#1d6fa4);box-shadow:0 2px 10px rgba(29,111,164,.35)}
  .btn-ev-save:hover{filter:brightness(1.1)}
  .btn-ev-save:active{transform:scale(.97)}

  .btn-ev-back{display:inline-flex;align-items:center;gap:.35rem;padding:.58rem 1.1rem;background:transparent;color:var(--text-muted,#64748b);border:1.5px solid var(--border,#d1d9e6);border-radius:var(--radius-xs,6px);font-size:.83rem;font-weight:700;cursor:pointer;font-family:inherit;text-decoration:none;white-space:nowrap;transition:background .15s,border-color .15s}
  .btn-ev-back:hover{background:var(--bg-section,#f0f2f5);border-color:var(--text-muted,#64748b)}

  .ev-save-status{font-size:.76rem;color:var(--text-muted,#64748b);margin-left:auto}

  @media(max-width:680px){
    .fgrid-2,.fgrid-3{grid-template-columns:1fr}
    .fspan{grid-column:1}
  }
</style>

<form method="POST" action="/agenda/events/<%= event ? event.id + '/edit' : 'new' %>" id="evForm">

  <!-- CTA TOP -->
  <div class="ev-cta-top">
    <a href="/agenda/events" class="btn-ev-back">&#8592; Torna agli eventi</a>
    <button type="submit" class="btn-ev-save <%= event ? 'save-blue' : '' %>">
      <% if(event){ %>&#10003; Salva Modifiche<% }else{ %>&#43; Crea Evento<% } %>
    </button>
  </div>

  <!-- 1. INFORMAZIONI PRINCIPALI -->
  <div class="ev-section">
    <div class="ev-section-hd">&#128203; Informazioni principali</div>
    <div class="ev-section-body">
      <div class="fspan">
        <div class="fg">
          <label>Titolo *</label>
          <input type="text" name="title" required value="<%= event ? event.title : '' %>" placeholder="Nome dell'evento..." maxlength="200">
        </div>
      </div>
      <div class="fgrid-2">
        <div class="fg">
          <label>Tipo evento</label>
          <select name="event_type">
            <option value="">&#8212; Seleziona &#8212;</option>
            <% ['Torneo','Dimostrazione','Panel','Workshop','Spettacolo','Altro'].forEach(function(t){ %>
              <option value="<%= t %>" <%= (event&&event.event_type===t)?'selected':'' %>><%= t %></option>
            <% }) %>
          </select>
        </div>
        <div class="fg">
          <label>Sala / Spazio</label>
          <select name="space_id">
            <option value="">&#8212; Seleziona &#8212;</option>
            <% if(typeof spaces!=='undefined'&&spaces){ spaces.forEach(function(s){ %>
              <option value="<%= s.id %>" <%= (event&&event.space_id==s.id)?'selected':'' %>><%= s.name %></option>
            <% })} %>
          </select>
        </div>
      </div>
      <div class="fspan" style="margin-bottom:0">
        <div class="fg">
          <label>Descrizione</label>
          <textarea name="description" rows="3" placeholder="Descrizione breve..."><%= event ? event.description||'' : '' %></textarea>
        </div>
      </div>
    </div>
  </div>

  <!-- 2. DATA E ORARIO -->
  <div class="ev-section">
    <div class="ev-section-hd">&#128336; Data e orario</div>
    <div class="ev-section-body" style="padding-bottom:.9rem">
      <div class="fgrid-3" style="margin-bottom:0">
        <div class="fg">
          <label>Data *</label>
          <input type="date" name="event_date" required value="<%= event ? event.event_date||'' : '' %>">
        </div>
        <div class="fg">
          <label>Ora inizio</label>
          <input type="time" name="start_time" value="<%= event ? event.start_time||'' : '' %>">
        </div>
        <div class="fg">
          <label>Ora fine</label>
          <input type="time" name="end_time" value="<%= event ? event.end_time||'' : '' %>">
        </div>
      </div>
    </div>
  </div>

  <!-- 3. SPEAKER E OSPITI -->
  <div class="ev-section">
    <div class="ev-section-hd">&#128100; Speaker e ospiti</div>
    <div class="ev-section-body">
      <div class="fg">
        <label>Speaker assegnati</label>
        <select name="speaker_ids[]" multiple style="min-height:88px">
          <% if(typeof speakers!=='undefined'&&speakers){ speakers.forEach(function(sp){ %>
            <option value="<%= sp.id %>"
              <%= (event&&event.speaker_ids&&event.speaker_ids.includes(sp.id))?'selected':'' %>>
              <%= sp.name %><% if(sp.category){ %> &#8212; <%= sp.category %><% } %>
            </option>
          <% })} %>
        </select>
        <span class="fg-hint">Ctrl+clic (o &#8984;+clic su Mac) per selezionare pi&#249; speaker.</span>
      </div>
    </div>
  </div>

  <!-- 4. ISCRIZIONI E POSTI -->
  <div class="ev-section">
    <div class="ev-section-hd">&#127997; Iscrizioni e posti</div>
    <div class="ev-section-body">
      <div class="fgrid-2" style="margin-bottom:.7rem">
        <div class="fg">
          <div class="cb-row">
            <input type="checkbox" name="requires_registration" id="req_reg" value="1"
              <%= (event&&event.requires_registration)?'checked':'' %>>
            <label for="req_reg">Richiede iscrizione</label>
          </div>
        </div>
        <div class="fg">
          <label>Max partecipanti</label>
          <input type="number" name="max_participants" min="0"
            value="<%= event ? event.max_participants||'' : '' %>"
            placeholder="Lascia vuoto = illimitato">
        </div>
      </div>
      <div class="fg" style="margin-bottom:0">
        <label>URL iscrizione</label>
        <input type="url" name="registration_url"
          value="<%= event ? event.registration_url||'' : '' %>"
          placeholder="https://...">
      </div>
    </div>
  </div>

  <!-- 5. VISIBILITÀ E ASPETTO -->
  <div class="ev-section">
    <div class="ev-section-hd">&#128065; Visibilit&#224; e aspetto</div>
    <div class="ev-section-body">
      <div class="fgrid-2" style="margin-bottom:.8rem">
        <div class="fg">
          <div class="cb-row">
            <input type="checkbox" name="is_published" id="is_pub" value="1"
              <%= (!event||event.is_published)?'checked':'' %>>
            <label for="is_pub">Pubblicato nel programma pubblico</label>
          </div>
        </div>
        <div class="fg">
          <div class="cb-row">
            <input type="checkbox" name="featured" id="ev_featured" value="1"
              <%= (event&&event.featured)?'checked':'' %>>
            <label for="ev_featured">&#11088; In evidenza</label>
          </div>
        </div>
      </div>
      <div class="fgrid-2" style="margin-bottom:0">
        <div class="fg">
          <label>Colore sala (punto colorato)</label>
          <div class="color-wrap">
            <input type="color" name="space_color" id="colorPicker" class="color-swatch"
              value="<%= event&&event.space_color?event.space_color:'#6b3fa0' %>">
            <input type="text" name="space_color_hex" id="colorHex"
              value="<%= event&&event.space_color?event.space_color:'#6b3fa0' %>"
              placeholder="#6b3fa0" maxlength="7" style="flex:1">
          </div>
        </div>
        <div class="fg">
          <label>Note interne (solo admin)</label>
          <input type="text" name="notes"
            value="<%= event ? event.notes||'' : '' %>"
            placeholder="Appunti interni...">
        </div>
      </div>
    </div>
  </div>

  <!-- CTA BOTTOM STICKY -->
  <div class="ev-cta-bottom">
    <button type="submit" class="btn-ev-save <%= event ? 'save-blue' : '' %>">
      <% if(event){ %>&#10003; Salva Modifiche<% }else{ %>&#43; Crea Evento<% } %>
    </button>
    <a href="/agenda/events" class="btn-ev-back">Annulla</a>
    <span class="ev-save-status" id="saveStatus"></span>
  </div>

</form>

<script>
(function(){
  var cp=document.getElementById('colorPicker');
  var ch=document.getElementById('colorHex');
  if(cp&&ch){
    cp.addEventListener('input',function(){ch.value=this.value;});
    ch.addEventListener('input',function(){if(/^#[0-9a-fA-F]{6}$/.test(this.value))cp.value=this.value;});
  }
  var form=document.getElementById('evForm');
  var dirty=false;
  if(form){
    form.addEventListener('change',function(){dirty=true;});
    form.addEventListener('submit',function(){
      dirty=false;
      var s=document.getElementById('saveStatus');
      if(s)s.textContent='Salvataggio in corso...';
    });
    window.addEventListener('beforeunload',function(e){
      if(dirty){e.preventDefault();e.returnValue='';}
    });
  }
})();
</script>

<%- include('../partials/footer') %>
