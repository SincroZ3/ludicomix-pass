<%- include('../partials/header') %>
<%
  var isNew  = !event || !event.id;
  var formAction = isNew ? '/agenda/events' : '/agenda/events/' + event.id;
  var ev = event || {};
%>

<style>
:root{
  --navy:#1e2d4e;--navy-d:#14203a;--gold:#c9a227;--gold-l:#e8c14a;
  --cream:#e8dfc8;--bg:#f0ede6;--surface:#fff;--border:#dbd4c4;
  --text:#1a1a2e;--muted:#6b6660;--violet:#6b3fa0;
  --red:#c0392b;--green:#1d6a39;
  --r6:6px;--r10:10px;--r14:14px;
  --sh1:0 2px 8px rgba(26,26,46,.09);--sh2:0 8px 28px rgba(26,26,46,.16);
  --tr:.18s cubic-bezier(.16,1,.3,1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,'Segoe UI',Arial,sans-serif;background:var(--bg);color:var(--text);font-size:15px;line-height:1.5}
a{text-decoration:none;color:inherit}
button,input,select,textarea{font:inherit;color:inherit}

/* TOPBAR */
.topbar{background:var(--navy);border-bottom:3px solid var(--gold);
  padding:0 1.5rem;display:flex;align-items:center;justify-content:space-between;
  height:58px;position:sticky;top:0;z-index:100;gap:1rem}
.tb-left{display:flex;align-items:center;gap:.65rem}
.tb-back{display:inline-flex;align-items:center;gap:.35rem;color:rgba(232,223,200,.7);
  font-size:.8rem;font-weight:600;padding:.3rem .7rem;border-radius:999px;
  border:1px solid rgba(232,223,200,.2);transition:all var(--tr)}
.tb-back:hover{background:rgba(255,255,255,.1);color:var(--cream)}
.tb-title{font-size:.95rem;font-weight:800;color:var(--cream)}

/* FLASH */
.flash{margin:1rem auto;max-width:900px;padding:.75rem 1rem;border-radius:var(--r10);
  font-size:.85rem;font-weight:600;display:flex;align-items:center;gap:.5rem}
.flash.error{background:#fde8e8;color:var(--red);border:1px solid #f5c6c6}
.flash.success{background:#d4efde;color:var(--green);border:1px solid #b2dfc0}

/* WRAP */
.form-wrap{max-width:900px;margin:1.5rem auto 120px;padding:0 1.25rem}

/* SEZIONE */
.fsec{background:var(--surface);border:1px solid var(--border);border-radius:var(--r14);
  padding:1.25rem 1.4rem;margin-bottom:1rem;box-shadow:var(--sh1)}
.fsec-title{font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.7px;
  color:var(--muted);margin-bottom:1rem;padding-bottom:.5rem;border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:.4rem}
.fsec-title::before{content:'';width:3px;height:1em;background:var(--gold);border-radius:2px;display:inline-block}

/* GRID */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:.85rem}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:.85rem}
.span2{grid-column:span 2}
@media(max-width:640px){.g2,.g3{grid-template-columns:1fr}.span2{grid-column:span 1}}

/* CAMPI */
.fg{display:flex;flex-direction:column;gap:.25rem}
.fg label{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--muted)}
.fg label .req{color:var(--red);margin-left:.15rem}
.fg input,.fg select,.fg textarea{
  padding:.42rem .75rem;border:1px solid var(--border);border-radius:var(--r6);
  background:var(--bg);color:var(--text);font-size:.87rem;outline:none;
  transition:border-color var(--tr),box-shadow var(--tr);width:100%;
}
.fg input:focus,.fg select:focus,.fg textarea:focus{
  border-color:var(--navy);box-shadow:0 0 0 3px rgba(30,45,78,.08)}
.fg textarea{resize:vertical;min-height:80px;line-height:1.55}
.fg .hint{font-size:.67rem;color:var(--muted);margin-top:.15rem}

/* IMAGE PREVIEW */
.img-preview{margin-top:.5rem;border-radius:var(--r10);overflow:hidden;
  border:1px solid var(--border);background:var(--bg);aspect-ratio:16/6;
  display:flex;align-items:center;justify-content:center;color:var(--muted);
  font-size:.8rem}
.img-preview img{width:100%;height:100%;object-fit:cover;display:none}

/* TOGGLE */
.toggle-row{display:flex;align-items:center;justify-content:space-between;
  padding:.65rem .9rem;border:1px solid var(--border);border-radius:var(--r10);
  background:var(--bg);gap:.75rem;cursor:pointer}
.tr-label{font-size:.85rem;font-weight:700;color:var(--text)}
.tr-hint{font-size:.72rem;color:var(--muted);margin-top:.1rem}
.tgl{position:relative;width:40px;height:22px;flex-shrink:0}
.tgl input{opacity:0;width:0;height:0;position:absolute}
.tgl-track{position:absolute;inset:0;border-radius:999px;background:var(--border);
  transition:background var(--tr);cursor:pointer}
.tgl input:checked+.tgl-track{background:var(--navy)}
.tgl-thumb{position:absolute;top:3px;left:3px;width:16px;height:16px;
  border-radius:50%;background:#fff;transition:transform var(--tr);pointer-events:none}
.tgl input:checked~.tgl-thumb{transform:translateX(18px)}

/* SPEAKER */
.spk-list{display:flex;flex-direction:column;gap:.5rem;max-height:240px;overflow-y:auto}
.spk-item{display:flex;align-items:center;gap:.65rem;padding:.5rem .75rem;
  border:1px solid var(--border);border-radius:var(--r10);background:var(--bg)}
.spk-chk{width:16px;height:16px;accent-color:var(--violet);flex-shrink:0;cursor:pointer}
.spk-name{font-size:.85rem;font-weight:600;flex:1;cursor:pointer}
.spk-role{padding:.2rem .5rem;border:1px solid var(--border);border-radius:var(--r6);
  font-size:.77rem;background:var(--surface)}

/* CTA STICKY */
.cta-bar{
  position:fixed;bottom:0;left:0;right:0;z-index:90;
  background:rgba(240,237,230,.96);backdrop-filter:blur(8px);
  border-top:2px solid var(--border);
  padding:.75rem 1.5rem;
  display:flex;align-items:center;justify-content:space-between;gap:1rem;
}
.cta-label{font-size:.8rem;color:var(--muted);font-weight:600}
.cta-right{display:flex;gap:.5rem}
.btn-cancel{padding:.42rem 1rem;border:1px solid var(--border);border-radius:var(--r6);
  font-size:.82rem;font-weight:700;color:var(--muted);background:var(--surface);
  transition:background var(--tr);text-decoration:none;display:inline-block}
.btn-cancel:hover{background:var(--border)}
.btn-save{display:inline-flex;align-items:center;gap:.35rem;
  padding:.48rem 1.5rem;border-radius:var(--r6);font-size:.88rem;font-weight:800;
  cursor:pointer;border:none;transition:all var(--tr)}
.btn-save.mod{background:var(--navy);color:var(--cream);box-shadow:0 2px 8px rgba(30,45,78,.25)}
.btn-save.mod:hover{background:var(--navy-d);box-shadow:0 4px 16px rgba(30,45,78,.3)}
.btn-save.new{background:#22c55e;color:#fff;box-shadow:0 2px 8px rgba(34,197,94,.3)}
.btn-save.new:hover{background:#16a34a}

/* AZIONI RAPIDE */
.sa-btn{display:flex;align-items:center;gap:.5rem;padding:.55rem .8rem;
  border:1px solid var(--border);border-radius:var(--r10);font-size:.83rem;font-weight:600;
  background:var(--surface);color:var(--text);transition:all var(--tr);cursor:pointer;
  text-decoration:none;width:100%;margin-bottom:.4rem}
.sa-btn:hover{background:var(--bg);border-color:var(--navy)}
.sa-btn.danger{color:var(--red)}
.sa-btn.danger:hover{background:#fde8e8;border-color:var(--red)}
.sa-btn.pub{color:var(--green)}
.sa-btn.pub:hover{background:#d4efde;border-color:var(--green)}
</style>

<!-- TOPBAR -->
<div class="topbar">
  <div class="tb-left">
    <a href="/agenda/events" class="tb-back">&#8592; Tutti gli eventi</a>
    <span class="tb-title">
      <%= isNew ? '&#10133; Nuovo evento' : '&#9998; ' + (ev.title||'Modifica evento') %>
    </span>
  </div>
</div>

<!-- FLASH -->
<% if(flash){ %>
<div class="flash <%= flash.type %>">
  <%= flash.type==='error'?'&#9888;':'&#10003;' %> <%- flash.msg %>
</div>
<% } %>

<!-- FORM -->
<div class="form-wrap">
<form id="evf" method="POST" action="<%= formAction %>" novalidate>

  <!-- ① INFORMAZIONI BASE -->
  <div class="fsec">
    <div class="fsec-title">Informazioni evento</div>
    <div class="fg" style="margin-bottom:.85rem">
      <label>Titolo <span class="req">*</span></label>
      <input type="text" name="title" value="<%= ev.title||'' %>"
             placeholder="Es. Panel: Il Futuro del Fumetto">
    </div>
    <div class="g2" style="margin-bottom:.85rem">
      <div class="fg">
        <label>Tipo evento</label>
        <select name="event_type">
          <% ['panel','workshop','talk','mostra','firma copie','gaming','altro'].forEach(function(t){ %>
            <option value="<%= t %>"
              <%= (ev.event_type||ev.eventtype||'panel')===t?'selected':'' %>>
              <%= t.charAt(0).toUpperCase()+t.slice(1) %>
            </option>
          <% }); %>
        </select>
      </div>
      <div class="fg">
        <label>Tag / Categorie</label>
        <input type="text" name="tags" value="<%= ev.tags||'' %>"
               placeholder="fumetto, cosplay, gaming">
        <span class="hint">Separati da virgola</span>
      </div>
    </div>
    <div class="fg" style="margin-bottom:.85rem">
      <label>Descrizione</label>
      <textarea name="description" rows="3"
        placeholder="Descrizione visibile nel programma pubblico..."><%= ev.description||'' %></textarea>
    </div>
    <div class="fg">
      <label>Immagine evento (URL)</label>
      <input type="url" name="image_url" id="img-url"
             value="<%= ev.image_url||ev.imageurl||'' %>"
             placeholder="https://esempio.com/immagine.jpg"
             oninput="prevImg(this.value)">
      <span class="hint">URL immagine — visibile nella card "In evidenza"</span>
      <div class="img-preview" id="img-prev">
        <span id="img-ph">&#128247; Nessuna immagine</span>
        <img id="img-thumb" src="" alt="Anteprima"
             onload="this.style.display='block';document.getElementById('img-ph').style.display='none'"
             onerror="this.style.display='none';document.getElementById('img-ph').style.display='block'">
      </div>
    </div>
  </div>

  <!-- ② PROGRAMMAZIONE -->
  <div class="fsec">
    <div class="fsec-title">Programmazione</div>
    <div class="g2" style="margin-bottom:.85rem">
      <div class="fg">
        <label>Sala / Spazio <span class="req">*</span></label>
        <select name="space_id" id="sel-space">
          <option value="">— Seleziona sala —</option>
          <% (spaces||[]).forEach(function(s){ %>
            <option value="<%= s.id %>"
              <%= ((ev.space_id||ev.spaceid)==s.id)?'selected':'' %>>
              <%= s.name %> (cap. <%= s.capacity %>)
            </option>
          <% }); %>
        </select>
      </div>
      <div class="fg">
        <label>Data <span class="req">*</span></label>
        <input type="date" name="date" id="inp-date"
               value="<%= ev.date||'' %>">
      </div>
    </div>
    <div class="g3">
      <div class="fg">
        <label>Ora inizio <span class="req">*</span></label>
        <input type="time" name="start_time" id="inp-start"
               value="<%= ev.start_time||ev.starttime||'' %>">
      </div>
      <div class="fg">
        <label>Ora fine <span class="req">*</span></label>
        <input type="time" name="end_time" id="inp-end"
               value="<%= ev.end_time||ev.endtime||'' %>">
      </div>
      <div class="fg">
        <label>Posti massimi</label>
        <input type="number" name="max_seats"
               value="<%= ev.max_seats||ev.maxseats||0 %>" min="0">
        <span class="hint">0 = ingresso libero</span>
      </div>
    </div>
  </div>

  <!-- ③ OSPITI / SPEAKER -->
  <div class="fsec">
    <div class="fsec-title">Ospiti e Speaker</div>
    <% if(!speakers || speakers.length === 0){ %>
      <p style="font-size:.84rem;color:var(--muted)">
        &#128101; Nessuno speaker registrato.
        <a href="/agenda/speakers" style="color:var(--violet);font-weight:700">Aggiungine uno →</a>
      </p>
    <% } else { %>
    <div class="spk-list">
      <% speakers.forEach(function(s){ %>
        <%
          var sel = (selectedSpeakers||[]).find(function(ss){
            return (ss.speaker_id||ss.speakerid)==s.id;
          });
          var selRole = sel ? (sel.role||'speaker') : 'speaker';
        %>
        <div class="spk-item">
          <input type="checkbox" name="speaker_ids" value="<%= s.id %>"
                 class="spk-chk" id="spk-<%= s.id %>"
                 <%= sel?'checked':'' %>
                 onchange="toggleRole(this,'role-<%= s.id %>')">
          <label for="spk-<%= s.id %>" class="spk-name"><%= s.name %></label>
          <select name="speaker_roles" id="role-<%= s.id %>"
                  class="spk-role"
                  style="display:<%= sel?'inline-block':'none' %>">
            <% ['speaker','moderatore','ospite','autore','giurato'].forEach(function(r){ %>
              <option value="<%= r %>" <%= selRole===r?'selected':'' %>>
                <%= r.charAt(0).toUpperCase()+r.slice(1) %>
              </option>
            <% }); %>
          </select>
        </div>
      <% }); %>
    </div>
    <% } %>
  </div>

  <!-- ④ PUBBLICAZIONE -->
  <div class="fsec">
    <div class="fsec-title">Pubblicazione e iscrizioni</div>
    <div class="g2">
      <label class="toggle-row">
        <div>
          <div class="tr-label">&#127760; Visibile nel programma</div>
          <div class="tr-hint">Appare nella pagina pubblica /programma</div>
        </div>
        <span class="tgl">
          <input type="checkbox" name="is_public" value="1"
                 <%= (ev.is_public||ev.ispublic)?'checked':'' %>>
          <div class="tgl-track"></div>
          <div class="tgl-thumb"></div>
        </span>
      </label>
      <label class="toggle-row">
        <div>
          <div class="tr-label">&#128225; Pubblicato</div>
          <div class="tr-hint">Attivo e visibile nel sito</div>
        </div>
        <span class="tgl">
          <input type="checkbox" name="published" value="1"
                 <%= ev.published?'checked':'' %>>
          <div class="tgl-track"></div>
          <div class="tgl-thumb"></div>
        </span>
      </label>
      <label class="toggle-row span2">
        <div>
          <div class="tr-label">&#127914; Iscrizioni pubbliche aperte</div>
          <div class="tr-hint">Mostra il bottone "Iscriviti" sulla pagina pubblica</div>
        </div>
        <span class="tgl">
          <input type="checkbox" name="registrations_open" value="1"
                 <%= (ev.registrations_open||ev.registrationsopen)?'checked':'' %>>
          <div class="tgl-track"></div>
          <div class="tgl-thumb"></div>
        </span>
      </label>
    </div>
  </div>

  <!-- ⑤ NOTE INTERNE -->
  <div class="fsec">
    <div class="fsec-title">Note interne</div>
    <div class="fg">
      <textarea name="notes" rows="2"
        placeholder="Visibili solo agli amministratori..."><%= ev.notes||'' %></textarea>
    </div>
  </div>

  <!-- AZIONI RAPIDE (solo modifica) -->
  <% if(!isNew){ %>
  <div class="fsec">
    <div class="fsec-title">Azioni rapide</div>
    <a href="/agenda/events/<%= ev.id %>/registrations" class="sa-btn">
      &#128101; Visualizza iscritti
    </a>
    <form method="POST" action="/agenda/events/<%= ev.id %>/publish" style="margin:0">
      <button type="submit" class="sa-btn pub">
        <%= ev.published ? '&#8617; Rimetti in bozza' : '&#128225; Pubblica ora' %>
      </button>
    </form>
    <form method="POST" action="/agenda/events/<%= ev.id %>/delete"
          onsubmit="return confirm('Eliminare definitivamente questo evento?')"
          style="margin:0">
      <button type="submit" class="sa-btn danger">&#128465; Elimina evento</button>
    </form>
  </div>
  <% } %>

</form>
</div>

<!-- CTA BAR STICKY -->
<div class="cta-bar">
  <span class="cta-label" id="cta-label">
    <%= isNew ? '&#10133; Nuovo evento' : '&#9998; ' + (ev.title||'Modifica') %>
  </span>
  <div class="cta-right">
    <a href="/agenda/events" class="btn-cancel">Annulla</a>
    <button type="submit" form="evf"
            class="btn-save <%= isNew?'new':'mod' %>"
            onclick="return validateForm()">
      <%= isNew ? '&#10003;&nbsp;Crea evento' : '&#128190;&nbsp;Salva modifiche' %>
    </button>
  </div>
</div>

<script>
/* ── Anteprima immagine ── */
(function(){
  var url = document.getElementById('img-url').value;
  if(url) prevImg(url);
})();

function prevImg(url){
  var img = document.getElementById('img-thumb');
  var ph  = document.getElementById('img-ph');
  if(!url){ img.style.display='none'; ph.style.display='block'; return; }
  img.onload = function(){ img.style.display='block'; ph.style.display='none'; };
  img.onerror= function(){ img.style.display='none'; ph.style.display='block'; };
  img.src = url;
}

/* ── Toggle ruolo speaker ── */
function toggleRole(chk, roleId){
  var el = document.getElementById(roleId);
  if(el) el.style.display = chk.checked ? 'inline-block' : 'none';
}

/* ── Validazione client-side (non blocca, avvisa) ── */
function validateForm(){
  var errors = [];
  var title = document.querySelector('[name="title"]').value.trim();
  var space = document.querySelector('[name="space_id"]').value;
  var date  = document.querySelector('[name="date"]').value;
  var start = document.querySelector('[name="start_time"]').value;
  var end   = document.querySelector('[name="end_time"]').value;

  if(!title)  errors.push('Titolo obbligatorio');
  if(!space)  errors.push('Seleziona una sala');
  if(!date)   errors.push('Data obbligatoria');
  if(!start)  errors.push('Ora inizio obbligatoria');
  if(!end)    errors.push('Ora fine obbligatoria');
  if(start && end && end <= start) errors.push('Ora fine deve essere successiva all\'inizio');

  if(errors.length > 0){
    alert('Attenzione:\n\n• ' + errors.join('\n• '));
    return false;
  }
  return true;
}

/* ── Avviso modifiche non salvate ── */
var _dirty = false;
document.getElementById('evf').addEventListener('input', function(){ _dirty=true; });
document.getElementById('evf').addEventListener('submit', function(){ _dirty=false; });
window.addEventListener('beforeunload', function(e){
  if(_dirty){ e.preventDefault(); e.returnValue=''; }
});
</script>

<%- include('../partials/footer') %>
