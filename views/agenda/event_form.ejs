    </div>
  </div>
</div>
<script>
(function() {
  var chk    = document.getElementById('chk-reg-open');
  var slider = document.getElementById('toggle-reg-slider');
  var knob   = document.getElementById('toggle-reg-knob');
  if (!chk) return;
  function update() {
    slider.style.background = chk.checked ? '#437a22' : '#cbd5e0';
    knob.style.left          = chk.checked ? '23px'   : '3px';
  }
  chk.addEventListener('change', update);
})();
</script>

<!-- MODALE CONFLITTO -->
<div id="conflict-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:9999;align-items:center;justify-content:center">
