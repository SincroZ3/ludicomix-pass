<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gestione Mappa — Admin</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, 'Segoe UI', Arial, sans-serif; font-size: 14px; background: #f4f6f9; color: #1a2744; }

    /* Header admin */
    .admin-header {
      background: #1e2d4e; color: #fff; padding: .75rem 1.5rem;
      display: flex; align-items: center; justify-content: space-between;
      border-bottom: 3px solid #f5c842;
    }
    .admin-header h1 { font-size: 1rem; font-weight: 800; }
    .admin-header-actions { display: flex; gap: .5rem; align-items: center; }
    .btn-sm {
      padding: .3rem .8rem; border-radius: 6px; font-size: .78rem;
      font-weight: 700; cursor: pointer; border: none; text-decoration: none;
      display: inline-flex; align-items: center; gap: .3rem; transition: background .15s;
    }
    .btn-primary { background: #f5c842; color: #1e2d4e; }
    .btn-primary:hover { background: #f7d060; }
    .btn-secondary { background: rgba(255,255,255,.15); color: #fff; border: 1px solid rgba(255,255,255,.3); }
    .btn-secondary:hover { background: rgba(255,255,255,.25); }
    .btn-danger { background: #e8372a; color: #fff; }
    .btn-danger:hover { background: #c42d21; }
    .btn-success { background: #2e7d32; color: #fff; }
    .btn-success:hover { background: #1b5e20; }

    /* Flash */
    .flash { padding: .5rem 1rem; font-size: .82rem; font-weight: 700; display: flex; align-items: center; justify-content: center; gap: .4rem; }
    .flash.saved         { background: #d4edda; color: #155724; }
    .flash.created       { background: #cce5ff; color: #004085; }
    .flash.removed       { background: #fff3cd; color: #856404; }
    .flash.deleted       { background: #fce8e6; color: #7c1e1e; }
    .flash.order_conflict{ background: #fff3cd; color: #856404; }
    .flash.error         { background: #f8d7da; color: #721c24; }

    /* Layout a due colonne */
    .layout { display: flex; height: calc(100vh - 58px); }

    /* Pannello sinistro — lista zone */
    .panel-left {
      width: 380px; flex-shrink: 0; overflow-y: auto;
      background: #fff; border-right: 1px solid #e2e8f0;
      display: flex; flex-direction: column;
    }
    .panel-header {
      padding: .85rem 1rem; border-bottom: 1px solid #e2e8f0;
      display: flex; align-items: center; justify-content: space-between;
      flex-shrink: 0; background: #f8f9fc; position: sticky; top: 0; z-index: 10;
    }
    .panel-header h2 { font-size: .88rem; font-weight: 800; color: #1e2d4e; }

    /* Form nuova zona */
    .new-zone-form {
      background: #f0f8ff; border-bottom: 1px solid #d1e8ff; padding: 1rem;
      display: none;
    }
    .new-zone-form.open { display: block; }
    .new-zone-form h3 { font-size: .8rem; font-weight: 800; color: #1e2d4e; margin-bottom: .75rem; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: .5rem; margin-bottom: .5rem; }
    .form-row.single { grid-template-columns: 1fr; }
    .fgroup { display: flex; flex-direction: column; gap: .2rem; }
    .fgroup label { font-size: .62rem; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: #8896ab; }
    .fgroup input, .fgroup select, .fgroup textarea {
      padding: .38rem .6rem; border: 1px solid #d1d9e6; border-radius: 6px;
      font-size: .82rem; color: #1a2744; background: #fff; outline: none;
      transition: border-color .15s;
    }
    .fgroup input:focus, .fgroup select:focus, .fgroup textarea:focus { border-color: #1e2d4e; }
    .form-actions { display: flex; gap: .4rem; margin-top: .6rem; }

    /* Card zona */
    .zone-card {
      border-bottom: 1px solid #f0f2f7; padding: .85rem 1rem;
      cursor: pointer; transition: background .12s;
    }
    .zone-card:hover { background: #f8f9ff; }
    .zone-card.selected { background: #eef2ff; border-left: 3px solid #1e2d4e; }
    .zone-card-header { display: flex; align-items: center; gap: .6rem; margin-bottom: .35rem; }
    .zc-badge {
      flex-shrink: 0; width: 28px; height: 28px; border-radius: 50%;
      color: #fff; font-weight: 900; font-size: .72rem;
      display: flex; align-items: center; justify-content: center;
    }
    .zc-name { font-size: .85rem; font-weight: 800; color: #1a2744; flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .zc-toggle { flex-shrink: 0; }
    .badge-type {
      display: inline-block; font-size: .58rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: .3px; padding: .12rem .45rem; border-radius: 999px;
      background: #f0f2f7; color: #4a5568;
    }
    .badge-inactive { background: #f8d7da; color: #721c24; }
    .badge-active   { background: #d4edda; color: #155724; }
    .no-coords { font-size: .72rem; color: #e8372a; font-style: italic; margin-top: .2rem; }

    /* Pannello destro — mappa + form edit */
    .panel-right { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
    #adminMap { flex: 1; }

    /* Form edit zona (overlay in basso sulla mappa) */
    .edit-panel {
      background: #fff; border-top: 2px solid #e2e8f0;
      padding: 1rem 1.2rem; flex-shrink: 0; display: none;
      max-height: 340px; overflow-y: auto;
    }
    .edit-panel.open { display: block; }
    .edit-panel-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: .8rem; }
    .edit-panel-title { font-size: .92rem; font-weight: 800; color: #1e2d4e; }
    .edit-panel-actions { display: flex; gap: .4rem; }
    .edit-form-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: .6rem; }
    .edit-form-grid .fgroup.full { grid-column: 1 / -1; }
    .coords-hint { font-size: .72rem; color: #718096; margin-top: .4rem; background: #f8f9fc; padding: .5rem .7rem; border-radius: 6px; border: 1px solid #e2e8f0; }
    .coords-hint strong { color: #1e2d4e; }

    /* Toggle active */
    .toggle-wrap { display: flex; align-items: center; gap: .5rem; }
    .toggle-wrap label { font-size: .8rem; font-weight: 600; color: #4a5568; cursor: pointer; }

    @media (max-width: 768px) {
      .layout { flex-direction: column; height: auto; }
      .panel-left { width: 100%; height: 40vh; }
      .panel-right { height: 60vh; }
      .edit-panel { max-height: 50vh; }
    }
  </style>
</head>
<body>

<div class="admin-header">
  <h1>🗺️ Gestione Mappa Pubblica</h1>
  <div class="admin-header-actions">
    <a href="/mappa-pubblica" target="_blank" class="btn-sm btn-secondary">👁️ Vedi Mappa Pubblica</a>
    <a href="/admin/zone-manager" class="btn-sm btn-primary">🗂️ Zone Manager</a>
    <a href="/home" class="btn-sm btn-secondary">← Admin</a>
  </div>
  <div style="font-size:11px;color:#999;padding:2px 8px;">server v6 map_points-fix — POI pubblici: <%= zones.length %></div>
</div>

<% if (flash) { %>
<div class="flash <%= flash %>" id="flashMsg">
  <span>
  <% if (flash==='saved')   { %>✅ Zona aggiornata con successo.<% } %>
  <% if (flash==='created') { %>✅ Nuova zona creata.<% } %>
  <% if (flash==='removed') { %>⚠️ Coordinate mappa rimosse dalla zona.<% } %>
  <% if (flash==='deleted') { %>🗑️ Zona eliminata definitivamente.<% } %>
  <% if (flash==='order_conflict') { %>❌ Il valore <strong>Ordine</strong> è già usato da un'altra zona. Scegli un numero diverso.<% } %>
  <% if (flash==='error')   { %>❌ Errore durante il salvataggio.<% } %>
  </span>
  <button onclick="document.getElementById('flashMsg').style.display='none'" style="background:none;border:none;cursor:pointer;font-size:1rem;line-height:1;margin-left:.8rem;opacity:.6;padding:0" title="Chiudi">✕</button>
</div>
<% } %>

<div class="layout">

  <!-- PANNELLO SINISTRA — LISTA ZONE -->
  <div class="panel-left">
    <div class="panel-header">
      <h2>Zone (<%= zones.length %>)</h2>
      <button class="btn-sm btn-primary" onclick="toggleNewForm()">+ Nuova Zona</button>
    </div>

    <!-- FORM NUOVA ZONA -->
    <div class="new-zone-form" id="newZoneForm">
      <h3>➕ Crea nuova zona</h3>
      <form method="POST" action="/admin/mappa-pubblica/zone/new">
        <div class="form-row">
          <div class="fgroup">
            <label>Nome zona *</label>
            <input type="text" name="name" required placeholder="Es. Palazzo Esposizioni">
          </div>
          <div class="fgroup">
            <label>Etichetta marker</label>
            <input type="text" name="map_label" placeholder="Es. 1 o 🎸" maxlength="4">
          </div>
        </div>
        <div class="form-row">
          <div class="fgroup">
            <label>Tipo</label>
            <select name="map_type">
              <option value="area">🎪 Area evento</option>
              <option value="eventi">🎭 Area eventi</option>
              <option value="sala">🎤 Sala incontri</option>
              <option value="mostra">🖼️ Mostra</option>
              <option value="extra">⭐ Extra</option>
              <option value="parking">🅿️ Parcheggio</option>
              <option value="bagni">🚻 Bagni</option>
              <option value="biglietteria">🎟️ Biglietteria</option>
              <option value="trasporti">🚌 Trasporti Pubblici</option>
              <option value="shop">🛍️ Punti Shop Ludicomix</option>
              <option value="palco">🎙️ Palchi &amp; Incontri</option>
            </select>
          </div>
          <div class="fgroup">
            <label>Ordine</label>
            <input type="number" name="sort_order" value="0" min="0">
          </div>
        </div>
        <div class="form-row">
          <div class="fgroup">
            <label>Latitudine</label>
            <input type="number" name="map_lat" step="0.000001" placeholder="43.719…">
          </div>
          <div class="fgroup">
            <label>Longitudine</label>
            <input type="number" name="map_lng" step="0.000001" placeholder="10.948…">
          </div>
        </div>
        <div class="form-row single">
          <div class="fgroup">
            <label>Indirizzo</label>
            <input type="text" name="map_address" placeholder="Via Roma 1, Empoli">
          </div>
        </div>
        <div class="form-row single">
          <div class="fgroup">
            <label>Descrizione</label>
            <textarea name="map_desc" rows="2" placeholder="Breve descrizione della zona…"></textarea>
          </div>
        </div>
        <div class="form-row">
          <div class="fgroup">
            <label>Tag (virgola)</label>
            <input type="text" name="map_tags" placeholder="fumetto, gioco, artisti">
          </div>
          <div class="fgroup">
            <label>Colore marker</label>
            <input type="color" name="map_color" value="#e8372a" style="height:34px;padding:2px">
          </div>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn-sm btn-success">✅ Crea</button>
          <button type="button" class="btn-sm btn-secondary" style="background:#f0f2f7;color:#4a5568" onclick="toggleNewForm()">Annulla</button>
        </div>
      </form>
    </div>

    <!-- LISTA -->
    <% if (zones.length === 0) { %>
    <div style="text-align:center;padding:3rem 1rem;color:#8896ab">
      <div style="font-size:2rem;margin-bottom:.5rem">🗺️</div>
      <p>Nessuna zona. Creane una con il pulsante qui sopra.</p>
    </div>
    <% } %>
    <% zones.forEach(function(z) { %>
    <%
      var typeColors = { area:'#e8372a', mostra:'#1e2d4e', extra:'#6b3fa0', parking:'#1e7ed4' };
      var color = z.map_color || typeColors[z.map_type] || '#555';
      var lbl = z.map_label || z.name.substring(0,3);
    %>
    <div class="zone-card" id="zc-<%= z.id %>" onclick="selectZone(<%= z.id %>)">
      <div class="zone-card-header">
        <div class="zc-badge" style="background:<%= color %>"><%= lbl %></div>
        <div class="zc-name"><%= z.name %></div>
        <span style="font-size:.6rem;color:#8896ab;flex-shrink:0;margin-right:.2rem">#<%= z.sort_order %></span>
        <span class="badge-type badge-<%= z.map_active ? 'active' : 'inactive' %>">
          <%= z.map_active ? '✓ Vis.' : '✗ Nasc.' %>
        </span>
      </div>
      <div>
        <span class="badge-type"><%= z.map_type || 'area' %></span>
        <% if (z.map_address) { %> <span style="font-size:.72rem;color:#718096">📍 <%= z.map_address %></span><% } %>
      </div>
      <% if (!z.map_lat || !z.map_lng) { %>
      <div class="no-coords">⚠️ Coordinate non impostate — non visibile sulla mappa</div>
      <% } %>
    </div>
    <% }); %>
  </div>

  <!-- PANNELLO DESTRA — MAPPA + EDIT -->
  <div class="panel-right">
    <div id="adminMap"></div>

    <div class="edit-panel" id="editPanel">
      <div class="edit-panel-header">
        <div class="edit-panel-title" id="editPanelTitle">Seleziona una zona</div>
        <div class="edit-panel-actions">
          <button class="btn-sm btn-success" id="btnSaveEdit" form="editForm" type="submit" style="display:none">💾 Salva</button>
          <button class="btn-sm btn-danger" id="btnRemoveCoords" onclick="removeCoords()" style="display:none">📍 Rimuovi coords</button>
          <button class="btn-sm" id="btnDeleteZone" onclick="confirmDelete()" style="display:none;background:#7c1e1e;color:#fff;border:none">🗑️ Elimina zona</button>
          <button class="btn-sm btn-secondary" style="background:#f0f2f7;color:#4a5568" onclick="closeEdit()">✕ Chiudi</button>
        </div>
      </div>
      <!-- Form nascosto per eliminazione zona -->
      <form id="deleteZoneForm" method="POST" action="" style="display:none"></form>

      <div class="coords-hint" id="coordsHint" style="display:none">
        💡 <strong>Trascina il marker</strong> sulla mappa per aggiornare le coordinate, oppure inseriscile manualmente qui sotto.
      </div>

      <form id="editForm" method="POST" action="">
        <div class="edit-form-grid">
          <div class="fgroup full">
            <label>Nome zona *</label>
            <input type="text" name="name" id="ef_name" required placeholder="Nome zona">
          </div>
          <div class="fgroup">
            <label>Ordine</label>
            <input type="number" name="sort_order" id="ef_sort_order" min="0" value="0">
          </div>
          <div class="fgroup">
            <label>Latitudine</label>
            <input type="number" name="map_lat" id="ef_lat" step="0.000001" placeholder="43.719…">
          </div>
          <div class="fgroup">
            <label>Longitudine</label>
            <input type="number" name="map_lng" id="ef_lng" step="0.000001" placeholder="10.948…">
          </div>
          <div class="fgroup">
            <label>Etichetta marker</label>
            <input type="text" name="map_label" id="ef_label" maxlength="4" placeholder="Es. 1 o 🎸">
          </div>
          <div class="fgroup">
            <label>Tipo</label>
            <select name="map_type" id="ef_type">
              <option value="area">🎪 Area evento</option>
              <option value="eventi">🎭 Area eventi</option>
              <option value="sala">🎤 Sala incontri</option>
              <option value="mostra">🖼️ Mostra</option>
              <option value="extra">⭐ Extra</option>
              <option value="parking">🅿️ Parcheggio</option>
              <option value="bagni">🚻 Bagni</option>
              <option value="biglietteria">🎟️ Biglietteria</option>
              <option value="trasporti">🚌 Trasporti Pubblici</option>
              <option value="shop">🛍️ Punti Shop Ludicomix</option>
              <option value="palco">🎙️ Palchi &amp; Incontri</option>
            </select>
          </div>
          <div class="fgroup">
            <label>Colore marker</label>
            <input type="color" name="map_color" id="ef_color" style="height:34px;padding:2px">
          </div>
          <div class="fgroup">
            <label>Zoom default</label>
            <input type="number" name="map_zoom" id="ef_zoom" min="12" max="19" value="17">
          </div>
          <div class="fgroup full">
            <label>Indirizzo</label>
            <input type="text" name="map_address" id="ef_address" placeholder="Via Roma 1, Empoli">
          </div>
          <div class="fgroup full">
            <label>Descrizione pubblica</label>
            <textarea name="map_desc" id="ef_desc" rows="2" placeholder="Breve descrizione…"></textarea>
          </div>
          <div class="fgroup full">
            <label>Tag (separati da virgola)</label>
            <input type="text" name="map_tags" id="ef_tags" placeholder="fumetto, gioco, artisti">
          </div>
          <div class="fgroup">
            <label>Visibile sulla mappa</label>
            <div class="toggle-wrap">
              <input type="checkbox" name="map_active" id="ef_active" value="1" style="width:16px;height:16px">
              <label for="ef_active">Pubblica</label>
            </div>
            <!-- hidden fallback per checkbox non spuntata -->
            <input type="hidden" name="map_active" value="0" id="ef_active_hidden">
          </div>
        </div>
        <div class="form-actions" style="margin-top:.8rem">
          <button type="submit" class="btn-sm btn-success">💾 Salva zona</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
var ZONES = <%- JSON.stringify(zones) %>;
var TYPE_COLORS = { area:'#e8372a', eventi:'#e05c00', sala:'#1a7a4a', mostra:'#1e2d4e', extra:'#6b3fa0', parking:'#1e7ed4', bagni:'#0e7490', biglietteria:'#b45309', trasporti:'#0369a1', shop:'#be185d', palco:'#7c3aed', default:'#555' };
function zColor(z) { return z.map_color || TYPE_COLORS[z.map_type] || TYPE_COLORS.default; }

/* ── MAPPA ADMIN ── */
var adminMap = L.map('adminMap', { center: [43.7183, 10.9488], zoom: 15 });
L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
  attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors © <a href="https://carto.com/">CARTO</a>',
  subdomains: 'abcd', maxZoom: 19
}).addTo(adminMap);

var adminMarkers = {};
var selectedId = null;
var dragMarker = null; // marker draggabile per zona selezionata

function makeAdminIcon(z, selected) {
  var color = zColor(z);
  var lbl = z.map_label || (z.name ? z.name.substring(0,3) : '?');
  return L.divIcon({
    className:'',
    html: '<div style="width:30px;height:30px;border-radius:50%;background:'+color+';color:#fff;font-weight:900;font-size:.75rem;display:flex;align-items:center;justify-content:center;border:' + (selected?'3px solid #f5c842':'2px solid #fff') + ';box-shadow:0 2px 8px rgba(0,0,0,.3);cursor:pointer">' + lbl + '</div>',
    iconSize:[30,30], iconAnchor:[15,15], popupAnchor:[0,-18]
  });
}

ZONES.forEach(function(z) {
  if (!z.map_lat || !z.map_lng) return;
  var m = L.marker([z.map_lat, z.map_lng], { icon: makeAdminIcon(z, false) }).addTo(adminMap);
  m.bindTooltip(z.name, { permanent: false, direction: 'top' });
  m.on('click', function() { selectZone(z.id); });
  adminMarkers[z.id] = m;
});

function selectZone(id) {
  var z = ZONES.find(function(x){return x.id===id;});
  if (!z) return;

  // Deselect old
  if (selectedId && adminMarkers[selectedId]) {
    var old = ZONES.find(function(x){return x.id===selectedId;});
    if (old) adminMarkers[selectedId].setIcon(makeAdminIcon(old, false));
  }
  // Remove old drag marker
  if (dragMarker) { adminMap.removeLayer(dragMarker); dragMarker = null; }

  selectedId = id;
  document.querySelectorAll('.zone-card').forEach(function(el){ el.classList.remove('selected'); });
  var card = document.getElementById('zc-'+id);
  if (card) { card.classList.add('selected'); card.scrollIntoView({behavior:'smooth',block:'nearest'}); }

  if (adminMarkers[id]) adminMarkers[id].setIcon(makeAdminIcon(z, true));

  // Focus mappa
  if (z.map_lat && z.map_lng) {
    adminMap.setView([z.map_lat, z.map_lng], Math.max(z.map_zoom||16, 16), {animate:true});
    // Aggiungi drag marker sopra quello fisso
    dragMarker = L.marker([z.map_lat, z.map_lng], {
      draggable: true,
      icon: L.divIcon({
        className:'',
        html:'<div style="width:34px;height:34px;border-radius:50%;background:'+zColor(z)+';color:#fff;font-weight:900;font-size:.82rem;display:flex;align-items:center;justify-content:center;border:3px solid #f5c842;box-shadow:0 3px 12px rgba(0,0,0,.4);cursor:grab;opacity:.9">' + (z.map_label||z.name.substring(0,3)) + '</div>',
        iconSize:[34,34],iconAnchor:[17,17]
      })
    }).addTo(adminMap);
    dragMarker.on('dragend', function(e) {
      var ll = e.target.getLatLng();
      document.getElementById('ef_lat').value = ll.lat.toFixed(6);
      document.getElementById('ef_lng').value = ll.lng.toFixed(6);
    });
    document.getElementById('coordsHint').style.display = 'block';
  } else {
    document.getElementById('coordsHint').style.display = 'none';
    // Aggiungi drag marker al centro della mappa per posizionamento iniziale
    var center = adminMap.getCenter();
    dragMarker = L.marker([center.lat, center.lng], {
      draggable: true,
      icon: L.divIcon({
        className:'',
        html:'<div style="width:34px;height:34px;border-radius:50%;background:'+zColor(z)+';color:#fff;font-weight:900;font-size:.82rem;display:flex;align-items:center;justify-content:center;border:3px dashed #f5c842;box-shadow:0 3px 12px rgba(0,0,0,.4);cursor:grab;opacity:.85">' + (z.map_label||z.name.substring(0,3)) + '</div>',
        iconSize:[34,34],iconAnchor:[17,17]
      })
    }).addTo(adminMap).bindTooltip('Trascina per posizionare', {permanent:true, direction:'top'});
    dragMarker.on('dragend', function(e) {
      var ll = e.target.getLatLng();
      document.getElementById('ef_lat').value = ll.lat.toFixed(6);
      document.getElementById('ef_lng').value = ll.lng.toFixed(6);
      dragMarker.unbindTooltip();
      document.getElementById('coordsHint').style.display = 'block';
    });
    dragMarker.on('drag', function(e) {
      var ll = e.target.getLatLng();
      document.getElementById('ef_lat').value = ll.lat.toFixed(6);
      document.getElementById('ef_lng').value = ll.lng.toFixed(6);
    });
  }

  // Popola form edit
  document.getElementById('editPanelTitle').textContent = '✏️ ' + z.name;
  document.getElementById('editForm').action   = '/admin/mappa-pubblica/zone/' + id;
  document.getElementById('deleteZoneForm').action = '/admin/mappa-pubblica/zone/' + id + '/delete';
  // ✅ FIX: nome e ordine ora modificabili
  document.getElementById('ef_name').value        = z.name || '';
  document.getElementById('ef_sort_order').value  = (z.sort_order !== undefined && z.sort_order !== null) ? z.sort_order : 0;
  document.getElementById('ef_lat').value    = z.map_lat  || '';
  document.getElementById('ef_lng').value    = z.map_lng  || '';
  document.getElementById('ef_label').value  = z.map_label || '';
  document.getElementById('ef_type').value   = z.map_type  || 'area';
  document.getElementById('ef_color').value  = z.map_color || '#e8372a';
  document.getElementById('ef_zoom').value   = z.map_zoom  || 17;
  document.getElementById('ef_address').value= z.map_address|| '';
  document.getElementById('ef_desc').value   = z.map_desc  || '';
  document.getElementById('ef_tags').value   = z.map_tags  || '';
  var activeChk = document.getElementById('ef_active');
  activeChk.checked = z.map_active == 1;
  activeChk.onchange = function() {
    document.getElementById('ef_active_hidden').disabled = activeChk.checked;
  };
  document.getElementById('ef_active_hidden').disabled = activeChk.checked;

  // ✅ Mostra pulsanti azione (nascosti finché nessuna zona è selezionata)
  document.getElementById('btnSaveEdit').style.display    = 'inline-flex';
  document.getElementById('btnRemoveCoords').style.display = z.map_lat ? 'inline-flex' : 'none';
  document.getElementById('btnDeleteZone').style.display  = 'inline-flex';

  document.getElementById('editPanel').classList.add('open');
  adminMap.invalidateSize();
}

function closeEdit() {
  document.getElementById('editPanel').classList.remove('open');
  if (dragMarker) { adminMap.removeLayer(dragMarker); dragMarker = null; }
  adminMap.invalidateSize();
}

function removeCoords() {
  if (!selectedId) return;
  if (!confirm('Rimuovere le coordinate di questa zona dalla mappa pubblica? (la zona rimane in elenco)')) return;
  var form = document.createElement('form');
  form.method = 'POST';
  form.action = '/admin/mappa-pubblica/zone/'+selectedId+'/remove-coords';
  document.body.appendChild(form);
  form.submit();
}

// ✅ NUOVO: eliminazione definitiva zona
function confirmDelete() {
  if (!selectedId) return;
  var z = ZONES.find(function(x){return x.id===selectedId;});
  var nome = z ? z.name : 'questa zona';
  if (!confirm('⚠️ Eliminare DEFINITIVAMENTE la zona "' + nome + '"?\n\nQuesta azione è irreversibile.')) return;
  document.getElementById('deleteZoneForm').submit();
}

function toggleNewForm() {
  var f = document.getElementById('newZoneForm');
  f.classList.toggle('open');
}

// Aggiorna live il colore del marker drag quando l'utente cambia colore nel picker
document.getElementById('ef_color').addEventListener('input', function() {
  if (dragMarker && selectedId) {
    var z = ZONES.find(function(x){return x.id===selectedId;});
    if (z) {
      z.map_color = this.value;
      dragMarker.setIcon(L.divIcon({
        className:'',
        html:'<div style="width:34px;height:34px;border-radius:50%;background:'+this.value+';color:#fff;font-weight:900;font-size:.82rem;display:flex;align-items:center;justify-content:center;border:3px solid #f5c842;box-shadow:0 3px 12px rgba(0,0,0,.4);cursor:grab">'+(z.map_label||z.name.substring(0,3))+'</div>',
        iconSize:[34,34],iconAnchor:[17,17]
      }));
    }
  }
});
// ── Flash auto-dismiss + pulizia URL ──
(function() {
  var fm = document.getElementById('flashMsg');
  if (!fm) return;
  // Pulisce il parametro ?flash dall'URL senza ricaricare la pagina
  if (window.history && window.history.replaceState) {
    var url = new URL(window.location.href);
    url.searchParams.delete('flash');
    url.searchParams.delete('order');
    url.searchParams.delete('id');
    window.history.replaceState({}, '', url.toString());
  }
  // Auto-hide dopo 5 secondi
  setTimeout(function() {
    fm.style.transition = 'opacity .4s';
    fm.style.opacity = '0';
    setTimeout(function() { fm.style.display = 'none'; }, 420);
  }, 5000);
})();
</script>
</body>
</html>