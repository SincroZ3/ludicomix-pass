<%- include('../partials/header') %>
<main class="content">

  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;margin-bottom:1.2rem;">
    <h1 class="page-title" style="margin:0;border:none;">🏛 Sale e Spazi</h1>
    <div style="display:flex;gap:.5rem;">
      <button class="primary" onclick="document.getElementById('modal-new-space').style.display='flex'">+ Nuova Sala</button>
      <a href="/agenda" class="secondary">← Agenda</a>
    </div>
  </div>

  <% if (flash) { %>
    <div class="alert alert-<%= flash.type === 'error' ? 'danger' : 'success' %>">
      <span><%= flash.type === 'error' ? '⚠️' : '✅' %></span>
      <span><%- flash.msg %></span>
    </div>
  <% } %>

  <% if (spaces.length === 0) { %>
    <div class="card" style="text-align:center;padding:3rem;color:var(--text-muted);">
      <div style="font-size:2.5rem;margin-bottom:.75rem;">🏛</div>
      <p>Nessuna sala configurata. Creane una per iniziare.</p>
    </div>
  <% } else { %>
    <div class="table-wrapper">
      <table>
        <thead><tr>
          <th>Nome</th><th>Descrizione</th><th>Capienza</th><th>Posizione</th><th>Colore</th><th>Stato</th><th>Eventi</th><th>Azioni</th>
        </tr></thead>
        <tbody>
        <% spaces.forEach(s => { %>
          <tr>
            <td><strong><%= s.name %></strong></td>
            <td style="color:var(--text-muted)"><%= s.description || '—' %></td>
            <td><%= s.capacity %></td>
            <td><%= s.location || '—' %></td>
            <td>
              <span style="display:inline-block;width:18px;height:18px;border-radius:3px;background:<%= s.color %>;vertical-align:middle;border:1px solid var(--border);"></span>
              <small><%= s.color %></small>
            </td>
            <td>
              <% if(s.active) { %>
                <span style="color:#1d6a39;font-weight:700;">Attiva</span>
              <% } else { %>
                <span style="color:var(--text-muted);">Disabilitata</span>
              <% } %>
            </td>
            <td><%= s.event_count %></td>
            <td style="white-space:nowrap;">
              <button class="secondary btn-edit-space"
                style="padding:.25rem .6rem;font-size:.76rem;"
                data-id="<%= s.id %>"
                data-name="<%= encodeURIComponent(s.name || '') %>"
                data-desc="<%= encodeURIComponent(s.description || '') %>"
                data-cap="<%= s.capacity %>"
                data-loc="<%= encodeURIComponent(s.location || '') %>"
                data-color="<%= s.color %>"
                data-active="<%= s.active ? '1' : '0' %>">
                Modifica
              </button>
              <% if(s.event_count == 0) { %>
                <form method="POST" action="/agenda/spaces/<%= s.id %>/delete" style="display:inline;"
                  onsubmit="return confirm('Eliminare la sala?')">
                  <button class="btn-danger">Elimina</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>

</main>

<!-- Modal: Nuova Sala -->
<div id="modal-new-space" class="modal-overlay" onclick="if(event.target===this)this.style.display='none'">
  <div class="modal">
    <div class="modal-header">
      <h2>Nuova Sala / Spazio</h2>
      <button class="modal-close" onclick="document.getElementById('modal-new-space').style.display='none'">✕</button>
    </div>
    <form method="POST" action="/agenda/spaces">
      <div class="modal-body">
        <div>
          <label>Nome sala <span class="req">*</span></label>
          <input type="text" name="name" required placeholder="es. Sala Principale">
        </div>
        <div>
          <label>Descrizione</label>
          <input type="text" name="description" placeholder="es. Auditorium principale, piano 0">
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
          <div>
            <label>Capienza massima <span class="req">*</span></label>
            <input type="number" name="capacity" required min="0" value="50">
          </div>
          <div>
            <label>Colore calendario</label>
            <input type="color" name="color" value="#4f98a3" style="width:100%;height:38px;padding:2px;cursor:pointer;">
          </div>
        </div>
        <div>
          <label>Posizione / Piano</label>
          <input type="text" name="location" placeholder="es. Piano 1 – Ala Nord">
        </div>
        <div class="modal-actions">
          <button type="button" class="secondary" onclick="document.getElementById('modal-new-space').style.display='none'">Annulla</button>
          <button type="submit" class="primary">Crea Sala</button>
        </div>
      </div>
    </form>
  </div>
</div>

<!-- Modal: Modifica Sala -->
<div id="modal-edit-space" class="modal-overlay" onclick="if(event.target===this)this.style.display='none'">
  <div class="modal">
    <div class="modal-header">
      <h2>Modifica Sala</h2>
      <button class="modal-close" onclick="document.getElementById('modal-edit-space').style.display='none'">✕</button>
    </div>
    <form method="POST" id="form-edit-space">
      <div class="modal-body">
        <div>
          <label>Nome sala <span class="req">*</span></label>
          <input type="text" name="name" id="es-name" required>
        </div>
        <div>
          <label>Descrizione</label>
          <input type="text" name="description" id="es-desc">
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
          <div>
            <label>Capienza</label>
            <input type="number" name="capacity" id="es-cap" min="0">
          </div>
          <div>
            <label>Colore</label>
            <input type="color" name="color" id="es-color" style="width:100%;height:38px;padding:2px;cursor:pointer;">
          </div>
        </div>
        <div>
          <label>Posizione</label>
          <input type="text" name="location" id="es-loc">
        </div>
        <div>
          <label>
            <input type="checkbox" name="active" id="es-active" value="1">
            Sala attiva
          </label>
        </div>
        <div class="modal-actions">
          <button type="button" class="secondary" onclick="document.getElementById('modal-edit-space').style.display='none'">Annulla</button>
          <button type="submit" class="primary">Salva</button>
        </div>
      </div>
    </form>
  </div>
</div>

<script>
document.querySelectorAll('.btn-edit-space').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var d = btn.dataset;
    document.getElementById('form-edit-space').action = '/agenda/spaces/' + d.id;
    document.getElementById('es-name').value   = decodeURIComponent(d.name);
    document.getElementById('es-desc').value   = decodeURIComponent(d.desc);
    document.getElementById('es-cap').value    = d.cap;
    document.getElementById('es-loc').value    = decodeURIComponent(d.loc);
    document.getElementById('es-color').value  = d.color;
    document.getElementById('es-active').checked = d.active === '1';
    document.getElementById('modal-edit-space').style.display = 'flex';
  });
});
</script>

<%- include('../partials/footer') %>
