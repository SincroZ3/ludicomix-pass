<%- include('partials/header') %>
<nav class="breadcrumb-bar">
  Sei in: <a href="/home">Home</a> <span class="sep">›</span>
  <a href="/admin/settings#utenti">Gestione Utenti</a> <span class="sep">›</span>
  <strong>Modifica utente</strong>
</nav>
<h1 class="page-title">👤 Modifica utente — <em><%= editUser.username %></em></h1>

<%
  var msgs = {
    '1':             { type:'success', text:'✅ Dati aggiornati con successo.' },
    'pwd':           { type:'success', text:'✅ Password reimpostata con successo.' },
    'invalid':       { type:'danger',  text:'❌ Dati non validi. Verifica tutti i campi.' },
    'username-taken':{ type:'danger',  text:'❌ Username già in uso da un altro utente.' },
    'self-demote':   { type:'danger',  text:'❌ Non puoi toglierti il ruolo Amministratore.' },
    'pwd-short':     { type:'danger',  text:'❌ La password deve essere di almeno 8 caratteri.' },
    'pwd-mismatch':  { type:'danger',  text:'❌ Le password non coincidono.' },
    'db':            { type:'danger',  text:'❌ Errore database. Riprova.' },
  };
  var msg = msgs[saved] || msgs[error];
%>
<% if(msg){ %>
  <div class="alert alert-<%= msg.type %>" style="margin-bottom:1rem;"><%= msg.text %></div>
<% } %>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;align-items:start;max-width:860px;">

  <!-- ── MODIFICA DATI ── -->
  <div class="card">
    <div class="card-title">✏️ Dati utente</div>
    <form method="POST" action="/admin/users/<%= editUser.id %>">

      <label>Username <span class="req">*</span>
        <input type="text" name="username" value="<%= editUser.username %>" required
               maxlength="60" autocomplete="off" style="margin-top:.2rem;"
               <%= editUser.id === currentUser.id ? '' : '' %>>
      </label>

      <label style="margin-top:1rem;">Ruolo <span class="req">*</span>
        <select name="role" style="margin-top:.2rem;">
          <%
            var roleDefs = [
              { val:'admin',     label:'🔑 Amministratore',  desc:'Accesso totale, impostazioni sistema e utenti' },
              { val:'organizer', label:'📋 Organizzatore',   desc:'Gestione operativa: stand, pass, partecipanti, bacheca' },
              { val:'operator',  label:'🎫 Operatore',       desc:'Crea/modifica pass e partecipanti, può scansionare' },
              { val:'scanner',   label:'📷 Scanner',         desc:'Solo pagina scan — steward/ingresso' },
              { val:'viewer',    label:'👁 Visualizzatore',  desc:'Sola lettura su tutto' },
            ];
          %>
          <% roleDefs.forEach(function(r){ %>
            <option value="<%= r.val %>" <%= editUser.role === r.val ? 'selected' : '' %>>
              <%= r.label %>
            </option>
          <% }); %>
        </select>
      </label>

      <!-- Role description live -->
      <div id="role-desc" style="margin-top:.5rem;padding:.5rem .7rem;border-radius:var(--radius-sm);
           background:var(--bg-section);font-size:.78rem;color:var(--text-secondary);border-left:3px solid var(--border);">
      </div>

      <% if(editUser.id === currentUser.id){ %>
        <div style="margin-top:.75rem;padding:.5rem .7rem;background:#fef9c3;border-radius:var(--radius-sm);
             font-size:.78rem;color:#854d0e;border-left:3px solid #c9a227;">
          ⚠️ Stai modificando il tuo account. Non puoi cambiarti il ruolo.
        </div>
      <% } %>

      <div style="margin-top:1.25rem;display:flex;gap:.65rem;align-items:center;">
        <button type="submit" class="primary">💾 Salva modifiche</button>
        <a href="/admin/settings#utenti" class="secondary">Annulla</a>
      </div>
    </form>
  </div>

  <!-- ── RESET PASSWORD ── -->
  <div>
    <div class="card">
      <div class="card-title">🔑 Reimposta password</div>
      <p style="font-size:.82rem;color:var(--text-secondary);margin:0 0 1rem;">
        Usa questa funzione se l&rsquo;utente ha perso l&rsquo;accesso.<br>
        La nuova password sarà attiva immediatamente.
      </p>
      <form method="POST" action="/admin/users/<%= editUser.id %>/reset-password" onsubmit="return confirmReset()">

        <label>Nuova password <span class="req">*</span>
          <input type="password" name="new_password" id="np" required minlength="8"
                 autocomplete="new-password" placeholder="Min. 8 caratteri" style="margin-top:.2rem;">
        </label>

        <label style="margin-top:.85rem;">Conferma password <span class="req">*</span>
          <input type="password" name="confirm_password" id="cp" required
                 autocomplete="new-password" placeholder="Ripeti la password" style="margin-top:.2rem;">
          <span id="pwd-match" style="font-size:.72rem;margin-top:.2rem;display:block;"></span>
        </label>

        <!-- Strength bar -->
        <div style="margin-top:.6rem;">
          <div style="height:4px;border-radius:9999px;background:var(--border-light);overflow:hidden;">
            <div id="pwd-bar" style="height:4px;width:0%;transition:width .3s,background .3s;border-radius:9999px;"></div>
          </div>
          <span id="pwd-strength" style="font-size:.7rem;color:var(--text-muted);"></span>
        </div>

        <button type="submit" class="primary" style="margin-top:1rem;background:#c0392b;color:#fff;">
          🔑 Reimposta password
        </button>
      </form>
    </div>

    <!-- Metadati utente -->
    <div class="card" style="padding:.85rem 1.1rem;">
      <div class="card-title">ℹ️ Info account</div>
      <table style="font-size:.8rem;width:100%;">
        <tr><td style="color:var(--text-muted);padding:.25rem 0;">ID utente</td>
            <td style="font-weight:700;">#<%= editUser.id %></td></tr>
        <tr><td style="color:var(--text-muted);padding:.25rem 0;">Creato il</td>
            <td><%= (editUser.created_at||'—').substring(0,16).replace('T',' ') %></td></tr>
        <tr><td style="color:var(--text-muted);padding:.25rem 0;">Ruolo attuale</td>
            <td><strong id="current-role-label"><%= editUser.role %></strong></td></tr>
      </table>
    </div>
  </div>
</div>

<!-- Tabella riepilogativa ruoli -->
<div class="card" style="max-width:860px;margin-top:.5rem;">
  <div class="card-title">📊 Permessi per ruolo</div>
  <div style="overflow-x:auto;">
    <table style="font-size:.78rem;width:100%;">
      <thead>
        <tr>
          <th style="text-align:left;padding:.45rem .75rem;">Funzione</th>
          <th style="text-align:center;">🔑 Admin</th>
          <th style="text-align:center;">📋 Organizzatore</th>
          <th style="text-align:center;">🎫 Operatore</th>
          <th style="text-align:center;">📷 Scanner</th>
          <th style="text-align:center;">👁 Viewer</th>
        </tr>
      </thead>
      <tbody>
        <%
          var perms = [
            ['Visualizza tutto',                   1,1,1,0,1],
            ['Crea/modifica partecipanti e pass',  1,1,1,0,0],
            ['Scansiona e marca consegnato',        1,1,1,1,0],
            ['Gestisce stand e raggruppamenti',     1,1,0,0,0],
            ['Zone, tipologie pass PDF',            1,1,0,0,0],
            ['Import CSV partecipanti',             1,1,0,0,0],
            ['Pubblica bacheca comunicazioni',      1,1,0,0,0],
            ['Impostazioni sistema (backup, SMTP)', 1,0,0,0,0],
            ['Gestione utenti',                     1,0,0,0,0],
          ];
          var tick = '✅'; var cross = '—';
        %>
        <% perms.forEach(function(p){ %>
        <tr>
          <td style="padding:.4rem .75rem;color:var(--text-secondary);"><%= p[0] %></td>
          <% [1,2,3,4,5].forEach(function(i){ %>
          <td style="text-align:center;padding:.4rem .5rem;">
            <% if(p[i]){ %><span style="color:#2d6a4f;font-size:.95rem;">✅</span>
            <% } else { %><span style="color:var(--border);font-size:.75rem;">—</span><% } %>
          </td>
          <% }); %>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<script>
var roleDefs = {
  admin:     '🔑 Accesso totale — impostazioni sistema, gestione utenti e tutto il resto.',
  organizer: '📋 Gestione operativa completa: stand, pass, partecipanti, import, bacheca. NON può gestire utenti o impostazioni di sistema.',
  operator:  '🎫 Crea e gestisce partecipanti e pass, può scansionare. NON può modificare la struttura stand/tipologie.',
  scanner:   '📷 Accede SOLO alla pagina Scanner. Al login viene portato direttamente alla scansione. Ideale per steward e personale ingresso.',
  viewer:    '👁 Sola lettura — vede tutto ma non può fare modifiche né scansionare.'
};

var sel = document.querySelector('[name=role]');
function updateDesc() {
  var d = document.getElementById('role-desc');
  d.textContent = roleDefs[sel.value] || '';
  var colors = {admin:'#1d6fa4',organizer:'#2d6a4f',operator:'#6b3fa0',scanner:'#c9a227',viewer:'#6b7280'};
  d.style.borderColor = colors[sel.value] || 'var(--border)';
}
sel.addEventListener('change', updateDesc);
updateDesc();

// Password strength
var np = document.getElementById('np');
var cp = document.getElementById('cp');
np.addEventListener('input', function(){
  var v = np.value, s = 0;
  if(v.length>=8) s++; if(v.length>=12) s++;
  if(/[A-Z]/.test(v)) s++; if(/[0-9]/.test(v)) s++; if(/[^A-Za-z0-9]/.test(v)) s++;
  var bar = document.getElementById('pwd-bar');
  var lbl = document.getElementById('pwd-strength');
  var lvl = [['0%','#e5e7eb',''],['20%','#c0392b','Debole'],['45%','#c9a227','Discreta'],
             ['65%','#1d6fa4','Buona'],['85%','#2d6a4f','Forte'],['100%','#15803d','Ottima']][Math.min(s,5)];
  bar.style.width=lvl[0]; bar.style.background=lvl[1]; lbl.textContent=lvl[2]; lbl.style.color=lvl[1];
  checkMatch();
});
cp.addEventListener('input', checkMatch);
function checkMatch(){
  var m = document.getElementById('pwd-match');
  if(!cp.value){m.textContent='';return;}
  if(np.value===cp.value){m.textContent='✅ Password corrispondente';m.style.color='#2d6a4f';}
  else{m.textContent='❌ Le password non corrispondono';m.style.color='#c0392b';}
}

function confirmReset(){
  return confirm('Sei sicuro di voler reimpostare la password di questo utente?\nL\'operazione è immediata.');
}
</script>

<%- include('partials/footer') %>
