<%- include('partials/header') %>
<nav class="breadcrumb-bar">
  Sei in: <a href="/home">Home</a> <span class="sep">›</span>
  <a href="/admin/settings#utenti">Gestione Utenti</a> <span class="sep">›</span>
  <strong>Modifica utente</strong>
</nav>
<h1 class="page-title">👤 Modifica utente — <em><%= editUser.username %></em></h1>

<%
  var msgs = {
    '1':             { type:'success', text:'✅ Dati aggiornati con successo.' },
    'pwd':           { type:'success', text:'✅ Password reimpostata con successo.' },
    'invalid':       { type:'danger',  text:'❌ Dati non validi. Verifica tutti i campi.' },
    'username-taken':{ type:'danger',  text:'❌ Username già in uso da un altro utente.' },
    'self-demote':   { type:'danger',  text:'❌ Non puoi toglierti il ruolo Amministratore.' },
    'pwd-short':     { type:'danger',  text:'❌ La password deve essere di almeno 8 caratteri.' },
    'pwd-mismatch':  { type:'danger',  text:'❌ Le password non coincidono.' },
    'db':            { type:'danger',  text:'❌ Errore database. Riprova.' },
  };
  var msg = msgs[saved] || msgs[error];
%>
<% if(msg){ %>
  <div class="alert alert-<%= msg.type %>" style="margin-bottom:1rem;"><%= msg.text %></div>
<% } %>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;align-items:start;max-width:860px;">

  <!-- ── MODIFICA DATI ── -->
  <div class="card">
    <div class="card-title">✏️ Dati utente</div>
    <form method="POST" action="/admin/users/<%= editUser.id %>" id="edit-user-form">

      <label>Username <span class="req">*</span>
        <input type="text" name="username" value="<%= editUser.username %>" required
               maxlength="60" autocomplete="off" style="margin-top:.2rem;">
      </label>

      <label style="margin-top:1rem;">Ruolo <span class="req">*</span>
        <select name="role" id="role-sel" style="margin-top:.2rem;">
          <%
            var roleDefs = [
              { val:'admin',     label:'🔑 Amministratore',  desc:'Accesso totale, impostazioni sistema e utenti' },
              { val:'organizer', label:'📋 Organizzatore',   desc:'Gestione operativa: stand, pass, partecipanti, bacheca' },
              { val:'operator',  label:'🎫 Operatore',       desc:'Crea/modifica pass e partecipanti, può scansionare' },
              { val:'scanner',   label:'📷 Scanner',         desc:'Solo pagina scan — steward/ingresso' },
              { val:'viewer',    label:'👁 Visualizzatore',  desc:'Sola lettura su tutto' },
              { val:'custom',    label:'⚙️ Custom',          desc:'Permessi personalizzati — spunta le funzioni abilitate sotto' },
            ];
          %>
          <% roleDefs.forEach(function(r){ %>
            <option value="<%= r.val %>" <%= editUser.role === r.val ? 'selected' : '' %>>
              <%= r.label %>
            </option>
          <% }); %>
        </select>
      </label>

      <!-- Role description live -->
      <div id="role-desc" style="margin-top:.5rem;padding:.5rem .7rem;border-radius:var(--radius-sm);
           background:var(--bg-section);font-size:.78rem;color:var(--text-secondary);border-left:3px solid var(--border);">
      </div>

      <% if(editUser.id === currentUser.id){ %>
        <div style="margin-top:.75rem;padding:.5rem .7rem;background:#fef9c3;border-radius:var(--radius-sm);
             font-size:.78rem;color:#854d0e;border-left:3px solid #c9a227;">
          ⚠️ Stai modificando il tuo account. Non puoi cambiarti il ruolo.
        </div>
      <% } %>

      <!-- ── PERMESSI CUSTOM (visibile solo se ruolo = custom) ── -->
      <div id="custom-perms-block" style="display:<%= editUser.role === 'custom' ? 'block' : 'none' %>;margin-top:1.1rem;">
        <div style="font-size:.82rem;font-weight:700;color:var(--text-primary);margin-bottom:.6rem;
                    padding-bottom:.4rem;border-bottom:1px solid var(--border);">
          ⚙️ Permessi personalizzati
        </div>

        <%
          // Definizione aree e sotto-permessi
          var permAreas = [
            { id:'participants', label:'📦 Partecipanti & Pass', subs:[
              { id:'participants.view',         label:'Visualizza lista e dettagli' },
              { id:'participants.edit',         label:'Crea e modifica partecipanti/pass' },
              { id:'participants.delete',       label:'Elimina partecipanti e pass' },
              { id:'participants.import',       label:'Importa da CSV' },
              { id:'participants.export',       label:'Esporta/scarica dati' },
            ]},
            { id:'agenda', label:'📅 Agenda & Eventi', subs:[
              { id:'agenda.view',               label:'Visualizza eventi' },
              { id:'agenda.edit',               label:'Crea e modifica eventi' },
              { id:'agenda.delete',             label:'Elimina eventi' },
              { id:'agenda.registrations',      label:'Gestisci iscrizioni agli eventi' },
              { id:'agenda.export',             label:'Esporta iscritti in Excel' },
            ]},
            { id:'scan', label:'📷 Scanner & Contatore', subs:[
              { id:'scan.scan',                 label:'Scansiona QR code (scanner ingresso)' },
              { id:'scan.contatore',            label:'Accedi al contatore visitatori' },
              { id:'scan.manual_deliver',       label:'Segna consegna manuale pass' },
            ]},
            { id:'org', label:'🗂️ Logistica & Struttura', subs:[
              { id:'org.view',                  label:'Visualizza stand, zone, raggruppamenti' },
              { id:'org.manage',                label:'Crea/modifica/elimina stand e zone' },
              { id:'org.mappa',                 label:'Accedi alla mappa stand' },
            ]},
            { id:'volunteers', label:'🙋 Volontari', subs:[
              { id:'volunteers.view',           label:'Visualizza lista volontari' },
              { id:'volunteers.edit',           label:'Crea e modifica volontari' },
              { id:'volunteers.delete',         label:'Elimina volontari' },
            ]},
            { id:'reports', label:'📊 Reports & Statistiche', subs:[
              { id:'reports.view',              label:'Visualizza reports e statistiche' },
            ]},
            { id:'bacheca', label:'📌 Bacheca', subs:[
              { id:'bacheca.view',              label:'Visualizza comunicazioni bacheca' },
              { id:'bacheca.edit',              label:'Pubblica e modifica comunicazioni' },
              { id:'bacheca.delete',            label:'Elimina comunicazioni' },
            ]},
            { id:'accreditamento', label:'🏅 Accreditamento', subs:[
              { id:'accreditamento.view',       label:'Visualizza accreditamenti' },
              { id:'accreditamento.manage',     label:'Gestisci e valida accreditamenti' },
            ]},
          ];
        %>

        <% permAreas.forEach(function(area){ %>
        <div class="perm-area" style="margin-bottom:.55rem;border:1px solid var(--border);border-radius:var(--radius-sm);overflow:hidden;">
          <!-- Intestazione area (click per espandere) -->
          <div class="perm-area-head" onclick="toggleArea(this)"
               style="display:flex;align-items:center;justify-content:space-between;
                      padding:.5rem .75rem;background:var(--bg-section);cursor:pointer;
                      user-select:none;font-size:.82rem;font-weight:600;">
            <span>
              <!-- Checkbox area: seleziona/deseleziona tutti -->
              <input type="checkbox" class="area-check"
                     data-area="<%= area.id %>"
                     onclick="event.stopPropagation();toggleAreaAll(this)"
                     style="margin-right:.4rem;cursor:pointer;"
                     <%= area.subs.every(function(s){ return (userPerms||[]).includes(s.id); }) ? 'checked' : '' %>>
              <%= area.label %>
            </span>
            <span class="perm-arrow" style="font-size:.7rem;color:var(--text-muted);transition:transform .2s;">▼</span>
          </div>
          <!-- Sotto-permessi -->
          <div class="perm-subs" style="padding:.5rem .75rem .6rem;display:grid;gap:.3rem;border-top:1px solid var(--border);">
            <% area.subs.forEach(function(sub){ %>
            <label style="display:flex;align-items:center;gap:.45rem;font-size:.8rem;cursor:pointer;margin:0;">
              <input type="checkbox" name="permissions" value="<%= sub.id %>"
                     data-area="<%= area.id %>"
                     class="sub-check"
                     onchange="syncAreaCheck('<%= area.id %>')"
                     <%= (userPerms||[]).includes(sub.id) ? 'checked' : '' %>>
              <%= sub.label %>
            </label>
            <% }); %>
          </div>
        </div>
        <% }); %>

        <div style="font-size:.72rem;color:var(--text-muted);margin-top:.4rem;">
          ℹ️ Le aree non spuntate saranno inaccessibili per questo utente.
        </div>
      </div>
      <!-- fine custom-perms-block -->

      <% if(editUser.id === currentUser.id){ %>
        <!-- niente -->
      <% } %>

      <div style="margin-top:1.25rem;display:flex;gap:.65rem;align-items:center;">
        <button type="submit" class="primary">💾 Salva modifiche</button>
        <a href="/admin/settings#utenti" class="secondary">Annulla</a>
      </div>
    </form>
  </div>

  <!-- ── RESET PASSWORD ── -->
  <div>
    <div class="card">
      <div class="card-title">🔑 Reimposta password</div>
      <p style="font-size:.82rem;color:var(--text-secondary);margin:0 0 1rem;">
        Usa questa funzione se l&rsquo;utente ha perso l&rsquo;accesso.<br>
        La nuova password sarà attiva immediatamente.
      </p>
      <form method="POST" action="/admin/users/<%= editUser.id %>/reset-password" onsubmit="return confirmReset()">
        <label>Nuova password <span class="req">*</span>
          <input type="password" name="new_password" id="np" required minlength="8"
                 autocomplete="new-password" placeholder="Min. 8 caratteri" style="margin-top:.2rem;">
        </label>
        <label style="margin-top:.85rem;">Conferma password <span class="req">*</span>
          <input type="password" name="confirm_password" id="cp" required
                 autocomplete="new-password" placeholder="Ripeti la password" style="margin-top:.2rem;">
          <span id="pwd-match" style="font-size:.72rem;margin-top:.2rem;display:block;"></span>
        </label>
        <div style="margin-top:.6rem;">
          <div style="height:4px;border-radius:9999px;background:var(--border-light);overflow:hidden;">
            <div id="pwd-bar" style="height:4px;width:0%;transition:width .3s,background .3s;border-radius:9999px;"></div>
          </div>
          <span id="pwd-strength" style="font-size:.7rem;color:var(--text-muted);"></span>
        </div>
        <button type="submit" class="primary" style="margin-top:1rem;background:#c0392b;color:#fff;">
          🔑 Reimposta password
        </button>
      </form>
    </div>

    <!-- Metadati utente -->
    <div class="card" style="padding:.85rem 1.1rem;">
      <div class="card-title">ℹ️ Info account</div>
      <table style="font-size:.8rem;width:100%;">
        <tr><td style="color:var(--text-muted);padding:.25rem 0;">ID utente</td>
            <td style="font-weight:700;">#<%= editUser.id %></td></tr>
        <tr><td style="color:var(--text-muted);padding:.25rem 0;">Creato il</td>
            <td><%= (editUser.created_at||'—').substring(0,16).replace('T',' ') %></td></tr>
        <tr><td style="color:var(--text-muted);padding:.25rem 0;">Ruolo attuale</td>
            <td><strong id="current-role-label"><%= editUser.role %></strong></td></tr>
        <% if(editUser.role === 'custom'){ %>
        <tr><td style="color:var(--text-muted);padding:.25rem 0;">Permessi attivi</td>
            <td><strong style="color:#4f46e5;"><%= (userPerms||[]).length %> permess<%= (userPerms||[]).length===1?'o':'i' %></strong></td></tr>
        <% } %>
      </table>
    </div>
  </div>
</div>

<script>
// ── Descrizioni ruolo ──────────────────────────────────────────────────
var roleDefs = {
  admin:     '🔑 Accesso totale — impostazioni sistema, gestione utenti e tutto il resto.',
  organizer: '📋 Gestione operativa completa: stand, pass, partecipanti, import, bacheca. NON può gestire utenti o impostazioni di sistema.',
  operator:  '🎫 Crea e gestisce partecipanti e pass, può scansionare. NON può modificare la struttura stand/tipologie.',
  scanner:   '📷 Accede SOLO alla pagina Scanner. Al login viene portato direttamente alla scansione.',
  viewer:    '👁 Sola lettura — vede tutto ma non può fare modifiche né scansionare.',
  custom:    '⚙️ Permessi personalizzati — usa le checkbox qui sotto per definire esattamente cosa può fare questo utente.',
};

var sel = document.getElementById('role-sel');
var customBlock = document.getElementById('custom-perms-block');

function updateDesc() {
  var d = document.getElementById('role-desc');
  d.textContent = roleDefs[sel.value] || '';
  var colors = {admin:'#1d6fa4',organizer:'#2d6a4f',operator:'#6b3fa0',scanner:'#c9a227',viewer:'#6b7280',custom:'#4f46e5'};
  d.style.borderColor = colors[sel.value] || 'var(--border)';
  // Mostra/nascondi blocco permessi custom
  customBlock.style.display = sel.value === 'custom' ? 'block' : 'none';
}
sel.addEventListener('change', updateDesc);
updateDesc();

// ── Accordion aree ────────────────────────────────────────────────────
function toggleArea(head) {
  var subs = head.nextElementSibling;
  var arrow = head.querySelector('.perm-arrow');
  var open = subs.style.display !== 'none';
  subs.style.display = open ? 'none' : 'grid';
  arrow.style.transform = open ? 'rotate(-90deg)' : 'rotate(0deg)';
}

// ── Seleziona/deseleziona tutti i sub di un'area ──────────────────────
function toggleAreaAll(areaChk) {
  var area = areaChk.dataset.area;
  var subs = document.querySelectorAll('input.sub-check[data-area="' + area + '"]');
  subs.forEach(function(s){ s.checked = areaChk.checked; });
}

// ── Sincronizza checkbox area quando cambiano i sub ───────────────────
function syncAreaCheck(areaId) {
  var subs  = document.querySelectorAll('input.sub-check[data-area="' + areaId + '"]');
  var all   = Array.from(subs).every(function(s){ return s.checked; });
  var none  = Array.from(subs).every(function(s){ return !s.checked; });
  var aChk  = document.querySelector('input.area-check[data-area="' + areaId + '"]');
  if (!aChk) return;
  aChk.checked       = all;
  aChk.indeterminate = !all && !none;
}

// Avvia accordion: tutte chiuse tranne quelle con sub spuntati
document.querySelectorAll('.perm-area').forEach(function(area) {
  var hasChecked = area.querySelectorAll('input.sub-check:checked').length > 0;
  var subs  = area.querySelector('.perm-subs');
  var arrow = area.querySelector('.perm-arrow');
  if (!hasChecked) {
    subs.style.display = 'none';
    arrow.style.transform = 'rotate(-90deg)';
  }
  // Sincronizza stato indeterminate all'avvio
  var areaId = area.querySelector('.area-check').dataset.area;
  syncAreaCheck(areaId);
});

// ── Password strength ─────────────────────────────────────────────────
var np = document.getElementById('np');
var cp = document.getElementById('cp');
np.addEventListener('input', function(){
  var v = np.value, s = 0;
  if(v.length>=8) s++; if(v.length>=12) s++;
  if(/[A-Z]/.test(v)) s++; if(/[0-9]/.test(v)) s++; if(/[^A-Za-z0-9]/.test(v)) s++;
  var bar = document.getElementById('pwd-bar');
  var lbl = document.getElementById('pwd-strength');
  var lvl = [['0%','#e5e7eb',''],['20%','#c0392b','Debole'],['45%','#c9a227','Discreta'],
             ['65%','#1d6fa4','Buona'],['85%','#2d6a4f','Forte'],['100%','#15803d','Ottima']][Math.min(s,5)];
  bar.style.width=lvl[0]; bar.style.background=lvl[1]; lbl.textContent=lvl[2]; lbl.style.color=lvl[1];
  checkMatch();
});
cp.addEventListener('input', checkMatch);
function checkMatch(){
  var m = document.getElementById('pwd-match');
  if(!cp.value){m.textContent='';return;}
  if(np.value===cp.value){m.textContent='✅ Password corrispondente';m.style.color='#2d6a4f';}
  else{m.textContent='❌ Le password non corrispondono';m.style.color='#c0392b';}
}
function confirmReset(){
  return confirm('Reimpostare la password per questo utente?');
}
</script>

<%- include('partials/footer') %>
