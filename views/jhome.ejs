<%- include('partials/header') %>
<nav class="breadcrumb-bar">Sei in: <strong>Home</strong></nav>
<h1 class="page-title">Dashboard <span id="dash-live-badge" style="font-size:.65rem;font-weight:600;letter-spacing:.5px;color:#2d6a4f;border:1px solid #2d6a4f;border-radius:9999px;padding:.15rem .55rem;vertical-align:middle;opacity:0;transition:opacity .4s">● LIVE</span></h1>
<style>
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(185px,1fr));gap:.9rem;margin-bottom:1.5rem}
.kpi-card{background:var(--bg-white);border:1px solid var(--border);border-radius:var(--radius-md);padding:1rem 1.2rem;box-shadow:var(--shadow-sm);border-top:3px solid var(--kc,var(--accent-blue))}
.kpi-label{font-size:.72rem;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);font-weight:700}
.kpi-value{font-size:2rem;font-weight:800;color:var(--kc,var(--accent-blue));line-height:1.1;margin:.2rem 0;transition:transform .25s,opacity .25s}
.kpi-sub{font-size:.75rem;color:var(--text-muted)}
.status-pills{display:flex;flex-wrap:wrap;gap:.4rem;margin-bottom:1.5rem}
.spill{display:inline-flex;align-items:center;gap:.35rem;padding:.3rem .75rem;border-radius:9999px;font-size:.78rem;font-weight:700;background:var(--bg-section);border:1px solid var(--border);color:var(--text-primary)}
.spill span{border-radius:9999px;padding:.05rem .5rem;font-size:.72rem;color:#fff;transition:transform .25s}
.dash-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem}
@media(max-width:680px){.dash-row{grid-template-columns:1fr}}
.dash-box{background:var(--bg-white);border:1px solid var(--border);border-radius:var(--radius-md);padding:1rem 1.2rem;box-shadow:var(--shadow-sm)}
.dash-box h3{font-size:.75rem;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);font-weight:700;margin:0 0 .75rem}
.pbar-wrap{background:var(--border-light);border-radius:9999px;height:7px;margin-top:.25rem}
.pbar{height:7px;border-radius:9999px;transition:width .5s ease}
.act-item{display:flex;gap:.5rem;align-items:flex-start;padding:.4rem 0;border-bottom:1px solid var(--border-light);font-size:.8rem}
.act-item:last-child{border:none}
.icon-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:.7rem;margin-top:.75rem}
.icon-item{display:flex;flex-direction:column;align-items:center;gap:.4rem;padding:.9rem .5rem;background:var(--bg-white);border:1px solid var(--border);border-radius:var(--radius-md);text-decoration:none;color:var(--text-primary);font-size:.78rem;font-weight:700;text-align:center;transition:box-shadow .15s,border-color .15s;box-shadow:var(--shadow-sm)}
.icon-item:hover{box-shadow:var(--shadow-md);border-color:var(--accent-blue);color:var(--accent-blue)}
.icon-emoji{font-size:1.7rem}
@keyframes kpi-bump{0%{transform:scale(1)}40%{transform:scale(1.12)}100%{transform:scale(1)}}
.kpi-bump{animation:kpi-bump .35s ease}
</style>
<% var ps=(stats&&stats.passesByStatus)?stats.passesByStatus:{}; %>
<% var totCons=(ps['CONSEGNATO']||0)+(ps['RICONSEGNATO']||0); %>
<% var STATI=['GENERATO','SCARICATO','STAMPATO','CONSEGNATO','RICONSEGNATO']; %>
<% var pillC={GENERATO:'#6b3fa0',SCARICATO:'#1d6fa4',STAMPATO:'#c9a227',CONSEGNATO:'#2d6a4f',RICONSEGNATO:'#c0392b'}; %>

<div class="kpi-grid">
  <div class="kpi-card" style="--kc:#1d6fa4">
    <div class="kpi-label">&#128101; Partecipanti</div>
    <div class="kpi-value" id="kpi-participants"><%= stats.totalParticipants %></div>
    <div class="kpi-sub">registrati</div>
  </div>
  <div class="kpi-card" style="--kc:#6b3fa0">
    <div class="kpi-label">&#127931; Pass generati</div>
    <div class="kpi-value" id="kpi-passes"><%= stats.totalPasses %></div>
    <div class="kpi-sub">totali</div>
  </div>
  <div class="kpi-card" style="--kc:#2d6a4f">
    <div class="kpi-label">&#10003; Consegnati</div>
    <div class="kpi-value" id="kpi-consegnati"><%= totCons %></div>
    <div class="kpi-sub">consegnati + riconsegnati</div>
  </div>
  <div class="kpi-card" id="kpi-senza-card" style="--kc:<%= stats.senzaPass>0?'#c0392b':'#2d6a4f' %>">
    <div class="kpi-label">&#9888; Senza pass</div>
    <div class="kpi-value" id="kpi-senza"><%= stats.senzaPass %></div>
    <div class="kpi-sub">partecipanti senza pass</div>
  </div>
  <div class="kpi-card" style="--kc:#2d6a4f">
    <div class="kpi-label">🚶 Visitatori oggi</div>
    <div class="kpi-value" id="kpi-visitatori">–</div>
    <div class="kpi-sub" id="kpi-visitatori-sub">QR + contatore manuale</div>
  </div>
</div>

<div class="status-pills">
  <% STATI.forEach(function(s){ %>
    <div class="spill"><%= s %> <span id="pill-<%= s %>" style="background:<%= pillC[s]||'#888' %>"><%= ps[s]||0 %></span></div>
  <% }); %>
</div>

<div class="dash-box">
  <h3>&#9889; Accesso rapido</h3>
  <div class="icon-grid">
    <a href="/participants"     class="icon-item"><span class="icon-emoji">&#128101;</span>Assegnatari Pass</a>
    <a href="/passes"           class="icon-item"><span class="icon-emoji">&#127931;</span>Pass Generati</a>
    <a href="/reports"          class="icon-item"><span class="icon-emoji">&#128202;</span>Reports</a>
    <a href="/volunteers"       class="icon-item"><span class="icon-emoji">🙋</span>Volontari</a>
    <a href="/admin/logistica"    class="icon-item"><span class="icon-emoji">📦</span>Logistica</a>
    <a href="/search"           class="icon-item"><span class="icon-emoji">&#128269;</span>Ricerca Pass</a>
    <a href="/account/password" class="icon-item"><span class="icon-emoji">&#128273;</span>Cambia Password</a>
    <a href="/account/security" class="icon-item"><span class="icon-emoji">&#128274;</span>Password Sicurezza</a>
    <% if(currentUser&&(currentUser.role==='admin'||currentUser.role==='organizer')){ %>
      <a href="/admin/mappa-pubblica" class="icon-item"><span class="icon-emoji">🗺️</span>Gestione Mappa</a>
    <% } %>
    <% if(currentUser&&currentUser.role==='admin'){ %>
        <a href="/admin/logs"     class="icon-item"><span class="icon-emoji">&#128203;</span>Log Azioni</a>
      <a href="/admin/settings" class="icon-item"><span class="icon-emoji">&#9881;&#65039;</span>Impostazioni</a>
      <a href="/admin/settings/portal-window" class="icon-item"><span class="icon-emoji">🗓</span>Finestra Portali</a>
    <% } %>
  </div>
</div>


<div class="dash-row" style="grid-template-columns:<% if(currentUser&&currentUser.role==='admin'){ %>1fr 1fr<% }else{ %>1fr<% } %>;">
  <div class="dash-box">
    <h3>&#128276; Attenzione stand</h3>
    <div id="alert-groups-container">
    <% if(!alertGroups||alertGroups.length===0){ %>
      <p style="color:var(--text-muted);font-size:.82rem;margin:0;">Tutto ok &mdash; nessun problema rilevato &#127881;</p>
    <% }else{alertGroups.forEach(function(g){ %>
      <%
        var noPass = g.participant_count>0 && g.pass_count===0;
        var freeSlots = (g.max_passes && g.max_passes>0 && g.pass_count<g.max_passes) ? (g.max_passes - g.pass_count) : 0;
      %>
      <div style="display:flex;align-items:center;justify-content:space-between;gap:.5rem;padding:.4rem 0;border-bottom:1px solid var(--border-light);">
        <div style="min-width:0;">
          <div style="font-size:.8rem;font-weight:700;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;max-width:155px;" title="<%= g.name %>"><%= g.name %></div>
          <% if(g.zone){ %><div style="font-size:.68rem;color:var(--text-muted);margin-top:.05rem;">&#128205; <%= g.zone %></div><% } %>
        </div>
        <div style="display:flex;flex-direction:column;gap:.25rem;align-items:flex-end;flex-shrink:0;">
          <% if(noPass){ %>
          <span style="display:inline-flex;align-items:center;gap:.25rem;padding:.18rem .55rem;border-radius:9999px;background:#c0392b;color:#fff;font-size:.65rem;font-weight:700;white-space:nowrap;">
            &#9888; senza pass (<%= g.participant_count %>)
          </span>
          <% } %>
          <% if(freeSlots>0){ %>
          <span style="display:inline-flex;align-items:center;gap:.25rem;padding:.18rem .55rem;border-radius:9999px;background:#1d6fa4;color:#fff;font-size:.65rem;font-weight:700;white-space:nowrap;">
            &#128204; <%= freeSlots %> posti liberi
          </span>
          <% } %>
        </div>
      </div>
    <% });} %>
    </div>
  <% if(currentUser&&currentUser.role==='admin'){ %>
  <div class="dash-box">
    <h3>&#128336; Attivit&agrave; recente</h3>
    <div id="activity-container">
    <% if(!recentActivity||recentActivity.length===0){ %>
      <p style="color:var(--text-muted);font-size:.82rem;margin:0;">Nessuna attivit&agrave; registrata.</p>
    <% }else{recentActivity.forEach(function(a){ %>
      <div class="act-item">
        <div style="flex:1;">
          <strong style="color:var(--brand-violet)">@<%= a.username||'?' %></strong>
          <span style="color:var(--text-secondary)"> &mdash; <%= (a.details||a.action||'').substring(0,55) %></span>
        </div>
        <span style="font-size:.7rem;color:var(--text-muted);white-space:nowrap;"><%= (a.created_at||'').substring(0,16).replace('T',' ') %></span>
      </div>
    <% });} %>
    </div>
  </div>
  <% } %>
</div>


<!-- ── NUOVE SEZIONI DASHBOARD LIVE ────────────────────────────────── -->

<!-- Banner chiusura (appare solo quando siamo vicini a un orario critico) -->
<div id="alert-closing-banner" style="display:none;margin-bottom:1rem;background:rgba(201,162,39,.12);border:1px solid #c9a227;border-radius:var(--radius-md);padding:.7rem 1rem;display:none;align-items:flex-start;gap:.5rem;font-size:.85rem;">
  <span style="font-size:1.1rem;flex-shrink:0">⏰</span>
  <div id="alert-closing-text"></div>
</div>

<!-- Presenze live per area -->
<div class="dash-box" style="margin-bottom:1rem;">
  <h3>🎡 Presenze live per area</h3>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:.7rem;margin-top:.25rem">
    <% [['mariambini','🎡','Mariambini'],['palazzetto','🏟️','Palazzetto'],['la_perla','🎬','La Perla'],['ludostria','🎲','Ludostria']].forEach(function(a){ %>
    <div style="background:var(--bg-section);border:1px solid var(--border);border-radius:var(--radius-md);padding:.75rem 1rem;">
      <div style="font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);margin-bottom:.3rem"><%= a[1] %> <%= a[2] %></div>
      <div id="pres-<%= a[0] %>" style="font-size:2rem;font-weight:800;color:#1d6fa4;line-height:1;font-variant-numeric:tabular-nums">–</div>
      <div style="display:flex;gap:.6rem;margin-top:.2rem;font-size:.7rem;font-variant-numeric:tabular-nums">
        <span style="color:#2d6a4f">↑ <span id="pres-in-<%= a[0] %>">–</span></span>
        <span style="color:#c9a227">↓ <span id="pres-out-<%= a[0] %>">–</span></span>
      </div>
    </div>
    <% }); %>
  </div>
</div>

<!-- Heatmap + Alert intelligenti -->
<div class="dash-row">
  <!-- Heatmap scan QR oggi -->
  <div class="dash-box">
    <h3>📊 Ingressi per ora — oggi</h3>
    <div style="display:flex;align-items:center;gap:.8rem;margin-bottom:.4rem;font-size:.65rem;color:var(--text-muted)">
      <span><span style="display:inline-block;width:8px;height:8px;background:#1d6fa4;border-radius:2px;margin-right:2px"></span>Scan QR</span>
      <span><span style="display:inline-block;width:8px;height:8px;background:#2d6a4f;border-radius:2px;margin-right:2px"></span>Contatore</span>
      <span style="margin-left:auto">Totale oggi: <strong id="heatmap-totale">–</strong></span>
    </div>
    <div id="heatmap-bars" style="display:flex;align-items:flex-end;gap:2px;height:90px;margin-top:.25rem">
      <span style="color:var(--text-muted);font-size:.8rem">Nessun dato ancora oggi</span>
    </div>
    <div style="font-size:.62rem;color:var(--text-muted);margin-top:.25rem;text-align:center">Ore (08–22)</div>
  </div>
  <!-- Alert intelligenti -->
  <div class="dash-box">
    <h3>⚠️ Alert intelligenti</h3>
    <div id="scan-anomali-wrap" style="display:none;margin-bottom:.75rem">
      <div style="font-size:.68rem;font-weight:700;color:#c0392b;text-transform:uppercase;letter-spacing:.5px;margin-bottom:.4rem">Scan anomali (&gt;3 volte in 2h)</div>
      <div id="scan-anomali-list"></div>
    </div>
    <div id="pass-nc-wrap" style="display:none">
      <div style="font-size:.68rem;font-weight:700;color:#c9a227;text-transform:uppercase;letter-spacing:.5px;margin-bottom:.4rem">Pass non ritirati</div>
      <div id="pass-nc-list"></div>
    </div>
    <div id="alert-empty" style="color:var(--text-muted);font-size:.82rem">✅ Nessun alert attivo</div>
  </div>
</div>



<script>
(function(){
  var PILL_COLORS={GENERATO:'#6b3fa0',SCARICATO:'#1d6fa4',STAMPATO:'#c9a227',CONSEGNATO:'#2d6a4f',RICONSEGNATO:'#c0392b'};
  var STATI=['GENERATO','SCARICATO','STAMPATO','CONSEGNATO','RICONSEGNATO'];

  function bump(el){
    el.classList.remove('kpi-bump');
    void el.offsetWidth;
    el.classList.add('kpi-bump');
  }

  function setVal(id, val){
    var el = document.getElementById(id);
    if(!el) return;
    var cur = el.textContent.trim();
    var old = cur === '–' ? null : parseInt(cur, 10);
    if(old !== val){
      el.textContent = val;
      bump(el);
    }
  }

  function renderAlertGroups(groups){
    var c = document.getElementById('alert-groups-container');
    if(!c) return;
    if(!groups || groups.length===0){
      c.innerHTML='<p style="color:var(--text-muted);font-size:.82rem;margin:0;">Tutto ok &mdash; nessun problema rilevato &#127881;</p>';
      return;
    }
    c.innerHTML = groups.map(function(g){
      var noPass    = g.participant_count>0 && g.pass_count===0;
      var freeSlots = (g.max_passes && g.max_passes>0 && g.pass_count<g.max_passes) ? (g.max_passes - g.pass_count) : 0;
      var badges = '';
      if(noPass)
        badges += '<span style="display:inline-flex;align-items:center;gap:.25rem;padding:.18rem .55rem;border-radius:9999px;background:#c0392b;color:#fff;font-size:.65rem;font-weight:700;white-space:nowrap;">&#9888; senza pass ('+g.participant_count+')</span>';
      if(freeSlots>0)
        badges += '<span style="display:inline-flex;align-items:center;gap:.25rem;padding:.18rem .55rem;border-radius:9999px;background:#1d6fa4;color:#fff;font-size:.65rem;font-weight:700;white-space:nowrap;">&#128204; '+freeSlots+' posti liberi</span>';
      var zone = g.zone ? '<div style="font-size:.68rem;color:var(--text-muted);margin-top:.05rem;">&#128205; '+g.zone+'</div>' : '';
      return '<div style="display:flex;align-items:center;justify-content:space-between;gap:.5rem;padding:.4rem 0;border-bottom:1px solid var(--border-light);">'
        +'<div style="min-width:0;"><div style="font-size:.8rem;font-weight:700;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;max-width:155px;" title="'+g.name+'">'+g.name+'</div>'+zone+'</div>'
        +'<div style="display:flex;flex-direction:column;gap:.25rem;align-items:flex-end;flex-shrink:0;">'+badges+'</div>'
        +'</div>';
    }).join('');
  }

  function renderActivity(items){
    var c = document.getElementById('activity-container');
    if(!c) return;
    if(!items || items.length===0){
      c.innerHTML='<p style="color:var(--text-muted);font-size:.82rem;margin:0;">Nessuna attività registrata.</p>';
      return;
    }
    c.innerHTML = items.map(function(a){
      var ts=(a.created_at||'').substring(0,16).replace('T',' ');
      var det=(a.details||a.action||'').substring(0,55);
      return '<div class="act-item"><div style="flex:1;"><strong style="color:var(--brand-violet)">@'+(a.username||'?')+'</strong><span style="color:var(--text-secondary)"> — '+det+'</span></div><span style="font-size:.7rem;color:var(--text-muted);white-space:nowrap;">'+ts+'</span></div>';
    }).join('');
  }

  // ── NUOVE FUNZIONI ────────────────────────────────────────────────────────

  function renderPresenze(presenze){
    ['mariambini','palazzetto','la_perla','ludostria'].forEach(function(area){
      var d = (presenze && presenze[area]) || {ins:0, outs:0, presenti:0};
      var el  = document.getElementById('pres-'    + area);
      var inE = document.getElementById('pres-in-' + area);
      var ouE = document.getElementById('pres-out-'+ area);
      if(el)  { var old=parseInt(el.textContent)||0; if(old!==d.presenti){el.textContent=d.presenti; bump(el);} }
      if(inE)  inE.textContent  = d.ins;
      if(ouE)  ouE.textContent  = d.outs;
    });
  }

  function renderHeatmap(data){
    var wrap = document.getElementById('heatmap-bars');
    if(!wrap) return;
    if(!data || !data.length){
      wrap.innerHTML='<span style="color:var(--text-muted);font-size:.8rem">Nessun dato ancora oggi</span>';
      var tot=document.getElementById('heatmap-totale'); if(tot) tot.textContent='0';
      return;
    }
    var byHour={};
    var totale=0;
    data.forEach(function(d){
      byHour[d.ora]={count:parseInt(d.count)||0, qr:parseInt(d.qr)||0, manual:parseInt(d.manual)||0};
      totale+=parseInt(d.count)||0;
    });
    var tot=document.getElementById('heatmap-totale'); if(tot) tot.textContent=totale;
    var max=Math.max.apply(null,Object.values(byHour).map(function(v){return v.count;}));
    if(max<1) max=1;
    var hours=[];
    for(var h=8;h<=22;h++) hours.push(String(h).padStart(2,'0'));
    wrap.innerHTML = hours.map(function(h){
      var d=byHour[h]||{count:0,qr:0,manual:0};
      var pct=Math.max(Math.round(d.count/max*100),d.count>0?3:0);
      var pctQr=d.count>0?Math.round(d.qr/d.count*100):0;
      var pctMan=100-pctQr;
      var tooltip=h+':00 — '+d.count+' ingressi ('+d.qr+' QR + '+d.manual+' manuali)';
      // Barra stacked: QR (blu) + manuale (verde)
      return '<div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:1px;height:100%;justify-content:flex-end;" title="'+tooltip+'">'
        +(pct>0
          ? '<div style="width:100%;height:'+pct+'%;display:flex;flex-direction:column;justify-content:flex-end;border-radius:3px 3px 0 0;overflow:hidden;min-height:3px;">'
            +'<div style="width:100%;height:'+pctMan+'%;background:#2d6a4f;min-height:'+(d.manual>0?'2':'0')+'px;"></div>'
            +'<div style="width:100%;height:'+pctQr+'%;background:#1d6fa4;min-height:'+(d.qr>0?'2':'0')+'px;"></div>'
            +'</div>'
          : '<div style="width:100%;height:2px;background:var(--border-light);border-radius:2px;"></div>')
        +'<div style="font-size:.58rem;color:var(--text-muted)">'+h+'</div>'
        +'</div>';
    }).join('');
  }

  function renderAlerts(d){
    // Banner chiusura
    var banner = document.getElementById('alert-closing-banner');
    var bannerText = document.getElementById('alert-closing-text');
    if(banner && d.nextClosing){
      var nc=d.nextClosing;
      var h=Math.floor(nc.diffMin/60), m=nc.diffMin%60;
      var tl = h>0 ? h+'h '+m+'m' : m+' min';
      bannerText.innerHTML = '<strong>Chiusura '+nc.label+' alle '+nc.closing+'</strong> — mancano <strong>'+tl+'</strong>';
      banner.style.display='flex';
    } else if(banner){
      banner.style.display='none';
    }

    var hasAlert=false;

    // Scan anomali
    var anomWrap=document.getElementById('scan-anomali-wrap');
    var anomList=document.getElementById('scan-anomali-list');
    if(d.scanAnomali && d.scanAnomali.length){
      hasAlert=true;
      anomWrap.style.display='block';
      anomList.innerHTML=d.scanAnomali.map(function(s){
        return '<div style="display:flex;justify-content:space-between;align-items:center;padding:.3rem .5rem;margin-bottom:.25rem;background:rgba(192,57,43,.08);border:1px solid rgba(192,57,43,.3);border-radius:var(--radius-sm);font-size:.78rem;">'
          +'<span><strong>'+(s.participant_name||s.code)+'</strong>'+(s.group_name?' <span style="opacity:.6">– '+s.group_name+'</span>':'')+'</span>'
          +'<span style="background:#c0392b;color:#fff;border-radius:9999px;padding:.05rem .45rem;font-size:.68rem;font-weight:700;">'+s.hits+'×</span>'
          +'</div>';
      }).join('');
    } else if(anomWrap){ anomWrap.style.display='none'; }

    // Pass non consegnati vicino chiusura
    var ncWrap=document.getElementById('pass-nc-wrap');
    var ncList=document.getElementById('pass-nc-list');
    if(d.alertPassNonRitirati && d.passNonConsegnati && d.passNonConsegnati.length){
      hasAlert=true;
      ncWrap.style.display='block';
      ncList.innerHTML=d.passNonConsegnati.map(function(g){
        return '<div style="display:flex;justify-content:space-between;align-items:center;padding:.3rem .5rem;margin-bottom:.25rem;background:rgba(201,162,39,.08);border:1px solid rgba(201,162,39,.3);border-radius:var(--radius-sm);font-size:.78rem;">'
          +'<span>'+g.group_name+(g.zone?' <span style="opacity:.6">📍'+g.zone+'</span>':'')+'</span>'
          +'<span style="background:#c9a227;color:#fff;border-radius:9999px;padding:.05rem .45rem;font-size:.68rem;font-weight:700;">'+g.non_consegnati+'</span>'
          +'</div>';
      }).join('');
    } else if(ncWrap){ ncWrap.style.display='none'; }

    var emptyEl=document.getElementById('alert-empty');
    if(emptyEl) emptyEl.style.display=hasAlert?'none':'block';
  }

  // ── REFRESH ───────────────────────────────────────────────────────────────

  function refresh(){
    fetch('/api/dashboard-stats')
      .then(function(r){ return r.ok ? r.json() : null; })
      .then(function(d){
        if(!d) return;
        var ps = d.stats.passesByStatus || {};
        var totCons = (ps['CONSEGNATO']||0)+(ps['RICONSEGNATO']||0);
        setVal('kpi-participants', d.stats.totalParticipants);
        setVal('kpi-passes',       d.stats.totalPasses);
        setVal('kpi-consegnati',   totCons);
        setVal('kpi-senza',        d.stats.senzaPass);
        var sc = document.getElementById('kpi-senza-card');
        if(sc) sc.style.setProperty('--kc', d.stats.senzaPass>0?'#c0392b':'#2d6a4f');
        STATI.forEach(function(s){
          var el=document.getElementById('pill-'+s);
          if(el){ var v=ps[s]||0; if(parseInt(el.textContent)!==v){ el.textContent=v; bump(el); } }
        });
        renderAlertGroups(d.alertGroups);
        renderActivity(d.recentActivity);
        // ── nuove sezioni ──
        renderPresenze(d.presenze || {});
        renderHeatmap(d.heatmapOre || []);
        renderAlerts(d);
        // KPI visitatori oggi
        setVal('kpi-visitatori', d.stats.ingressiOggi || 0);
        document.getElementById('dash-live-badge').style.opacity='1';
      })
      .catch(function(){});
  }

  refresh();
  setInterval(refresh, 15000);
})();
</script>
