<%-include('partials/header') %>
<nav class="breadcrumb-bar">Sei in: <a href="/home">Home</a> <span class="sep">›</span> <strong>Cambia Password</strong></nav>
<h1 class="page-title">Cambia Password di Accesso</h1>

<div class="card" style="max-width:480px;">
  <div class="card-title">Modifica password di accesso</div>
  <p style="font-size:0.82rem;color:var(--text-muted);margin:0 0 0.75rem;">I campi contrassegnati dal simbolo <span style="color:#c0392b">*</span> sono obbligatori.</p>
  <form method="post" style="display:grid;gap:0.75rem;">
    <label>Vecchia Password <span style="color:#c0392b">*</span><br><input type="password" name="old_password" required></label>
    <label>Nuova Password <span style="color:#c0392b">*</span><br><input type="password" name="new_password" required></label>
    <label>Conferma nuova password <span style="color:#c0392b">*</span><br><input type="password" name="confirm_password" required></label>
    <% if (error) { %><div class="alert alert-danger"><span>⚠️</span> <%= error %></div><% } %>
    <% if (success) { %><div class="alert alert-success"><span>✅</span> <%= success %></div><% } %>
    <div><button type="submit" class="primary">Aggiorna Password</button></div>
  </form>
</div>
<%-include('partials/footer') %>
