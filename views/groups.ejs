<%-include('partials/header') %>
<nav class="breadcrumb-bar">Sei in: <a href="/home">Home</a> <span class="sep">›</span> <strong>Raggruppamenti Pass</strong></nav>
<h1 class="page-title">Lista Raggruppamenti Pass</h1>

<div class="card">
  <div class="card-title">Aggiungi nuovo Raggruppamento Pass</div>
  <form method="post" style="display:grid;grid-template-columns:1fr 1fr 1fr auto;gap:0.75rem 1rem;align-items:end;">
    <label>Denominazione <span style="color:#c0392b">*</span><br><input type="text" name="name" required></label>
    <label>Ordine di priorità<br><input type="number" name="priority" value="0"></label>
    <label>Tipologia Pass PDF<br>
      <select name="pass_type_id">
        <option value="">— Nessuna —</option>
        <% types.forEach(t => { %><option value="<%= t.id %>"><%= t.name %></option><% }) %>
      </select>
    </label>
    <div><button type="submit" class="primary">+ Salva</button></div>
  </form>
</div>

<% if (groups.length === 0) { %>
  <p style="color:var(--text-muted);">Nessun raggruppamento inserito.</p>
<% } else { %>
<div class="table-wrapper">
  <table>
    <thead>
      <tr>
        <th>Denominazione</th>
        <th>Priorità</th>
        <th>Tipologia Pass PDF</th>
        <th>Modifica</th>
        <th>Cancella</th>
      </tr>
    </thead>
    <tbody>
      <% groups.forEach(g => { %>
        <tr>
          <td><strong><%= g.name %></strong></td>
          <td><%= g.priority %></td>
          <td><%= g.pass_type_name || '—' %></td>
          <td>
            <button type="button" class="primary" style="font-size:0.78rem;padding:0.3rem 0.7rem;"
              onclick="apriModificaGruppo(<%= g.id %>, '<%- g.name.replace(/'/g,"\\'") %>', <%= g.priority %>, '<%= g.pass_type_id || '' %>')">
              ✏️ Modifica
            </button>
          </td>
          <td>
            <form method="post" action="/groups/<%= g.id %>/delete" onsubmit="return confirm('Cancellare il raggruppamento «<%= g.name %>»?');">
              <button type="submit" class="btn-danger">✕ Cancella</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>

<!-- MODALE MODIFICA RAGGRUPPAMENTO -->
<div class="modal-overlay" id="modal-edit-group" style="display:none">
  <div class="modal" style="max-width:480px;">
    <div class="modal-header">
      <h2>✏️ Modifica Raggruppamento Pass</h2>
      <button type="button" class="modal-close" onclick="document.getElementById('modal-edit-group').style.display='none'">×</button>
    </div>
    <form id="form-edit-group" method="post" class="modal-body" style="display:grid;gap:0.75rem;">
      <label>Denominazione <span style="color:#c0392b">*</span><br>
        <input type="text" name="name" id="edit-group-name" required>
      </label>
      <label>Ordine di priorità<br>
        <input type="number" name="priority" id="edit-group-priority">
      </label>
      <label>Tipologia Pass PDF<br>
        <select name="pass_type_id" id="edit-group-passtype">
          <option value="">— Nessuna —</option>
          <% types.forEach(t => { %>
            <option value="<%= t.id %>"><%= t.name %></option>
          <% }) %>
        </select>
      </label>
      <div class="modal-actions">
        <button type="button" class="secondary" onclick="document.getElementById('modal-edit-group').style.display='none'">Annulla</button>
        <button type="submit" class="primary">Salva modifiche</button>
      </div>
    </form>
  </div>
</div>

<script>
function apriModificaGruppo(id, name, priority, passTypeId) {
  document.getElementById('edit-group-name').value = name;
  document.getElementById('edit-group-priority').value = priority;
  var sel = document.getElementById('edit-group-passtype');
  for (var i = 0; i < sel.options.length; i++) {
    sel.options[i].selected = (sel.options[i].value === String(passTypeId));
  }
  document.getElementById('form-edit-group').action = '/groups/' + id + '/edit';
  document.getElementById('modal-edit-group').style.display = 'flex';
}
</script>
<%-include('partials/footer') %>
