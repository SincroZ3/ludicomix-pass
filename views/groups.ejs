<%-include('partials/header') %>
<nav class="breadcrumb-bar">Sei in: <a href="/home">Home</a> <span class="sep">›</span> <strong>Raggruppamenti Pass</strong></nav>
<h1 class="page-title">Lista Raggruppamenti Pass</h1>

<div class="card">
  <div class="card-title">Aggiungi nuovo Raggruppamento Pass</div>
  <form method="post" style="display:grid;grid-template-columns:1fr 1fr 1fr auto;gap:0.75rem 1rem;align-items:end;">
    <label>Denominazione <span class="req">*</span><br><input type="text" name="name" required></label>
    <label>Ordine di priorità<br><input type="number" name="priority" value="0"></label>
    <label>Tipologia Pass PDF (opzionale)<br>
      <select name="pass_type_id">
        <option value="">— Nessuna —</option>
        <% types.forEach(t => { %><option value="<%= t.id %>"><%= t.name %></option><% }) %>
      </select>
    </label>
    <div><button type="submit" class="primary">+ Salva</button></div>
  </form>
</div>

<% if (groups.length === 0) { %>
  <p style="color:var(--text-muted);">Nessun raggruppamento inserito.</p>
<% } else { %>
<div class="table-wrapper">
  <table>
    <thead>
      <tr>
        <th>Denominazione Raggruppamento Pass</th>
        <th>Ordine di priorità</th>
        <th>Tipologia Pass PDF</th>
        <th>Cancella</th>
      </tr>
    </thead>
    <tbody>
      <% groups.forEach(g => { %>
        <tr>
          <td><strong><%= g.name %></strong></td>
          <td><%= g.priority %></td>
          <td><%= g.pass_type_name || '—' %></td>
          <td>
            <form method="post" action="/groups/<%= g.id %>/delete" onsubmit="return confirm('Cancellare il raggruppamento «<%= g.name %>»?');">
              <button type="submit" class="btn-danger">✕ Cancella</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>
<%-include('partials/footer') %>
