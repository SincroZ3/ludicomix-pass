<%- include('partials/header') %>
<nav class="breadcrumb-bar">Sei in: <a href="/home">Home</a> &rsaquo; <strong>&#128506; Mappa Stand</strong></nav>
<h1 class="page-title">&#128506; Mappa Stand per Zone</h1>
<style>
.zone-tabs{display:flex;flex-wrap:wrap;gap:.4rem;margin-bottom:1rem}
.ztab{padding:.4rem 1rem;border-radius:9999px;border:1px solid var(--border);background:var(--bg-white);font-size:.82rem;font-weight:700;cursor:pointer;color:var(--text-primary);transition:background .15s,border-color .15s}
.ztab.active{background:var(--brand-dark,#1e2d4e);color:#fff;border-color:var(--brand-dark,#1e2d4e)}
.ztab:hover:not(.active){border-color:var(--accent-blue);color:var(--accent-blue)}
.zone-panel{display:none}.zone-panel.active{display:block}
.map-wrap{display:flex;gap:1rem;align-items:flex-start}
.map-area-wrap{flex:1;min-width:0}
.map-area{position:relative;width:100%;min-height:520px;background:#e8ecf3;border-radius:var(--radius-lg);border:2px dashed #ccd2df;background-size:contain;background-repeat:no-repeat;background-position:center top;overflow:hidden;transition:border-color .15s}
.map-area.drag-over{border-color:var(--accent-blue);background-color:rgba(29,111,164,.04)}
.map-area.has-bg{background-color:#f0f2f5}
.stand-box{position:absolute;transform:translate(-50%,-50%);border-radius:6px;padding:.3rem .5rem;font-size:.68rem;font-weight:700;color:#fff;cursor:grab;max-width:110px;box-shadow:0 2px 8px rgba(0,0,0,.28);z-index:10;text-align:center;line-height:1.25;transition:box-shadow .12s;user-select:none;overflow:hidden}
.stand-box:hover{box-shadow:0 4px 14px rgba(0,0,0,.38)}.stand-box.dragging{opacity:.35}
.stand-box .sn{font-size:.67rem;font-weight:800;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;max-width:100px}
.stand-box .sp{font-size:.57rem;opacity:.85;margin-top:.1rem}
.map-sidebar{width:210px;flex-shrink:0}
.sidebar-title{font-size:.73rem;font-weight:800;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);margin-bottom:.6rem;display:flex;justify-content:space-between;align-items:center}
.sidebar-box{background:var(--bg-white);border:1px solid var(--border);border-radius:var(--radius-sm);padding:.45rem .6rem;margin-bottom:.4rem;font-size:.78rem;cursor:grab;transition:box-shadow .12s,border-color .12s}
.sidebar-box:hover{box-shadow:var(--shadow-sm);border-color:var(--accent-blue)}.sidebar-box.dragging{opacity:.35}
.sbn{font-weight:700;font-size:.78rem;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}
.sbm{font-size:.68rem;color:var(--text-muted);margin-top:.1rem}
.map-empty-msg{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--text-muted);font-size:.85rem;text-align:center;padding:2rem;gap:.5rem;pointer-events:none}
.map-toolbar{display:flex;flex-wrap:wrap;gap:.4rem;align-items:center;margin-bottom:.6rem}
.leg{display:inline-flex;padding:.2rem .65rem;border-radius:9999px;font-size:.75rem;font-weight:700;color:#fff}
.save-badge{position:fixed;bottom:1.2rem;right:1.2rem;background:#2d6a4f;color:#fff;padding:.4rem .9rem;border-radius:9999px;font-size:.78rem;font-weight:700;display:none;box-shadow:0 3px 12px rgba(0,0,0,.25);z-index:9999}
@media(max-width:680px){.map-wrap{flex-direction:column}.map-sidebar{width:100%}}
</style>

<%
function sc(s){if(!s.pass_count)return'#9ca3af';var p=s.consegnati/s.pass_count;if(p>=.8)return'#2d6a4f';if(p>0)return'#c9a227';return'#c0392b';}
var zoneNames=zones.map(function(z){return z.name;});
var noZoneGroups=groups.filter(function(g){return !g.zone||zoneNames.indexOf(g.zone)===-1;});
%>

<% if(zones.length===0){ %>
  <div class="card"><p style="color:var(--text-muted);">Nessuna zona/padiglione configurata.<% if(isAdmin){ %> <a href="/admin/settings">Aggiungila dalle impostazioni</a>.<% } %></p></div>
<% }else{ %>
<div class="zone-tabs">
  <% zones.forEach(function(z,zi){ var zg=groups.filter(function(g){return g.zone===z.name;}); %>
  <button class="ztab <%=zi===0?'active':''%>" data-zone="<%=z.id%>" onclick="switchZone(<%=z.id%>)">
    <%=z.name%> <span style="font-size:.68rem;opacity:.65;margin-left:.25rem;">(<%=zg.length%>)</span>
  </button>
  <% }); %>
  <% if(noZoneGroups.length>0){ %>
  <button class="ztab" data-zone="0" onclick="switchZone(0)">&#10067; Senza zona <span style="font-size:.68rem;opacity:.65;margin-left:.25rem;">(<%=noZoneGroups.length%>)</span></button>
  <% } %>
</div>

<% zones.forEach(function(z,zi){
  var zGroups=groups.filter(function(g){return g.zone===z.name;});
  var positioned=zGroups.filter(function(g){return g.map_x!=null&&g.map_y!=null;});
  var unpositioned=zGroups.filter(function(g){return g.map_x==null||g.map_y==null;});
%>
<div id="zone-panel-<%=z.id%>" class="zone-panel <%=zi===0?'active':''%>">
  <% if(isAdmin){ %>
  <div class="map-toolbar">
    <form method="POST" action="/admin/zones/<%=z.id%>/upload-bg" enctype="multipart/form-data" style="display:inline">
      <label style="cursor:pointer;padding:.35rem .8rem;border-radius:var(--radius-sm);border:1px solid var(--border);background:var(--bg-white);font-size:.78rem;font-weight:600;display:inline-flex;align-items:center;gap:.35rem;">
        &#128449; <%=z.background_image?'Cambia planimetria':'Carica planimetria'%>
        <input type="file" name="bg_image" accept="image/*" onchange="this.form.submit()" style="display:none">
      </label>
    </form>
    <% if(z.background_image){ %>
    <form method="POST" action="/admin/zones/<%=z.id%>/delete-bg" style="display:inline" onsubmit="return confirm('Rimuovere la planimetria?')">
      <button type="submit" class="btn-danger" style="font-size:.75rem;padding:.35rem .7rem;">&#128465; Rimuovi sfondo</button>
    </form>
    <% } %>
    <span style="font-size:.74rem;color:var(--text-muted);margin-left:auto;">Trascina gli stand sulla mappa &bull; Doppio click per rimuovere</span>
  </div>
  <% } %>

  <div class="map-wrap">
    <div class="map-area-wrap">
      <div id="map-area-<%=z.id%>"
           class="map-area<%=z.background_image?' has-bg':''%>"
           style="<%if(z.background_image){%>background-image:url('/zone-bg/<%=z.background_image%>');<%}%>"
           <% if(isAdmin){ %>ondragover="onDragOver(event,<%=z.id%>)" ondragleave="onDragLeave(event,<%=z.id%>)" ondrop="onDrop(event,<%=z.id%>)"<% } %>>
        <% positioned.forEach(function(g){ %>
        <div class="stand-box" id="sbox-<%=g.id%>" data-gid="<%=g.id%>"
             style="left:<%=g.map_x.toFixed(2)%>%;top:<%=g.map_y.toFixed(2)%>%;background:<%=sc(g)%>"
             <% if(isAdmin){ %>draggable="true" ondragstart="onDragStart(event,<%=g.id%>)" ondblclick="removeFromMap(<%=g.id%>,<%=z.id%>)" title="Doppio click per rimuovere dalla mappa"<% } %>>
          <div class="sn"><%=g.stand_name%></div>
          <div class="sp"><%=g.consegnati%>/<%=g.pass_count%></div>
        </div>
        <% }); %>
        <% if(positioned.length===0){ %>
        <div class="map-empty-msg" id="hint-<%=z.id%>">
          <div style="font-size:2rem;opacity:.4;"><%=z.background_image?'&#128466;':'&#128449;'%></div>
          <div style="opacity:.5;font-size:.8rem;"><%if(isAdmin){%><%=z.background_image?'Trascina gli stand sulla planimetria':'Carica una planimetria e trascina gli stand'%><%}else{%>Mappa non ancora configurata<%}%></div>
        </div>
        <% } %>
      </div>
    </div>
    <div class="map-sidebar">
      <div class="sidebar-title">
        <span>&#128204; Non posizionati</span>
        <span id="unp-count-<%=z.id%>" style="background:var(--border);border-radius:9999px;padding:.1rem .45rem;font-size:.68rem;"><%=unpositioned.length%></span>
      </div>
      <div id="sidebar-<%=z.id%>">
        <% if(unpositioned.length===0){ %>
        <div style="font-size:.78rem;color:var(--text-muted);text-align:center;padding:.75rem 0;">&#10003; Tutti posizionati!</div>
        <% }else{ unpositioned.forEach(function(g){ %>
        <div class="sidebar-box" id="sbox-<%=g.id%>" data-gid="<%=g.id%>" style="border-left:3px solid <%=sc(g)%>"
             <% if(isAdmin){ %>draggable="true" ondragstart="onDragStart(event,<%=g.id%>)"<% } %>>
          <div class="sbn"><%=g.stand_name%></div>
          <div class="sbm"><%=g.consegnati%>/<%=g.pass_count%> consegnati</div>
        </div>
        <% });} %>
      </div>
    </div>
  </div>
</div>
<% }); %>

<% if(noZoneGroups.length>0){ %>
<div id="zone-panel-0" class="zone-panel">
  <div class="map-wrap">
    <div class="map-area-wrap">
      <div class="map-area" style="min-height:180px;display:flex;align-items:center;justify-content:center;">
        <div style="color:var(--text-muted);font-size:.85rem;text-align:center;padding:1.5rem;">
          &#10067; Questi espositori non hanno una zona assegnata.<br>
          Assegnali a una zona dalle <a href="/participants">impostazioni assegnatari</a>.
        </div>
      </div>
    </div>
    <div class="map-sidebar">
      <div class="sidebar-title">Stand senza zona</div>
      <% noZoneGroups.forEach(function(g){ %>
      <div class="sidebar-box" style="border-left:3px solid <%=sc(g)%>">
        <div class="sbn"><%=g.stand_name%></div>
        <div class="sbm"><%=g.zone||'&mdash;'%> &middot; <%=g.pass_count%> pass</div>
      </div>
      <% });%>
    </div>
  </div>
</div>
<% } %>
<% } %>

<div style="display:flex;flex-wrap:wrap;gap:.45rem;align-items:center;margin-top:1rem;font-size:.76rem;">
  <strong>Legenda:</strong>
  <span class="leg" style="background:#2d6a4f;">&ge;80% consegnati</span>
  <span class="leg" style="background:#c9a227;color:#28251d;">parziale</span>
  <span class="leg" style="background:#c0392b;">0 consegnati</span>
  <span class="leg" style="background:#9ca3af;">nessun pass</span>
</div>
<div id="save-badge" class="save-badge">&#10003; Salvato</div>

<script>
function switchZone(zid){
  document.querySelectorAll('.zone-panel').forEach(function(p){p.classList.remove('active');});
  document.querySelectorAll('.ztab').forEach(function(t){t.classList.remove('active');});
  var panel=document.getElementById('zone-panel-'+zid);if(panel)panel.classList.add('active');
  var tab=document.querySelector('.ztab[data-zone="'+zid+'"]');if(tab)tab.classList.add('active');
}
</script>
<% if(isAdmin){ %>
<script>
var GDATA=<%- JSON.stringify(groups) %>;
var activeDragId=null;
function onDragStart(e,gid){
  activeDragId=gid;e.dataTransfer.setData('text/plain',String(gid));e.dataTransfer.effectAllowed='move';
  setTimeout(function(){var el=document.getElementById('sbox-'+gid);if(el)el.classList.add('dragging');},0);
}
function onDragOver(e,zid){e.preventDefault();e.dataTransfer.dropEffect='move';document.getElementById('map-area-'+zid).classList.add('drag-over');}
function onDragLeave(e,zid){var ma=document.getElementById('map-area-'+zid);if(!ma.contains(e.relatedTarget))ma.classList.remove('drag-over');}
function onDrop(e,zid){
  e.preventDefault();document.getElementById('map-area-'+zid).classList.remove('drag-over');
  var gid=activeDragId||parseInt(e.dataTransfer.getData('text/plain'),10);if(!gid)return;
  var ma=document.getElementById('map-area-'+zid),rect=ma.getBoundingClientRect();
  var x=Math.max(2,Math.min(98,((e.clientX-rect.left)/rect.width)*100));
  var y=Math.max(2,Math.min(96,((e.clientY-rect.top)/rect.height)*100));
  saveXY(gid,x,y,zid);
}
function saveXY(gid,x,y,zid){
  fetch('/admin/groups/'+gid+'/map-xy',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'map_x='+x.toFixed(2)+'&map_y='+y.toFixed(2)})
  .then(function(r){return r.json();}).then(function(d){
    if(!d.ok)return;
    var old=document.getElementById('sbox-'+gid);if(old)old.remove();
    var g=GDATA.find(function(x){return x.id==gid;});if(!g)return;
    var box=document.createElement('div');
    box.className='stand-box';box.id='sbox-'+gid;box.setAttribute('data-gid',gid);box.draggable=true;
    box.style.cssText='left:'+x.toFixed(2)+'%;top:'+y.toFixed(2)+'%;background:'+gColor(g);
    box.title='Doppio click per rimuovere dalla mappa';
    box.innerHTML='<div class="sn">'+(g.stand_name||'')+'</div><div class="sp">'+(g.consegnati||0)+'/'+(g.pass_count||0)+'</div>';
    box.addEventListener('dragstart',function(e){onDragStart(e,gid);});
    box.addEventListener('dblclick',function(){removeFromMap(gid,zid);});
    document.getElementById('map-area-'+zid).appendChild(box);
    var hint=document.getElementById('hint-'+zid);if(hint)hint.style.display='none';
    var ctr=document.getElementById('unp-count-'+zid);if(ctr)ctr.textContent=Math.max(0,parseInt(ctr.textContent)-1);
    showSaved();
  });
}
function removeFromMap(gid,zid){
  if(!confirm('Rimuovere dalla mappa?'))return;
  fetch('/admin/groups/'+gid+'/map-xy',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'map_x=&map_y='})
  .then(function(r){return r.json();}).then(function(d){
    if(!d.ok)return;
    var box=document.getElementById('sbox-'+gid);if(box)box.remove();
    var g=GDATA.find(function(x){return x.id==gid;});if(!g)return;
    var sb=document.getElementById('sidebar-'+zid);if(!sb)return;
    var empty=sb.querySelector('[style*="Tutti posizionati"]');if(empty)empty.remove();
    var sbox=document.createElement('div');
    sbox.className='sidebar-box';sbox.id='sbox-'+gid;sbox.setAttribute('data-gid',gid);sbox.draggable=true;
    sbox.style.borderLeft='3px solid '+gColor(g);
    sbox.innerHTML='<div class="sbn">'+(g.stand_name||'')+'</div><div class="sbm">'+(g.consegnati||0)+'/'+(g.pass_count||0)+' consegnati</div>';
    sbox.addEventListener('dragstart',function(e){onDragStart(e,gid);});
    sb.appendChild(sbox);
    var ctr=document.getElementById('unp-count-'+zid);if(ctr)ctr.textContent=parseInt(ctr.textContent)+1;
    showSaved();
  });
}
function gColor(g){if(!g.pass_count)return'#9ca3af';var p=g.consegnati/g.pass_count;return p>=.8?'#2d6a4f':p>0?'#c9a227':'#c0392b';}
function showSaved(){var b=document.getElementById('save-badge');b.style.display='block';clearTimeout(b._t);b._t=setTimeout(function(){b.style.display='none';},2000);}
document.addEventListener('dragend',function(){document.querySelectorAll('.stand-box,.sidebar-box').forEach(function(el){el.classList.remove('dragging');});activeDragId=null;});
</script>
<% } %>
<%- include('partials/footer') %>
