<%- include('partials/header') %>
<nav class="breadcrumb-bar">
  Sei in: <a href="/home">Home</a>
  <span class="sep">&rsaquo;</span> <strong>🎫 Accreditamento Espositori</strong>
</nav>
<h1 class="page-title">🎫 Accreditamento Espositori</h1>

<% if (saved) { %>
<div class="alert alert-success" style="margin-bottom:1.25rem;padding:.75rem 1rem;border-radius:8px;
  background:<%= saved==='approvato' ? '#d1fae5' : '#fee2e2' %>;
  color:<%= saved==='approvato' ? '#065f46' : '#991b1b' %>;
  border:1px solid <%= saved==='approvato' ? '#6ee7b7' : '#fecaca' %>;">
  <% if(saved==='approvato') { %>✅ Richiesta approvata, portale attivato e email inviata!
  <% } else if(saved==='rifiutato') { %>❌ Richiesta rifiutata.
  <% } %>
</div>
<% } %>

<div style="margin-bottom:1.25rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem;">
  <div class="pill-tabs" style="margin:0">
    <button type="button" class="pill-tab active" id="btn-in_attesa"   onclick="showTab('in_attesa',this)">⏳ In attesa <span class="badge-count"><%= requests.filter(function(r){return r.status==='in_attesa';}).length %></span></button>
    <button type="button" class="pill-tab"        id="btn-portale_att" onclick="showTab('portale_attivato',this)">🚀 Portale attivato <span class="badge-count"><%= requests.filter(function(r){return r.status==='portale_attivato';}).length %></span></button>
    <button type="button" class="pill-tab"        id="btn-rifiutato"   onclick="showTab('rifiutato',this)">❌ Rifiutate <span class="badge-count"><%= requests.filter(function(r){return r.status==='rifiutato';}).length %></span></button>
  </div>
  <div style="display:flex;align-items:center;gap:.6rem;">
    <span style="font-size:.78rem;color:#64748b;">Link form pubblico:</span>
    <code id="pub-link" style="font-size:.78rem;background:#f1f5f9;padding:.25rem .55rem;border-radius:5px;border:1px solid #e2e8f0;">/richiesta-accreditamento</code>
    <button onclick="copyLink()" style="font-size:.75rem;padding:.25rem .65rem;border-radius:5px;border:1px solid #d1d9e6;background:#fff;cursor:pointer;" title="Copia link completo">📋</button>
    <a href="/richiesta-accreditamento" target="_blank" style="font-size:.75rem;padding:.25rem .65rem;border-radius:5px;border:1px solid #1e2d4e;color:#1e2d4e;text-decoration:none;">🔗 Apri</a>
  </div>
</div>

<style>
.badge-count{display:inline-block;background:rgba(255,255,255,.3);color:inherit;border-radius:9999px;padding:.05rem .45rem;font-size:.72rem;font-weight:700;margin-left:.3rem;}
.pill-tab .badge-count{background:rgba(0,0,0,.07);}
.pill-tab.active .badge-count{background:rgba(255,255,255,.3);}
.req-card{background:#fff;border-radius:10px;border:1px solid #e2e8f0;padding:1.25rem 1.5rem;margin-bottom:1rem;box-shadow:0 1px 4px rgba(0,0,0,.05);}
.req-header{display:flex;flex-wrap:wrap;gap:.4rem .75rem;align-items:baseline;margin-bottom:.6rem;}
.req-header strong{font-size:1.05rem;color:#1e2d4e;}
.req-header .muted{font-size:.82rem;color:#94a3b8;}
.req-notes{font-size:.88rem;color:#475569;margin:.5rem 0;border-left:3px solid #e2e8f0;padding-left:.75rem;}
.approve-form,.reject-form{display:flex;flex-wrap:wrap;gap:.5rem;align-items:center;margin-top:.75rem;padding-top:.75rem;border-top:1px dashed #e2e8f0;}
.approve-form select,.approve-form input,.reject-form input{border:1.5px solid #d1d5db;border-radius:7px;padding:.4rem .65rem;font-size:.88rem;min-width:130px;}
.approve-form select:focus,.approve-form input:focus,.reject-form input:focus{outline:none;border-color:#1e2d4e;}
.btn-approve{background:#1e2d4e;color:#f5c842;border:none;border-radius:7px;padding:.45rem 1rem;font-size:.88rem;font-weight:700;cursor:pointer;white-space:nowrap;}
.btn-approve:hover{background:#162340;}
.btn-reject{background:#fee2e2;color:#991b1b;border:none;border-radius:7px;padding:.45rem 1rem;font-size:.88rem;font-weight:600;cursor:pointer;white-space:nowrap;}
.btn-reject:hover{background:#fecaca;}
.badge-status{font-size:.72rem;font-weight:700;padding:.18rem .5rem;border-radius:12px;text-transform:uppercase;letter-spacing:.04em;}
.s-in_attesa{background:#fef3c7;color:#92400e;}
.s-portale_attivato{background:#dbeafe;color:#1e40af;}
.s-rifiutato{background:#fee2e2;color:#991b1b;}
.empty-acc{text-align:center;color:#94a3b8;padding:2.5rem 1rem;font-size:.95rem;}
.acc-panel{display:none;}.acc-panel.visible{display:block;}
</style>

<!-- ═══ IN ATTESA ═══ -->
<div id="panel-in_attesa" class="acc-panel visible">
  <% var pending=requests.filter(function(r){return r.status==='in_attesa';}); %>
  <% if(!pending.length){ %><div class="empty-acc">✅ Nessuna richiesta in attesa.</div><% } %>
  <% pending.forEach(function(r){ %>
  <div class="req-card">
    <div class="req-header">
      <strong><%= r.company_name %></strong>
      <span class="badge-status s-in_attesa">In attesa</span>
      <span class="muted">👤 <%= r.contact_name %></span>
      <span class="muted">✉️ <%= r.email %></span>
      <% if(r.phone){ %><span class="muted">📞 <%= r.phone %></span><% } %>
      <% if(r.stand_type){ %><span class="muted">🏷 <%= r.stand_type %></span><% } %>
      <% if(r.stand_size){ %><span class="muted">📐 <%= r.stand_size %></span><% } %>
      <span class="muted" style="margin-left:auto;">📅 <%= new Date(r.created_at).toLocaleDateString('it-IT') %></span>
    </div>
    <% if(r.notes){ %><p class="req-notes"><%= r.notes %></p><% } %>
    <form method="POST" action="/admin/accreditamento/<%= r.id %>/approva" class="approve-form">
      <select name="group_id" required title="Raggruppamento">
        <option value="">— Raggruppamento —</option>
        <% groups.forEach(function(g){ %><option value="<%= g.id %>"><%= g.name %></option><% }); %>
      </select>
      <input type="text"   name="zone"       placeholder="Zona (A, B, Ext…)">
      <input type="text"   name="stand_name" placeholder="Nome stand" value="<%= r.company_name %>">
      <input type="number" name="max_passes" placeholder="Max pass" min="1" style="max-width:105px;">
      <button type="submit" class="btn-approve">✅ Approva e attiva portale</button>
    </form>
    <form method="POST" action="/admin/accreditamento/<%= r.id %>/rifiuta" class="reject-form"
          onsubmit="return confirm('Rifiutare la richiesta di <%= r.company_name %>?');">
      <input type="text" name="rejection_reason" placeholder="Motivazione (opzionale)" style="flex:1;min-width:200px;">
      <button type="submit" class="btn-reject">❌ Rifiuta</button>
    </form>
  </div>
  <% }); %>
</div>

<!-- ═══ PORTALE ATTIVATO ═══ -->
<div id="panel-portale_attivato" class="acc-panel">
  <% var activated=requests.filter(function(r){return r.status==='portale_attivato';}); %>
  <% if(!activated.length){ %><div class="empty-acc">Nessuna richiesta con portale attivato.</div><% } %>
  <% activated.forEach(function(r){ %>
  <div class="req-card">
    <div class="req-header">
      <strong><%= r.company_name %></strong>
      <span class="badge-status s-portale_attivato">Portale attivato</span>
      <span class="muted">👤 <%= r.contact_name %></span>
      <span class="muted">✉️ <%= r.email %></span>
      <% if(r.stand_type){ %><span class="muted">🏷 <%= r.stand_type %></span><% } %>
      <span class="muted" style="margin-left:auto;">Approvato da <strong><%= r.reviewer_name||'sistema' %></strong> il <%= r.reviewed_at ? new Date(r.reviewed_at).toLocaleDateString('it-IT') : '—' %></span>
    </div>
    <% if(r.notes){ %><p class="req-notes"><%= r.notes %></p><% } %>
    <% if(r.assignment_group_id){ %>
      <a href="/assignment-groups/<%= r.assignment_group_id %>" style="display:inline-block;margin-top:.5rem;font-size:.85rem;color:#1e2d4e;font-weight:600;">→ Vai alla scheda CRM</a>
    <% } %>
  </div>
  <% }); %>
</div>

<!-- ═══ RIFIUTATE ═══ -->
<div id="panel-rifiutato" class="acc-panel">
  <% var rejected=requests.filter(function(r){return r.status==='rifiutato';}); %>
  <% if(!rejected.length){ %><div class="empty-acc">Nessuna richiesta rifiutata.</div><% } %>
  <% rejected.forEach(function(r){ %>
  <div class="req-card">
    <div class="req-header">
      <strong><%= r.company_name %></strong>
      <span class="badge-status s-rifiutato">Rifiutata</span>
      <span class="muted">👤 <%= r.contact_name %></span>
      <span class="muted">✉️ <%= r.email %></span>
      <span class="muted" style="margin-left:auto;">da <%= r.reviewer_name||'sistema' %> il <%= r.reviewed_at ? new Date(r.reviewed_at).toLocaleDateString('it-IT') : '—' %></span>
    </div>
    <% if(r.rejection_reason){ %><p class="req-notes">Motivazione: <%= r.rejection_reason %></p><% } %>
  </div>
  <% }); %>
</div>

<script>
function showTab(name, btn) {
  document.querySelectorAll('.acc-panel').forEach(function(p){ p.classList.remove('visible'); });
  document.querySelectorAll('.pill-tab').forEach(function(b){ b.classList.remove('active'); });
  document.getElementById('panel-' + name).classList.add('visible');
  btn.classList.add('active');
}
function copyLink() {
  var url = location.origin + '/richiesta-accreditamento';
  if (navigator.clipboard) {
    navigator.clipboard.writeText(url).then(function(){ alert('Link copiato: ' + url); });
  } else {
    prompt('Copia questo link:', url);
  }
}
</script>
<%- include('partials/footer') %>
