<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Richieste Accreditamento — Admin</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    /* ── TABS STATUS ── */
    .acc-tabs{display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:1.5rem}
    .acc-tab{padding:.45rem 1rem;border-radius:20px;font-size:.82rem;font-weight:600;cursor:pointer;border:1.5px solid transparent;background:#f1f5f9;color:#475569;transition:all .15s}
    .acc-tab.active,.acc-tab:hover{background:#1e2d4e;color:#fff}
    .req-section{display:none}.req-section.visible{display:block}

    /* ── TYPE SECTION HEADER ── */
    .type-section{margin-bottom:2rem}
    .type-header{display:flex;align-items:center;gap:.5rem;padding:.5rem .75rem;border-radius:8px;margin-bottom:.75rem;font-weight:700;font-size:.88rem;border-left:4px solid}
    .type-header.espositore{background:#fefce8;color:#854d0e;border-color:#f5c842}
    .type-header.stampa    {background:#eff6ff;color:#1e40af;border-color:#3b82f6}
    .type-header.autore    {background:#f0fdf4;color:#14532d;border-color:#22c55e}
    .type-header.creator   {background:#fdf4ff;color:#701a75;border-color:#d946ef}
    .type-header .count    {margin-left:auto;font-size:.78rem;font-weight:600;opacity:.7}
    .empty-type            {font-size:.82rem;color:#94a3b8;padding:.5rem .75rem}

    /* ── CARDS ── */
    .req-card{background:#fff;border-radius:10px;border:1px solid #e2e8f0;padding:1.1rem 1.4rem;margin-bottom:.85rem;box-shadow:0 1px 4px rgba(0,0,0,.05)}
    .req-top{display:flex;flex-wrap:wrap;gap:.4rem .65rem;align-items:baseline;margin-bottom:.5rem}
    .req-top strong{font-size:1rem;color:#1e2d4e}
    .meta{font-size:.8rem;color:#94a3b8}
    .meta-pill{font-size:.76rem;background:#f1f5f9;color:#475569;border-radius:12px;padding:.12rem .5rem;white-space:nowrap}
    .badge{font-size:.72rem;font-weight:700;padding:.18rem .5rem;border-radius:10px;text-transform:uppercase;letter-spacing:.04em}
    .badge-in_attesa        {background:#fef3c7;color:#92400e}
    .badge-portale_attivato {background:#dbeafe;color:#1e40af}
    .badge-rifiutato        {background:#fee2e2;color:#991b1b}
    .req-notes{font-size:.84rem;color:#475569;border-left:3px solid #e2e8f0;padding-left:.65rem;margin:.45rem 0 .65rem}

    /* ── APPROVE FORMS ── */
    .approve-wrap{border-top:1px dashed #e2e8f0;padding-top:.85rem;margin-top:.65rem}
    .approve-form,.reject-form{display:flex;flex-wrap:wrap;gap:.45rem;align-items:center}
    .approve-form select,.approve-form input,.reject-form input{border:1.5px solid #d1d5db;border-radius:7px;padding:.38rem .6rem;font-size:.85rem}
    .approve-form select:focus,.approve-form input:focus,.reject-form input:focus{outline:none;border-color:#1e2d4e}
    .approve-form .w-auto{width:auto;min-width:130px}
    .approve-form .w-num{width:90px}
    .reject-form .w-full{flex:1;min-width:180px}
    .btn-approve{background:#1e2d4e;color:#f5c842;border:none;border-radius:7px;padding:.42rem 1rem;font-size:.85rem;font-weight:700;cursor:pointer}
    .btn-approve:hover{background:#162340}
    .btn-reject{background:#fee2e2;color:#991b1b;border:none;border-radius:7px;padding:.42rem .9rem;font-size:.85rem;font-weight:600;cursor:pointer}
    .btn-reject:hover{background:#fecaca}
    .btn-link{display:inline-block;margin-top:.65rem;font-size:.82rem;color:#1e2d4e;text-decoration:underline}
    .sep{width:100%;height:0;border:none}
    .info-tag{font-size:.76rem;background:#f8fafc;border:1px solid #e2e8f0;border-radius:6px;padding:.15rem .5rem;color:#374151}

    .empty-state{text-align:center;color:#94a3b8;padding:2.5rem 1rem;font-size:.92rem}
    .toast{position:fixed;bottom:1.5rem;right:1.5rem;background:#1e2d4e;color:#f5c842;border-radius:10px;padding:.75rem 1.25rem;font-size:.9rem;font-weight:600;box-shadow:0 4px 16px rgba(0,0,0,.18);z-index:9999;animation:slideIn .3s ease}
    @keyframes slideIn{from{transform:translateY(20px);opacity:0}to{transform:translateY(0);opacity:1}}
  </style>
</head>
<body>
  <%- include('partials/header') %>
  <div class="container" style="max-width:980px;margin:2rem auto;padding:0 1.25rem">

    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;flex-wrap:wrap;gap:.5rem">
      <h1 style="font-size:1.4rem;color:#1e2d4e">Richieste di Accreditamento</h1>
      <div style="display:flex;gap:.5rem;flex-wrap:wrap">
        <a href="/richiesta-accreditamento/espositori" target="_blank"
           style="font-size:.82rem;color:#1e2d4e;border:1.5px solid #1e2d4e;border-radius:20px;padding:.3rem .85rem;text-decoration:none;white-space:nowrap">
          🏪 Form Espositori
        </a>
        <a href="/richiesta-accreditamento/media" target="_blank"
           style="font-size:.82rem;color:#1e2d4e;border:1.5px solid #1e2d4e;border-radius:20px;padding:.3rem .85rem;text-decoration:none;white-space:nowrap">
          📰 Form Stampa & Autori
        </a>
      </div>
    </div>

    <% if (saved) { %>
      <script>setTimeout(()=>{var t=document.createElement('div');t.className='toast';t.textContent=(<%= JSON.stringify({approvato:'✅ Richiesta approvata — portale attivato',rifiutato:'❌ Richiesta rifiutata'}[saved]||'Salvato') %>);document.body.appendChild(t);setTimeout(()=>t.remove(),4000)},100)</script>
    <% } %>

    <%
      var byStatus = { in_attesa:[], portale_attivato:[], rifiutato:[] };
      requests.forEach(function(r){ if(byStatus[r.status]) byStatus[r.status].push(r); });

      // Ordine di visualizzazione dei tipi
      var TYPE_ORDER = ['espositore','stampa','autore','content_creator'];
      var TYPE_META  = {
        espositore:      { icon:'🏪', label:'Espositori & Associazioni', cls:'espositore' },
        stampa:          { icon:'📰', label:'Stampa & Media',            cls:'stampa'     },
        autore:          { icon:'✍️', label:'Autori',                   cls:'autore'     },
        content_creator: { icon:'🎥', label:'Content Creator',           cls:'creator'    }
      };
      function byType(list, type){
        return list.filter(function(r){ return (r.accreditation_type||'espositore')===type; });
      }
    %>

    <div class="acc-tabs">
      <button class="acc-tab active" onclick="showTab('in_attesa',this)">
        ⏳ In attesa (<%= byStatus.in_attesa.length %>)
      </button>
      <button class="acc-tab" onclick="showTab('portale_attivato',this)">
        🚀 Approvate (<%= byStatus.portale_attivato.length %>)
      </button>
      <button class="acc-tab" onclick="showTab('rifiutato',this)">
        ❌ Rifiutate (<%= byStatus.rifiutato.length %>)
      </button>
    </div>

    <!-- ═══════════════ IN ATTESA ═══════════════ -->
    <div id="tab-in_attesa" class="req-section visible">
      <% if (!byStatus.in_attesa.length) { %>
        <div class="empty-state">Nessuna richiesta in attesa 🎉</div>
      <% } else { %>
        <% TYPE_ORDER.forEach(function(type){ %>
          <% var group = byType(byStatus.in_attesa, type); if (!group.length) return; %>
          <% var tm = TYPE_META[type]; %>
          <div class="type-section">
            <div class="type-header <%= tm.cls %>">
              <%= tm.icon %> <%= tm.label %>
              <span class="count"><%= group.length %> richiesta<%= group.length!==1?'e':'' %></span>
            </div>

            <% group.forEach(function(r){ %>
            <div class="req-card">
              <div class="req-top">
                <strong><%= r.company_name %></strong>
                <% if (type==='stampa' && r.press_role) { %><span class="info-tag"><%= r.press_role %></span><% } %>
                <% if (type==='autore' && r.publisher)  { %><span class="info-tag">📚 <%= r.publisher %></span><% } %>
                <% if (type==='autore' && r.genre)      { %><span class="info-tag"><%= r.genre %></span><% } %>
                <% if (type==='content_creator') { %>
                  <% if (r.platform)    { %><span class="info-tag"><%= r.platform %></span><% } %>
                  <% if (r.subscribers) { %><span class="info-tag">👥 <%= r.subscribers %></span><% } %>
                <% } %>
                <span style="margin-left:auto" class="meta">
                  📅 <%= new Date(r.created_at).toLocaleDateString('it-IT') %>
                </span>
              </div>
              <div style="display:flex;flex-wrap:wrap;gap:.3rem .5rem;margin-bottom:.3rem">
                <span class="meta">👤 <%= r.contact_name %></span>
                <span class="meta">✉️ <%= r.email %></span>
                <% if (r.phone) { %><span class="meta">📞 <%= r.phone %></span><% } %>
                <% if (type==='espositore') { %>
                  <% if (r.stand_type) { %><span class="meta-pill">🏷️ <%= r.stand_type %></span><% } %>
                  <% if (r.stand_size) { %><span class="meta-pill">📐 <%= r.stand_size %></span><% } %>
                <% } %>
                <% if (type==='content_creator' && r.channel_url) { %>
                  <a href="<%= r.channel_url %>" target="_blank" class="meta">🔗 <%= r.channel_url.replace(/https?:\/\/(www\.)?/,'').substr(0,40) %></a>
                <% } %>
              </div>
              <% if (r.notes) { %><p class="req-notes"><%= r.notes %></p><% } %>

              <div class="approve-wrap">
                <!-- ── FORM APPROVAZIONE: diversa per tipo ── -->
                <% if (type === 'espositore') { %>
                  <!-- ESPOSITORE: zone + stand_name + max_passes -->
                  <form method="POST" action="/admin/accreditamento/<%= r.id %>/approva" class="approve-form">
                    <input type="hidden" name="accreditation_type" value="espositore">
                    <select name="group_id" required class="w-auto" title="Raggruppamento">
                      <option value="">— Raggruppamento —</option>
                      <% groups.forEach(function(g){ %><option value="<%= g.id %>"><%= g.name %></option><% }); %>
                    </select>
                    <input type="text"   name="zone"       placeholder="Zona (es. A, B, Ext)" class="w-auto">
                    <input type="text"   name="stand_name" placeholder="Nome stand" value="<%= r.company_name %>" class="w-auto">
                    <input type="number" name="max_passes" placeholder="Max pass" min="1" class="w-num">
                    <button type="submit" class="btn-approve">✅ Approva</button>
                  </form>

                <% } else { %>
                  <!-- STAMPA / AUTORE / CREATOR: solo gruppo + max_passes (no stand/zona) -->
                  <form method="POST" action="/admin/accreditamento/<%= r.id %>/approva" class="approve-form">
                    <input type="hidden" name="accreditation_type" value="<%= type %>">
                    <select name="group_id" required class="w-auto" title="Raggruppamento">
                      <option value="">— Raggruppamento —</option>
                      <% groups.forEach(function(g){ %><option value="<%= g.id %>"><%= g.name %></option><% }); %>
                    </select>
                    <input type="number" name="max_passes" placeholder="Pass (default 1)" min="1" max="10" class="w-num" value="1">
                    <button type="submit" class="btn-approve">✅ Approva</button>
                  </form>
                <% } %>

                <div class="sep"></div>
                <form method="POST" action="/admin/accreditamento/<%= r.id %>/rifiuta" class="reject-form"
                      onsubmit="return confirm('Confermi il rifiuto per <%= r.company_name.replace(/'/g,"\'\'") %>?')">
                  <input type="text" name="rejection_reason" placeholder="Motivazione rifiuto (opzionale)" class="w-full">
                  <button type="submit" class="btn-reject">❌ Rifiuta</button>
                </form>
              </div>
            </div>
            <% }); /* end forEach group */ %>
          </div>
        <% }); /* end TYPE_ORDER */ %>
      <% } %>
    </div>

    <!-- ═══════════════ APPROVATE ═══════════════ -->
    <div id="tab-portale_attivato" class="req-section">
      <% if (!byStatus.portale_attivato.length) { %>
        <div class="empty-state">Nessuna richiesta approvata.</div>
      <% } else { %>
        <% TYPE_ORDER.forEach(function(type){ %>
          <% var group = byType(byStatus.portale_attivato, type); if (!group.length) return; %>
          <% var tm = TYPE_META[type]; %>
          <div class="type-section">
            <div class="type-header <%= tm.cls %>">
              <%= tm.icon %> <%= tm.label %>
              <span class="count"><%= group.length %></span>
            </div>
            <% group.forEach(function(r){ %>
            <div class="req-card">
              <div class="req-top">
                <strong><%= r.company_name %></strong>
                <span class="badge badge-portale_attivato">Portale attivato</span>
                <% if (type==='stampa' && r.press_role)     { %><span class="info-tag"><%= r.press_role %></span><% } %>
                <% if (type==='autore' && r.publisher)      { %><span class="info-tag">📚 <%= r.publisher %></span><% } %>
                <% if (type==='content_creator' && r.platform) { %><span class="info-tag"><%= r.platform %></span><% } %>
                <span style="margin-left:auto" class="meta">
                  Approvato da <strong><%= r.reviewer_name||'sistema' %></strong>
                  il <%= r.reviewed_at ? new Date(r.reviewed_at).toLocaleDateString('it-IT') : '—' %>
                </span>
              </div>
              <div style="display:flex;flex-wrap:wrap;gap:.3rem .5rem">
                <span class="meta">👤 <%= r.contact_name %></span>
                <span class="meta">✉️ <%= r.email %></span>
              </div>
              <% if (r.notes) { %><p class="req-notes"><%= r.notes %></p><% } %>
              <% if (r.assignment_group_id) { %>
                <a href="/assignment-groups/<%= r.assignment_group_id %>" class="btn-link">
                  → Vai alla scheda CRM
                </a>
              <% } %>
            </div>
            <% }); %>
          </div>
        <% }); %>
      <% } %>
    </div>

    <!-- ═══════════════ RIFIUTATE ═══════════════ -->
    <div id="tab-rifiutato" class="req-section">
      <% if (!byStatus.rifiutato.length) { %>
        <div class="empty-state">Nessuna richiesta rifiutata.</div>
      <% } else { %>
        <% TYPE_ORDER.forEach(function(type){ %>
          <% var group = byType(byStatus.rifiutato, type); if (!group.length) return; %>
          <% var tm = TYPE_META[type]; %>
          <div class="type-section">
            <div class="type-header <%= tm.cls %>">
              <%= tm.icon %> <%= tm.label %>
              <span class="count"><%= group.length %></span>
            </div>
            <% group.forEach(function(r){ %>
            <div class="req-card">
              <div class="req-top">
                <strong><%= r.company_name %></strong>
                <span class="badge badge-rifiutato">Rifiutata</span>
                <span style="margin-left:auto" class="meta">
                  da <strong><%= r.reviewer_name||'sistema' %></strong>
                  il <%= r.reviewed_at ? new Date(r.reviewed_at).toLocaleDateString('it-IT') : '—' %>
                </span>
              </div>
              <div style="display:flex;flex-wrap:wrap;gap:.3rem .5rem">
                <span class="meta">👤 <%= r.contact_name %></span>
                <span class="meta">✉️ <%= r.email %></span>
              </div>
              <% if (r.rejection_reason) { %>
                <p class="req-notes">Motivazione: <%= r.rejection_reason %></p>
              <% } %>
            </div>
            <% }); %>
          </div>
        <% }); %>
      <% } %>
    </div>

  </div>

  <script>
  function showTab(id, btn) {
    document.querySelectorAll('.req-section').forEach(function(s){ s.classList.remove('visible'); });
    document.querySelectorAll('.acc-tab').forEach(function(b){ b.classList.remove('active'); });
    document.getElementById('tab-'+id).classList.add('visible');
    btn.classList.add('active');
  }
  </script>
</body>
</html>

