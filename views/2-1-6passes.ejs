<%-include('partials/header') %>
<% if(replaced){ %><div style="background:#f0fdf4;border:1.5px solid #2d6a4f;border-radius:8px;padding:.7rem 1rem;display:flex;gap:.75rem;margin-bottom:1rem;font-size:.85rem;"><span>&#128260;</span><span>Pass <strong>#<%= replaced %></strong> creato come sostituto. Il pass originale &egrave; stato invalidato.</span></div><% } %>
<nav class="breadcrumb-bar">Sei in: <a href="/home">Home</a> <span class="sep">›</span> <strong>Pass Generati</strong></nav>
<h1 class="page-title">Pass Generati</h1>

<div style="display:flex;gap:0.75rem;align-items:center;margin-bottom:1rem;flex-wrap:wrap;">
  <a href="/passes/new" class="primary">+ Nuovo Pass singolo</a>
</div>

<% if (passes.length === 0) { %>
  <div class="alert alert-info"><span>ℹ️</span> Nessun pass generato.</div>
<% } else { %>

<!-- BARRA RICERCA -->
<div class="card" style="padding:0.75rem 1rem;margin-bottom:1rem;">
  <div style="display:flex;gap:0.75rem;align-items:flex-end;flex-wrap:wrap;">
    <div style="flex:1;min-width:200px;">
      <label style="margin:0;font-size:0.78rem;">🔍 Cerca tra i pass (nome, cognome, tipologia, codice, stato…)<br>
        <input type="text" id="pass-search" placeholder="Scrivi per filtrare…"
               oninput="filtraPass()" style="margin-top:0.25rem;">
      </label>
    </div>
    <div style="min-width:160px;">
      <label style="margin:0;font-size:0.78rem;">Filtra per stato<br>
        <select id="pass-stato-filter" onchange="filtraPass()" style="margin-top:0.25rem;">
          <option value="">— Tutti gli stati —</option>
          <% statuses.forEach(function(s){ %>
            <option value="<%= s %>"><%= s %></option>
          <% }); %>
        </select>
      </label>
    </div>
    <button type="button" onclick="azzeraFiltri()" class="secondary" style="height:38px;margin-bottom:1px;">✕ Azzera</button>
  </div>
  <div id="pass-count" style="font-size:0.78rem;color:var(--text-muted);margin-top:0.5rem;"></div>
</div>

<div class="table-wrapper">
  <table id="passes-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Data</th>
        <th>Codice</th>
        <th>Assegnatario</th>
        <th>Tipologia</th>
        <th>Stato</th>
        <th>PDF</th>
        <th>Storico</th>
        <th>Sost.</th>
        <th>Cancella</th>
      </tr>
    </thead>
    <tbody>
      <% passes.forEach(function(p){ %>
        <tr class="pass-row"
            data-nome="<%= (p.participant_name||'').toLowerCase() %>"
            data-tipo="<%= (p.pass_type_name||'').toLowerCase() %>"
            data-codice="<%= (p.code||'').toLowerCase() %>"
            data-stato="<%= (p.status||'').toLowerCase() %>"
            data-id="<%= p.id %>">
          <td><span class="chip">#<%= p.id %></span></td>
          <td style="white-space:nowrap;font-size:0.78rem;color:var(--text-muted);"><%= p.created_at %></td>
          <td style="font-family:monospace;font-size:0.78rem;"><%= p.code || '' %></td>
          <td><strong><%= p.participant_name %></strong></td>
          <td><%= p.pass_type_name %></td>
          <td>
            <form method="post" action="/passes/<%= p.id %>/status" class="status-form">
              <select name="status" onchange="this.form.submit()">
                <% statuses.forEach(function(s){ %>
                  <option value="<%= s %>" <%= p.status === s ? 'selected' : '' %>><%= s %></option>
                <% }); %>
              </select>
            </form>
          </td>
          <td>
            <% if (p.pdf_file) { %>
              <a href="/passes/<%= p.id %>/download" target="_blank" class="link-action">⬇ PDF</a>
            <% } else { %><span style="color:var(--text-muted);">n/d</span><% } %>
          </td>
          <td>
            <button type="button" class="secondary"
              style="font-size:.72rem;padding:.25rem .6rem;min-width:auto;"
              onclick="mostraStorico(<%= p.id %>)">&#128203;</button>
          </td>
          <td>
            <% if(p.status!=="INVALIDATO"){ %>
            <form method="post" action="/passes/<%= p.id %>/replace"
                  onsubmit="return confirm('Invalidare pass #<%= p.id %> e creare sostituto?');"
                  style="display:inline;">
              <button type="submit" class="secondary"
                style="font-size:.72rem;padding:.25rem .55rem;background:#c9a227;color:#fff;border:none;"
                title="Sostituisci">&#128260;</button>
            </form>
            <% } %>
          </td>
          <td>
            <form method="post" action="/passes/<%= p.id %>/delete"
                  onsubmit="return confirm('Cancellare il pass #<%= p.id %>?');">
              <button type="submit" class="btn-danger">✕</button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
  <div id="pass-nessuno" style="display:none;padding:1rem;text-align:center;color:var(--text-muted);font-size:0.9rem;">
    🔍 Nessun pass corrisponde ai filtri applicati.
  </div>
</div>

<script>
function filtraPass() {
  var q     = (document.getElementById('pass-search').value || '').toLowerCase().trim();
  var stato = (document.getElementById('pass-stato-filter').value || '').toLowerCase();
  var rows  = document.querySelectorAll('tr.pass-row');
  var vis   = 0;

  rows.forEach(function(row) {
    var testo = row.dataset.nome + ' ' + row.dataset.tipo + ' ' +
                row.dataset.codice + ' ' + row.dataset.id;
    var okTesto = !q     || testo.indexOf(q) !== -1;
    var okStato = !stato || row.dataset.stato === stato;
    var show = okTesto && okStato;
    row.style.display = show ? '' : 'none';
    if (show) vis++;
  });

  var cnt = document.getElementById('pass-count');
  var none = document.getElementById('pass-nessuno');
  if (q || stato) {
    cnt.textContent = vis + ' pass visibili su ' + rows.length + ' totali.';
  } else {
    cnt.textContent = '';
  }
  none.style.display = (vis === 0) ? '' : 'none';
}

function azzeraFiltri() {
  document.getElementById('pass-search').value = '';
  document.getElementById('pass-stato-filter').value = '';
  filtraPass();
}
</script>

<% } %>
<%-include('partials/footer') %>
