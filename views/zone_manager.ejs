<%- include('partials/header') %>

<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,Segoe UI,Arial,sans-serif;font-size:14px;background:#f4f6f9;color:#1a2744}
.header{background:#1e2d4e;color:#fff;padding:.75rem 1.5rem;display:flex;align-items:center;justify-content:space-between;border-bottom:3px solid #f5c842}
.header h1{font-size:1rem;font-weight:800}
.header-actions{display:flex;gap:.5rem;align-items:center;flex-wrap:wrap}
.btn{padding:.35rem .9rem;border-radius:6px;font-size:.78rem;font-weight:700;cursor:pointer;border:none;text-decoration:none;display:inline-flex;align-items:center;gap:.3rem;transition:background .15s}
.btn-primary{background:#f5c842;color:#1e2d4e}.btn-primary:hover{background:#f7d060}
.btn-secondary{background:rgba(255,255,255,.15);color:#fff;border:1px solid rgba(255,255,255,.3)}.btn-secondary:hover{background:rgba(255,255,255,.25)}
.btn-danger{background:#e8372a;color:#fff}.btn-danger:hover{background:#c42d21}
.btn-sm{padding:.25rem .65rem;font-size:.72rem}
.flash{padding:.6rem 1.2rem;font-size:.82rem;font-weight:700;text-align:center}
.flash.saved{background:#d4edda;color:#155724}
.flash.created{background:#cce5ff;color:#004085}
.flash.deleted{background:#fce8e6;color:#7c1e1e}
.container{max-width:1150px;margin:1.5rem auto;padding:0 1rem}
.page-title{font-size:1.1rem;font-weight:800;color:#1e2d4e;margin-bottom:1rem;display:flex;align-items:center;gap:.5rem;flex-wrap:wrap}
.badge{display:inline-flex;align-items:center;gap:.25rem;padding:.2rem .6rem;border-radius:999px;font-size:.7rem;font-weight:700;white-space:nowrap}
.badge-internal{background:#dbeafe;color:#1e40af}
.badge-both{background:#fef3c7;color:#92400e}
.badge-public{background:#dcfce7;color:#166534}
.legend{display:flex;gap:.75rem;margin-bottom:1.2rem;flex-wrap:wrap;padding:1rem;background:#fff;border-radius:10px;box-shadow:0 1px 4px rgba(0,0,0,.07)}
.legend-item{display:flex;align-items:flex-start;gap:.5rem;font-size:.78rem;flex:1;min-width:200px}
.legend-item p{color:#4a5568;line-height:1.4}
.zones-table{width:100%;border-collapse:collapse;background:#fff;border-radius:10px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.08)}
.zones-table th{background:#f8f9fc;color:#4a5568;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;padding:.6rem 1rem;text-align:left;border-bottom:1px solid #e2e8f0}
.zones-table td{padding:.6rem 1rem;border-bottom:1px solid #f0f2f7;vertical-align:middle}
.zones-table tr:last-child td{border-bottom:none}
.zones-table tr:hover td{background:#fafbff}
.zone-name{font-weight:700;color:#1a2744}
.zone-meta{font-size:.7rem;color:#aaa;margin-top:.1rem}
.scope-select{padding:.3rem .5rem;border:1px solid #d1d9e6;border-radius:6px;font-size:.78rem;background:#fff;color:#1a2744;cursor:pointer;min-width:150px}
.new-zone-card{background:#fff;border-radius:10px;box-shadow:0 1px 4px rgba(0,0,0,.08);padding:1.2rem;margin-bottom:1.2rem}
.new-zone-card h2{font-size:.88rem;font-weight:800;color:#1e2d4e;margin-bottom:.85rem}
.form-row{display:flex;gap:.7rem;flex-wrap:wrap;align-items:flex-end}
.fgroup{display:flex;flex-direction:column;gap:.22rem;flex:1;min-width:140px}
.fgroup label{font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#8896ab}
.fgroup input,.fgroup select{padding:.38rem .6rem;border:1px solid #d1d9e6;border-radius:6px;font-size:.82rem;color:#1a2744;background:#fff}
.fgroup input:focus,.fgroup select:focus{outline:none;border-color:#1e2d4e}
.filters{display:flex;gap:.4rem;margin-bottom:1rem;flex-wrap:wrap}
.filter-btn{padding:.28rem .85rem;border-radius:20px;font-size:.74rem;font-weight:700;cursor:pointer;border:2px solid #e2e8f0;background:#fff;color:#4a5568;transition:all .15s}
.filter-btn:hover{border-color:#1e2d4e;color:#1e2d4e}
.filter-btn.active{border-color:#1e2d4e;background:#1e2d4e;color:#fff}
.edit-input{padding:.25rem .45rem;border:1px solid #d1d9e6;border-radius:5px;font-size:.78rem;color:#1a2744}
</style>

<nav class="breadcrumb-bar">Sei in: <a href="/home">Home</a> &rsaquo; <a href="/admin/hub">Admin Hub</a> &rsaquo; <strong>Zone / Padiglioni</strong></nav>



<div class="header">
  <h1>&#128194; Zone Manager</h1>
  <div class="header-actions">
    <a href="/admin/zone-manager" class="btn btn-secondary btn-sm">&#128260; Aggiorna</a>
    <a href="/admin/zone-manager" class="btn btn-secondary btn-sm">&#128506; Mappa Pubblica</a>
    <a href="/mappa" class="btn btn-secondary btn-sm">&#128204; Mappa Stand</a>
    <a href="/admin/settings" class="btn btn-secondary btn-sm">&#9881; Impostazioni</a>
    <a href="/home" class="btn btn-secondary btn-sm">&#127968; Admin</a>
  </div>
</div>

<% if (locals.flash === 'saved') { %>
<div class="flash saved">&#10003; Zona aggiornata</div>
<% } else if (locals.flash === 'created') { %>
<div class="flash created">&#10003; Nuova zona creata</div>
<% } else if (locals.flash === 'deleted') { %>
<div class="flash deleted">&#128465; Zona eliminata</div>
<% } %>

<div class="container">

  <div class="page-title">
    &#128194; Gestione Zone &amp; Visibilit&agrave;
    <span style="font-size:.72rem;font-weight:600;color:#718096"><%= zones.length %> zone totali</span>
  </div>

  <div class="legend">
    <div class="legend-item">
      <span class="badge badge-internal">&#127963; Solo interna</span>
      <p>Menu <strong>Creazione Gruppi</strong> + <strong>Mappa Stand</strong><br>Non appare nella mappa pubblica</p>
    </div>
    <div class="legend-item" style="border-left:1px solid #e2e8f0;padding-left:.75rem">
      <span class="badge badge-both">&#128257; Entrambe</span>
      <p>Appare <strong>ovunque</strong>: Gruppi, Mappa Stand <em>e</em> Mappa Pubblica Leaflet<br><em>Usa per Palazzetto, Mariambini, Vanvere&hellip;</em></p>
    </div>
    <div class="legend-item" style="border-left:1px solid #e2e8f0;padding-left:.75rem">
      <span class="badge badge-public">&#127757; Solo pubblica</span>
      <p>Solo nel Gestionale Mappa Pubblica (Leaflet)<br><em>Usa per parcheggi, bagni, biglietterie&hellip;</em></p>
    </div>
  </div>

  <div class="new-zone-card">
    <h2>&#43; Crea nuova zona</h2>
    <form method="POST" action="/admin/zones">
      <div class="form-row">
        <div class="fgroup" style="flex:2;min-width:200px">
          <label>Nome zona *</label>
          <input type="text" name="name" required placeholder="es. Palazzetto dello Sport">
        </div>
        <div class="fgroup" style="max-width:90px">
          <label>Ordine</label>
          <input type="number" name="sort_order" value="0" min="0">
        </div>
        <div class="fgroup" style="max-width:180px">
          <label>Visibilit&agrave;</label>
          <select name="zone_scope">
            <option value="internal">&#127963; Solo interna</option>
            <option value="both">&#128257; Entrambe</option>
            <option value="public">&#127757; Solo pubblica</option>
          </select>
        </div>
        <div class="fgroup" style="max-width:110px;justify-content:flex-end">
          <label>&nbsp;</label>
          <button type="submit" class="btn btn-primary">Crea zona</button>
        </div>
      </div>
    </form>
  </div>

<%
var cAll  = zones.length;
var cInt  = 0;
var cBoth = 0;
var cPub  = 0;
for (var i = 0; i < zones.length; i++) {
  var sc = zones[i].zone_scope || 'internal';
  if (sc === 'internal') cInt++;
  else if (sc === 'both') cBoth++;
  else if (sc === 'public') cPub++;
}
%>

  <div class="filters">
    <button class="filter-btn active" onclick="filterScope('all',this)">Tutte (<%= cAll %>)</button>
    <button class="filter-btn"        onclick="filterScope('internal',this)">&#127963; Solo interna (<%= cInt %>)</button>
    <button class="filter-btn"        onclick="filterScope('both',this)">&#128257; Entrambe (<%= cBoth %>)</button>
    <button class="filter-btn"        onclick="filterScope('public',this)">&#127757; Solo pubblica (<%= cPub %>)</button>
  </div>

  <table class="zones-table">
    <thead>
      <tr>
        <th>Zona</th>
        <th>Visibilit&agrave;</th>
        <th>Stand</th>
        <th style="min-width:330px">Modifica</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
<% if (!zones || zones.length === 0) { %>
      <tr><td colspan="5" style="text-align:center;padding:3rem;color:#718096">Nessuna zona trovata</td></tr>
<% } %>
<% for (var j = 0; j < zones.length; j++) { %>
<%   var z = zones[j]; %>
<%   var scope = z.zone_scope || 'internal'; %>
<%   var badgeClass = (scope === 'public') ? 'badge-public' : (scope === 'both') ? 'badge-both' : 'badge-internal'; %>
<%   var badgeLabel = (scope === 'public') ? '&#127757; Solo pubblica' : (scope === 'both') ? '&#128257; Entrambe' : '&#127963; Solo interna'; %>
      <tr data-scope="<%= scope %>">
        <td>
          <div class="zone-name"><%- z.name %></div>
<% if (z.map_lat) { %>
          <div class="zone-meta">&#128205; <%= parseFloat(z.map_lat).toFixed(4) %></div>
<% } else { %>
          <div class="zone-meta">No coordinate GPS</div>
<% } %>
        </td>
        <td>
          <form method="POST" action="/admin/zones/<%= z.id %>/set-scope" style="margin:0">
            <select name="zone_scope" class="scope-select" onchange="this.form.submit()">
              <option value="internal" <%= (scope === 'internal') ? 'selected' : '' %>>&#127963; Solo interna</option>
              <option value="both"     <%= (scope === 'both')     ? 'selected' : '' %>>&#128257; Entrambe</option>
              <option value="public"   <%= (scope === 'public')   ? 'selected' : '' %>>&#127757; Solo pubblica</option>
            </select>
          </form>
        </td>
        <td>
<% if (z.stands_count > 0) { %>
          <a href="/participants" style="font-weight:700;color:#1e2d4e"><%= z.stands_count %></a>
<% } else { %>
          <span style="color:#bbb">0</span>
<% } %>
        </td>
        <td>
          <form method="POST" action="/admin/zones/<%= z.id %>/edit" style="display:flex;gap:.35rem;align-items:center;flex-wrap:wrap;margin:0">
            <input type="text"   name="name"       value="<%- z.name %>"            required class="edit-input" style="width:150px">
            <input type="number" name="sort_order" value="<%= z.sort_order || 0 %>" class="edit-input" style="width:52px" title="Ordine">
            <select name="zone_scope" class="edit-input" style="width:155px">
              <option value="internal" <%= (scope === 'internal') ? 'selected' : '' %>>&#127963; Solo interna</option>
              <option value="both"     <%= (scope === 'both')     ? 'selected' : '' %>>&#128257; Entrambe</option>
              <option value="public"   <%= (scope === 'public')   ? 'selected' : '' %>>&#127757; Solo pubblica</option>
            </select>
            <button type="submit" class="btn btn-primary btn-sm">Salva</button>
          </form>
        </td>
        <td>
<% if (!z.stands_count || z.stands_count === 0) { %>
          <form method="POST" action="/admin/zones/<%= z.id %>/delete" style="margin:0" id="del-<%= z.id %>">
            <button type="button" onclick="confirmDel(<%= z.id %>)" class="btn btn-danger btn-sm" title="Elimina">&#128465;</button>
          </form>
<% } else { %>
          <button class="btn btn-sm" style="background:#f0f2f7;color:#ccc;cursor:not-allowed" disabled title="Ha stand assegnati">&#128465;</button>
<% } %>
        </td>
      </tr>
<% } %>
    </tbody>
  </table>

  <p style="margin-top:1rem;font-size:.72rem;color:#aaa;text-align:right">
    &#128161; Riclassifica automatica tutte le zone:
    <a href="/admin/fix-zone-scope" target="_blank" style="color:#1e2d4e;font-weight:700">/admin/fix-zone-scope</a>
  </p>

</div>

<script>
function filterScope(scope, btn) {
  var rows = document.querySelectorAll('tbody tr[data-scope]');
  for (var i = 0; i < rows.length; i++) {
    rows[i].style.display = (scope === 'all' || rows[i].getAttribute('data-scope') === scope) ? '' : 'none';
  }
  var btns = document.querySelectorAll('.filter-btn');
  for (var k = 0; k < btns.length; k++) btns[k].classList.remove('active');
  btn.classList.add('active');
}
function confirmDel(id) {
  if (confirm('Eliminare questa zona? L\'azione è irreversibile.')) {
    document.getElementById('del-' + id).submit();
  }
}
setTimeout(function() {
  var f = document.querySelector('.flash');
  if (f) { f.style.transition = 'opacity .4s'; f.style.opacity = 0; setTimeout(function(){ f.remove(); }, 400); }
}, 4000);
</script>


<%- include('partials/footer') %>
