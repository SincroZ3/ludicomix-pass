<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= run.title %> — Checklist</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .progress-bar{height:10px;background:#e2e8f0;border-radius:9999px;margin-bottom:1.25rem;overflow:hidden}
    .progress-fill{height:100%;background:linear-gradient(90deg,#22c55e,#4ade80);border-radius:9999px;transition:width .3s}
    .ci-item{display:flex;align-items:center;gap:.85rem;padding:.75rem;border-radius:10px;border:1.5px solid #e2e8f0;margin-bottom:.5rem;cursor:pointer;transition:all .15s;background:#fff;user-select:none}
    .ci-item.done{background:#f0fdf4;border-color:#86efac}
    .ci-check{width:26px;height:26px;border-radius:50%;border:2.5px solid #d1d9e6;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;transition:all .15s}
    .ci-item.done .ci-check{border-color:#22c55e;background:#22c55e;color:#fff}
    .ci-text{flex:1;font-size:.9rem;color:#1e2d4e;font-weight:500}
    .ci-item.done .ci-text{text-decoration:line-through;color:#94a3b8}
    .ci-meta{font-size:.7rem;color:#94a3b8;white-space:nowrap}
    .phase-badge{display:inline-block;font-size:.68rem;font-weight:800;padding:.15rem .5rem;border-radius:9999px;text-transform:uppercase}
    .ph-montaggio{background:#dbeafe;color:#1e40af}
    .ph-smontaggio{background:#fef3c7;color:#92400e}
    .ph-allestimento{background:#f3e8ff;color:#6b21a8}
    .ph-altro{background:#f1f5f9;color:#475569}
    .complete-banner{background:#d1fae5;border:2px solid #86efac;border-radius:12px;padding:1rem 1.25rem;text-align:center;color:#065f46;font-weight:700;font-size:1rem;margin-bottom:1rem}
    .log-card{background:#fff;border:1px solid #e2e8f0;border-radius:12px;box-shadow:0 1px 4px rgba(30,45,78,.06);margin-bottom:1.25rem;overflow:hidden}
    .log-card-head{display:flex;align-items:center;justify-content:space-between;gap:.75rem;padding:.75rem 1.2rem;border-bottom:1px solid #f1f5f9;background:#fafbfc}
    .log-card-title{font-size:.8rem;font-weight:800;text-transform:uppercase;letter-spacing:.55px;color:#1e2d4e}
    .log-card-body{padding:1.1rem 1.2rem}
  </style>
</head>
<body>
<nav class="breadcrumb-bar">Sei in: <a href="/">Home</a> › <a href="/admin/checklist">Checklist</a> › <strong><%= run.title %></strong></nav>
<div class="container" style="max-width:800px;margin:1.5rem auto;padding:0 1.25rem">

  <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1.25rem;flex-wrap:wrap">
    <span class="phase-badge ph-<%= run.phase||'altro' %>"><%= run.phase %></span>
    <h1 style="font-size:1.25rem;font-weight:800;color:#1e2d4e"><%= run.title %></h1>
    <% if(run.area){ %><span style="font-size:.8rem;color:#64748b">— <%= run.area %></span><% } %>
    <% if(run.completed_at){ %><span style="margin-left:auto;font-size:.78rem;background:#d1fae5;color:#065f46;font-weight:700;padding:.22rem .7rem;border-radius:9999px">✅ Completata</span><% } %>
  </div>

  <%
    var total=runItems.length;
    var done=runItems.filter(function(i){return i.done;}).length;
    var pct=total>0?Math.round((done/total)*100):0;
  %>
  <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:.5rem">
    <span style="font-size:.82rem;font-weight:700;color:#1e2d4e"><%= done %> / <%= total %> completate</span>
    <span style="font-size:.82rem;color:#64748b"><%= pct %>%</span>
  </div>
  <div class="progress-bar"><div class="progress-fill" id="prog-fill" style="width:<%= pct %>%"></div></div>

  <div id="complete-banner" class="complete-banner" style="display:<%= done===total&&total>0?'block':'none' %>">🎉 Checklist completata!</div>

  <div class="log-card">
    <div class="log-card-head">
      <span class="log-card-title">Voci checklist</span>
      <span style="font-size:.75rem;color:#64748b">Avviata: <%= (run.started_at||'').substring(0,16).replace('T',' ') %></span>
    </div>
    <div class="log-card-body">
      <% if(!runItems.length){ %>
        <div style="text-align:center;padding:2rem;color:#94a3b8">Questo template non aveva voci.</div>
      <% } else { runItems.forEach(function(it){ %>
        <div class="ci-item<%= it.done?' done':'' %>" id="ri-<%= it.id %>" onclick="toggle(<%= run.id %>,<%= it.id %>)">
          <div class="ci-check"><%= it.done?'✓':'' %></div>
          <span class="ci-text"><%= it.text %></span>
          <% if(it.done&&it.done_by){ %><span class="ci-meta"><%= it.done_by %> · <%= (it.done_at||'').substring(11,16) %></span><% } %>
        </div>
      <% }); } %>
    </div>
  </div>

  <div style="text-align:center;margin-top:1rem">
    <a href="/admin/checklist" style="font-size:.84rem;color:#64748b">← Torna alle checklist</a>
  </div>
</div>

<script>
var total=<%= total %>, done=<%= done %>;
function toggle(runId,itemId){
  var el=document.getElementById('ri-'+itemId);
  var isDone=!el.classList.contains('done');
  fetch('/admin/checklist/run/'+runId+'/item/'+itemId+'/toggle',{
    method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({done:isDone})
  }).then(function(r){return r.json();}).then(function(d){
    if(!d.ok) return;
    var chk=el.querySelector('.ci-check');
    if(isDone){el.classList.add('done');chk.textContent='✓';done++;}
    else{el.classList.remove('done');chk.textContent='';done--;}
    var pct=total>0?Math.round((done/total)*100):0;
    document.getElementById('prog-fill').style.width=pct+'%';
    document.getElementById('complete-banner').style.display=(done===total&&total>0)?'block':'none';
  });
}
</script>
</body>
</html>
