<%- include('partials/header') %>
<style>
  .gm-card{background:#fff;border:1px solid #e2e8f0;border-radius:12px;box-shadow:0 1px 4px rgba(30,45,78,.06);padding:1.2rem 1.4rem;margin-bottom:1.1rem}
  .gm-table{width:100%;border-collapse:collapse;font-size:.83rem}
  .gm-table th{text-align:left;padding:.42rem .7rem;font-size:.67rem;text-transform:uppercase;letter-spacing:.45px;color:#64748b;font-weight:700;border-bottom:2px solid #e2e8f0;white-space:nowrap}
  .gm-table td{padding:.48rem .7rem;border-bottom:1px solid #f1f5f9;vertical-align:middle}
  .gm-table tr:hover td{background:#f8fafc}
  .gm-btn{display:inline-flex;align-items:center;gap:.3rem;padding:.3rem .75rem;border-radius:7px;font-size:.75rem;font-weight:700;border:none;cursor:pointer;text-decoration:none;transition:opacity .15s}
  .gm-btn:hover{opacity:.82}
  .gm-btn-primary{background:#1d6fa4;color:#fff}
  .gm-btn-danger{background:#fee2e2;color:#991b1b}
  .alert-ok{background:#dcfce7;color:#155724;border:1px solid #a7f3d0;border-radius:8px;padding:.55rem 1rem;font-size:.82rem;margin-bottom:1rem}
  .alert-err{background:#fee2e2;color:#991b1b;border:1px solid #fca5a5;border-radius:8px;padding:.55rem 1rem;font-size:.82rem;margin-bottom:1rem}
  select,input[type=text],input[type=number],textarea{width:100%;padding:.42rem .65rem;border:1.5px solid #d1d9e6;border-radius:7px;font-size:.83rem;background:#fff;transition:border-color .15s}
  select:focus,input:focus,textarea:focus{outline:none;border-color:#1d6fa4}
  label{font-size:.73rem;font-weight:700;color:#475569;display:block;margin-bottom:.2rem}
  .form-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:.8rem}
  @media(max-width:640px){.form-grid{grid-template-columns:1fr}}
</style>

<div style="max-width:860px;margin:0 auto;padding:1.2rem 1rem">
  <div style="display:flex;align-items:center;gap:1rem;margin-bottom:.5rem;flex-wrap:wrap">
    <a href="/assignment-groups/<%= group.id %>" style="font-size:.78rem;color:#64748b;text-decoration:none">&#8592; <%= group.name %></a>
  </div>

  <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:.8rem;margin-bottom:1.3rem">
    <div>
      <h1 style="font-size:1.3rem;font-weight:800;color:#1e2d4e;margin:0">Materiali &mdash; <%= group.name %></h1>
      <p style="font-size:.78rem;color:#64748b;margin:.2rem 0 0">
        <% if(group.zone){ %><strong><%= group.zone %></strong><% } %>
        <% if(group.stand_code){ %> &middot; Stand <strong><%= group.stand_code %></strong><% } %>
        <% if(group.category_name){ %> &middot; <%= group.category_name %><% } %>
      </p>
    </div>
    <a href="/admin/logistica/resoconto" class="gm-btn gm-btn-primary">Resoconto fabbisogni &rarr;</a>
  </div>

  <% if(saved==='ok'){ %><div class="alert-ok">✅ Materiale aggiunto.</div><% } %>
  <% if(saved==='err'){ %><div class="alert-err">⚠️ Errore: controlla i campi e riprova.</div><% } %>

  <!-- FORM AGGIUNGI -->
  <div class="gm-card">
    <h3 style="font-size:.8rem;text-transform:uppercase;letter-spacing:.5px;color:#64748b;font-weight:700;margin:0 0 1rem">Aggiungi materiale</h3>
    <form method="POST" action="/assignment-groups/<%= group.id %>/materiali">
      <div class="form-grid">
        <div>
          <label>Categoria</label>
          <select name="category" required>
            <% logisticCategories.forEach(function(cat){ %>
              <option value="<%= cat.keyname %>"><%= cat.icon %> <%= cat.label %></option>
            <% }) %>
            <% if(!logisticCategories.length){ %>
              <option value="altro">📦 Altro</option>
            <% } %>
          </select>
        </div>
        <div>
          <label>Articolo</label>
          <input type="text" name="itemname" placeholder="es. Tavolo pieghevole, Cassa audio, Gazebo 3x3…" maxlength="100" required>
        </div>
        <div>
          <label>Quantità</label>
          <input type="number" name="quantity" value="1" min="1" max="999" required>
        </div>
        <div style="grid-column:span 2">
          <label>Note (opzionale)</label>
          <input type="text" name="notes" placeholder="Specifiche aggiuntive" maxlength="255">
        </div>
      </div>
      <div style="margin-top:.9rem;display:flex;gap:.5rem">
        <button type="submit" class="gm-btn gm-btn-primary">Aggiungi</button>
      </div>
    </form>
  </div>

  <!-- TABELLA MATERIALI ESISTENTI -->
  <div class="gm-card">
    <h3 style="font-size:.8rem;text-transform:uppercase;letter-spacing:.5px;color:#64748b;font-weight:700;margin:0 0 1rem">
      Materiali richiesti
      <% if(materials.length){ %>
        <span style="background:#e0f2fe;color:#0369a1;padding:.1rem .5rem;border-radius:9999px;font-size:.68rem;font-weight:700;margin-left:.4rem"><%= materials.length %></span>
      <% } %>
    </h3>
    <% if(!materials.length){ %>
      <div style="text-align:center;padding:2rem 1rem;color:#94a3b8">
        <div style="font-size:2rem;margin-bottom:.4rem">📦</div>
        <p style="font-size:.83rem">Nessun materiale aggiunto.</p>
      </div>
    <% } else { %>
    <div style="overflow-x:auto">
      <table class="gm-table">
        <thead><tr>
          <th>#</th><th>Categoria</th><th>Articolo</th><th>Qt</th>
          <th>Stato</th><th>Conf.</th><th>Cons.</th><th>Note</th><th>Azione</th>
        </tr></thead>
        <tbody>
        <% materials.forEach(function(m){ %>
          <tr id="row-<%= m.id %>">
            <td style="color:#94a3b8;font-size:.72rem"><%= m.id %></td>
            <td style="color:#64748b;font-size:.76rem"><%= m.category %></td>
            <td style="font-weight:600"><%= m.item_name %></td>
            <td style="font-weight:700;font-variant-numeric:tabular-nums;text-align:right"><%= m.quantity %></td>
            <td>
              <select class="status-sel" data-id="<%= m.id %>" onchange="updateStatus(this)" style="width:auto;padding:.2rem .4rem;font-size:.72rem;border-radius:6px">
                <% ['richiesto','confermato','consegnato','annullato'].forEach(function(s){ %>
                  <option value="<%= s %>"<%= m.status===s?' selected':'' %>><%= s %></option>
                <% }) %>
              </select>
            </td>
            <td><input type="number" class="conf-qty" data-id="<%= m.id %>" value="<%= m.confirmed_qty||0 %>" min="0" max="999" onchange="updateStatus(this)" style="width:58px;padding:.22rem .4rem;font-size:.76rem;border-radius:6px;border:1.5px solid #d1d9e6"></td>
            <td><input type="number" class="del-qty"  data-id="<%= m.id %>" value="<%= m.delivered_qty||0 %>" min="0" max="999" onchange="updateStatus(this)" style="width:58px;padding:.22rem .4rem;font-size:.76rem;border-radius:6px;border:1.5px solid #d1d9e6"></td>
            <td style="font-size:.76rem;color:#64748b;max-width:140px"><%= m.notes %></td>
            <td><button class="gm-btn gm-btn-danger" onclick="deleteMaterial(<%= m.id %>)" style="padding:.22rem .6rem;font-size:.7rem">✕</button></td>
          </tr>
        <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>

<script>
  const GRPID = <%= group.id %>;

  async function updateStatus(el) {
    const id = el.dataset.id;
    const row = document.getElementById('row-' + id);
    const status   = row.querySelector('.status-sel').value;
    const confQty  = row.querySelector('.conf-qty').value;
    const delQty   = row.querySelector('.del-qty').value;
    try {
      const r = await fetch(`/assignment-groups/${GRPID}/materiali/${id}/status`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status, confirmedqty: confQty, deliveredqty: delQty })
      });
      const d = await r.json();
      if (!d.ok) alert('Errore aggiornamento: ' + d.error);
    } catch(e) { alert('Errore di rete: ' + e.message); }
  }

  async function deleteMaterial(id) {
    if (!confirm('Eliminare questa voce di materiale?')) return;
    try {
      const r = await fetch(`/assignment-groups/${GRPID}/materiali/${id}`, { method: 'DELETE' });
      const d = await r.json();
      if (d.ok) {
        const row = document.getElementById('row-' + id);
        if (row) row.remove();
      } else { alert('Errore: ' + d.error); }
    } catch(e) { alert('Errore di rete: ' + e.message); }
  }
</script>
<%- include('partials/footer') %>
