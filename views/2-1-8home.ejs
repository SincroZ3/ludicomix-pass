<%- include('partials/header') %>
<nav class="breadcrumb-bar">Sei in: <strong>Home</strong></nav>
<h1 class="page-title">Dashboard</h1>
<style>
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(185px,1fr));gap:.9rem;margin-bottom:1.5rem}
.kpi-card{background:var(--bg-white);border:1px solid var(--border);border-radius:var(--radius-md);padding:1rem 1.2rem;box-shadow:var(--shadow-sm);border-top:3px solid var(--kc,var(--accent-blue))}
.kpi-label{font-size:.72rem;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);font-weight:700}
.kpi-value{font-size:2rem;font-weight:800;color:var(--kc,var(--accent-blue));line-height:1.1;margin:.2rem 0}
.kpi-sub{font-size:.75rem;color:var(--text-muted)}
.status-pills{display:flex;flex-wrap:wrap;gap:.4rem;margin-bottom:1.5rem}
.spill{display:inline-flex;align-items:center;gap:.35rem;padding:.3rem .75rem;border-radius:9999px;font-size:.78rem;font-weight:700;background:var(--bg-section);border:1px solid var(--border);color:var(--text-primary)}
.spill span{border-radius:9999px;padding:.05rem .5rem;font-size:.72rem;color:#fff}
.dash-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem}
@media(max-width:680px){.dash-row{grid-template-columns:1fr}}
.dash-box{background:var(--bg-white);border:1px solid var(--border);border-radius:var(--radius-md);padding:1rem 1.2rem;box-shadow:var(--shadow-sm)}
.dash-box h3{font-size:.75rem;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);font-weight:700;margin:0 0 .75rem}
.pbar-wrap{background:var(--border-light);border-radius:9999px;height:7px;margin-top:.25rem}
.pbar{height:7px;border-radius:9999px}
.act-item{display:flex;gap:.5rem;align-items:flex-start;padding:.4rem 0;border-bottom:1px solid var(--border-light);font-size:.8rem}
.act-item:last-child{border:none}
.icon-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:.7rem;margin-top:.75rem}
.icon-item{display:flex;flex-direction:column;align-items:center;gap:.4rem;padding:.9rem .5rem;background:var(--bg-white);border:1px solid var(--border);border-radius:var(--radius-md);text-decoration:none;color:var(--text-primary);font-size:.78rem;font-weight:700;text-align:center;transition:box-shadow .15s,border-color .15s;box-shadow:var(--shadow-sm)}
.icon-item:hover{box-shadow:var(--shadow-md);border-color:var(--accent-blue);color:var(--accent-blue)}
.icon-emoji{font-size:1.7rem}
</style>
<% var ps=(stats&&stats.passesByStatus)?stats.passesByStatus:{}; %>
<% var totCons=(ps['CONSEGNATO']||0)+(ps['RICONSEGNATO']||0); %>
<% var STATI=['GENERATO','SCARICATO','STAMPATO','CONSEGNATO','RICONSEGNATO']; %>
<% var pillC={GENERATO:'#6b3fa0',SCARICATO:'#1d6fa4',STAMPATO:'#c9a227',CONSEGNATO:'#2d6a4f',RICONSEGNATO:'#c0392b'}; %>

<div class="kpi-grid">
  <div class="kpi-card" style="--kc:#1d6fa4">
    <div class="kpi-label">&#128101; Partecipanti</div>
    <div class="kpi-value"><%= stats.totalParticipants %></div>
    <div class="kpi-sub">registrati</div>
  </div>
  <div class="kpi-card" style="--kc:#6b3fa0">
    <div class="kpi-label">&#127931; Pass generati</div>
    <div class="kpi-value"><%= stats.totalPasses %></div>
    <div class="kpi-sub">totali</div>
  </div>
  <div class="kpi-card" style="--kc:#2d6a4f">
    <div class="kpi-label">&#10003; Consegnati</div>
    <div class="kpi-value"><%= totCons %></div>
    <div class="kpi-sub">consegnati + riconsegnati</div>
  </div>
  <div class="kpi-card" style="--kc:<%= stats.senzaPass>0?'#c0392b':'#2d6a4f' %>">
    <div class="kpi-label">&#9888; Senza pass</div>
    <div class="kpi-value"><%= stats.senzaPass %></div>
    <div class="kpi-sub">partecipanti senza pass</div>
  </div>
</div>

<div class="status-pills">
  <% STATI.forEach(function(s){ %>
    <div class="spill"><%= s %> <span style="background:<%= pillC[s]||'#888' %>"><%= ps[s]||0 %></span></div>
  <% }); %>
</div>

<div class="dash-row" style="grid-template-columns:<% if(currentUser&&currentUser.role==='admin'){ %>1fr 1fr<% }else{ %>1fr<% } %>;">
  <div class="dash-box">
    <h3>&#128680; Gruppi vicini al limite (&ge;80%)</h3>
    <% if(!alertGroups||alertGroups.length===0){ %>
      <p style="color:var(--text-muted);font-size:.82rem;margin:0;">Nessun gruppo supera l&rsquo;80% del limite &#127881;</p>
    <% }else{alertGroups.forEach(function(g){ %>
      <% var pct=Math.min(100,Math.round(g.pass_count/g.max_passes*100)); %>
      <% var bc=pct>=100?'#c0392b':pct>=90?'#c9a227':'#1d6fa4'; %>
      <div style="margin-bottom:.75rem;">
        <div style="display:flex;justify-content:space-between;font-size:.8rem;">
          <strong><%= g.name %></strong>
          <span style="color:<%= bc %>;font-weight:700;"><%= g.pass_count %>&thinsp;/&thinsp;<%= g.max_passes %> (<%= pct %>%)</span>
        </div>
        <div class="pbar-wrap"><div class="pbar" style="width:<%= pct %>%;background:<%= bc %>"></div></div>
      </div>
    <% });} %>
  </div>
  <% if(currentUser&&currentUser.role==='admin'){ %>
  <div class="dash-box">
    <h3>&#128336; Attivit&agrave; recente</h3>
    <% if(!recentActivity||recentActivity.length===0){ %>
      <p style="color:var(--text-muted);font-size:.82rem;margin:0;">Nessuna attivit&agrave; registrata.</p>
    <% }else{recentActivity.forEach(function(a){ %>
      <div class="act-item">
        <div style="flex:1;">
          <strong style="color:var(--brand-violet)">@<%= a.username||'?' %></strong>
          <span style="color:var(--text-secondary)"> &mdash; <%= (a.details||a.action||'').substring(0,55) %></span>
        </div>
        <span style="font-size:.7rem;color:var(--text-muted);white-space:nowrap;"><%= (a.created_at||'').substring(0,16).replace('T',' ') %></span>
      </div>
    <% });} %>
  </div>
  <% } %>
</div>

<div class="dash-box">
  <h3>&#9889; Accesso rapido</h3>
  <div class="icon-grid">
    <a href="/participants"     class="icon-item"><span class="icon-emoji">&#128101;</span>Assegnatari Pass</a>
    <a href="/passes"           class="icon-item"><span class="icon-emoji">&#127931;</span>Pass Generati</a>
    <a href="/reports"          class="icon-item"><span class="icon-emoji">&#128202;</span>Reports</a>
    <a href="/search"           class="icon-item"><span class="icon-emoji">&#128269;</span>Ricerca Pass</a>
    <a href="/account/password" class="icon-item"><span class="icon-emoji">&#128273;</span>Cambia Password</a>
    <a href="/account/security" class="icon-item"><span class="icon-emoji">&#128274;</span>Password Sicurezza</a>
    <% if(currentUser&&currentUser.role==='admin'){ %>
        <a href="/admin/logs"     class="icon-item"><span class="icon-emoji">&#128203;</span>Log Azioni</a>
      <a href="/admin/settings" class="icon-item"><span class="icon-emoji">&#9881;&#65039;</span>Impostazioni</a>
    <% } %>
  </div>
</div>
<%- include('partials/footer') %>
