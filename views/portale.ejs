<script>
(function(){
  var token = '<%= token %>';
  window.__SRV_TOKEN = token; // esposto globalmente per il modulo servizi
  var marked = false;

  // Segna come letti al caricamento se la bacheca è visibile
  function markRead() {
    if (marked) return;
    marked = true;
    fetch('/portale/'+token+'/bacheca/read', { method:'POST' })
      .then(function(){
        var b = document.getElementById('unread-badge');
        if (b) { b.style.display='none'; b.textContent=''; }
      }).catch(function(){});
  }

  // Auto-mark letti dopo 2s dalla visualizzazione della pagina (bacheca è in cima)
  var unread = <%= typeof unreadCount !== 'undefined' ? unreadCount : 0 %>;
  if (unread > 0) { setTimeout(markRead, 2000); }

  // Toggle collassa/espandi intera bacheca
  window.toggleBacheca = function() {
    var body  = document.getElementById('bach-body');
    var label = document.getElementById('bach-toggle-label');
    if (!body) return;
    if (body.style.maxHeight === '0px') {
      body.style.maxHeight = '2000px'; body.style.opacity = '1';
      label.textContent = '▲ Nascondi';
    } else {
      body.style.maxHeight = '0px'; body.style.opacity = '0';
      label.textContent = '▼ Mostra';
    }
  };

  // Toggle messaggi letti (se sezione collassata)
  window.toggleRead = function() {
    var list = document.getElementById('read-list');
    var btn  = document.getElementById('read-toggle');
    if (!list) return;
    if (list.style.display === 'none' || !list.style.display) {
      list.style.display = 'block'; btn.textContent = 'Nascondi ▴';
    } else {
      list.style.display = 'none'; btn.textContent = 'Mostra ▾';
    }
  };

  // Polling ogni 60s — aggiorna badge se arrivano nuovi messaggi
  setInterval(function(){
    fetch('/api/portale/'+token+'/unread')
      .then(function(r){ return r.json(); })
      .then(function(d){
        var b = document.getElementById('unread-badge');
        if (!b) return;
        if (d.unread > 0) {
          b.textContent = d.unread;
          b.style.display = 'inline-block';
          marked = false; // reset so next interaction marks them
        }
      }).catch(function(){});
  }, 60000);
})();

  // ── DOVE SIETE? ───────────────────────────────────────────────────────────
  (function(){
    var MY_ID   = <%= group.id %>;
    var MY_NAME = '<%= (group.stand_name || group.name || '').replace(/'/g, "\\'") %>';
    var MY_CODE = '<%= (group.stand_code || '').replace(/'/g, "\\'") %>';
    var MY_ZONE = '<%= (group.zone || '').replace(/'/g, "\\'") %>';
    var BG_IMG  = '<% if(zoneInfo && zoneInfo.background_image){ %>/zone-bg/<%= zoneInfo.background_image %><% } %>';
    var ALL_STANDS = <%- JSON.stringify(zoneStands || []) %>;

    // ── COORDINATE REFERENCE ─────────────────────────────────────────────────
    // map_x/map_y sono % del div admin (width=REF_W, height=REF_H).
    // Usiamo queste stesse dimensioni come spazio coordinate interno del canvas:
    // il canvas avrà canvas.width=REF_W, canvas.height=REF_H e verrà scalato
    // al 100% del container via CSS → coordinate identiche alla mappa admin.
    var REF_W = <%= (typeof mapRefW !== 'undefined' && mapRefW) ? mapRefW : 1200 %>;
    var REF_H = <%= (typeof mapRefH !== 'undefined' && mapRefH) ? mapRefH : 520 %>;

    // Assicura che lo stand corrente sia in ALL_STANDS
    if (!ALL_STANDS.find(function(s){ return s.id === MY_ID; })) {
      ALL_STANDS.push({
        id: MY_ID,
        map_x: <%= group.map_x || 50 %>,
        map_y: <%= group.map_y || 50 %>,
        map_w: <%= group.map_w || 8 %>,
        map_h: <%= group.map_h || 5 %>
      });
    }

    // ── RENDERING ────────────────────────────────────────────────────────────
    function drawMap(canvas, highlightPulse) {
      if (!canvas) return;

      // Il canvas usa le stesse coordinate del div admin
      canvas.width  = REF_W;
      canvas.height = REF_H;
      canvas.style.width  = '100%';
      canvas.style.height = 'auto';

      var ctx = canvas.getContext('2d');
      var W = REF_W, H = REF_H;
      ctx.clearRect(0, 0, W, H);

      function renderStands() {
        ALL_STANDS.forEach(function(s) {
          var sw = (s.map_w || 8) / 100 * W;
          var sh = (s.map_h || 5) / 100 * H;
          // map_x/map_y = CENTRO stand (transform:translate(-50%,-50%) nel admin)
          var sx = s.map_x / 100 * W - sw / 2;
          var sy = s.map_y / 100 * H - sh / 2;
          var isMe = s.id === MY_ID;

          if (isMe) {
            ctx.shadowColor = 'rgba(245,200,66,.85)';
            ctx.shadowBlur  = highlightPulse ? 24 : 16;
            ctx.fillStyle   = 'rgba(245,200,66,.92)';
            ctx.strokeStyle = '#c9a227';
            ctx.lineWidth   = 3;
          } else {
            ctx.shadowBlur  = 0;
            ctx.fillStyle   = 'rgba(100,116,139,.20)';
            ctx.strokeStyle = 'rgba(100,116,139,.50)';
            ctx.lineWidth   = 1;
          }

          // Forma (polygon o rect)
          var shape = null;
          if (s.map_shape) { try { shape = JSON.parse(s.map_shape); } catch(e){} }
          if (shape && Array.isArray(shape) && shape.length > 2) {
            ctx.beginPath();
            ctx.moveTo(sx + shape[0][0]/100*sw, sy + shape[0][1]/100*sh);
            for (var i=1; i<shape.length; i++)
              ctx.lineTo(sx + shape[i][0]/100*sw, sy + shape[i][1]/100*sh);
            ctx.closePath();
            ctx.fill(); ctx.stroke();
          } else {
            ctx.beginPath();
            ctx.roundRect ? ctx.roundRect(sx,sy,sw,sh,3) : ctx.rect(sx,sy,sw,sh);
            ctx.fill(); ctx.stroke();
          }
          ctx.shadowBlur = 0;

          // Etichetta solo per lo stand corrente
          if (isMe) {
            var label    = MY_CODE ? ('Stand ' + MY_CODE) : MY_NAME;
            var fontSize = Math.max(11, Math.min(18, sw * 0.16));
            ctx.font          = 'bold ' + fontSize + 'px Inter,sans-serif';
            ctx.textAlign     = 'center';
            ctx.textBaseline  = 'bottom';

            var tw = ctx.measureText(label).width + 14;
            var th = fontSize + 10;
            var lx = sx + sw/2 - tw/2;
            var ly = sy - th - 5;
            if (ly < 2) ly = sy + sh + 5;

            ctx.fillStyle = 'rgba(30,45,78,.88)';
            ctx.beginPath();
            ctx.roundRect ? ctx.roundRect(lx,ly,tw,th,4) : ctx.rect(lx,ly,tw,th);
            ctx.fill();

            ctx.fillStyle = '#f5c842';
            ctx.fillText(label, sx + sw/2, ly + th - 4);

            // Stella al centro
            ctx.fillStyle    = '#c9a227';
            ctx.beginPath();
            ctx.arc(sx+sw/2, sy+sh/2, Math.min(sw,sh)*0.13, 0, Math.PI*2);
            ctx.fill();
            ctx.fillStyle    = '#fff';
            ctx.font         = 'bold ' + Math.max(9, Math.min(sw,sh)*0.18) + 'px sans-serif';
            ctx.textBaseline = 'middle';
            ctx.fillText('★', sx+sw/2, sy+sh/2);
          }
        });

        // Watermark
        ctx.save();
        ctx.font      = 'bold 11px Inter,sans-serif';
        ctx.fillStyle = 'rgba(30,45,78,.30)';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'bottom';
        ctx.fillText('Ludicomix — ' + MY_ZONE, W-8, H-6);
        ctx.restore();
      }

      if (BG_IMG) {
        var img = new Image();
        img.crossOrigin = 'anonymous';
        img.onload = function() {
          // Replica esatta CSS admin: background-size:contain; background-position:center top
          var scale = Math.min(W / img.naturalWidth, H / img.naturalHeight);
          var dw = img.naturalWidth * scale, dh = img.naturalHeight * scale;
          var dx = (W - dw) / 2; // center horizontale
          var dy = 0;            // top
          ctx.fillStyle = '#e8ecf3';
          ctx.fillRect(0, 0, W, H);
          ctx.drawImage(img, dx, dy, dw, dh);
          renderStands();
        };
        img.onerror = function() { BG_IMG = ''; ctx.fillStyle='#e8ecf3'; ctx.fillRect(0,0,W,H); renderStands(); };
        img.src = BG_IMG;
      } else {
        ctx.fillStyle = '#e8ecf3';
        ctx.fillRect(0, 0, W, H);
        // Grid leggera
        ctx.strokeStyle = 'rgba(148,163,184,.2)';
        ctx.lineWidth = 1;
        for (var gx=0; gx<=W; gx+=W/24){ctx.beginPath();ctx.moveTo(gx,0);ctx.lineTo(gx,H);ctx.stroke();}
        for (var gy=0; gy<=H; gy+=H/12){ctx.beginPath();ctx.moveTo(0,gy);ctx.lineTo(W,gy);ctx.stroke();}
        renderStands();
      }
    }

    // Prima render
    var smallCanvas = document.getElementById('dove-canvas');
    if (smallCanvas) {
      drawMap(smallCanvas, false);
      var pulse = false;
      setInterval(function(){
        pulse = !pulse;
        drawMap(smallCanvas, pulse);
      }, 2000);
    }

    // Modal
    window.openMapModal = function() {
      var modal = document.getElementById('dove-modal');
      if (!modal) return;
      modal.classList.add('open');
      drawMap(document.getElementById('dove-canvas-large'), true);
    };
    window.closeMapModal = function() {
      var modal = document.getElementById('dove-modal');
      if (modal) modal.classList.remove('open');
    };

    // Download immagine
    window.downloadMapImage = function() {
      var exp = document.createElement('canvas');
      exp.width  = REF_W * 2;   // doppia risoluzione per qualità social
      exp.height = REF_H * 2;
      var ctx2 = exp.getContext('2d');
      var EW = exp.width, EH = exp.height;

      function exportDraw(bgImg) {
        ctx2.fillStyle = '#e8ecf3';
        ctx2.fillRect(0, 0, EW, EH);

        if (bgImg) {
          var scale = Math.min(EW / bgImg.naturalWidth, EH / bgImg.naturalHeight);
          var dw = bgImg.naturalWidth * scale, dh = bgImg.naturalHeight * scale;
          ctx2.drawImage(bgImg, (EW-dw)/2, 0, dw, dh);
        }

        // Stand
        ALL_STANDS.forEach(function(s) {
          var sw = (s.map_w||8)/100*EW, sh = (s.map_h||5)/100*EH;
          var sx = s.map_x/100*EW - sw/2, sy = s.map_y/100*EH - sh/2;
          var isMe = s.id === MY_ID;
          var shape = null;
          if (s.map_shape){try{shape=JSON.parse(s.map_shape);}catch(e){}}
          ctx2.shadowBlur = 0;
          if (isMe){ ctx2.shadowColor='rgba(245,200,66,.85)';ctx2.shadowBlur=32;ctx2.fillStyle='rgba(245,200,66,.92)';ctx2.strokeStyle='#c9a227';ctx2.lineWidth=5; }
          else      { ctx2.fillStyle='rgba(100,116,139,.20)';ctx2.strokeStyle='rgba(100,116,139,.50)';ctx2.lineWidth=1.5; }
          if (shape&&shape.length>2){
            ctx2.beginPath();ctx2.moveTo(sx+shape[0][0]/100*sw,sy+shape[0][1]/100*sh);
            for(var i=1;i<shape.length;i++)ctx2.lineTo(sx+shape[i][0]/100*sw,sy+shape[i][1]/100*sh);
            ctx2.closePath();
          } else { ctx2.beginPath();ctx2.rect(sx,sy,sw,sh); }
          ctx2.fill(); ctx2.stroke();
          ctx2.shadowBlur = 0;
          if (isMe) {
            var label=MY_CODE?('Stand '+MY_CODE):MY_NAME;
            ctx2.font='bold 22px Inter,sans-serif';ctx2.textAlign='center';ctx2.textBaseline='bottom';
            var tw=ctx2.measureText(label).width+18,th=32;
            var lx=sx+sw/2-tw/2,ly=sy-th-7;if(ly<2)ly=sy+sh+7;
            ctx2.fillStyle='rgba(30,45,78,.88)';ctx2.fillRect(lx,ly,tw,th);
            ctx2.fillStyle='#f5c842';ctx2.fillText(label,sx+sw/2,ly+th-5);
          }
        });

        // Header banner
        ctx2.fillStyle='rgba(30,45,78,.90)';
        ctx2.fillRect(0, 0, EW, 56);
        ctx2.font='bold 22px Inter,sans-serif';
        ctx2.fillStyle='#f5c842';
        ctx2.textAlign='left';ctx2.textBaseline='middle';
        ctx2.fillText('📍 '+(MY_CODE?'Stand '+MY_CODE+' — ':'')+MY_NAME+'   ·   '+MY_ZONE, 18, 28);
        ctx2.fillStyle='rgba(255,255,255,.45)';
        ctx2.font='14px Inter,sans-serif';
        ctx2.textAlign='right';
        ctx2.fillText('ludicomix.it', EW-16, 28);

        exp.toBlob(function(blob){
          var a=document.createElement('a');
          a.href=URL.createObjectURL(blob);
          a.download='dove-sono-'+(MY_CODE||MY_NAME).toLowerCase().replace(/\s+/g,'-')+'.png';
          a.click();
        },'image/png');
      }

      if (BG_IMG) {
        var imgE=new Image(); imgE.crossOrigin='anonymous';
        imgE.onload=function(){exportDraw(imgE);};
        imgE.onerror=function(){exportDraw(null);};
        imgE.src=BG_IMG;
      } else { exportDraw(null); }
    };

    document.addEventListener('keydown', function(e){
      if(e.key==='Escape') window.closeMapModal();
    });
  })();



// ── Servizi ──────────────────────────────────────────────────────────────────
var __SRV_TYPE = null;
var __SRV_LABELS = {
  corrente:'⚡ Corrente', gazebo:'⛺ Gazebo',
  tavoli_extra:'🪑 Tavoli', sedie_extra:'🪑 Sedie',
  transenne:'🚧 Transenne', altro:'📦 Altro'
};
var __SRV_STATUS = {
  in_attesa:{label:'In attesa',cls:'srv-pill-wait'},
  approvato:{label:'Approvato', cls:'srv-pill-ok'},
  consegnato:{label:'Consegnato',cls:'srv-pill-done'},
  annullato:{label:'Annullato', cls:'srv-pill-cancel'}
};
function selectSrvType(btn) {
  document.querySelectorAll('.srv-type-btn').forEach(function(b){b.classList.remove('sel');});
  btn.classList.add('sel');
  __SRV_TYPE = btn.getAttribute('data-type');
  document.getElementById('srv-form-extra').style.display='block';
  document.getElementById('srv-msg').style.display='none';
}
function submitSrvRequest() {
  if(!__SRV_TYPE) return;
  var qty=parseInt(document.getElementById('srv-qty').value,10)||1;
  var notes=document.getElementById('srv-notes').value.trim();
  var btn=document.getElementById('srv-submit-btn');
  var msg=document.getElementById('srv-msg');
  btn.disabled=true; btn.textContent='⏳ Invio…';
  fetch('/api/portale/'+__SRV_TOKEN+'/service-request',{
    method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({type:__SRV_TYPE,quantity:qty,notes:notes})
  })
  .then(function(r){return r.json();})
  .then(function(d){
    btn.disabled=false; btn.textContent='📨 Invia richiesta';
    msg.style.display='block';
    if(d.ok){
      msg.className='form-msg ok'; msg.textContent='✅ Richiesta inviata!';
      document.querySelectorAll('.srv-type-btn').forEach(function(b){b.classList.remove('sel');});
      document.getElementById('srv-form-extra').style.display='none';
      document.getElementById('srv-notes').value='';
      document.getElementById('srv-qty').value='1';
      __SRV_TYPE=null; loadSrvHistory();
    } else {
      msg.className='form-msg err'; msg.textContent='❌ '+(d.error||'Errore imprevisto');
    }
  })
  .catch(function(){
    btn.disabled=false; btn.textContent='📨 Invia richiesta';
    msg.style.display='block'; msg.className='form-msg err'; msg.textContent='Errore di rete.';
  });
}
function loadSrvHistory(){
  var list=document.getElementById('srv-list');
  if(!list) return;
  fetch('/api/portale/'+__SRV_TOKEN+'/service-requests')
  .then(function(r){return r.json();})
  .then(function(rows){
    if(!rows.length){list.innerHTML='<li class="empty-msg" style="padding:.5rem 0">Nessuna richiesta ancora inviata.</li>';return;}
    list.innerHTML=rows.map(function(r){
      var sc=__SRV_STATUS[r.status]||__SRV_STATUS.in_attesa;
      return '<li><span class="srv-pill '+sc.cls+'">'+sc.label+'</span> <strong>'+(r.quantity>1?r.quantity+'× ':'')+(__SRV_LABELS[r.type]||r.type)+'</strong>'+(r.notes?' <span style="color:var(--muted)">— '+r.notes+'</span>':'')+' <span style="font-size:.72rem;color:var(--faint);margin-left:auto;white-space:nowrap">'+((r.requested_at||'').substring(0,16).replace('T',' '))+'</span></li>';
    }).join('');
  })
  .catch(function(){list.innerHTML='<li class="empty-msg" style="padding:.5rem 0">Impossibile caricare le richieste.</li>';});
}
if(typeof __SRV_TOKEN!=='undefined'&&__SRV_TOKEN){loadSrvHistory();}


// ═══════════════════════════════════════════════════════════
//  PORTALE — Funzioni interattive (nominativi, docs, ticket)
// ═══════════════════════════════════════════════════════════

function esc(s) {
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ── Aggiungi nominativo ───────────────────────────────────
function addNominativo(e) {
  e.preventDefault();
  if (typeof __WC !== 'undefined' && __WC) {
    alert("La finestra di inserimento è chiusa. Non è possibile aggiungere nominativi."); return;
  }
  var form = document.getElementById('add-nom-form');
  var btn  = document.getElementById('add-nom-btn');
  var msg  = document.getElementById('add-nom-msg');
  var fd   = new FormData(form);
  var fn   = (fd.get('first_name') || '').trim();
  var ln   = (fd.get('last_name')  || '').trim();
  var role = (fd.get('role')       || '').trim();

  if (!fn || !ln) { msg.textContent = "Nome e cognome obbligatori."; msg.className = 'form-msg err'; return; }

  btn.disabled = true; btn.textContent = "Salvataggio...";
  msg.textContent = ''; msg.className = 'form-msg';

  fetch('/api/portale/' + window.__SRV_TOKEN + '/participants', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ first_name: fn, last_name: ln, role: role })
  })
  .then(function(r){ return r.json().then(function(d){ return {ok:r.ok,data:d}; }); })
  .then(function(result) {
    btn.disabled = false; btn.textContent = "\u2713 Aggiungi";
    if (!result.ok) {
      msg.textContent = result.data.error || "Errore durante il salvataggio.";
      msg.className = 'form-msg err';
      return;
    }
    var listEl = document.getElementById('nom-list');
    if (listEl) {
      var row = document.createElement('div');
      row.id = 'nom-row-' + result.data.id;
      row.className = 'item-card';
      row.style.cssText = 'display:flex;align-items:center;gap:.65rem;padding:.55rem .85rem;';
      row.innerHTML =
        '<span style="font-size:1.1rem;">\uD83D\uDC64</span>' +
        '<div style="flex:1;min-width:0;">' +
          '<div style="font-size:.85rem;font-weight:700;">' + esc(ln) + ' ' + esc(fn) + '</div>' +
          (role ? '<div style="font-size:.74rem;color:var(--muted);">' + esc(role) + '</div>' : '') +
        '</div>' +
        '<span class="pill pill-gray" style="font-size:.68rem;">\u23F3 Senza pass</span>' +
        '<button type="button" onclick="removeNominativo(' + result.data.id + ', this)" ' +
          'class="btn btn-danger btn-xs" title="Rimuovi nominativo">\u2715 Rimuovi</button>';
      listEl.appendChild(row);
    }
    form.reset();
    msg.textContent = "\u2713 Nominativo aggiunto con successo!";
    msg.className = 'form-msg ok';
    setTimeout(function(){ msg.textContent = ''; msg.className = 'form-msg'; }, 3500);
  })
  .catch(function(){
    btn.disabled = false; btn.textContent = "\u2713 Aggiungi";
    msg.textContent = "Errore di rete. Riprova."; msg.className = 'form-msg err';
  });
}

// ── Rimuovi nominativo ────────────────────────────────────
function removeNominativo(pid, btnEl) {
  if (!confirm("Rimuovere questo nominativo dalla lista?")) return;
  var msgEl = document.getElementById('nom-remove-msg');
  if (msgEl) { msgEl.style.display = 'none'; }
  btnEl.disabled = true;

  fetch('/api/portale/' + window.__SRV_TOKEN + '/participants/' + pid + '/delete', { method: 'POST' })
  .then(function(r){ return r.json().then(function(d){ return {ok:r.ok,data:d}; }); })
  .then(function(result) {
    if (!result.ok) {
      if (msgEl) { msgEl.textContent = result.data.error || "Impossibile rimuovere."; msgEl.style.display = 'block'; msgEl.className = 'form-msg err'; }
      btnEl.disabled = false;
      return;
    }
    var row = document.getElementById('nom-row-' + pid);
    if (row) { row.style.transition = 'opacity .3s'; row.style.opacity = '0'; setTimeout(function(){ row.remove(); }, 320); }
  })
  .catch(function(){
    if (msgEl) { msgEl.textContent = "Errore di rete. Riprova."; msgEl.style.display = 'block'; }
    btnEl.disabled = false;
  });
}

// ── Upload documento ──────────────────────────────────────
function uploadPortalDoc(e) {
  e.preventDefault();
  if (typeof __WC !== 'undefined' && __WC) {
    alert("La finestra di caricamento documenti è chiusa."); return;
  }
  var form = document.getElementById('portal-doc-form');
  var btn  = document.getElementById('portal-doc-btn');
  var msg  = document.getElementById('portal-doc-msg');
  var fd   = new FormData(form);

  var f = fd.get('docfile');
  if (!f || f.size === 0) { msg.textContent = "Seleziona un file da caricare."; msg.className = 'form-msg err'; return; }

  btn.disabled = true; btn.textContent = "Caricamento...";
  msg.textContent = ''; msg.className = 'form-msg';

  fetch('/portale/' + window.__SRV_TOKEN + '/documents', { method: 'POST', body: fd })
  .then(function(r){ return r.json().then(function(d){ return {ok:r.ok,data:d}; }); })
  .then(function(result) {
    btn.disabled = false; btn.textContent = "\u2B06 Carica documento";
    if (!result.ok) {
      msg.textContent = result.data.error || "Errore durante il caricamento.";
      msg.className = 'form-msg err';
    } else {
      form.reset();
      msg.textContent = "\u2713 Documento caricato correttamente.";
      msg.className = 'form-msg ok';
    }
  })
  .catch(function(){
    btn.disabled = false; btn.textContent = "\u2B06 Carica documento";
    msg.textContent = "Errore di rete. Riprova."; msg.className = 'form-msg err';
  });
}

// ── Nuovo ticket ──────────────────────────────────────────
function submitTicket(e) {
  e.preventDefault();
  var form = document.getElementById('ticket-form');
  var btn  = document.getElementById('ticket-btn');
  var msg  = document.getElementById('ticket-msg');
  var fd   = new FormData(form);
  var subj = (fd.get('subject') || '').trim();
  var text = (fd.get('message') || '').trim();

  if (!subj || !text) { msg.textContent = "Oggetto e messaggio obbligatori."; msg.className = 'form-msg err'; return; }

  btn.disabled = true; btn.textContent = "Invio...";
  msg.textContent = ''; msg.className = 'form-msg';

  fetch('/portale/' + window.__SRV_TOKEN + '/tickets', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ subject: subj, message: text })
  })
  .then(function(r){ return r.json().then(function(d){ return {ok:r.ok,data:d}; }); })
  .then(function(result) {
    btn.disabled = false; btn.textContent = "\uD83D\uDCE8 Invia richiesta";
    if (!result.ok) {
      msg.textContent = result.data.error || "Errore durante l'invio.";
      msg.className = 'form-msg err';
    } else {
      form.reset();
      msg.textContent = "\u2713 Richiesta inviata. Riceverai risposta al più presto.";
      msg.className = 'form-msg ok';
      setTimeout(function(){ window.location.reload(); }, 2500);
    }
  })
  .catch(function(){
    btn.disabled = false; btn.textContent = "\uD83D\uDCE8 Invia richiesta";
    msg.textContent = "Errore di rete. Riprova."; msg.className = 'form-msg err';
  });
}

// ── Risposta a ticket ─────────────────────────────────────
function submitReply(tid, btnEl) {
  var input = document.getElementById('reply-input-' + tid);
  var msg   = document.getElementById('reply-msg-' + tid);
  if (!input || !input.value.trim()) {
    if (msg) { msg.textContent = "Scrivi un messaggio prima di inviare."; msg.className = 'form-msg err'; }
    return;
  }
  btnEl.disabled = true; btnEl.textContent = "Invio...";
  if (msg) { msg.textContent = ''; msg.className = 'form-msg'; }

  fetch('/portale/' + window.__SRV_TOKEN + '/tickets/' + tid + '/reply', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ message: input.value.trim() })
  })
  .then(function(r){ return r.json().then(function(d){ return {ok:r.ok,data:d}; }); })
  .then(function(result) {
    btnEl.disabled = false; btnEl.textContent = "\uD83D\uDCE8 Invia";
    if (!result.ok) {
      if (msg) { msg.textContent = result.data.error || "Errore."; msg.className = 'form-msg err'; }
    } else {
      input.value = '';
      if (msg) { msg.textContent = "\u2713 Risposta inviata."; msg.className = 'form-msg ok'; }
      setTimeout(function(){ window.location.reload(); }, 1200);
    }
  })
  .catch(function(){
    btnEl.disabled = false; btnEl.textContent = "\uD83D\uDCE8 Invia";
    if (msg) { msg.textContent = "Errore di rete. Riprova."; msg.className = 'form-msg err'; }
  });
}

</script>
