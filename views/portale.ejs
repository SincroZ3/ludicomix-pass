<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Portale Espositore — <%= group.name %> · Ludicomix</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
/* ── RESET & TOKENS ── */
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#1e2d4e;--navy-mid:#253660;--accent:#6b3fa0;
  --yellow:#f5c842;--gold:#c9a227;
  --violet:#6b3fa0;--violet-light:#8b5cc0;
  --green:#2d6a4f;--red:#c0392b;--blue:#1d6fa4;--gray:#9ca3af;
  --bg:#f0f2f5;--surface:#fff;--border:#d1d9e6;--border-light:#e8ecf3;
  --text:#1a2744;--muted:#64748b;--faint:#94a3b8;
  --radius:12px;--radius-sm:8px;--radius-xs:6px;
  --shadow:0 1px 3px rgba(30,45,78,.08),0 2px 8px rgba(30,45,78,.05);
  --shadow-md:0 3px 12px rgba(30,45,78,.11);
  --shadow-lg:0 8px 32px rgba(30,45,78,.16);
}
body{font-family:'Inter',system-ui,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;line-height:1.55}
a{color:inherit;text-decoration:none}

/* ══════════════════════════════════════════
   TOPBAR / HEADER STAND (invariati)
══════════════════════════════════════════ */
.topbar{display:flex;justify-content:space-between;align-items:center;padding:0 1.5rem;background:var(--navy);min-height:70px;border-bottom:3px solid var(--yellow)}
.brand{display:flex;align-items:center;gap:.75rem}
.brand-ciuco{height:62px;width:auto;display:block;margin-right:.25rem;filter:drop-shadow(0 2px 4px rgba(0,0,0,.4))}
.brand-logo-img{height:54px;width:auto;display:block;filter:drop-shadow(0 1px 2px rgba(0,0,0,.3))}
.brand-text-block{display:flex;flex-direction:column;gap:.05rem}
.brand-sub{font-size:.75rem;color:#aec6e8;font-style:italic;letter-spacing:.2px}
.topbar-right{font-size:.72rem;color:rgba(255,255,255,.4);display:flex;align-items:center;gap:.3rem;white-space:nowrap}
.hdr-stand{background:linear-gradient(135deg,var(--navy) 0%,var(--navy-mid) 60%,#2a1a4e 100%);padding:1.6rem 0;position:relative;overflow:hidden}
.hdr-stand::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 80% 50%,rgba(107,63,160,.22) 0%,transparent 65%);pointer-events:none}
.hdr-inner{max-width:900px;margin:0 auto;padding:0 1.5rem;position:relative}
.hdr-title{font-size:clamp(1.5rem,4vw,2.1rem);font-weight:800;color:#fff;line-height:1.2}
.hdr-title span{color:var(--yellow)}
.wrap{max-width:900px;margin:0 auto;padding:1.4rem 1.5rem 3rem}

/* ══════════════════════════════════════════
   SEZIONE UNIFICATA — pattern uguale ovunque
══════════════════════════════════════════ */
.sec-card{
  background:var(--surface);border:1px solid var(--border);
  border-radius:var(--radius);box-shadow:var(--shadow-md);
  margin-bottom:1.4rem;overflow:hidden;
}
.sec-card-hd{
  display:flex;align-items:center;justify-content:space-between;
  gap:.75rem;padding:.85rem 1.2rem;
  border-bottom:1px solid var(--border-light);
  background:var(--surface);
}
.sec-card-hd-left{display:flex;align-items:center;gap:.55rem}
.sec-card-icon{font-size:1rem;line-height:1;flex-shrink:0}
.sec-card-title{font-size:.78rem;font-weight:800;text-transform:uppercase;letter-spacing:.55px;color:var(--text)}
.sec-card-badge{
  background:var(--red);color:#fff;border-radius:9999px;
  min-width:20px;height:20px;font-size:.65rem;font-weight:800;
  line-height:20px;text-align:center;padding:0 5px;
}
.sec-card-badge-violet{background:var(--violet)}
.sec-card-badge-blue{background:var(--blue)}
.sec-card-actions{display:flex;gap:.45rem;align-items:center;flex-shrink:0}
.sec-card-body{padding:1.15rem 1.2rem}

/* ══════════════════════════════════════════
   BOTTONI UNIFICATI
══════════════════════════════════════════ */
.btn{
  display:inline-flex;align-items:center;justify-content:center;gap:.4rem;
  padding:.5rem 1.1rem;border:none;border-radius:var(--radius-xs);
  font-size:.82rem;font-weight:700;cursor:pointer;text-decoration:none;
  transition:background .15s,box-shadow .15s,transform .1s;font-family:inherit;
  white-space:nowrap;line-height:1;
}
.btn:active{transform:scale(.98)}
.btn-primary{background:var(--navy);color:#fff}
.btn-primary:hover{background:var(--violet)}
.btn-accent{background:var(--accent);color:#fff}
.btn-accent:hover{background:var(--violet-light)}
.btn-outline{background:transparent;color:var(--text);border:1.5px solid var(--border)}
.btn-outline:hover{background:var(--bg);border-color:var(--navy)}
.btn-ghost-navy{background:rgba(255,255,255,.15);border:none;color:#fff}
.btn-ghost-navy:hover{background:rgba(255,255,255,.28)}
.btn-danger{background:var(--red);color:#fff}
.btn-danger:hover{background:#a93224}
.btn-success{background:var(--green);color:#fff}
.btn-success:hover{background:#1f5038}
.btn-full{width:100%}
.btn-sm{padding:.34rem .75rem;font-size:.76rem}
.btn-xs{padding:.25rem .6rem;font-size:.7rem}

/* ══════════════════════════════════════════
   FORM ELEMENTS UNIFICATI
══════════════════════════════════════════ */
.fld{display:flex;flex-direction:column;gap:.3rem}
.fld-label{font-size:.72rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px}
.fld-input,.fld-select,.fld-textarea{
  width:100%;padding:.44rem .7rem;
  border:1.5px solid var(--border);border-radius:var(--radius-xs);
  font-size:.83rem;font-family:inherit;color:var(--text);background:var(--surface);
  transition:border-color .15s,box-shadow .15s;
}
.fld-input:focus,.fld-select:focus,.fld-textarea:focus{
  outline:none;border-color:var(--violet);
  box-shadow:0 0 0 3px rgba(107,63,160,.12);
}
.fld-textarea{resize:vertical}
.fld-file{width:100%;font-size:.82rem;padding:.35rem 0}
.form-grid{display:grid;gap:.65rem;margin-bottom:.85rem}
.form-grid-2{grid-template-columns:1fr 1fr}
.form-span-2{grid-column:1/-1}
.form-footer{display:flex;align-items:center;gap:.75rem;flex-wrap:wrap}
.form-msg{font-size:.76rem;color:var(--muted)}
.form-msg.ok{color:var(--green)}
.form-msg.err{color:var(--red)}

/* ══════════════════════════════════════════
   ITEM CARDS (bach / ticket / doc)
══════════════════════════════════════════ */
.item-list{display:grid;gap:.55rem;margin-bottom:1rem}
.item-card{
  background:var(--bg);border:1px solid var(--border-light);
  border-radius:var(--radius-sm);padding:.85rem 1rem;
  transition:box-shadow .15s;
}
.item-card:hover{box-shadow:var(--shadow)}
.item-card-hd{display:flex;align-items:flex-start;justify-content:space-between;gap:.6rem;margin-bottom:.3rem;flex-wrap:wrap}
.item-card-title{font-size:.88rem;font-weight:700;color:var(--text)}
.item-card-meta{font-size:.7rem;color:var(--faint);margin-top:.1rem}
.item-card-body{font-size:.82rem;color:var(--text);line-height:1.55;white-space:pre-wrap}
.item-card-footer{display:flex;align-items:center;gap:.5rem;margin-top:.65rem;flex-wrap:wrap}

/* Item card con evidenziazione unread */
.item-card.unread{
  background:#fff;border-left:3px solid var(--violet);
  box-shadow:var(--shadow);
}
.item-card.unread-urgent{background:#fff9f9;border-left:3px solid var(--red)}
.item-card.unread-warning{background:#fffef4;border-left:3px solid var(--gold)}
.item-card.unread-info{background:#f5f9ff;border-left:3px solid var(--blue)}
.item-card.read{opacity:.7}

/* Reply thread (ticket) */
.reply-thread{border-top:1px solid var(--border-light);padding-top:.6rem;display:grid;gap:.4rem;margin-top:.5rem}
.reply-bubble{
  padding:.45rem .8rem;border-radius:var(--radius-xs);
  font-size:.81rem;color:var(--text);
}
.reply-admin{background:#eff6ff;border-left:3px solid var(--blue)}
.reply-user{background:var(--bg);border-left:3px solid var(--border)}
.reply-author{font-size:.7rem;font-weight:700;margin-bottom:.2rem}
.reply-author.admin{color:var(--blue)}
.reply-author.user{color:var(--muted)}
.reply-form{display:flex;gap:.5rem;margin-top:.75rem}
.reply-form .fld-input{flex:1}

/* ══════════════════════════════════════════
   PILLS / BADGE STATUS
══════════════════════════════════════════ */
.pill{display:inline-flex;align-items:center;padding:.2rem .6rem;border-radius:9999px;font-size:.68rem;font-weight:800;white-space:nowrap}
.pill-blue{background:#eff6ff;color:#1d6fa4}
.pill-yellow{background:#fefce8;color:#b45309}
.pill-green{background:#f0fdf4;color:#2d6a4f}
.pill-red{background:#fef2f2;color:#c0392b}
.pill-gray{background:#f1f5f9;color:#64748b}
.pill-navy{background:var(--navy);color:var(--yellow)}
.pill-violet{background:rgba(107,63,160,.12);color:var(--violet)}
.pill-orange{background:#fff7ed;color:#c2410c}

/* ══════════════════════════════════════════
   STATO VUOTO UNIFICATO
══════════════════════════════════════════ */
.empty-state{text-align:center;padding:1.8rem 1rem}
.empty-icon{font-size:2rem;margin-bottom:.4rem}
.empty-msg{font-size:.83rem;color:var(--muted)}

/* ══════════════════════════════════════════
   DETAILS/SUMMARY UNIFICATI
══════════════════════════════════════════ */
details.sec-details{
  border:1px solid var(--border-light);border-radius:var(--radius-sm);
  background:var(--surface);overflow:hidden;
}
details.sec-details summary{
  cursor:pointer;padding:.65rem .9rem;
  font-size:.84rem;font-weight:700;color:var(--accent);
  list-style:none;user-select:none;
  border-bottom:1px solid transparent;transition:border-color .15s;
}
details.sec-details[open] summary{border-bottom-color:var(--border-light)}
details.sec-details summary:hover{background:rgba(107,63,160,.04)}
.details-body{padding:.85rem .9rem}

/* ══════════════════════════════════════════
   INFO CARDS KPI (invariate)
══════════════════════════════════════════ */
.info-strip{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:.65rem;margin-bottom:1.4rem}
.info-card{background:var(--surface);border:1px solid var(--border-light);border-radius:var(--radius-sm);padding:.7rem 1rem;box-shadow:var(--shadow);display:flex;flex-direction:column;gap:.2rem}
.info-card-label{font-size:.6rem;text-transform:uppercase;letter-spacing:.7px;font-weight:800;color:var(--faint);display:flex;align-items:center;gap:.3rem}
.info-card-value{font-size:.95rem;font-weight:700;color:var(--text);margin-top:.1rem;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}
.info-card-value.accent-violet{color:var(--violet)}
.info-card-value.accent-blue{color:var(--blue)}
.info-card-value.accent-green{color:var(--green)}
.info-card-value.accent-gold{color:var(--gold)}

/* ══════════════════════════════════════════
   PROGRESS CARD (invariata)
══════════════════════════════════════════ */
.prog-card{background:var(--surface);border:1px solid var(--border-light);border-radius:var(--radius);box-shadow:var(--shadow-md);padding:1.2rem 1.4rem;margin-bottom:1.5rem;display:flex;align-items:center;gap:1.4rem;flex-wrap:wrap}
.prog-num{font-size:2rem;font-weight:800;color:var(--violet);line-height:1;white-space:nowrap}
.prog-num span{font-size:1rem;color:var(--faint);font-weight:600}
.prog-sub{font-size:.74rem;color:var(--muted);margin-top:.15rem}
.prog-bar-wrap{flex:1;min-width:160px}
.prog-bar-track{height:9px;background:var(--border);border-radius:9999px;overflow:hidden;margin-bottom:.45rem}
.prog-bar-fill{height:9px;border-radius:9999px;background:linear-gradient(90deg,var(--violet),var(--violet-light));transition:width .6s ease}
.prog-pct{font-size:.75rem;color:var(--muted)}
.prog-pct strong{color:var(--green);font-weight:700}

/* sec-title (mantenuto per compatibilità, ora usato solo come fallback) */
.sec-title{font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.9px;color:var(--muted);margin:1.6rem 0 .85rem;display:flex;align-items:center;gap:.45rem}
.sec-title::after{content:'';flex:1;height:1px;background:var(--border-light)}

/* ══════════════════════════════════════════
   PASS GRID (invariata)
══════════════════════════════════════════ */
.pass-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(265px,1fr));gap:.9rem;margin-bottom:1.5rem}
.pass-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);padding:1.15rem 1.25rem;display:flex;flex-direction:column;gap:.8rem;transition:box-shadow .15s,transform .15s}
.pass-card:hover{box-shadow:var(--shadow-lg);transform:translateY(-2px)}
.pass-card-top{display:flex;align-items:flex-start;justify-content:space-between;gap:.5rem}
.pass-avatar{width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,var(--violet),var(--violet-light));display:flex;align-items:center;justify-content:center;font-size:.9rem;font-weight:800;color:#fff;flex-shrink:0}
.pass-name{font-size:.9rem;font-weight:700;line-height:1.25}
.pass-role{font-size:.72rem;color:var(--muted);margin-top:.1rem}
.pass-type-badge{display:inline-flex;padding:.2rem .65rem;border-radius:9999px;font-size:.67rem;font-weight:700;background:rgba(29,111,164,.1);color:var(--blue);white-space:nowrap;flex-shrink:0}
.pass-card-mid{display:flex;align-items:center;justify-content:space-between;gap:.5rem}
.status-pill{display:inline-flex;align-items:center;gap:.3rem;padding:.24rem .7rem;border-radius:9999px;font-size:.69rem;font-weight:700;color:#fff}
.status-dot{width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,.7)}
.sGEN{background:var(--violet)}.sSCA{background:var(--blue)}.sSTA{background:#c9a227;color:#28251d}
.sCON{background:var(--green)}.sRIC{background:var(--red)}.sINV{background:var(--gray)}
.pass-code{font-size:.66rem;color:var(--faint);font-family:monospace}
.btn-dl{display:flex;align-items:center;justify-content:center;gap:.45rem;width:100%;padding:.65rem 1rem;background:var(--navy);color:#fff;border-radius:var(--radius-xs);font-size:.8rem;font-weight:700;text-decoration:none;transition:background .15s}
.btn-dl:hover{background:var(--violet)}
.nopass-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:.65rem;margin-bottom:1.5rem}
.nopass-card{background:var(--surface);border:1px solid #fde8d8;border-radius:var(--radius-sm);padding:.85rem 1.05rem;display:flex;align-items:center;gap:.8rem}
.nopass-avatar{width:38px;height:38px;border-radius:50%;background:#fef3ec;display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0}
.nopass-name{font-size:.84rem;font-weight:700}
.nopass-role{font-size:.7rem;color:var(--muted);margin-top:.05rem}
.nopass-tag{font-size:.67rem;color:var(--red);font-weight:600;margin-top:.2rem;font-style:italic}

/* ══════════════════════════════════════════
   MAPPA DOVE SIETE (invariata)
══════════════════════════════════════════ */
.dove-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow-md);margin-bottom:1.5rem;overflow:hidden}
.dove-header{display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:.75rem;padding:1rem 1.2rem .85rem;border-bottom:1px solid var(--border-light)}
.dove-zone-badge{display:inline-block;background:var(--navy);color:var(--yellow);font-size:.65rem;font-weight:800;text-transform:uppercase;letter-spacing:.6px;padding:.18rem .65rem;border-radius:9999px;margin-bottom:.3rem}
.dove-stand-name{font-size:1.1rem;font-weight:800;color:var(--text);line-height:1.2}
.dove-stand-code{font-size:.75rem;color:var(--muted);margin-top:.2rem}
.dove-actions{display:flex;gap:.5rem;flex-wrap:wrap;align-items:center}
.dove-btn{display:inline-flex;align-items:center;gap:.3rem;padding:.38rem .85rem;border-radius:var(--radius-xs);border:1.5px solid var(--border);background:var(--surface);font-size:.76rem;font-weight:700;cursor:pointer;color:var(--text);transition:background .15s,border-color .15s;font-family:inherit}
.dove-btn:hover{background:var(--bg);border-color:var(--navy)}
.dove-btn-share{background:var(--yellow);border-color:var(--gold);color:var(--navy)}
.dove-btn-share:hover{background:#f0bc20}
.dove-canvas-wrap{position:relative;cursor:zoom-in;background:#e8ecf3;overflow:hidden;max-height:320px}
.dove-canvas-wrap canvas{display:block;width:100%;height:auto;max-height:320px;object-fit:contain}
.dove-canvas-overlay{position:absolute;bottom:.6rem;right:.8rem;background:rgba(30,45,78,.7);color:#fff;border-radius:9999px;padding:.22rem .75rem;font-size:.72rem;font-weight:600;pointer-events:none}
.dove-hint{padding:.65rem 1.2rem;font-size:.72rem;color:var(--muted);background:#fffbeb;border-top:1px solid #fde68a}
.dove-modal{display:none;position:fixed;inset:0;z-index:8000;background:rgba(10,20,45,.7);backdrop-filter:blur(3px);align-items:center;justify-content:center;padding:1rem}
.dove-modal.open{display:flex}
.dove-modal-box{background:#fff;border-radius:var(--radius);box-shadow:0 24px 64px rgba(10,20,45,.3);width:100%;max-width:1100px;max-height:90vh;display:flex;flex-direction:column;overflow:hidden}
.dove-modal-header{display:flex;align-items:center;justify-content:space-between;padding:.75rem 1.1rem;border-bottom:1px solid var(--border-light);font-size:.88rem;font-weight:700;color:var(--text);flex-shrink:0}
.dove-modal-close{width:32px;height:32px;border-radius:50%;border:none;background:#f1f5f9;cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;transition:background .15s}
.dove-modal-close:hover{background:#e2e8f0}
.dove-modal-canvas-wrap{overflow:auto;flex:1}
.dove-modal-canvas-wrap canvas{display:block;width:100%;height:auto}
@keyframes dove-pulse{0%,100%{box-shadow:0 0 0 0 rgba(245,200,66,.5)}50%{box-shadow:0 0 0 10px rgba(245,200,66,0)}}

/* ══════════════════════════════════════════
   BANNER FINESTRA CHIUSA
══════════════════════════════════════════ */
.wc-banner{
  display:none;
  background:linear-gradient(135deg,#fff7ed,#fef3c7);
  border:1px solid #fde68a;border-radius:var(--radius);
  padding:.85rem 1.2rem;margin-bottom:1.4rem;
  display:none;align-items:center;gap:.75rem;
}
.wc-banner-icon{font-size:1.4rem;flex-shrink:0}
.wc-banner-text{font-size:.8rem;color:#78350f;line-height:1.5;flex:1}
.wc-banner-text strong{color:#92400e}

/* ══════════════════════════════════════════
   MODALE FINESTRA CHIUSA
══════════════════════════════════════════ */
.wc-modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:9999;align-items:center;justify-content:center;padding:1rem}
.wc-modal-box{background:#fff;border-radius:16px;max-width:440px;width:100%;box-shadow:0 20px 60px rgba(0,0,0,.25);overflow:hidden}
.wc-modal-hd{background:linear-gradient(135deg,#fef3c7,#fff7ed);padding:1.4rem 1.5rem 1rem;border-bottom:1px solid #fde68a;display:flex;align-items:flex-start;gap:1rem}
.wc-modal-icon{font-size:2.4rem;line-height:1;flex-shrink:0}
.wc-modal-title{font-weight:900;color:#92400e;font-size:1rem;margin-bottom:.3rem}
.wc-modal-subtitle{font-size:.83rem;color:#78350f;line-height:1.55}
.wc-modal-body{padding:1rem 1.5rem}
.wc-modal-list{font-size:.82rem;color:#374151;line-height:1.7;padding-left:1.1rem;margin-bottom:1rem}

/* ══════════════════════════════════════════
   FOOTER
══════════════════════════════════════════ */
.footer{text-align:center;padding:2rem 1rem;font-size:.69rem;color:var(--faint)}
.footer strong{color:var(--muted)}

/* ══════════════════════════════════════════
   ANIMAZIONI
══════════════════════════════════════════ */
@keyframes pulse-badge{0%,100%{opacity:1}50%{opacity:.55}}

/* ══════════════════════════════════════════
   RESPONSIVE — Mobile First
══════════════════════════════════════════ */

/* ── Tablet (max 768px) ── */
@media(max-width:768px){
  .wrap{padding:1rem .85rem 2.5rem}
  .hdr-inner{padding:0 .85rem}
  .info-strip{grid-template-columns:repeat(2,1fr);gap:.5rem}
  .pass-grid{grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:.7rem}
  .nopass-grid{grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:.55rem}
  .form-grid-2{grid-template-columns:1fr 1fr}
  .item-card-hd{flex-direction:column;align-items:flex-start;gap:.3rem}
  .item-card-meta{font-size:.68rem}
  .sec-card-hd{flex-wrap:wrap;gap:.45rem}
  .sec-card-actions{width:100%;justify-content:flex-end}
}

/* ── Smartphone (max 520px) ── */
@media(max-width:520px){
  /* Topbar */
  .topbar{padding:0 .75rem;min-height:56px;gap:.4rem}
  .brand-ciuco{height:42px}
  .brand-logo-img{height:36px}
  .brand-text-block{display:none}
  .topbar-right{font-size:.62rem;letter-spacing:0}

  /* Header stand */
  .hdr-stand{padding:.9rem 0}
  .hdr-title{font-size:clamp(1.2rem,5vw,1.6rem)}

  /* Contenuto principale */
  .wrap{padding:.75rem .65rem 2rem}
  .hdr-inner{padding:0 .65rem}

  /* Info strip: 2 colonne strette */
  .info-strip{grid-template-columns:1fr 1fr;gap:.4rem}
  .info-strip > *{padding:.55rem .65rem}

  /* Pass grid: 1 colonna */
  .pass-grid,.nopass-grid{grid-template-columns:1fr;gap:.6rem}

  /* Pass card: layout verticale ottimizzato */
  .pass-card{padding:.75rem .85rem}

  /* Progress bar */
  .prog-num{font-size:1.5rem}
  .prog-bar-wrap{min-width:0;width:100%}

  /* Form: 1 colonna */
  .form-grid-2{grid-template-columns:1fr}
  .form-footer{flex-direction:column;align-items:stretch;gap:.5rem}
  .form-footer .btn{width:100%;justify-content:center}
  .form-footer .form-msg{text-align:center}

  /* Sezione card */
  .sec-card{border-radius:10px;margin-bottom:1rem}
  .sec-card-hd{padding:.7rem .85rem;flex-wrap:wrap;gap:.4rem}
  .sec-card-title{font-size:.72rem}
  .sec-card-actions{width:100%;justify-content:flex-end;margin-top:.1rem}
  .sec-card-body{padding:.85rem .85rem}

  /* Item card */
  .item-card{padding:.7rem .8rem}
  .item-card-hd{flex-direction:column;align-items:flex-start;gap:.25rem}
  .item-card-title{font-size:.84rem}
  .item-card-meta{font-size:.67rem}
  .item-card-footer{gap:.4rem}
  .item-card-footer .btn{font-size:.72rem;padding:.28rem .6rem}

  /* Bottoni */
  .btn{font-size:.8rem;padding:.45rem .9rem}
  .btn-sm{font-size:.73rem;padding:.32rem .65rem}
  .btn-xs{font-size:.67rem;padding:.22rem .5rem}

  /* Servizi */
  .srv-type-grid{grid-template-columns:repeat(2,1fr);gap:.4rem}

  /* Nopass card */
  .nopass-card{padding:.7rem .85rem}
  .nopass-card > div:first-child{font-size:.82rem}

  /* Banner finestra chiusa */
  #wc-banner{padding:.6rem .75rem;font-size:.75rem}
  #wc-banner > div{gap:.4rem}

  /* Popup finestra chiusa */
  #wc-modal-overlay > div{margin:1rem;width:calc(100% - 2rem);max-height:90vh;overflow-y:auto}
}

/* ── Smartphone piccolo (max 380px) ── */
@media(max-width:380px){
  .topbar{min-height:50px}
  .brand-ciuco{height:36px}
  .brand-logo-img{height:30px}
  .hdr-title{font-size:1.15rem}
  .info-strip{grid-template-columns:1fr}
  .sec-card-hd{padding:.6rem .7rem}
  .sec-card-body{padding:.7rem .7rem}
  .wrap{padding:.6rem .5rem 1.8rem}
}

/* ── Servizi ─────────────────────────────────────────── */
.srv-type-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.5rem;margin:.5rem 0 .75rem}
/* srv-type responsive incluso nel blocco mobile sopra */
.srv-type-btn{
  display:flex;flex-direction:column;align-items:center;gap:.25rem;
  padding:.65rem .4rem;border:1.5px solid var(--border);border-radius:var(--radius-sm);
  cursor:pointer;background:var(--bg);font-family:inherit;
  transition:border-color .15s,background .15s;
  font-size:.78rem;font-weight:700;color:var(--muted);
}
.srv-type-btn:hover{border-color:var(--navy);background:var(--surface);color:var(--text)}
.srv-type-btn.sel{border-color:var(--navy);background:var(--navy);color:var(--yellow)}
.srv-type-btn .ico{font-size:1.35rem;line-height:1}
.srv-extra{display:none;border-top:1px solid var(--border-light);padding-top:.75rem;margin-top:.5rem}
.srv-list{list-style:none;padding:0;margin:0}
.srv-list li{display:flex;align-items:center;gap:.6rem;padding:.5rem 0;border-bottom:1px solid var(--border-light);font-size:.83rem}
.srv-list li:last-child{border-bottom:none}
.srv-pill{display:inline-block;font-size:.65rem;font-weight:800;padding:.15rem .5rem;border-radius:9999px;white-space:nowrap}
.srv-pill-wait{background:rgba(201,162,39,.15);color:var(--gold)}
.srv-pill-ok{background:rgba(45,106,79,.13);color:var(--green)}
.srv-pill-done{background:rgba(29,111,164,.13);color:var(--blue)}
.srv-pill-cancel{background:rgba(192,57,43,.12);color:var(--red)}

/* ── UX mobile: tap feedback e scroll fluido ── */
@media(hover:none){
  .btn:hover{background:initial;color:initial}
  .btn-primary:hover{background:var(--navy);color:#fff}
  .btn-accent:hover{background:var(--accent);color:#fff}
  .btn-outline:hover{background:transparent;border-color:var(--border)}
  .btn:active{transform:scale(.96);opacity:.88}
  .item-card{-webkit-tap-highlight-color:transparent}
  .sec-card-hd{-webkit-tap-highlight-color:transparent}
  html{-webkit-text-size-adjust:100%;scroll-behavior:smooth}
}
</style>
</head>
<body>
<!-- ════════════════════════════════════════════════════
     BETA POPUP — appare solo alla prima visita per sessione
     ════════════════════════════════════════════════════ -->
<div id="beta-overlay"
     style="display:none;position:fixed;inset:0;z-index:9999;
            background:rgba(0,0,0,0.58);align-items:flex-start;
            justify-content:center;padding:2rem 1rem;overflow-y:auto;">
  <div style="background:#fff;border-radius:18px;max-width:460px;width:100%;
              padding:2rem 2rem 1.75rem;text-align:center;margin:auto;
              box-shadow:0 24px 64px rgba(0,0,0,0.28);">
    <img id="beta-ciuchino" src="" alt="Work in progress"
         style="width:170px;height:auto;margin:0 auto .85rem;display:block;">
    <h2 style="font-size:1.2rem;font-weight:800;color:#1e2d4e;margin:0 0 .6rem;">
      🚧 Portale in Beta Testing
    </h2>
    <p style="font-size:.87rem;color:#475569;line-height:1.65;margin:0 0 1.25rem;text-align:left;">
      Benvenuto nel <strong>Portale Espositore</strong>!<br><br>
      Questo portale è attualmente in una fase di <strong>beta testing</strong>:
      alcune funzionalità potrebbero non operare in maniera ottimale o essere
      soggette a modifiche nelle prossime settimane.<br><br>
      Se riscontri <strong>anomalie o malfunzionamenti</strong>, ti chiediamo
      gentilmente di segnalarli all'organizzazione scrivendo a
      <a href="mailto:info@ludicomix.it" style="color:#01696f;font-weight:600;text-decoration:none;">
        info@ludicomix.it
      </a>
      oppure tramite la sezione <em>Assistenza</em> del portale.<br><br>
      Grazie per la pazienza e la collaborazione! 🙏
    </p>
    <button onclick="closeBetaPopup()"
            style="background:#1e2d4e;color:#f5c842;border:none;border-radius:10px;
                   padding:.65rem 2rem;font-size:.95rem;font-weight:800;cursor:pointer;
                   box-shadow:0 4px 14px rgba(30,45,78,.28);">
      ✅ Ho capito, procedo!
    </button>
  </div>
</div>
<script>
(function(){
  document.getElementById('beta-ciuchino').src='data:image/jpeg;base64,';
  document.getElementById('beta-overlay').style.display='flex';
})();
function closeBetaPopup(){
  document.getElementById('beta-overlay').style.display='none';
}
</script>
<!-- ═════════════════════════ FINE BETA POPUP ═════════════════════════ -->

<!-- ═══ POPUP FINESTRA CHIUSA (appare solo una volta per sessione) ═══ -->
<div id="wc-modal-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:9999;align-items:center;justify-content:center;padding:1rem;">
  <div style="background:#fff;border-radius:16px;max-width:440px;width:100%;box-shadow:0 20px 60px rgba(0,0,0,.25);overflow:hidden;">
    <div style="background:linear-gradient(135deg,#fef3c7,#fff7ed);padding:1.4rem 1.5rem 1rem;border-bottom:1px solid #fde68a;display:flex;align-items:flex-start;gap:1rem;">
      <div style="font-size:2.4rem;line-height:1;flex-shrink:0;">⏱</div>
      <div>
        <div style="font-weight:900;color:#92400e;font-size:1rem;margin-bottom:.3rem;">Portale in modalità sola lettura</div>
        <div id="wc-modal-text" style="font-size:.83rem;color:#78350f;line-height:1.55;">
          La finestra di inserimento nominativi e caricamento documenti è attualmente chiusa.
        </div>
      </div>
    </div>
    <div style="padding:1rem 1.5rem;">
      <ul style="font-size:.82rem;color:#374151;line-height:1.7;padding-left:1.1rem;margin-bottom:1rem;">
        <li>Puoi ancora <strong>scaricare i tuoi pass</strong> già generati</li>
        <li>Puoi ancora <strong>contattare l'organizzazione</strong> tramite il sistema ticket</li>
        <li>Non è più possibile aggiungere o rimuovere nominativi</li>
        <li>Non è più possibile caricare nuovi documenti</li>
      </ul>
      <button onclick="closeWcModal()" style="width:100%;background:#6b3fa0;color:#fff;border:none;border-radius:10px;padding:.65rem 1.2rem;font-size:.9rem;font-weight:700;cursor:pointer;">
        Ho capito — Vai al portale
      </button>
    </div>
  </div>
</div>

<script>var __WC=(<%- JSON.stringify(typeof windowClosed!=="undefined"&&windowClosed===true) %>);var __WU="<%- typeof windowUntil!=="undefined"&&windowUntil?windowUntil:"" %>";</script>

<%
var wp = parts.filter(function(p){ return p.pass_id; });
var np = parts.filter(function(p){ return !p.pass_id; });
var SC = {GENERATO:'sGEN',SCARICATO:'sSCA',STAMPATO:'sSTA',CONSEGNATO:'sCON',RICONSEGNATO:'sRIC',INVALIDATO:'sINV'};
var SL = {GENERATO:'Generato',SCARICATO:'Scaricato',STAMPATO:'Stampato',CONSEGNATO:'Consegnato',RICONSEGNATO:'Riconsegnato',INVALIDATO:'Invalidato'};
function initials(p){ return ((p.first_name||'').charAt(0)+(p.last_name||'').charAt(0)).toUpperCase(); }
var pct = parts.length > 0 ? Math.round(wp.length/parts.length*100) : 0;
%>

<!-- ═══ TOPBAR ═══ -->
<header class="topbar">
  <div class="brand">
    <img src="data:image/png;base64," class="brand-ciuco" alt="Ciuchino Ludicomix" alt="Ciuchino Ludicomix">
    <img src="data:image/png;base64," class="brand-logo-img" alt="Logo Ludicomix" alt="Ludicomix Empoli" style="mix-blend-mode:screen;">
    <div class="brand-text-block">
      <span class="brand-sub">Portale Espositore</span>
    </div>
  </div>
  <div class="topbar-right">&#128274; Accesso riservato &middot; Non condividere questo link</div>
</header>
<div id="wc-banner" style="display:none;background:linear-gradient(135deg,#fff7ed,#fef3c7);border-bottom:2px solid #fbbf24;padding:.9rem 1.2rem;align-items:flex-start;gap:.85rem;"><div style="font-size:1.6rem;flex-shrink:0;">⏱</div><div><div style="font-weight:800;color:#92400e;font-size:.88rem;margin-bottom:.2rem;">Finestra di inserimento chiusa</div><div id="wc-text" style="font-size:.82rem;color:#78350f;line-height:1.5;">Il periodo di inserimento è terminato. Puoi ancora <strong>scaricare i tuoi pass</strong> e contattare l'organizzazione.</div></div></div>

<!-- ═══ HEADER STAND (solo titolo) ═══ -->
<div class="hdr-stand">
  <div class="hdr-inner">
    <h1 class="hdr-title">Ciao, <span><%= group.name %>!</span></h1>
  </div>
</div>

<!-- ═══ CONTENUTO ═══ -->
<div class="wrap">

<% if(typeof announcements !== 'undefined' && announcements && announcements.length > 0){ %>
<%
  var annUnread = announcements.filter(function(a){ return !a.is_read; });
  var annRead   = announcements.filter(function(a){ return  a.is_read; });
%>

<!-- ═══ BACHECA COMUNICAZIONI (in cima, sempre visibile) ═══ -->
<div id="bacheca" class="sec-card" style="margin-bottom:1.4rem;">

  <!-- header -->
  <div class="sec-card-hd">
    <div class="sec-card-hd-left">
      <span class="sec-card-icon">📣</span>
      <span class="sec-card-title">Comunicazioni dell&rsquo;organizzazione</span>
      <% if(unreadCount > 0){ %>
      <span id="unread-badge" class="sec-card-badge" style="animation:pulse-badge 1.8s ease-in-out infinite;"><%= unreadCount %></span>
      <% } else { %>
      <span id="unread-badge" class="sec-card-badge" style="display:none;"></span>
      <% } %>
    </div>
    <div class="sec-card-actions">
      <button onclick="toggleBacheca()" id="bach-toggle" class="btn btn-outline btn-sm">
        <span id="bach-toggle-label">▲ Nascondi</span>
      </button>
    </div>
  </div>

  <!-- corpo messaggi -->
  <div id="bach-body" class="sec-card-body" style="transition:max-height .35s ease,opacity .25s ease;max-height:2000px;opacity:1;padding:0;">

    <!-- NON LETTI -->
    <% if(annUnread.length > 0){ %>
    <div style="padding:.45rem 1.2rem .3rem;background:#f5f9ff;border-bottom:1px solid var(--border-light);">
      <span style="font-size:.65rem;font-weight:800;color:var(--blue);text-transform:uppercase;letter-spacing:.5px;">
        🔔 <%= annUnread.length %> non lett<%= annUnread.length===1?'o':'i' %>
      </span>
    </div>
    <div class="item-list" style="padding:.85rem 1.2rem .5rem;">
    <% annUnread.forEach(function(a, i){ %>
    <%
      var uc={info:'unread-info',warning:'unread-warning',urgent:'unread-urgent'};
      var pc={info:'pill-blue',warning:'pill-yellow',urgent:'pill-red'};
      var pl={info:'ℹ️ INFO',warning:'⚠️ AVVISO',urgent:'🚨 URGENTE'};
    %>
    <div class="item-card <%= uc[a.type]||'unread-info' %>">
      <div class="item-card-hd">
        <div style="display:flex;align-items:center;gap:.4rem;flex-wrap:wrap;">
          <% if(a.is_pinned){ %><span class="pill pill-orange">📌 IN EVIDENZA</span><% } %>
          <span class="pill <%= pc[a.type]||'pill-blue' %>"><%= pl[a.type]||'ℹ️ INFO' %></span>
          <strong class="item-card-title"><%= a.emoji||'📣' %> <%= a.title %></strong>
        </div>
        <span class="item-card-meta">🕐 <%= (a.created_at||'').substring(0,16).replace('T',' ') %></span>
      </div>
      <p class="item-card-body"><%= a.message %></p>
    </div>
    <% }); %>
    </div>
    <% } %>

    <!-- LETTI -->
    <% if(annRead.length > 0){ %>
    <div id="read-section">
      <% if(annUnread.length > 0){ %>
      <div style="padding:.4rem 1.2rem;background:var(--border-light);display:flex;align-items:center;justify-content:space-between;">
        <span style="font-size:.65rem;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.4px;"><%= annRead.length %> già lette</span>
        <button onclick="toggleRead()" id="read-toggle" class="btn btn-xs" style="background:none;color:var(--blue);padding:.2rem .4rem;">Mostra ▾</button>
      </div>
      <div id="read-list" style="display:none;">
      <% } %>
      <div class="item-list" style="padding:.85rem 1.2rem .5rem;">
      <% annRead.forEach(function(a){ %>
      <div class="item-card read">
        <div class="item-card-hd">
          <div style="display:flex;align-items:center;gap:.4rem;flex-wrap:wrap;">
            <% if(a.is_pinned){ %><span class="pill pill-gray">📌</span><% } %>
            <strong class="item-card-title" style="font-size:.84rem;color:var(--muted);"><%= a.emoji||'📣' %> <%= a.title %></strong>
          </div>
          <span class="item-card-meta">🕐 <%= (a.created_at||'').substring(0,16).replace('T',' ') %></span>
        </div>
        <p class="item-card-body" style="font-size:.79rem;color:var(--muted);"><%= a.message %></p>
      </div>
      <% }); %>
      </div>
      <% if(annUnread.length > 0){ %>
      </div>
      <% } %>
    </div>
    <% } %>

  </div><!-- /bach-body -->
</div><!-- /bacheca -->
<% } %>


  <!-- INFO CARDS (stile KPI dashboard) -->
  <div class="info-strip">
    <% if(group.zone){ %>
    <div class="info-card">
      <div class="info-card-label">&#128205; Zona / Padiglione</div>
      <div class="info-card-value accent-blue"><%= group.zone %></div>
    </div>
    <% } %>
    <% if(group.cat_name){ %>
    <div class="info-card">
      <div class="info-card-label">&#127981; Categoria</div>
      <div class="info-card-value accent-violet"><%= group.cat_name %></div>
    </div>
    <% } %>
    <% if(group.stand_code){ %>
    <div class="info-card">
      <div class="info-card-label">&#128204; Codice Stand</div>
      <div class="info-card-value accent-gold"><%= group.stand_code %></div>
    </div>
    <% } %>
    <div class="info-card">
      <div class="info-card-label">&#128101; Assegnatari</div>
      <div class="info-card-value accent-green"><%= parts.length %></div>
    </div>
    <div class="info-card">
      <div class="info-card-label">&#9989; Pass pronti</div>
      <div class="info-card-value" style="color:<%= pct===100?'var(--green)':pct>0?'var(--gold)':'var(--red)' %>"><%= wp.length %> / <%= parts.length %></div>
    </div>
  </div>

  <!-- PROGRESS BAR -->
  <div class="prog-card">
    <div>
      <div class="prog-num"><%= wp.length %><span>&thinsp;/&thinsp;<%= parts.length %></span></div>
      <div class="prog-sub">pass <%= (wp.length===parts.length&&parts.length>0)?'tutti pronti':'disponibili' %></div>
    </div>
    <div class="prog-bar-wrap">
      <div class="prog-bar-track"><div class="prog-bar-fill" style="width:<%= pct %>%"></div></div>
      <div class="prog-pct">
        <% if(pct===100){ %><strong>&#10003; Tutti i pass sono pronti!</strong>
        <% }else if(pct===0){ %>Nessun pass ancora generato
        <% }else{ %><strong><%= pct %>%</strong> completato &mdash; <%= np.length %> in preparazione<% } %>
      </div>
    </div>
  </div>

  <!-- PASS DISPONIBILI -->
  <% if(wp.length){ %>
  <div class="sec-title">&#9989; Pass disponibili</div>
  <div class="pass-grid">
    <% wp.forEach(function(p){ %>
    <div class="pass-card">
      <div class="pass-card-top">
        <div style="display:flex;gap:.7rem;align-items:center;min-width:0">
          <div class="pass-avatar"><%= initials(p) %></div>
          <div style="min-width:0">
            <div class="pass-name"><%= p.last_name %> <%= p.first_name %></div>
            <% if(p.role){ %><div class="pass-role"><%= p.role %></div><% } %>
          </div>
        </div>
        <% if(p.type_name){ %><span class="pass-type-badge"><%= p.type_name %></span><% } %>
      </div>
      <div class="pass-card-mid">
        <span class="status-pill <%= SC[p.status]||'sGEN' %>">
          <span class="status-dot"></span><%= SL[p.status]||p.status %>
        </span>
        <span class="pass-code"><%= (p.code||'').substring(0,10) %>&hellip;</span>
      </div>
      <% if(p.status!=='INVALIDATO'){ %>
      <a href="/portale/<%= token %>/download/<%= p.pass_id %>" class="btn-dl" target="_blank">
        &#11015;&#65039;&nbsp; Scarica PDF
      </a>
      <% }else{ %>
      <div style="text-align:center;font-size:.73rem;color:var(--gray);padding:.4rem 0;">Pass invalidato</div>
      <% } %>
    </div>
    <% }); %>
  </div>
  <% } %>

  <!-- SENZA PASS -->
  <% if(np.length){ %>
  <div class="sec-title" style="color:var(--red);">&#9888;&#65039; In preparazione (<%= np.length %>)</div>
  <div class="nopass-grid">
    <% np.forEach(function(p){ %>
    <div class="nopass-card">
      <div class="nopass-avatar">&#128100;</div>
      <div>
        <div class="nopass-name"><%= p.last_name %> <%= p.first_name %></div>
        <% if(p.role){ %><div class="nopass-role"><%= p.role %></div><% } %>
        <div class="nopass-tag">Pass non ancora generato</div>
      </div>
    </div>
    <% }); %>
  </div>
  <% } %>


<% if (group.portal_nom_enabled !== 0) { %>
  <!-- ═══ GESTIONE NOMINATIVI SELF-SERVICE ═══ -->
  <div class="sec-card" id="nom-section" style="margin-top:1.4rem;">
    <div class="sec-card-hd">
      <div class="sec-card-hd-left">
        <span class="sec-card-icon">&#128221;</span>
        <span class="sec-card-title">Gestione Nominativi</span>
      </div>
      <div class="sec-card-actions">
        <% var _maxP = group.max_passes || 0; var _usedP = parts.length; %>
        <% if(_maxP > 0){ %>
          <span id="slot-counter" class="pill <%= _usedP >= _maxP ? 'pill-red' : 'pill-green' %>">
            <%= _usedP %> / <%= _maxP %> slot
          </span>
        <% } else { %>
          <span id="slot-counter" class="pill pill-gray">
            <span id="slot-used"><%= _usedP %></span> inseriti
          </span>
        <% } %>
      </div>
    </div>
    <div class="sec-card-body">

      <!-- Lista nominativi con pulsante rimozione -->
      <div id="nom-list" class="item-list" style="margin-bottom:1rem;">
        <% parts.forEach(function(p){ %>
        <div id="nom-row-<%= p.participant_id %>" data-pid="<%= p.participant_id %>"
          class="item-card" style="display:flex;align-items:center;gap:.65rem;padding:.55rem .85rem;">
          <div style="width:32px;height:32px;border-radius:50%;background:<%= p.pass_id ? '#dcfce7' : '#fef3c7' %>;display:flex;align-items:center;justify-content:center;font-size:.82rem;font-weight:800;color:<%= p.pass_id ? '#166534' : '#854d0e' %>;flex-shrink:0;">
            <%= ((p.first_name||'').charAt(0)+(p.last_name||'').charAt(0)).toUpperCase() %>
          </div>
          <div style="flex:1;min-width:0;">
            <div style="font-size:.85rem;font-weight:700;color:var(--navy);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= p.last_name %> <%= p.first_name %></div>
