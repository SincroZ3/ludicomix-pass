<%- include('partials/header') %>
<style>
.rk-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:.7rem;margin-bottom:1.3rem}
.rk{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:.9rem 1rem;text-align:center;box-shadow:0 1px 4px rgba(30,45,78,.06)}
.rk .v{font-size:1.7rem;font-weight:800;line-height:1}
.rk .l{font-size:.62rem;color:#64748b;font-weight:700;text-transform:uppercase;letter-spacing:.4px;margin-top:.2rem}
.rbox{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:1.1rem 1.2rem;margin-bottom:1rem;box-shadow:0 1px 4px rgba(30,45,78,.06)}
.rbox h3{font-size:.68rem;text-transform:uppercase;letter-spacing:.5px;color:#64748b;font-weight:700;margin:0 0 .8rem}
.rtab{width:100%;border-collapse:collapse;font-size:.82rem}
.rtab th{text-align:left;padding:.42rem .65rem;font-size:.65rem;text-transform:uppercase;letter-spacing:.4px;color:#64748b;border-bottom:2px solid #e2e8f0;font-weight:700;white-space:nowrap}
.rtab td{padding:.46rem .65rem;border-bottom:1px solid #f1f5f9;vertical-align:middle}
.rtab tr:hover td{background:#f8fafc}
.cat-hdr td{background:#f1f5f9;font-size:.68rem;font-weight:700;text-transform:uppercase;color:#64748b;letter-spacing:.3px;padding:.28rem .65rem;border-bottom:1px solid #e2e8f0}
.qn{font-variant-numeric:tabular-nums;text-align:right;font-weight:700}
.pb-bg{background:#e2e8f0;border-radius:9999px;height:6px;display:inline-block;vertical-align:middle;width:60px;overflow:hidden}
.pb{background:#1d6fa4;height:6px;border-radius:9999px;transition:width .4s}
.bs{display:inline-block;padding:.1rem .45rem;border-radius:9999px;font-size:.62rem;font-weight:700;text-transform:uppercase;white-space:nowrap}
.bs-ok{background:#dcfce7;color:#155724}.bs-warn{background:#fef9c3;color:#854d0e}.bs-danger{background:#fee2e2;color:#991b1b}
.tab-pills{display:flex;gap:.35rem;margin-bottom:.9rem;flex-wrap:wrap}
.tp{padding:.3rem .85rem;border-radius:9999px;border:1.5px solid #d1d9e6;font-size:.74rem;font-weight:700;color:#64748b;cursor:pointer;background:#f1f5f9}
.tp.active{background:#1d6fa4;color:#fff;border-color:#1d6fa4}
.rpanel{display:none}.rpanel.active{display:block}
.btn-exp{display:inline-flex;align-items:center;gap:.4rem;background:#155724;color:#fff;padding:.42rem 1rem;border-radius:8px;font-size:.78rem;font-weight:700;text-decoration:none}
.btn-exp:hover{background:#0a3d18}
.alert-row td{background:#fffbf0!important}.danger-row td{background:#fff0f0!important}
</style>

<div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.8rem;margin-bottom:1.1rem">
  <div>
    <nav style="font-size:.76rem;color:#64748b;margin-bottom:.2rem">
      <a href="/admin/logistica" style="color:#64748b">Logistica</a> › <strong>Resoconto Fabbisogni</strong>
    </nav>
    <h1 style="font-size:1.3rem;font-weight:800;color:#1e2d4e;margin:0">📋 Resoconto Fabbisogni Materiali</h1>
  </div>
  <a href="/admin/logistica/resoconto/export.csv" class="btn-exp">⬇️ Esporta CSV</a>
</div>

<!-- KPI -->
<div class="rk-grid">
  <div class="rk" style="border-top:3px solid #1d6fa4"><div class="v" style="color:#1d6fa4"><%= kpi.num_gruppi %></div><div class="l">Gruppi</div></div>
  <div class="rk" style="border-top:3px solid #856404"><div class="v" style="color:#856404"><%= kpi.tot_richieste %></div><div class="l">Unità richieste</div></div>
  <div class="rk" style="border-top:3px solid #155724"><div class="v" style="color:#155724"><%= kpi.tot_confermate %></div><div class="l">Confermate</div></div>
  <div class="rk" style="border-top:3px solid #2d6a4f"><div class="v" style="color:#2d6a4f"><%= kpi.tot_consegnate %></div><div class="l">Consegnate</div></div>
  <div class="rk" style="border-top:3px solid #c0392b">
    <div class="v" style="color:#c0392b"><%= kpi.tot_richieste - kpi.tot_confermate %></div>
    <div class="l">Da confermare</div>
  </div>
</div>

<!-- Alert carenze inventario -->
<% var alerts=[];
   if(inventory&&inventory.length&&byItem&&byItem.length){
     byItem.forEach(function(it){
       var found=inventory.find(function(iv){
         return iv.name.toLowerCase().includes(it.item_name.toLowerCase())
             || it.item_name.toLowerCase().includes(iv.name.toLowerCase());
       });
       if(found && found.total_qty < it.tot_requested)
         alerts.push({item:it.item_name, needed:it.tot_requested, have:found.total_qty,
                      gap:it.tot_requested-found.total_qty});
     });
   }
%>
<% if(alerts.length){ %>
<div class="rbox" style="border-left:4px solid #c9a227;background:#fffbf0;margin-bottom:1rem">
  <h3 style="color:#856404">⚠️ Carenze rispetto all'inventario</h3>
  <% alerts.forEach(function(a){ %>
  <div style="display:flex;justify-content:space-between;align-items:center;gap:1rem;padding:.3rem 0;border-bottom:1px solid #f1f5f9;flex-wrap:wrap">
    <strong style="font-size:.82rem"><%= a.item %></strong>
    <span style="font-size:.8rem;color:#856404">
      Richiesti <strong><%= a.needed %></strong> ·
      Disponibili <strong><%= a.have %></strong> ·
      <strong style="color:#c0392b">Mancano <%= a.gap %></strong>
    </span>
  </div>
  <% }); %>
</div>
<% } %>

<!-- Tab pills -->
<div class="tab-pills">
  <button class="tp active" onclick="switchTab('articoli',this)">🗂 Per articolo</button>
  <button class="tp" onclick="switchTab('gruppi',this)">👥 Per gruppo</button>
  <button class="tp" onclick="switchTab('inventario',this)">📦 Confronto inventario</button>
</div>

<!-- TAB: articoli -->
<div class="rpanel active" id="tab-articoli">
  <div class="rbox">
    <h3>Riepilogo per articolo</h3>
    <% if(!byItem||!byItem.length){ %>
      <p style="color:#94a3b8;font-size:.82rem">Nessuna richiesta materiale registrata.</p>
    <% } else {
         var curCat=null;
         var catKeys=Object.keys(MATERIAL_CATALOG); %>
    <div style="overflow-x:auto">
    <table class="rtab">
      <thead><tr>
        <th>Articolo</th><th>Gruppi</th>
        <th class="qn">Richieste</th><th class="qn">Confermate</th>
        <th class="qn">Da reperire</th><th>Avanzamento</th>
      </tr></thead>
      <tbody>
      <% byItem.forEach(function(it){
           var cat=it.category, co=MATERIAL_CATALOG[cat]||{};
           if(cat!==curCat){curCat=cat; %>
        <tr class="cat-hdr"><td colspan="6"><%= co.icon||'' %> <%= co.label||cat %></td></tr>
      <% }
         var gap=Math.max(0,(it.tot_requested||0)-(it.tot_confirmed||0));
         var pct=it.tot_requested>0 ? Math.round((it.tot_confirmed||0)/it.tot_requested*100) : 0;
      %>
        <tr class="<%= gap>0?'alert-row':'' %>">
          <td>
            <strong><%= it.item_name %></strong>
            <% if(it.subcategory){ %><span style="font-size:.68rem;color:#94a3b8"> · <%= it.subcategory %></span><% } %>
          </td>
          <td style="text-align:center;color:#64748b;font-size:.76rem"><%= it.num_groups %></td>
          <td class="qn"><%= it.tot_requested||0 %></td>
          <td class="qn" style="color:#155724"><%= it.tot_confirmed||0 %></td>
          <td class="qn" style="color:<%= gap>0?'#c0392b':'#155724' %>">
            <strong><%= gap>0 ? '⚠ '+gap : '✓ 0' %></strong>
          </td>
          <td>
            <div class="pb-bg"><div class="pb" style="width:<%= pct %>%"></div></div>
            <span style="font-size:.63rem;color:#94a3b8;margin-left:.3rem"><%= pct %>%</span>
          </td>
        </tr>
      <% }); %>
      </tbody>
    </table>
    </div>
    <% } %>
  </div>
</div>

<!-- TAB: gruppi -->
<div class="rpanel" id="tab-gruppi">
  <div class="rbox">
    <h3>Riepilogo per gruppo</h3>
    <% if(!byGroup||!byGroup.length){ %>
      <p style="color:#94a3b8;font-size:.82rem">Nessun dato.</p>
    <% } else { %>
    <div style="overflow-x:auto">
    <table class="rtab">
      <thead><tr>
        <th>Gruppo</th><th>Zona</th><th>Stand</th>
        <th class="qn">Articoli</th><th class="qn">Qtà tot</th><th class="qn">Conf.</th>
        <th>Sommario</th><th></th>
      </tr></thead>
      <tbody>
      <% byGroup.forEach(function(g){ %>
        <tr>
          <td><strong><%= g.group_name %></strong></td>
          <td style="font-size:.76rem;color:#64748b"><%= g.zone||'—' %></td>
          <td style="font-size:.76rem"><%= g.stand_code||'—' %></td>
          <td class="qn"><%= g.num_items %></td>
          <td class="qn"><%= g.tot_requested||0 %></td>
          <td class="qn" style="color:#155724"><%= g.tot_confirmed||0 %></td>
          <td style="font-size:.71rem;color:#64748b;max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"
              title="<%= g.sommario||'' %>"><%= g.sommario||'' %></td>
          <td>
            <a href="/assignment-groups/<%= g.id %>/materiali"
               style="font-size:.74rem;color:#1d6fa4;text-decoration:none;white-space:nowrap">
              🔗 Dettaglio
            </a>
          </td>
        </tr>
      <% }); %>
      </tbody>
    </table>
    </div>
    <% } %>
  </div>
</div>

<!-- TAB: inventario -->
<div class="rpanel" id="tab-inventario">
  <div class="rbox">
    <h3>Confronto con inventario magazzino</h3>
    <% if(!inventory||!inventory.length){ %>
      <p style="color:#94a3b8;font-size:.82rem">
        Nessun articolo in inventario.
        <a href="/admin/logistica" style="color:#1d6fa4">Aggiungi attrezzatura →</a>
      </p>
    <% } else { %>
    <div style="overflow-x:auto">
    <table class="rtab">
      <thead><tr>
        <th>Articolo inventario</th><th>Categoria</th>
        <th class="qn">Disponibili</th><th class="qn">Richiesti</th>
        <th class="qn">Gap</th><th>Stato</th>
      </tr></thead>
      <tbody>
      <% inventory.forEach(function(iv){
           var totR=0;
           byItem.forEach(function(it){
             if(it.item_name.toLowerCase().includes(iv.name.toLowerCase())
             || iv.name.toLowerCase().includes(it.item_name.toLowerCase()))
               totR += it.tot_requested||0;
           });
           var gap=iv.total_qty-totR;
           var cls=gap<0?'bs-danger':gap===0?'bs-warn':'bs-ok';
           var lbl=gap<0?'⚠ Carenza':gap===0?'= Esatto':'✓ OK';
      %>
        <tr class="<%= gap<0?'danger-row':'' %>">
          <td><strong><%= iv.name %></strong></td>
          <td style="font-size:.76rem;color:#64748b"><%= iv.category||'—' %></td>
          <td class="qn"><%= iv.total_qty %></td>
          <td class="qn"><%= totR %></td>
          <td class="qn" style="color:<%= gap<0?'#c0392b':gap===0?'#856404':'#155724' %>">
            <strong><%= gap>0?'+'+gap:gap %></strong>
          </td>
          <td><span class="bs <%= cls %>"><%= lbl %></span></td>
        </tr>
      <% }); %>
      </tbody>
    </table>
    </div>
    <% } %>
  </div>
</div>

<script>
function switchTab(name,btn){
  document.querySelectorAll('.rpanel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tp').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  btn.classList.add('active');
}
</script>
<%- include('partials/footer') %>
