    <form method="POST" action="/admin/settings/auto-pass-template" enctype="multipart/form-data" style="display:flex;align-items:center;gap:.6rem;flex-wrap:wrap;">
      <input type="file" name="auto_pass_template" accept=".pdf" required style="font-size:.82rem;">
      <button type="submit" class="primary" style="font-size:.8rem;padding:.38rem .9rem;">&#128640; Carica template</button>
