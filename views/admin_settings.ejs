<script>
// ── Funzioni accordion permessi custom — SCOPE GLOBALE (usate da onclick inline) ──
function toggleNewArea(head) {
  var subs  = head.nextElementSibling;
  var arrow = head.querySelector('.new-perm-arrow');
  var open  = subs && subs.style.display !== 'none';
  if(subs)  subs.style.display = open ? 'none' : 'block';
  if(arrow) arrow.style.transform = open ? 'rotate(-90deg)' : 'rotate(0deg)';
}
function toggleNewAreaAll(areaChk) {
  var area = areaChk.dataset.area;
  document.querySelectorAll('input.new-sub-check[data-area="'+area+'"]').forEach(function(s){ s.checked = areaChk.checked; });
  // Se spunta l'area, apre automaticamente la sottosezione
  var head  = areaChk.closest('[onclick]');
  var subs  = head && head.nextElementSibling;
  var arrow = head && head.querySelector('.new-perm-arrow');
  if(subs && areaChk.checked && subs.style.display === 'none') {
    subs.style.display = 'block';
    if(arrow) arrow.style.transform = 'rotate(0deg)';
  }
  syncNewAreaCheck(area);
}
function syncNewAreaCheck(areaId) {
  var subs    = document.querySelectorAll('input.new-sub-check[data-area="'+areaId+'"]');
  var checked = Array.from(subs).filter(function(s){ return s.checked; }).length;
  var total   = subs.length;
  var all     = checked === total;
  var none    = checked === 0;
  var ac      = document.querySelector('input.new-area-check[data-area="'+areaId+'"]');
  if(!ac) return;
  ac.checked = all; ac.indeterminate = !all && !none;
  var badge = document.querySelector('.new-perm-count[data-area="'+areaId+'"]');
  if(badge) {
    badge.textContent = checked > 0 ? checked+'/'+total : '';
    badge.style.color = checked === total ? 'var(--success, #437a22)' : checked > 0 ? 'var(--color-primary, #01696f)' : 'var(--text-muted)';
    badge.style.fontWeight = checked > 0 ? '700' : '500';
  }
}
</script>

<script>
(function () {

  // Init badge contatori al caricamento
  document.querySelectorAll('input.new-area-check').forEach(function(ac) {
    syncNewAreaCheck(ac.dataset.area);
  });

  var PANELS = { zone: 'panel-zone', raggruppamenti: 'panel-raggruppamenti', tipologie: 'panel-tipologie', backup:'panel-backup',notifiche:'panel-notifiche', utenti: 'panel-utenti', scan: 'panel-scan', auto_pass: 'panel-auto_pass', edizioni: 'panel-edizioni' };
  var tabs   = document.querySelectorAll('[data-tab]');

  function showTab(key) {
    tabs.forEach(function(t){ t.classList.toggle('active', t.dataset.tab === key); });
    Object.keys(PANELS).forEach(function(k){
      document.getElementById(PANELS[k]).style.display = (k === key) ? '' : 'none';
    });
    history.replaceState(null, '', '#' + key);
  }

  tabs.forEach(function(t){ t.addEventListener('click', function(){ showTab(t.dataset.tab); }); });

  var hash = location.hash.replace('#', '');
  if (PANELS[hash]) showTab(hash);
})();

function apriModificaZona(id, name, order) {
  document.getElementById('edit-zone-name').value  = name;
  document.getElementById('edit-zone-order').value = order;
  document.getElementById('form-edit-zone').action = '/admin/zones/' + id + '/edit';
  document.getElementById('modal-edit-zone').style.display = 'flex';
}

function apriModificaGruppo(id, name, priority, passTypeId) {
  document.getElementById('edit-group-name').value     = name;
  document.getElementById('edit-group-priority').value = priority;
  var sel = document.getElementById('edit-group-passtype');
  for (var i = 0; i < sel.options.length; i++) {
    sel.options[i].selected = (sel.options[i].value === String(passTypeId));
  }
  document.getElementById('form-edit-group').action = '/groups/' + id + '/edit';
  document.getElementById('modal-edit-group').style.display = 'flex';
}

(function(){
  var rows=Array.from(document.querySelectorAll('#sa-table tbody tr'));
  var cnt=document.getElementById('sa-count');
  function update(){
    var q=(document.getElementById('sa-search')?document.getElementById('sa-search').value:'').toLowerCase();
    var r=document.getElementById('sa-filter')?document.getElementById('sa-filter').value:'';
    var v=0;
    rows.forEach(function(row){
      var show=(!q||row.textContent.toLowerCase().includes(q))&&(!r||row.getAttribute('data-result')===r);
      row.style.display=show?'':'none';if(show)v++;
    });
    if(cnt)cnt.textContent=v+' / '+rows.length+' righe';
  }
  var s=document.getElementById('sa-search');var f=document.getElementById('sa-filter');
  if(s)s.addEventListener('input',update);if(f)f.addEventListener('change',update);
  if(rows.length)update();
})();

// ── Test SMTP ────────────────────────────────────────────────────────────────
(function() {
  var btn    = document.getElementById('btn-smtp-test');
  var result = document.getElementById('smtp-result');
  if (!btn || !result) return;

  btn.addEventListener('click', function() {
    var form = document.getElementById('smtp-form');
    var data = new FormData(form);
    btn.disabled = true;
    btn.textContent = '⏳ Invio in corso…';
    result.style.display = 'none';

    fetch('/admin/settings/smtp-test', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams(data).toString()
    })
    .then(function(r) { return r.json(); })
    .then(function(json) {
      result.style.display = '';
      if (json.ok) {
        result.style.background = '#dcfce7';
        result.style.color      = '#166534';
        result.textContent      = '✅ Email di test inviata correttamente!';
      } else {
        result.style.background = '#fee2e2';
        result.style.color      = '#991b1b';
        result.textContent      = '❌ Errore: ' + json.error;
      }
    })
    .catch(function(e) {
      result.style.display    = '';
      result.style.background = '#fee2e2';
      result.style.color      = '#991b1b';
      result.textContent      = '❌ Errore di rete: ' + e.message;
    })
    .finally(function() {
      btn.disabled    = false;
      btn.textContent = '📧 Test email';
    });
  });
})();
</script>

