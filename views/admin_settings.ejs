    <% }else{ %>
      <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.75rem;font-size:.82rem;color:#b91c1c;">
        <span>&#9888;&#65039;</span> Nessun template caricato — la generazione non sarà possibile.
      </div>
