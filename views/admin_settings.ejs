          <div style="font-size:.8rem;font-weight:700;margin-bottom:.5rem;padding-bottom:.35rem;border-bottom:1px solid var(--border);">
            ⚙️ Permessi personalizzati
          </div>
          <%
            var newPermAreas = [
              { id:'participants', label:'📦 Partecipanti & Pass', subs:[
                { id:'participants.view',    label:'Visualizza' },
                { id:'participants.edit',    label:'Crea/modifica' },
                { id:'participants.delete',  label:'Elimina' },
                { id:'participants.import',  label:'Importa CSV' },
                { id:'participants.export',  label:'Esporta dati' },
              ]},
              { id:'agenda', label:'📅 Agenda & Eventi', subs:[
                { id:'agenda.view',          label:'Visualizza' },
                { id:'agenda.edit',          label:'Crea/modifica' },
                { id:'agenda.delete',        label:'Elimina' },
                { id:'agenda.registrations', label:'Gestisci iscrizioni' },
                { id:'agenda.export',        label:'Esporta Excel' },
              ]},
              { id:'scan', label:'📷 Scanner & Contatore', subs:[
                { id:'scan.scan',            label:'Scan QR ingresso' },
                { id:'scan.contatore',       label:'Contatore visitatori' },
                { id:'scan.manual_deliver',  label:'Consegna manuale' },
              ]},
              { id:'org', label:'🗂️ Logistica', subs:[
                { id:'org.view',             label:'Visualizza' },
                { id:'org.manage',           label:'Crea/modifica struttura' },
                { id:'org.mappa',            label:'Mappa stand' },
              ]},
              { id:'volunteers', label:'🙋 Volontari', subs:[
                { id:'volunteers.view',      label:'Visualizza' },
                { id:'volunteers.edit',      label:'Crea/modifica' },
                { id:'volunteers.delete',    label:'Elimina' },
              ]},
              { id:'reports', label:'📊 Reports', subs:[
                { id:'reports.view',         label:'Visualizza statistiche' },
              ]},
              { id:'bacheca', label:'📌 Bacheca', subs:[
                { id:'bacheca.view',         label:'Visualizza' },
                { id:'bacheca.edit',         label:'Pubblica/modifica' },
                { id:'bacheca.delete',       label:'Elimina' },
              ]},
              { id:'accreditamento', label:'🏅 Accreditamento', subs:[
                { id:'accreditamento.view',   label:'Visualizza' },
                { id:'accreditamento.manage', label:'Gestisci' },
              ]},
            ];
          %>
          <% newPermAreas.forEach(function(area){ %>
          <div style="margin-bottom:.4rem;border:1px solid var(--border);border-radius:4px;overflow:hidden;">
            <div onclick="toggleNewArea(this)"
                 style="display:flex;align-items:center;justify-content:space-between;padding:.4rem .65rem;
                        background:var(--bg-section);cursor:pointer;font-size:.78rem;font-weight:600;user-select:none;">
              <span>
                <input type="checkbox" class="new-area-check" data-area="<%= area.id %>"
                       onclick="event.stopPropagation();toggleNewAreaAll(this)"
                       style="margin-right:.35rem;cursor:pointer;">
                <%= area.label %>
              </span>
              <span class="new-perm-count" data-area="<%= area.id %>" style="font-size:.68rem;color:var(--text-muted);margin-right:.4rem;font-weight:500;"></span>
              <span class="new-perm-arrow" style="font-size:.65rem;color:var(--text-muted);transition:transform .2s;transform:rotate(-90deg);display:inline-block;">▼</span>
            </div>
            <div class="new-perm-subs" style="padding:.4rem .65rem .5rem;display:none;border-top:1px solid var(--border);">
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:.25rem;">
              <% area.subs.forEach(function(sub){ %>
                <label style="display:flex;align-items:center;gap:.35rem;font-size:.77rem;cursor:pointer;margin:0;">
                  <input type="checkbox" name="permissions" value="<%= sub.id %>"
                         data-area="<%= area.id %>" class="new-sub-check"
                         onchange="syncNewAreaCheck('<%= area.id %>')">
                  <%= sub.label %>
                </label>
              <% }); %>
              </div>
            </div>
          </div>
          <% }); %>
          <div style="font-size:.7rem;color:var(--text-muted);margin-top:.3rem;">
            ℹ️ Puoi modificare i permessi in qualsiasi momento dalla pagina di modifica utente.
          </div>
        </div>

        <div><button type="submit" class="primary">&#43; Crea Utente</button></div>
      </form>
    </div>

    <!-- Tabella permessi -->
    <div class="card" style="margin:0;">
      <div class="card-title">&#128202; Permessi per ruolo</div>
      <div style="overflow-x:auto;">
        <table style="font-size:.75rem;width:100%;">
          <thead>
            <tr>
              <th style="text-align:left;">Funzione</th>
              <th style="text-align:center;">&#128273; Admin</th>
              <th style="text-align:center;">&#128203; Org.</th>
              <th style="text-align:center;">&#127915; Op.</th>
              <th style="text-align:center;">&#128247; Scan</th>
              <th style="text-align:center;">&#128065; View</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>Visualizza tutto</td>
              <td style="text-align:center;color:#2d6a4f;">&#10003;</td><td style="text-align:center;color:#2d6a4f;">&#10003;</td>
              <td style="text-align:center;color:#2d6a4f;">&#10003;</td><td style="text-align:center;color:var(--text-muted);">&#8212;</td>
              <td style="text-align:center;color:#2d6a4f;">&#10003;</td></tr>
            <tr><td>Crea/modifica partecipanti e pass</td>
              <td style="text-align:center;color:#2d6a4f;">&#10003;</td><td style="text-align:center;color:#2d6a4f;">&#10003;</td>
              <td style="text-align:center;color:#2d6a4f;">&#10003;</td><td style="text-align:center;color:var(--text-muted);">&#8212;</td>
              <td style="text-align:center;color:var(--text-muted);">&#8212;</td></tr>
            <tr><td>Scansiona e marca consegnato</td>
              <td style="text-align:center;color:#2d6a4f;">&#10003;</td><td style="text-align:center;color:#2d6a4f;">&#10003;</td>
              <td style="text-align:center;color:#2d6a4f;">&#10003;</td><td style="text-align:center;color:#2d6a4f;">&#10003;</td>
              <td style="text-align:center;color:var(--text-muted);">&#8212;</td></tr>
            <tr><td>Gestisce stand, zone, tipologie</td>
              <td style="text-align:center;color:#2d6a4f;">&#10003;</td><td style="text-align:center;color:#2d6a4f;">&#10003;</td>
              <td style="text-align:center;color:var(--text-muted);">&#8212;</td><td style="text-align:center;color:var(--text-muted);">&#8212;</td>
              <td style="text-align:center;color:var(--text-muted);">&#8212;</td></tr>
            <tr><td>Import CSV, bacheca comunicazioni</td>
              <td style="text-align:center;color:#2d6a4f;">&#10003;</td><td style="text-align:center;color:#2d6a4f;">&#10003;</td>
              <td style="text-align:center;color:var(--text-muted);">&#8212;</td><td style="text-align:center;color:var(--text-muted);">&#8212;</td>
              <td style="text-align:center;color:var(--text-muted);">&#8212;</td></tr>
            <tr><td>Impostazioni sistema, backup</td>
              <td style="text-align:center;color:#2d6a4f;">&#10003;</td><td style="text-align:center;color:var(--text-muted);">&#8212;</td>
              <td style="text-align:center;color:var(--text-muted);">&#8212;</td><td style="text-align:center;color:var(--text-muted);">&#8212;</td>
              <td style="text-align:center;color:var(--text-muted);">&#8212;</td></tr>
            <tr><td>Gestione utenti</td>
              <td style="text-align:center;color:#2d6a4f;">&#10003;</td><td style="text-align:center;color:var(--text-muted);">&#8212;</td>
              <td style="text-align:center;color:var(--text-muted);">&#8212;</td><td style="text-align:center;color:var(--text-muted);">&#8212;</td>
              <td style="text-align:center;color:var(--text-muted);">&#8212;</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Elenco utenti -->
  <div class="card">
    <div class="card-title">&#128100; Elenco Utenti</div>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>ID</th><th>Username</th><th>Ruolo</th><th>Creato il</th>
            <th style="text-align:center;">Modifica</th>
            <th style="text-align:center;">Elimina</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(function(u){ %>
          <%
            var roleChips = {
              admin:     ['#e8edf8','#1a2744','&#128273; Amministratore'],
              organizer: ['#e8f5e9','#1b5e20','&#128203; Organizzatore'],
              operator:  ['#ede7f6','#4a148c','&#127915; Operatore'],
              scanner:   ['#fff8e1','#e65100','&#128247; Scanner'],
              viewer:    ['#fce4ec','#880e4f','&#128065; Visualizzatore'],
              custom:    ['#eef2ff','#3730a3','&#9881;&#65039; Custom'],
            };
            var chip = roleChips[u.role] || ['#f3f4f6','#374151', u.role];
          %>
            <tr>
              <td><span class="chip">#<%= u.id %></span></td>
              <td><strong><%= u.username %></strong>
                <% if(u.id===currentUser.id){ %>
                  <span style="font-size:.68rem;color:var(--text-muted);"> (tu)</span>
                <% } %>
              </td>
              <td>
                <span class="chip" style="background:<%= chip[0] %>;color:<%= chip[1] %>;">
                  <%- chip[2] %>
                </span>
                <% if(u.role === 'custom'){ %>
                  <% var uPermsCount = 0; try { uPermsCount = JSON.parse(u.permissions||'[]').length; } catch(e){} %>
                  <span style="font-size:.68rem;color:#4f46e5;margin-left:.3rem;">(<%= uPermsCount %> perm.)</span>
                <% } %>
              </td>
              <td style="font-size:.78rem;color:var(--text-muted);">
                <%= (u.created_at||'').substring(0,16).replace('T',' ') %>
              </td>
              <td style="text-align:center;">
                <a href="/admin/users/<%= u.id %>/edit" class="link-action">
                  &#9999;&#65039; Modifica
                </a>
              </td>
              <td style="text-align:center;">
                <% if(u.id!==currentUser.id){ %>
                  <form method="post" action="/admin/users/<%= u.id %>/delete"
                    onsubmit="return confirm('Eliminare l\'utente <%= u.username %>?');">
                    <button type="submit" class="btn-danger">&#10005; Elimina</button>
                  </form>
                <% }else{ %>
                  <span style="font-size:.75rem;color:var(--text-muted);">&#8212;</span>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <script>
  (function(){
    var defs = {
      admin:     '&#128273; Accesso totale &#8212; impostazioni sistema, gestione utenti.',
      organizer: '&#128203; Gestione operativa: stand, pass, partecipanti, import, bacheca. NON pu&#242; gestire utenti o impostazioni di sistema.',
      custom:    '&#9881;&#65039; Permessi personalizzati &#8212; usa le checkbox qui sotto per definire esattamente cosa pu&#242; fare questo utente.',
      operator:  '&#127915; Crea e gestisce partecipanti e pass, pu&#242; scansionare. NON modifica la struttura stand/tipologie.',
      scanner:   '&#128247; Accede SOLO alla pagina Scanner. Al login viene portato direttamente alla scansione. Ideale per steward.',
      viewer:    '&#128065; Sola lettura &#8212; vede tutto ma non pu&#242; fare modifiche n&#233; scansionare.',
    };
    var colors = {admin:'#1e2d4e',organizer:'#1b5e20',operator:'#4a148c',scanner:'#e65100',viewer:'#880e4f',custom:'#4f46e5'};
    var sel = document.getElementById('new-role-sel');
    var desc = document.getElementById('new-role-desc');
    var customPermsBlock = document.getElementById('new-custom-perms');
    function upd(){
      if(desc){ desc.innerHTML = defs[sel.value]||''; desc.style.borderColor = colors[sel.value]||'var(--border)'; }
      if(customPermsBlock){ customPermsBlock.style.display = sel.value === 'custom' ? 'block' : 'none'; }
    }
    sel.addEventListener('change', upd);
    upd();
  })();
  </script>

</div>


<div id="panel-scan" class="settings-panel" style="display:none;">
  <div class="card" style="overflow-x:auto">
    <%
    var SA_LABELS={SUCCESS:'Consegnato',NOT_FOUND:'Non trovato',INVALIDATO:'Invalidato',GIA_CONSEGNATO:'Gia consegnato',GIA_RICONSEGNATO:'Gia riconsegnato'};
    var SA_CLS={SUCCESS:'sa-ok',NOT_FOUND:'sa-err',INVALIDATO:'sa-err',GIA_CONSEGNATO:'sa-warn',GIA_RICONSEGNATO:'sa-warn'};
    %>
    <style>
    .sa-badge{display:inline-flex;align-items:center;padding:.16rem .55rem;border-radius:9999px;font-size:.68rem;font-weight:700}
    .sa-ok{background:#2d6a4f;color:#fff}.sa-err{background:#c0392b;color:#fff}.sa-warn{background:#c9a227;color:#1a2744}
    .sa-table{width:100%;border-collapse:collapse;font-size:.81rem}
    .sa-table th{background:var(--bg-offset,#f0f2f5);padding:.55rem .8rem;text-align:left;font-size:.7rem;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);border-bottom:2px solid var(--border,#d1d9e6)}
    .sa-table td{padding:.48rem .8rem;border-bottom:1px solid var(--border-light,#e8ecf3)}
    .sa-table tr:hover td{background:var(--bg-hover,#f8fafc)}
    </style>
    <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:1rem;">
      <input type="text" id="sa-search" placeholder="&#128269; Cerca codice, nome, gruppo..." style="padding:.35rem .7rem;border:1px solid var(--border,#d1d9e6);border-radius:8px;font-size:.8rem;min-width:220px">
      <select id="sa-filter" style="padding:.35rem .7rem;border:1px solid var(--border,#d1d9e6);border-radius:8px;font-size:.8rem">
        <option value="">Tutti gli esiti</option>
        <option value="SUCCESS">&#9989; Consegnato</option>
        <option value="NOT_FOUND">&#10060; Non trovato</option>
        <option value="INVALIDATO">&#128683; Invalidato</option>
        <option value="GIA_CONSEGNATO">&#9888;&#65039; Gia consegnato</option>
        <option value="GIA_RICONSEGNATO">&#9888;&#65039; Gia riconsegnato</option>
      </select>
      <span id="sa-count" style="font-size:.78rem;color:var(--text-muted);align-self:center"></span>
    </div>
    <% if(!scanAttempts||!scanAttempts.length){ %>
      <p style="color:var(--text-muted);padding:1.5rem 0;text-align:center;">Nessun tentativo di scansione registrato.</p>
    <% }else{ %>
    <table class="sa-table" id="sa-table">
      <thead><tr><th>Data / Ora</th><th>Codice QR</th><th>Esito</th><th>Assegnatario</th><th>Gruppo</th><th>Operatore</th><th>IP</th></tr></thead>
      <tbody>
      <% scanAttempts.forEach(function(a){ %>
      <tr data-result="<%=a.result%>">
        <td style="white-space:nowrap;color:var(--text-muted);font-size:.74rem;"><%=a.created_at%></td>
        <td><code style="font-size:.78rem"><%=a.code%></code></td>
        <td><span class="sa-badge <%=SA_CLS[a.result]||'sa-warn'%>"><%=SA_LABELS[a.result]||a.result%></span></td>
        <td><%=a.participant_name||'&mdash;'%></td>
        <td><%=a.group_name||'&mdash;'%></td>
        <td style="font-weight:600">@<%=a.username||'?'%></td>
        <td style="font-size:.72rem;color:var(--text-muted)"><%=a.ip||'&mdash;'%></td>
      </tr>
      <% }); %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>


<div id="panel-auto_pass" class="settings-panel" style="display:none;">
  <% const apTmpl = (apSettings && apSettings.ap_template) ? apSettings.ap_template : null; %>

  <!-- Upload template -->
  <div class="card" style="margin-bottom:1rem;">
    <div class="card-title">&#128196; Template PDF base</div>
    <p style="font-size:.82rem;color:var(--text-muted);margin-bottom:.75rem;">
      Carica il PDF base del pass parcheggio. I campi <strong>Espositore</strong>, <strong>n.</strong> e <strong>di</strong> verranno compilati automaticamente al momento della generazione.
    </p>
    <% if(apTmpl){ %>
      <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.75rem;font-size:.82rem;">
        <span style="color:#2d6a4f;font-size:1rem;">&#9989;</span>
        <strong>Template attivo:</strong> <code><%=apTmpl%></code>
      </div>
    <% }else{ %>
      <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.75rem;font-size:.82rem;color:#b91c1c;">
        <span>&#9888;&#65039;</span> Nessun template caricato — la generazione non sarà possibile.
      </div>
    <% } %>
    <form method="POST" action="/admin/settings/auto-pass-template" enctype="multipart/form-data" style="display:flex;align-items:center;gap:.6rem;flex-wrap:wrap;">
      <input type="file" name="auto_pass_template" accept=".pdf" required style="font-size:.82rem;">
      <button type="submit" class="btn btn-primary" style="font-size:.8rem;padding:.38rem .9rem;">&#128640; Carica template</button>
    </form>
  </div>

  <!-- Coordinate campi -->
  <div class="card">
    <div class="card-title">&#127919; Posizione campi sul PDF</div>
    <p style="font-size:.81rem;color:var(--text-muted);margin-bottom:.85rem;">
      Coordinate in <strong>punti PDF</strong> (origin = angolo in basso a sinistra). Modifica questi valori dopo aver generato un pass di prova per aggiustare il posizionamento.
    </p>
    <form method="POST" action="/admin/settings/auto-pass-coords">
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:.75rem;margin-bottom:1rem;">
        <% const apS = apSettings||{}; %>
        <label style="font-size:.8rem;display:grid;gap:.2rem;">Nome espositore X<input type="number" name="ap_esp_x" value="<%=apS.ap_esp_x||350%>" class="form-control" style="font-size:.82rem;padding:.3rem .5rem;"></label>
        <label style="font-size:.8rem;display:grid;gap:.2rem;">Nome espositore Y<input type="number" name="ap_esp_y" value="<%=apS.ap_esp_y||125%>" class="form-control" style="font-size:.82rem;padding:.3rem .5rem;"></label>
        <label style="font-size:.8rem;display:grid;gap:.2rem;">Dimensione font (pt)<input type="number" name="ap_esp_size" value="<%=apS.ap_esp_size||20%>" class="form-control" style="font-size:.82rem;padding:.3rem .5rem;"></label>
        <label style="font-size:.8rem;display:grid;gap:.2rem;">Numero pass X<input type="number" name="ap_num_x" value="<%=apS.ap_num_x||95%>" class="form-control" style="font-size:.82rem;padding:.3rem .5rem;"></label>
        <label style="font-size:.8rem;display:grid;gap:.2rem;">Numero pass Y<input type="number" name="ap_num_y" value="<%=apS.ap_num_y||125%>" class="form-control" style="font-size:.82rem;padding:.3rem .5rem;"></label>
        <label style="font-size:.8rem;display:grid;gap:.2rem;">Totale ("di") X<input type="number" name="ap_tot_x" value="<%=apS.ap_tot_x||95%>" class="form-control" style="font-size:.82rem;padding:.3rem .5rem;"></label>
        <label style="font-size:.8rem;display:grid;gap:.2rem;">Totale ("di") Y<input type="number" name="ap_tot_y" value="<%=apS.ap_tot_y||95%>" class="form-control" style="font-size:.82rem;padding:.3rem .5rem;"></label>
        <label style="font-size:.8rem;display:grid;gap:.2rem;">QR tracking X<input type="number" name="ap_qr_x" value="<%=apS.ap_qr_x||660%>" class="form-control" style="font-size:.82rem;padding:.3rem .5rem;"></label>
        <label style="font-size:.8rem;display:grid;gap:.2rem;">QR tracking Y<input type="number" name="ap_qr_y" value="<%=apS.ap_qr_y||45%>" class="form-control" style="font-size:.82rem;padding:.3rem .5rem;"></label>
        <label style="font-size:.8rem;display:grid;gap:.2rem;">QR tracking dimensione<input type="number" name="ap_qr_size" value="<%=apS.ap_qr_size||80%>" class="form-control" style="font-size:.82rem;padding:.3rem .5rem;"></label>
      </div>
      <button type="submit" class="btn btn-primary" style="font-size:.8rem;padding:.38rem .9rem;">&#10003; Salva coordinate</button>
    </form>
  </div>
</div>


<!-- ===== TAB EDIZIONI ===== -->
<div id="panel-edizioni" class="settings-panel" style="display:none">
  <div class="card">
    <div class="card-title">🗓️ Gestione Edizioni</div>

    <% var edSaved = (typeof query !== 'undefined' ? query : (locals.query||{})).saved; %>
    <% var edErr   = (typeof query !== 'undefined' ? query : (locals.query||{})).err; %>
    <% if (edSaved) { %>
      <div style="background:#d1fae5;color:#065f46;padding:.65rem 1rem;border-radius:8px;margin-bottom:1rem;font-size:.88rem">✅ Salvato</div>
    <% } %>

    <!-- Edizione corrente in evidenza -->
    <% var currentEd = (typeof editions !== 'undefined') ? editions.find(function(e){return e.is_current==1}) : null; %>
    <% if (currentEd) { %>
    <div style="display:flex;align-items:center;gap:.75rem;background:#eff6ff;border:1.5px solid #bfdbfe;border-radius:10px;padding:1rem 1.25rem;margin-bottom:1.5rem">
      <span style="font-size:1.5rem">🏆</span>
      <div>
        <div style="font-weight:800;font-size:1rem;color:#1e2d4e"><%= currentEd.name %></div>
        <div style="font-size:.8rem;color:#64748b">Edizione attiva — tutti i nuovi stand e le accreditazioni vengono associati a questa edizione</div>
      </div>
    </div>
    <% } %>

    <!-- Lista edizioni -->
    <table style="width:100%;border-collapse:collapse;margin-bottom:1.5rem;font-size:.88rem">
      <thead>
        <tr style="background:#f8fafc;border-bottom:2px solid #e2e8f0">
          <th style="padding:.6rem .75rem;text-align:left;color:#475569">Edizione</th>
          <th style="padding:.6rem .75rem;text-align:left;color:#475569">Anno</th>
          <th style="padding:.6rem .75rem;text-align:left;color:#475569">Stato</th>
          <th style="padding:.6rem .75rem;text-align:right;color:#475569">Azioni</th>
        </tr>
      </thead>
      <tbody>
        <% if (typeof editions !== 'undefined' && editions.length) { editions.forEach(function(ed) { %>
        <tr style="border-bottom:1px solid #f1f5f9">
          <td style="padding:.65rem .75rem;font-weight:700;color:#1e2d4e"><%= ed.name %></td>
          <td style="padding:.65rem .75rem;color:#64748b"><%= ed.year || '—' %></td>
          <td style="padding:.65rem .75rem">
            <% if (ed.is_current) { %>
              <span style="background:#d1fae5;color:#065f46;font-size:.72rem;font-weight:700;padding:.2rem .55rem;border-radius:12px;text-transform:uppercase">● Attiva</span>
            <% } else { %>
              <span style="background:#f1f5f9;color:#94a3b8;font-size:.72rem;font-weight:600;padding:.2rem .55rem;border-radius:12px;text-transform:uppercase">Archivio</span>
            <% } %>
          </td>
          <td style="padding:.65rem .75rem;text-align:right">
            <% if (!ed.is_current) { %>
            <form method="post" action="/admin/editions/<%= ed.id %>/set-current" style="display:inline"
              onsubmit="return confirm('Impostare «<%= ed.name %>» come edizione corrente?')">
              <button type="submit" style="background:#1e2d4e;color:#f5c842;border:none;border-radius:6px;padding:.3rem .75rem;font-size:.78rem;font-weight:700;cursor:pointer">↑ Imposta corrente</button>
            </form>
            <form method="post" action="/admin/editions/<%= ed.id %>/delete" style="display:inline;margin-left:.3rem"
              onsubmit="return confirm('Eliminare «<%= ed.name %>»? Solo se non ha stand associati.')">
              <button type="submit" style="background:#fee2e2;color:#991b1b;border:none;border-radius:6px;padding:.3rem .65rem;font-size:.78rem;font-weight:600;cursor:pointer">🗑</button>
            </form>
            <% } else { %>
            <span style="color:#94a3b8;font-size:.78rem;font-style:italic">Edizione corrente</span>
            <% } %>
          </td>
        </tr>
        <% }); } else { %>
        <tr><td colspan="4" style="padding:1.5rem;text-align:center;color:#94a3b8;font-size:.88rem">Nessuna edizione configurata</td></tr>
        <% } %>
      </tbody>
    </table>

    <!-- Errori -->
    <% if (edErr === 'current') { %>
      <div style="background:#fee2e2;color:#991b1b;padding:.5rem .85rem;border-radius:7px;font-size:.82rem;margin-bottom:.75rem">⚠️ Non puoi eliminare l'edizione corrente</div>
    <% } else if (edErr === 'inuse') { %>
      <div style="background:#fef3c7;color:#92400e;padding:.5rem .85rem;border-radius:7px;font-size:.82rem;margin-bottom:.75rem">⚠️ Questa edizione ha stand associati — non può essere eliminata</div>
    <% } else if (edErr === 'anno') { %>
      <div style="background:#fee2e2;color:#991b1b;padding:.5rem .85rem;border-radius:7px;font-size:.82rem;margin-bottom:.75rem">⚠️ L'anno è obbligatorio (es. 2027)</div>
    <% } else if (edErr === 'db') { %>
      <div style="background:#fee2e2;color:#991b1b;padding:.5rem .85rem;border-radius:7px;font-size:.82rem;margin-bottom:.75rem">⚠️ Errore database — controlla i log del server</div>
    <% } %>

    <!-- Crea nuova edizione -->
    <div style="border-top:1px solid #e2e8f0;padding-top:1.25rem">
      <div style="font-weight:700;font-size:.9rem;color:#1e2d4e;margin-bottom:.75rem">➕ Crea nuova edizione</div>
      <form method="post" action="/admin/editions" style="display:flex;gap:.75rem;align-items:flex-end;flex-wrap:wrap">
        <div>
          <label style="display:block;font-size:.74rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.5px;margin-bottom:.3rem">Nome edizione *</label>
          <input type="text" name="name" placeholder="es. Ludicomix 2027" required
            style="border:1.5px solid #d1d9e6;border-radius:8px;padding:.45rem .75rem;font-size:.9rem;min-width:220px">
        </div>
        <div>
          <label style="display:block;font-size:.74rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.5px;margin-bottom:.3rem">Anno</label>
          <input type="number" name="year" placeholder="2027" min="2020" max="2099" required
            style="border:1.5px solid #d1d9e6;border-radius:8px;padding:.45rem .75rem;font-size:.9rem;width:110px">
        </div>
        <button type="submit" class="btn btn-primary" style="padding:.5rem 1.25rem;font-size:.88rem">Crea edizione</button>
      </form>
      <p style="font-size:.78rem;color:#94a3b8;margin-top:.65rem">
        💡 Dopo la creazione usa <strong>↑ Imposta corrente</strong> per attivare la nuova edizione.
        I dati delle edizioni precedenti restano accessibili nell'archivio.
      </p>
    </div>
  </div>
</div>



