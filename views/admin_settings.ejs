<div id="panel-scan" class="settings-panel" style="display:none;">
  <div class="card" style="border-top:3px solid var(--accent-blue,#1d6fa4);overflow-x:auto">
    <%
    var SA_LABELS={SUCCESS:'Consegnato',NOT_FOUND:'Non trovato',INVALIDATO:'Invalidato',GIA_CONSEGNATO:'Gia consegnato',GIA_RICONSEGNATO:'Gia riconsegnato'};
    var SA_CLS={SUCCESS:'sa-ok',NOT_FOUND:'sa-err',INVALIDATO:'sa-err',GIA_CONSEGNATO:'sa-warn',GIA_RICONSEGNATO:'sa-warn'};
    %>
    <style>
    .sa-badge{display:inline-flex;align-items:center;padding:.16rem .55rem;border-radius:9999px;font-size:.68rem;font-weight:700}
    .sa-ok{background:#2d6a4f;color:#fff}.sa-err{background:#c0392b;color:#fff}.sa-warn{background:#c9a227;color:#1a2744}
    .sa-table{width:100%;border-collapse:collapse;font-size:.81rem}
    .sa-table th{background:var(--bg-offset,#f0f2f5);padding:.55rem .8rem;text-align:left;font-size:.7rem;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted);border-bottom:2px solid var(--border,#d1d9e6)}
    .sa-table td{padding:.48rem .8rem;border-bottom:1px solid var(--border-light,#e8ecf3)}
