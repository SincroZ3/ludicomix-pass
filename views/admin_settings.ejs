      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:.75rem;margin-bottom:1rem;">
        <% const apS = apSettings||{}; %>
        <label style="font-size:.8rem;display:grid;gap:.2rem;">Nome espositore X<input type="number" name="ap_esp_x" value="<%=apS.ap_esp_x||350%>" class="form-control" style="font-size:.82rem;padding:.3rem .5rem;"></label>
        <label style="font-size:.8rem;display:grid;gap:.2rem;">Nome espositore Y<input type="number" name="ap_esp_y" value="<%=apS.ap_esp_y||125%>" class="form-control" style="font-size:.82rem;padding:.3rem .5rem;"></label>
        <label style="font-size:.8rem;display:grid;gap:.2rem;">Dimensione font (pt)<input type="number" name="ap_esp_size" value="<%=apS.ap_esp_size||20%>" class="form-control" style="font-size:.82rem;padding:.3rem .5rem;"></label>
        <label style="font-size:.8rem;display:grid;gap:.2rem;">Numero pass X<input type="number" name="ap_num_x" value="<%=apS.ap_num_x||95%>" class="form-control" style="font-size:.82rem;padding:.3rem .5rem;"></label>
        <label style="font-size:.8rem;display:grid;gap:.2rem;">Numero pass Y<input type="number" name="ap_num_y" value="<%=apS.ap_num_y||125%>" class="form-control" style="font-size:.82rem;padding:.3rem .5rem;"></label>
        <label style="font-size:.8rem;display:grid;gap:.2rem;">Totale ("di") X<input type="number" name="ap_tot_x" value="<%=apS.ap_tot_x||95%>" class="form-control" style="font-size:.82rem;padding:.3rem .5rem;"></label>
        <label style="font-size:.8rem;display:grid;gap:.2rem;">Totale ("di") Y<input type="number" name="ap_tot_y" value="<%=apS.ap_tot_y||95%>" class="form-control" style="font-size:.82rem;padding:.3rem .5rem;"></label>
        <label style="font-size:.8rem;display:grid;gap:.2rem;">QR tracking X<input type="number" name="ap_qr_x" value="<%=apS.ap_qr_x||660%>" class="form-control" style="font-size:.82rem;padding:.3rem .5rem;"></label>
        <label style="font-size:.8rem;display:grid;gap:.2rem;">QR tracking Y<input type="number" name="ap_qr_y" value="<%=apS.ap_qr_y||45%>" class="form-control" style="font-size:.82rem;padding:.3rem .5rem;"></label>
        <label style="font-size:.8rem;display:grid;gap:.2rem;">QR tracking dimensione<input type="number" name="ap_qr_size" value="<%=apS.ap_qr_size||80%>" class="form-control" style="font-size:.82rem;padding:.3rem .5rem;"></label>
      </div>
      <button type="submit" class="primary" style="font-size:.8rem;padding:.38rem .9rem;">&#10003; Salva coordinate</button>
    </form>
  </div>
</div>



<script>
(function () {
  var PANELS = { zone: 'panel-zone', raggruppamenti: 'panel-raggruppamenti', tipologie: 'panel-tipologie', backup:'panel-backup',notifiche:'panel-notifiche', utenti: 'panel-utenti', scan: 'panel-scan', auto_pass: 'panel-auto_pass', portali: 'panel-portali' };
  var tabs   = document.querySelectorAll('[data-tab]');

  function showTab(key) {
    tabs.forEach(function(t){ t.classList.toggle('active', t.dataset.tab === key); });
    Object.keys(PANELS).forEach(function(k){
      document.getElementById(PANELS[k]).style.display = (k === key) ? '' : 'none';
    });
    history.replaceState(null, '', '#' + key);
  }

  tabs.forEach(function(t){ t.addEventListener('click', function(){ showTab(t.dataset.tab); }); });

  var hash = location.hash.replace('#', '');
  if (PANELS[hash]) showTab(hash);
})();

function apriModificaZona(id, name, order) {
  document.getElementById('edit-zone-name').value  = name;
  document.getElementById('edit-zone-order').value = order;
  document.getElementById('form-edit-zone').action = '/admin/zones/' + id + '/edit';
  document.getElementById('modal-edit-zone').style.display = 'flex';
}

function apriModificaGruppo(id, name, priority, passTypeId) {
  document.getElementById('edit-group-name').value     = name;
  document.getElementById('edit-group-priority').value = priority;
  var sel = document.getElementById('edit-group-passtype');
  for (var i = 0; i < sel.options.length; i++) {
    sel.options[i].selected = (sel.options[i].value === String(passTypeId));
  }
  document.getElementById('form-edit-group').action = '/groups/' + id + '/edit';
  document.getElementById('modal-edit-group').style.display = 'flex';
}

(function(){
  var rows=Array.from(document.querySelectorAll('#sa-table tbody tr'));
  var cnt=document.getElementById('sa-count');
  function update(){
    var q=(document.getElementById('sa-search')?document.getElementById('sa-search').value:'').toLowerCase();
    var r=document.getElementById('sa-filter')?document.getElementById('sa-filter').value:'';
    var v=0;
    rows.forEach(function(row){
      var show=(!q||row.textContent.toLowerCase().includes(q))&&(!r||row.getAttribute('data-result')===r);
      row.style.display=show?'':'none';if(show)v++;
    });
    if(cnt)cnt.textContent=v+' / '+rows.length+' righe';
  }
  var s=document.getElementById('sa-search');var f=document.getElementById('sa-filter');
  if(s)s.addEventListener('input',update);if(f)f.addEventListener('change',update);
  if(rows.length)update();
})();
</script>




