<%- include('partials/header') %>
<nav class="breadcrumb-bar">Sei in: <a href="/home">Home</a> &rsaquo; <strong>&#128269; Tentativi Scansione</strong></nav>
<h1 class="page-title">&#128269; Cronologia Tentativi Scansione</h1>

<style>
.sa-filters{display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:1rem;}
.sa-filters select,.sa-filters input{
  padding:.35rem .7rem;border:1px solid var(--border,#d1d9e6);
  border-radius:8px;font-size:.8rem;background:var(--bg-white,#fff);
  color:var(--text-primary,#1a2744);
}
.sa-badge{display:inline-flex;align-items:center;padding:.16rem .55rem;border-radius:9999px;font-size:.68rem;font-weight:700;white-space:nowrap}
.sa-ok{background:#2d6a4f;color:#fff}
.sa-err{background:#c0392b;color:#fff}
.sa-warn{background:#c9a227;color:#1a2744}
.sa-table{width:100%;border-collapse:collapse;font-size:.81rem}
.sa-table th{background:var(--bg-offset,#f0f2f5);padding:.55rem .8rem;text-align:left;
  font-size:.7rem;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted,#64748b);
  border-bottom:2px solid var(--border,#d1d9e6)}
.sa-table td{padding:.48rem .8rem;border-bottom:1px solid var(--border-light,#e8ecf3)}
.sa-table tr:hover td{background:var(--bg-hover,#f8fafc)}
.sa-code{font-family:monospace;font-size:.78rem;color:var(--text-muted,#64748b)}
.sa-empty{padding:3rem 1rem;text-align:center;color:var(--text-muted,#64748b)}
</style>

<%
var LABELS = {
  SUCCESS: 'Consegnato',
  NOT_FOUND: 'Non trovato',
  INVALIDATO: 'Invalidato',
  GIA_CONSEGNATO: 'Già consegnato',
  GIA_RICONSEGNATO: 'Già riconsegnato'
};
var CLS = {
  SUCCESS: 'sa-ok',
  NOT_FOUND: 'sa-err',
  INVALIDATO: 'sa-err',
  GIA_CONSEGNATO: 'sa-warn',
  GIA_RICONSEGNATO: 'sa-warn'
};
%>

<div class="card" style="overflow-x:auto">

  <div class="sa-filters">
    <input type="text" id="sa-search" placeholder="&#128269; Cerca codice, nome, gruppo..." style="min-width:220px">
    <select id="sa-filter-result">
      <option value="">Tutti gli esiti</option>
      <option value="SUCCESS">&#9989; Consegnato</option>
      <option value="NOT_FOUND">&#10060; Non trovato</option>
      <option value="INVALIDATO">&#128683; Invalidato</option>
      <option value="GIA_CONSEGNATO">&#9888;&#65039; Già consegnato</option>
      <option value="GIA_RICONSEGNATO">&#9888;&#65039; Già riconsegnato</option>
    </select>
    <span id="sa-count" style="font-size:.78rem;color:var(--text-muted,#64748b);align-self:center"></span>
  </div>

  <% if(!attempts.length){ %>
    <div class="sa-empty">
      <div style="font-size:2rem;margin-bottom:.5rem">&#128269;</div>
      <p>Nessun tentativo di scansione registrato.</p>
    </div>
  <% }else{ %>
  <table class="sa-table" id="sa-table">
    <thead><tr>
      <th>Data / Ora</th>
      <th>Codice QR</th>
      <th>Esito</th>
      <th>Assegnatario</th>
      <th>Gruppo</th>
      <th>Operatore</th>
      <th>IP</th>
    </tr></thead>
    <tbody>
    <% attempts.forEach(function(a){ %>
    <tr data-result="<%= a.result %>">
      <td style="white-space:nowrap;color:var(--text-muted);font-size:.74rem;"><%= a.created_at %></td>
      <td><span class="sa-code"><%= a.code %></span></td>
      <td><span class="sa-badge <%= CLS[a.result]||'sa-warn' %>"><%= LABELS[a.result]||a.result %></span></td>
      <td><%= a.participant_name||'&mdash;' %></td>
      <td><%= a.group_name||'&mdash;' %></td>
      <td style="font-weight:600">@<%= a.username||'?' %></td>
      <td style="font-size:.72rem;color:var(--text-muted)"><%= a.ip||'&mdash;' %></td>
    </tr>
    <% }); %>
    </tbody>
  </table>
  <% } %>
</div>

<script>
(function(){
  var rows = Array.from(document.querySelectorAll('#sa-table tbody tr'));
  var cnt  = document.getElementById('sa-count');
  function update(){
    var q   = (document.getElementById('sa-search').value||'').toLowerCase();
    var res = document.getElementById('sa-filter-result').value;
    var vis = 0;
    rows.forEach(function(r){
      var text = r.textContent.toLowerCase();
      var matchQ   = !q   || text.includes(q);
      var matchRes = !res || r.getAttribute('data-result') === res;
      var show = matchQ && matchRes;
      r.style.display = show ? '' : 'none';
      if(show) vis++;
    });
    if(cnt) cnt.textContent = vis + ' / ' + rows.length + ' righe';
  }
  document.getElementById('sa-search').addEventListener('input', update);
  document.getElementById('sa-filter-result').addEventListener('change', update);
  update();
})();
</script>

<%- include('partials/footer') %>
