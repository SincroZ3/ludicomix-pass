<%-include('partials/header') %>
<nav class="breadcrumb-bar">Sei in: <a href="/home">Home</a> <span class="sep">›</span> <a href="/participants">Assegnatari Pass</a> <span class="sep">›</span> <%= groupInfo.category_name %> <span class="sep">›</span> <strong><%= groupInfo.name %></strong></nav>
<h1 class="page-title"><%= groupInfo.name %></h1>

<% const isViewer = currentUser && currentUser.role === 'viewer';
   const VIEWER_STATUSES = ['SCARICATO','STAMPATO','CONSEGNATO','RICONSEGNATO'];
%>

<% if (isViewer) { %>
  <div class="alert alert-info"><span>&#128065;</span> Sei in modalit&#224; <strong>Visualizzatore</strong>: puoi consultare i dati e modificare lo stato dei pass, ma non aggiungere o eliminare assegnatari.</div>
<% } %>

<!-- INFO RIEPILOGO -->
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:0.75rem;margin-bottom:1.25rem;">
  <div class="card" style="margin:0;"><div class="card-title">Categoria</div><strong><%= groupInfo.category_name %></strong></div>
  <div class="card" style="margin:0;"><div class="card-title">Stand / Riferimento</div><strong><%= groupInfo.stand_name || groupInfo.name %></strong></div>
  <div class="card" style="margin:0;">
    <div class="card-title">Zona / Padiglione</div>
    <strong><%= groupInfo.zone || '&mdash;' %></strong>
    <% if (groupInfo.stand_code) { %>&nbsp;&middot;&nbsp;Codice: <strong><%= groupInfo.stand_code %></strong><% } %>
  </div>
  <div class="card" style="margin:0;">
    <div class="card-title">Pass</div>
    <strong><%= participants.length %></strong> assegnatari&nbsp;&middot;&nbsp;
    Limite: <strong><%= groupInfo.max_passes != null ? groupInfo.max_passes : 'illimitati' %></strong>
  </div>
  <% if (groupInfo.email) { %>
  <div class="card" style="margin:0;">
    <div class="card-title">Email riferimento</div>
    <a href="mailto:<%= groupInfo.email %>"><%= groupInfo.email %></a>
  </div>
  <% } %>
</div>

<% if (!isViewer) { %>
<details style="margin-bottom:1rem;">
  <summary style="cursor:pointer;font-weight:700;font-size:0.85rem;color:var(--accent-blue);padding:0.4rem 0;">&#9999;&#65039; Modifica dati gruppo / stand</summary>
  <div class="card" style="margin-top:0.5rem;">
    <form method="post" action="/assignment-groups/<%= groupInfo.id %>/edit" style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem 1rem;">
      <label>Nome gruppo <span style="color:#c0392b">*</span><br>
        <input type="text" name="name" value="<%= groupInfo.name %>" required>
      </label>
      <label>Nome stand / riferimento<br>
        <input type="text" name="stand_name" value="<%= groupInfo.stand_name || '' %>">
      </label>
      <label>Zona / Padiglione<br>
        <input type="text" name="zone" value="<%= groupInfo.zone || '' %>">
      </label>
      <label>Codice stand<br>
        <input type="text" name="stand_code" value="<%= groupInfo.stand_code || '' %>">
      </label>
      <div style="grid-column:1/-1;">
        <button type="submit" class="primary">Salva modifiche</button>
      </div>
    </form>
  </div>
</details>

<details style="margin-bottom:1rem;">
  <summary style="cursor:pointer;font-weight:700;font-size:0.85rem;color:var(--accent-blue);padding:0.4rem 0;">&#128221; Note ed Email gruppo <% if (groupInfo.notes || groupInfo.email) { %><span class="chip" style="background:#e8f5e9;color:#1b5e20;margin-left:0.4rem;">compilate</span><% } %></summary>
  <div class="card" style="margin-top:0.5rem;max-width:600px;">
    <form method="post" action="/assignment-groups/<%= groupInfo.id %>/notes" style="display:grid;gap:0.75rem;">
      <label>Note<br>
        <textarea name="notes" rows="3" style="resize:vertical;"><%= groupInfo.notes || '' %></textarea>
      </label>
      <label>Email di riferimento gruppo<br>
        <input type="email" name="email" value="<%= groupInfo.email || '' %>" placeholder="email@esempio.it">
      </label>
      <div><button type="submit" class="primary">Salva modifiche</button></div>
    </form>
  </div>
</details>
<% } else { %>
  <% if (groupInfo.notes) { %>
    <div class="alert alert-info" style="margin-bottom:1rem;"><span>&#128221;</span> <strong>Note:</strong> <%= groupInfo.notes %></div>
  <% } %>
<% } %>

<% if (!isViewer) { %>

<!-- MODIFICA LIMITE -->
<details style="margin-bottom:1rem;">
  <summary style="cursor:pointer;font-weight:700;font-size:0.85rem;color:var(--accent-blue);padding:0.4rem 0;">&#128295; Modifica limite massimo di pass per questo gruppo</summary>
  <div class="card" style="margin-top:0.5rem;max-width:440px;">
    <form method="post" action="/assignment-groups/<%= groupInfo.id %>/limit" style="display:grid;gap:0.75rem;">
      <label>Numero massimo di pass (0 o vuoto = illimitati)<br>
        <input type="number" name="max_passes" min="0" value="<%= groupInfo.max_passes || '' %>">
      </label>
      <label>Password amministratore <span style="color:#c0392b">*</span><br>
        <input type="password" name="admin_password" required>
      </label>
      <div><button type="submit" class="primary">Aggiorna limite</button></div>
    </form>
  </div>
</details>

<!-- INSERIMENTO MULTIPLO -->
<details open style="margin-bottom:1.25rem;">
  <summary style="cursor:pointer;font-weight:700;font-size:0.85rem;color:var(--accent-blue);padding:0.4rem 0;">&#10133; Aggiungi assegnatari (anche multipli)</summary>
  <div class="card" style="margin-top:0.5rem;">
    <p style="font-size:0.82rem;color:var(--text-secondary);margin:0 0 0.75rem;">
      Inserisci uno o pi&#249; nominativi, <strong>uno per riga</strong>, nel formato <code>Nome Cognome</code>.<br>
      Puoi incollare direttamente una lista da email o Excel.
    </p>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
      <div>
        <label>Lista nominativi <span style="color:#c0392b">*</span><br>
          <textarea id="bulk-names" rows="8"
            placeholder="Mario Rossi&#10;Anna Bianchi&#10;Luca Verdi&#10;..."
            style="font-family:monospace;font-size:0.85rem;resize:vertical;"
            oninput="aggiornaPrev()"></textarea>
        </label>
        <div id="bulk-count" style="font-size:0.78rem;color:var(--text-muted);margin-top:0.25rem;"></div>
      </div>
      <div style="display:flex;flex-direction:column;gap:0.5rem;">
        <div class="card" style="margin:0;background:var(--bg-section);flex:1;">
          <div class="card-title">Anteprima nominativi</div>
          <div id="bulk-preview-list" style="font-size:0.82rem;max-height:180px;overflow-y:auto;"></div>
        </div>
        <button type="button" class="primary"
          onclick="avviaBulk('<%= groupInfo.id %>')"
          style="align-self:flex-start;">
          &#10133; Inserisci nominativi
        </button>
        <div id="bulk-ok"  class="alert alert-success" style="display:none;margin:0;"></div>
        <div id="bulk-err" class="alert alert-danger"  style="display:none;margin:0;"></div>
      </div>
    </div>
  </div>
</details>
<% } %>

<!-- TABELLA ASSEGNATARI -->
<h2>Elenco assegnatari <span class="chip"><%= participants.length %></span></h2>

<% if (participants.length === 0) { %>
  <div class="alert alert-info"><span>&#8505;&#65039;</span> Nessun nominativo inserito per questo gruppo.</div>
<% } else { %>
  <form method="post" action="/passes/bulk" id="form-bulk-passes" onsubmit="return verificaDuplicati(event, this)">
    <input type="hidden" name="assignment_group_id" value="<%= groupInfo.id %>">
    <% if (!isViewer) { %>
    <div class="card" style="display:flex;gap:1rem;align-items:flex-end;flex-wrap:wrap;margin-bottom:0.75rem;">
      <label style="margin:0;flex:1;min-width:200px;">Tipologia di Pass da generare <span style="color:#c0392b">*</span><br>
        <select name="pass_type_id" required>
          <% types.forEach(function(t){ %><option value="<%= t.id %>"><%= t.name %></option><% }); %>
        </select>
      </label>
      <button type="button" class="primary" id="btn-genera" onclick="controllaEGenera(this)">&#128424; Genera pass selezionati</button>
    </div>
    <% } %>
    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <% if (!isViewer) { %><th><input type="checkbox" title="Seleziona tutti" onclick="document.querySelectorAll('.chk-group').forEach(function(c){c.checked=this.checked;}.bind(this))"></th><% } %>
            <th>Cognome e Nome</th>
            <th>Email</th>
            <th>Cod. Riferimento</th>
            <th>Stato Pass</th>
            <th>PDF</th>
            <% if (!isViewer) { %><th>Cancella</th><% } %>
          </tr>
        </thead>
        <tbody>
          <% participants.forEach(function(p){ %>
            <tr>
              <% if (!isViewer) { %>
              <td><input type="checkbox" class="chk-group" name="participant_ids" value="<%= p.id %>"></td>
              <% } %>
              <td><strong><%= p.last_name %> <%= p.first_name %></strong></td>
              <td style="font-size:0.8rem;"><%= p.email || '' %></td>
              <td style="font-size:0.8rem;font-family:monospace;"><%= p.ref_code || '' %></td>
              <td>
                <% if (p.last_pass_id) { %>
                  <form method="post" action="/passes/<%= p.last_pass_id %>/status" class="status-form">
                    <input type="hidden" name="redirect_to_group" value="<%= groupInfo.id %>">
                    <select name="status" onchange="this.form.submit()">
                      <% const allowedStatuses = isViewer ? VIEWER_STATUSES : PASS_STATUSES; %>
                      <% allowedStatuses.forEach(function(s){ %>
                        <option value="<%= s %>" <%= p.last_status === s ? 'selected' : '' %>><%= s %></option>
                      <% }); %>
                    </select>
                  </form>
                <% } else { %>
                  <span style="color:var(--text-muted);font-size:0.78rem;">nessun pass</span>
                <% } %>
              </td>
              <td>
                <% if (p.last_pass_id) { %>
                  <a href="/passes/<%= p.last_pass_id %>/download" target="_blank" class="link-action" style="font-size:0.8rem;">&#11015; PDF</a>
                <% } else { %>
                  <span style="color:var(--text-muted);">&mdash;</span>
                <% } %>
              </td>
              <% if (!isViewer) { %>
              <td>
                <form method="post" action="/participants/<%= p.id %>/delete" onsubmit="return confirm('Eliminare <%= p.last_name %> <%= p.first_name %>?');">
                  <input type="hidden" name="redirect_to_group_id" value="<%= groupInfo.id %>">
                  <button type="submit" class="btn-danger">&#10005;</button>
                </form>
              </td>
              <% } %>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </form>
<% } %>

<!-- MODALE STALLO ALLA MESSICANA -->
<div class="modal-overlay" id="modal-stallo" style="display:none">
  <div class="modal" style="max-width:540px;">
    <div class="modal-header" style="background:#f3e5f5;border-bottom-color:#ce93d8;">
      <h2 style="color:#4a148c;">&#129300; Omonimo rilevato!</h2>
      <button type="button" class="modal-close" onclick="stalloSkip()">&#215;</button>
    </div>
    <div class="modal-body" style="text-align:center;">
      <img src="data:image/jpeg;base64,"
           style="max-width:280px;width:100%;margin:0 auto 0.75rem;display:block;border-radius:8px;" alt="Stallo alla messicana">
      <p style="font-size:1rem;font-weight:700;color:#4a148c;margin:0 0 0.25rem;">
        Stai inserendo: <strong id="stallo-nome" style="color:#1a2744;"></strong>
      </p>
      <div id="stallo-warn-inv" class="alert alert-warning" style="display:none;text-align:left;margin:0.5rem 0;">
        <span>&#9888;&#65039;</span> <strong>Attenzione:</strong> nome e cognome potrebbero essere invertiti rispetto al duplicato!
      </div>
      <div class="card" style="text-align:left;margin:0.5rem 0 0;">
        <div class="card-title">Gi&#224; presente nel sistema</div>
        <table style="font-size:0.85rem;box-shadow:none;border:none;background:transparent;">
          <tr><td style="font-weight:700;color:var(--text-secondary);padding:0.25rem 0.5rem 0.25rem 0;white-space:nowrap;">Nome Cognome</td><td id="stallo-dup-nome" style="font-weight:700;"></td></tr>
          <tr><td style="font-weight:700;color:var(--text-secondary);padding:0.25rem 0.5rem 0.25rem 0;">Gruppo</td><td id="stallo-dup-gruppo"></td></tr>
          <tr><td style="font-weight:700;color:var(--text-secondary);padding:0.25rem 0.5rem 0.25rem 0;">Categoria</td><td id="stallo-dup-cat"></td></tr>
          <tr><td style="font-weight:700;color:var(--text-secondary);padding:0.25rem 0.5rem 0.25rem 0;">Tipologia pass</td><td id="stallo-dup-tipo"></td></tr>
          <tr><td style="font-weight:700;color:var(--text-secondary);padding:0.25rem 0.5rem 0.25rem 0;">Stato pass</td><td id="stallo-dup-stato"></td></tr>
        </table>
      </div>
      <div class="modal-actions" style="margin-top:1rem;justify-content:center;gap:1rem;">
        <button type="button" class="secondary" onclick="stalloSkip()">&#10060; Non inserire</button>
        <button type="button" class="primary" onclick="stalloConferma()">&#10003; Inserisci comunque</button>
      </div>
    </div>
  </div>
</div>

<!-- MODALE MARONNO - LIMITE SUPERATO -->
<div class="modal-overlay" id="modal-maronno" style="display:none">
  <div class="modal" style="max-width:500px;">
    <div class="modal-header" style="background:#fff8e1;border-bottom-color:#f6c343;">
      <h2 style="color:#7d5a00;">&#9888;&#65039; Limite pass superato!</h2>
      <button type="button" class="modal-close" onclick="document.getElementById('modal-maronno').style.display='none'">&#215;</button>
    </div>
    <div class="modal-body" style="text-align:center;">
      <img src="data:image/jpeg;base64,"
           style="max-width:200px;width:100%;margin:0 auto 0.5rem;display:block;" alt="E se poi te ne penti?">
      <p id="mar-msg" style="font-size:1rem;font-weight:700;color:#7d5a00;margin:0 0 0.25rem;"></p>
      <p id="mar-sub" style="font-size:0.85rem;color:var(--text-secondary);margin:0 0 1rem;"></p>
      <div class="card" style="text-align:left;margin:0;">
        <div class="card-title">Vuoi aumentare il limite per procedere?</div>
        <label>Nuovo numero massimo di pass <span style="color:#c0392b">*</span><br>
          <input type="number" id="mar-max" min="1" style="max-width:140px;">
        </label>
        <label style="margin-top:0.6rem;">Password amministratore <span style="color:#c0392b">*</span><br>
          <input type="password" id="mar-pwd">
        </label>
        <div id="mar-err" style="color:#c0392b;font-size:0.82rem;margin-top:0.4rem;display:none;"></div>
      </div>
      <div class="modal-actions" style="margin-top:1rem;justify-content:center;">
        <button type="button" class="secondary" onclick="document.getElementById('modal-maronno').style.display='none'">Annulla</button>
        <button type="button" class="primary" onclick="maronnoForza()">Aumenta limite e inserisci</button>
      </div>
    </div>
  </div>
</div>

<script>
var GID = '<%= groupInfo.id %>';
var _nomiPending = '';
var _stalloQueue = [];
var _stalloConf = [];
var _stalloNomeCorrente = '';

// Anteprima textarea
function aggiornaPrev() {
  var val = document.getElementById('bulk-names').value;
  var lines = val.split('\n').map(function(l){ return l.trim(); }).filter(function(l){ return l !== ''; });
  var cnt = document.getElementById('bulk-count');
  if (cnt) cnt.textContent = lines.length + ' nominativo/i';
  var list = document.getElementById('bulk-preview-list');
  if (!list) return;
  if (lines.length === 0) { list.innerHTML = '<span style="color:var(--text-muted)">Nessun nominativo</span>'; return; }
  list.innerHTML = lines.map(function(l, i) {
    return '<div style="padding:0.15rem 0;border-bottom:1px solid #eee;"><span style="color:#aaa;margin-right:4px;">' + (i+1) + '.</span>' + l.replace(/</g,'&lt;').replace(/>/g,'&gt;') + '</div>';
  }).join('');
}

function parsaNome(line) {
  var p = line.trim().split(/\s+/);
  return { fn: p[0]||'', ln: p.slice(1).join(' ') };
}

// Controllo duplicati prima di generare bulk
function controllaEGenera(btn) {
  var form = btn.closest('form');
  var checkboxes = form.querySelectorAll('.chk-group:checked');
  if (checkboxes.length === 0) { alert('Seleziona almeno un assegnatario.'); return; }

  var ids = Array.from(checkboxes).map(function(c){ return c.value; });
  var params = new URLSearchParams();
  ids.forEach(function(id){ params.append('participant_ids', id); });

  fetch('/passes/check-existing', {
    method: 'POST',
    headers: {'Content-Type': 'application/x-www-form-urlencoded'},
    body: params.toString()
  }).then(function(r){ return r.json(); })
    .then(function(data) {
      if (data.duplicates && data.duplicates.length > 0) {
        var names = data.duplicates.map(function(d){ return d.name; }).join(', ');
        document.getElementById('stop-msg').textContent =
          'I seguenti assegnatari hanno già un pass generato: ' + names +
          '. Eliminare prima il pass esistente da "Pass Generati".';
        document.getElementById('modal-stop').style.display = 'flex';
      } else {
        form.submit();
      }
    })
    .catch(function(){ form.submit(); });
}

// Avvia inserimento bulk nominativi
function avviaBulk(groupId) {
  var val = document.getElementById('bulk-names').value.trim();
  if (!val) { mostraErr('Inserisci almeno un nominativo'); return; }
  _nomiPending = val;
  GID = groupId || GID;

  var lines = val.split('\n').map(function(l){ return l.trim(); }).filter(function(l){ return l !== ''; });

  var checks = lines.map(function(line) {
    var n = parsaNome(line);
    var p = new URLSearchParams();
    p.append('first_name', n.fn);
    p.append('last_name', n.ln);
    p.append('assignment_group_id', GID);
    return fetch('/participants/check-duplicate', {
      method: 'POST',
      headers: {'Content-Type': 'application/x-www-form-urlencoded'},
      body: p.toString()
    }).then(function(r){ return r.json(); })
      .then(function(d){ return { line: line, n: n, dups: d.duplicates||[] }; });
  });

  Promise.all(checks)
    .then(function(res) {
      var conDup = res.filter(function(r){ return r.dups.length > 0; });
      var senzaDup = res.filter(function(r){ return r.dups.length === 0; });
      if (conDup.length === 0) {
        inserisciTutti(lines.join('\n'), GID);
      } else {
        _stalloQueue = conDup.slice();
        _stalloConf = senzaDup.map(function(r){ return r.line; });
        prossimoStallo();
      }
    })
    .catch(function(e){ mostraErr('Errore: ' + e.message); });
}

function prossimoStallo() {
  if (_stalloQueue.length === 0) {
    if (_stalloConf.length === 0) { mostraErr('Nessun nominativo da inserire.'); return; }
    inserisciTutti(_stalloConf.join('\n'), GID);
    return;
  }
  var item = _stalloQueue.shift();
  _stalloNomeCorrente = item.line;
  var d = item.dups[0];
  document.getElementById('stallo-nome').textContent = item.n.fn + ' ' + item.n.ln;
  document.getElementById('stallo-dup-nome').textContent = (d.last_name||'') + ' ' + (d.first_name||'');
  document.getElementById('stallo-dup-gruppo').textContent = d.group_name || '---';
  document.getElementById('stallo-dup-cat').textContent = d.category_name || '---';
  document.getElementById('stallo-dup-tipo').textContent = d.pass_type_name || 'nessun pass';
  document.getElementById('stallo-dup-stato').textContent = d.last_status || 'nessun pass';
  var inv = (d.first_name||'').toLowerCase() === item.n.ln.toLowerCase() &&
            (d.last_name||'').toLowerCase() === item.n.fn.toLowerCase();
  document.getElementById('stallo-warn-inv').style.display = inv ? '' : 'none';
  document.getElementById('modal-stallo').style.display = 'flex';
}

function stalloConferma() {
  _stalloConf.push(_stalloNomeCorrente);
  document.getElementById('modal-stallo').style.display = 'none';
  setTimeout(prossimoStallo, 150);
}

function stalloSkip() {
  document.getElementById('modal-stallo').style.display = 'none';
  setTimeout(prossimoStallo, 150);
}

function inserisciTutti(nomi, groupId) {
  var p = new URLSearchParams();
  p.append('names_list', nomi);
  p.append('assignment_group_id', groupId);
  fetch('/participants/bulk-import', {
    method: 'POST',
    headers: {'Content-Type': 'application/x-www-form-urlencoded'},
    body: p.toString()
  }).then(function(r){ return r.json().then(function(d){ return {s:r.status, d:d}; }); })
    .then(function(obj) {
      if (obj.d.success) {
        mostraOk('Inseriti ' + obj.d.inserted + ' nominativo/i!');
        setTimeout(function(){ window.location.reload(); }, 1000);
      } else if (obj.s === 409 && obj.d.warning) {
        apriMaronno(obj.d);
      } else {
        mostraErr(obj.d.error || "Errore durante l'inserimento");
      }
    })
    .catch(function(){ mostraErr('Errore di rete'); });
}

function apriMaronno(d) {
  _nomiPending = document.getElementById('bulk-names').value.trim();
  document.getElementById('mar-msg').textContent = 'Stai inserendo ' + d.adding + ' nominativi ma il limite e' ' + d.max + '!';
  document.getElementById('mar-sub').textContent = 'Attualmente ci sono ' + d.current + '. Dopo sarebbero ' + d.total_after + ' (' + d.over + ' oltre il limite).';
  document.getElementById('mar-max').value = d.total_after;
  document.getElementById('mar-pwd').value = '';
  document.getElementById('mar-err').style.display = 'none';
  document.getElementById('modal-maronno').style.display = 'flex';
}

function maronnoForza() {
  var newMax = document.getElementById('mar-max').value;
  var pwd = document.getElementById('mar-pwd').value;
  var errEl = document.getElementById('mar-err');
  if (!newMax) { errEl.textContent = 'Inserisci il nuovo limite'; errEl.style.display = ''; return; }
  if (!pwd) { errEl.textContent = 'Inserisci la password'; errEl.style.display = ''; return; }
  errEl.style.display = 'none';
  var p = new URLSearchParams();
  p.append('names_list', _nomiPending);
  p.append('assignment_group_id', GID);
  p.append('force_over_limit', '1');
  p.append('new_max_passes', newMax);
  p.append('admin_password', pwd);
  fetch('/participants/bulk-import', {
    method: 'POST',
    headers: {'Content-Type': 'application/x-www-form-urlencoded'},
    body: p.toString()
  }).then(function(r){ return r.json(); })
    .then(function(d) {
      if (d.success) {
        document.getElementById('modal-maronno').style.display = 'none';
        mostraOk('Inseriti ' + d.inserted + ' nominativi, limite aggiornato a ' + newMax);
        setTimeout(function(){ window.location.reload(); }, 1000);
      } else {
        errEl.textContent = d.error || 'Errore';
        errEl.style.display = '';
      }
    }).catch(function(){ errEl.textContent = 'Errore di rete'; errEl.style.display = ''; });
}

function mostraOk(msg) {
  var el = document.getElementById('bulk-ok');
  el.innerHTML = msg; el.style.display = '';
  document.getElementById('bulk-err').style.display = 'none';
}
function mostraErr(msg) {
  var el = document.getElementById('bulk-err');
  el.innerHTML = msg; el.style.display = '';
  document.getElementById('bulk-ok').style.display = 'none';
}
</script>

