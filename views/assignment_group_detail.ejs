<script>
// ── Variabili globali ──
var GID = '<%= groupInfo.id %>';   // group id iniettato da EJS
var _nomiPending = '';
var _stalloQueue = [];
var _stalloConf = [];
var _stalloNomeCorrente = '';

// ── Anteprima textarea ──
function aggiornaPrev() {
  var val = document.getElementById('bulk-names').value;
  var lines = val.split('\n').map(function(l){ return l.trim(); }).filter(function(l){ return l !== ''; });
  document.getElementById('bulk-count').textContent = lines.length + ' nominativo/i';
  var list = document.getElementById('bulk-preview-list');
  if (lines.length === 0) {
    list.innerHTML = '<span style="color:var(--text-muted)">Nessun nominativo</span>';
    return;
  }
  list.innerHTML = lines.map(function(l, i) {
    return '<div style="padding:0.15rem 0;border-bottom:1px solid #eee;">'
         + '<span style="color:#aaa;margin-right:4px;">' + (i+1) + '.</span>' + escHtml(l) + '</div>';
  }).join('');
}

function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function mostraOk(msg)  { var e=document.getElementById('bulk-ok');  e.textContent=msg; e.style.display=''; document.getElementById('bulk-err').style.display='none'; }
function mostraErr(msg) { var e=document.getElementById('bulk-err'); e.textContent=msg; e.style.display=''; document.getElementById('bulk-ok').style.display='none';  }

function parsaNome(line) {
  var p = line.trim().split(/\s+/);
  return { fn: p[0]||'', ln: p.slice(1).join(' ') };
}

// ── Avvia inserimento bulk ──
function avviaBulk(groupId) {
  var val = document.getElementById('bulk-names').value.trim();
  if (!val) { mostraErr('Inserisci almeno un nominativo'); return; }
  _nomiPending = val;
  GID = groupId || GID;

  var lines = val.split('\n').map(function(l){ return l.trim(); }).filter(function(l){ return l !== ''; });

  // Controlla duplicati per ogni riga in parallelo
  var checks = lines.map(function(line) {
    var n = parsaNome(line);
    var p = new URLSearchParams();
    p.append('first_name', n.fn);
    p.append('last_name', n.ln);
    p.append('assignment_group_id', GID);
    return fetch('/participants/check-duplicate', {
      method: 'POST',
      headers: {'Content-Type':'application/x-www-form-urlencoded'},
      body: p.toString()
    }).then(function(r){ return r.json(); })
      .then(function(d){ return { line:line, n:n, dups: d.duplicates||[] }; });
  });

  Promise.all(checks)
    .then(function(res) {
      var conDup    = res.filter(function(r){ return r.dups.length > 0; });
      var senzaDup  = res.filter(function(r){ return r.dups.length === 0; });
      if (conDup.length === 0) {
        inserisciTutti(lines.join('\n'), GID);
      } else {
        _stalloQueue = conDup.slice();
        _stalloConf  = senzaDup.map(function(r){ return r.line; });
        prossimoStallo();
      }
    })
    .catch(function(e){ mostraErr('Errore controllo duplicati: ' + e.message); });
}

// ── Stallo alla messicana ──
function prossimoStallo() {
  if (_stalloQueue.length === 0) {
    if (_stalloConf.length === 0) { mostraErr('Nessun nominativo da inserire.'); return; }
    inserisciTutti(_stalloConf.join('\n'), GID);
    return;
  }
  var item = _stalloQueue.shift();
  _stalloNomeCorrente = item.line;
  var d = item.dups[0];
  document.getElementById('stallo-nome').textContent = item.n.fn + ' ' + item.n.ln;
  document.getElementById('stallo-dup-nome').textContent = (d.last_name||'') + ' ' + (d.first_name||'');
  document.getElementById('stallo-dup-gruppo').textContent = d.group_name || '---';
  document.getElementById('stallo-dup-cat').textContent = d.category_name || '---';
  document.getElementById('stallo-dup-tipo').textContent = d.pass_type_name || 'nessun pass';
  document.getElementById('stallo-dup-stato').textContent = d.last_status || 'nessun pass';
  var inv = (d.first_name||'').toLowerCase() === item.n.ln.toLowerCase() &&
            (d.last_name||'').toLowerCase()  === item.n.fn.toLowerCase();
  document.getElementById('stallo-warn-inv').style.display = inv ? '' : 'none';
  document.getElementById('modal-stallo').style.display = 'flex';
}

function stalloConferma() {
  _stalloConf.push(_stalloNomeCorrente);
  document.getElementById('modal-stallo').style.display = 'none';
  setTimeout(prossimoStallo, 150);
}

function stalloSkip() {
  document.getElementById('modal-stallo').style.display = 'none';
  setTimeout(prossimoStallo, 150);
}

// ── Inserimento effettivo ──
function inserisciTutti(nomi, groupId) {
  var p = new URLSearchParams();
  p.append('names_list', nomi);
  p.append('assignment_group_id', groupId);
  fetch('/participants/bulk-import', {
    method: 'POST',
    headers: {'Content-Type':'application/x-www-form-urlencoded'},
    body: p.toString()
  }).then(function(r){ return r.json().then(function(d){ return {s:r.status, d:d}; }); })
    .then(function(obj) {
      if (obj.d.success) {
        mostraOk('Inseriti ' + obj.d.inserted + ' nominativo/i!');
        setTimeout(function(){ window.location.reload(); }, 1000);
      } else if (obj.s === 409 && obj.d.warning) {
        apriMaronno(obj.d);
      } else {
        mostraErr(obj.d.error || 'Errore durante l\'inserimento');
      }
    })
    .catch(function(){ mostraErr('Errore di rete'); });
}

// ── Maronno (limite superato) ──
function apriMaronno(d) {
  _nomiPending = document.getElementById('bulk-names').value.trim();
  document.getElementById('mar-msg').textContent = 'Stai inserendo ' + d.adding + ' nominativi ma il limite è ' + d.max + '!';
  document.getElementById('mar-sub').textContent = 'Attualmente ci sono ' + d.current + '. Dopo sarebbero ' + d.total_after + ' (' + d.over + ' oltre il limite).';
  document.getElementById('mar-max').value = d.total_after;
  document.getElementById('mar-pwd').value = '';
  document.getElementById('mar-err').style.display = 'none';
  document.getElementById('modal-maronno').style.display = 'flex';
}

function maronnoForza() {
  var newMax = document.getElementById('mar-max').value;
  var pwd    = document.getElementById('mar-pwd').value;
  var errEl  = document.getElementById('mar-err');
  if (!newMax) { errEl.textContent = 'Inserisci il nuovo limite'; errEl.style.display=''; return; }
  if (!pwd)    { errEl.textContent = 'Inserisci la password';     errEl.style.display=''; return; }
  errEl.style.display = 'none';
  var p = new URLSearchParams();
  p.append('names_list', _nomiPending);
  p.append('assignment_group_id', GID);
  p.append('force_over_limit', '1');
  p.append('new_max_passes', newMax);
  p.append('admin_password', pwd);
  fetch('/participants/bulk-import', {
    method: 'POST',
    headers: {'Content-Type':'application/x-www-form-urlencoded'},
    body: p.toString()
  }).then(function(r){ return r.json(); })
    .then(function(d) {
      if (d.success) {
        document.getElementById('modal-maronno').style.display = 'none';
        mostraOk('Inseriti ' + d.inserted + ' nominativi, limite aggiornato a ' + newMax);
        setTimeout(function(){ window.location.reload(); }, 1000);
      } else {
        errEl.textContent = d.error || 'Errore';
        errEl.style.display = '';
      }
    }).catch(function(){ errEl.textContent = 'Errore di rete'; errEl.style.display=''; });
}
</script>
</div><!-- /tab-pass -->

