      <label style="font-size:.8rem;">Tipo<br><select name="doc_type" style="margin-top:.25rem;width:100%;"><option value="contratto">Contratto</option><option value="modulo_firmato">Modulo firmato</option><option value="ricevuta">Ricevuta</option><option value="nota_interna">Nota interna</option><option value="altro">Altro</option></select></label>
      <label style="font-size:.8rem;">Note<br><input type="text" name="notes" style="margin-top:.25rem;width:100%;"></label>
      <div style="grid-column:1/-1;display:flex;gap:.5rem;align-items:center;"><button type="submit" class="primary" style="font-size:.82rem;">⬆ Carica</button><span id="doc-msg" style="font-size:.78rem;"></span></div>
    </form>
  </details>

  <!-- ═══════════════════════════════════════════════════════════
       DOCUMENTI CARICATI DALL'ESPOSITORE dal portale
  ═══════════════════════════════════════════════════════════ -->
  <div style="margin-top:1.5rem;border-top:1px solid #e2e8f0;padding-top:1.2rem;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.8rem;">
      <h3 style="font-size:.9rem;font-weight:700;color:#1a2744;margin:0;">
        📤 Documenti caricati dall'espositore
      </h3>
      <% if(typeof portalDocs!=='undefined'&&portalDocs.length){ %>
        <span style="font-size:.75rem;color:#64748b;"><%= portalDocs.length %> file</span>
      <% } %>
    </div>

    <% if(typeof portalDocs!=='undefined'&&portalDocs.length){ %>
      <div style="display:grid;gap:.5rem;">
        <% portalDocs.forEach(function(pd){ %>
          <%
            var pdStatusMap={ricevuto:{bg:'#e0f2fe',fg:'#0369a1',lbl:'Ricevuto'},
              in_revisione:{bg:'#fef9c3',fg:'#854d0e',lbl:'In revisione'},
              approvato:{bg:'#dcfce7',fg:'#166534',lbl:'Approvato'},
              rifiutato:{bg:'#fee2e2',fg:'#991b1b',lbl:'Rifiutato'}};
            var pdS=pdStatusMap[pd.status]||{bg:'#f1f5f9',fg:'#475569',lbl:pd.status};
          %>
          <div style="display:grid;grid-template-columns:1fr auto auto;gap:.5rem;align-items:center;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:.55rem .85rem;">
            <div>
              <div style="font-size:.83rem;font-weight:600;color:#1a2744;">
                <%= pd.original_name||pd.filename %>
              </div>
              <div style="font-size:.73rem;color:#64748b;margin-top:.1rem;">
                <span style="text-transform:capitalize;"><%= (pd.doc_type||'altro').replace(/_/g,' ') %></span>
                · <%= new Date(pd.uploaded_at).toLocaleDateString('it-IT') %>
                <% if(pd.review_notes){ %> · <em><%= pd.review_notes %></em><% } %>
              </div>
            </div>
            <!-- Badge stato -->
            <span style="background:<%= pdS.bg %>;color:<%= pdS.fg %>;border-radius:20px;font-size:.7rem;font-weight:700;padding:.2rem .65rem;white-space:nowrap;">
              <%= pdS.lbl %>
            </span>
            <!-- Azioni -->
            <% if(!isViewer){ %>
            <div style="display:flex;gap:.35rem;align-items:center;">
              <a href="/admin/portal-docs/<%= pd.id %>/download" target="_blank"
                 style="background:#1d6fa4;color:#fff;border-radius:6px;font-size:.72rem;font-weight:700;padding:.25rem .6rem;text-decoration:none;">
                ⬇ Scarica
              </a>
              <form method="POST" action="/admin/portal-docs/<%= pd.id %>/review" style="display:inline;">
                <select name="status" onchange="this.form.submit()"
                  style="font-size:.72rem;border:1px solid #d1d9e6;border-radius:6px;padding:.22rem .4rem;background:#fff;cursor:pointer;color:#1a2744;">
                  <option value="ricevuto"     <%= pd.status==='ricevuto'?'selected':''     %>>Ricevuto</option>
                  <option value="in_revisione" <%= pd.status==='in_revisione'?'selected':'' %>>In revisione</option>
                  <option value="approvato"    <%= pd.status==='approvato'?'selected':''    %>>Approvato</option>
                  <option value="rifiutato"    <%= pd.status==='rifiutato'?'selected':''    %>>Rifiutato</option>
                </select>
              </form>
            </div>
            <% } %>
          </div>
        <% }); %>
      </div>
    <% }else{ %>
      <p style="color:#94a3b8;font-size:.82rem;font-style:italic;">Nessun documento caricato dall'espositore.</p>
    <% } %>
  </div>

</div>
<% } %>
</div><!-- /tab-documenti -->
<script>
/* ── Tab switching ── */
function crmTab(tabId, btn) {
  document.querySelectorAll('.crm-panel').forEach(function(p){ p.classList.remove('active'); });
  document.querySelectorAll('.crm-tab').forEach(function(b){ b.classList.remove('active'); });
  var panel = document.getElementById('tab-' + tabId);
  if (panel) panel.classList.add('active');
  if (btn)   btn.classList.add('active');
  history.replaceState(null, '', '#tab-' + tabId);
}
(function(){
  var hash = location.hash.replace('#tab-','');
  if (hash && document.getElementById('tab-' + hash)) {
    crmTab(hash, document.querySelector('[data-tab="'+hash+'"]'));
  }
})();

function _post(url, data) {
  return fetch(url, { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body: new URLSearchParams(data).toString() }).then(function(r){ return r.json(); });
}
function _msg(id, txt, ok) {
  var el = document.getElementById(id);
  if (!el) return;
  el.textContent = txt; el.style.color = ok ? '#2d6a4f' : '#c0392b';
  setTimeout(function(){ el.textContent=''; }, 3000);
}

/* Referenti */
function addContact(e, gid) {
  e.preventDefault();
  var data = {}; new FormData(document.getElementById('contact-form')).forEach(function(v,k){ data[k]=v; });
  _post('/assignment-groups/'+gid+'/contacts', data).then(function(d){
    if (d.ok) { _msg('contact-msg','✓ Aggiunto!',true); setTimeout(function(){ location.reload(); }, 800); }
    else _msg('contact-msg', d.error||'Errore', false);
  });
}
function setPrimaryContact(gid, cid) {
  _post('/assignment-groups/'+gid+'/contacts/'+cid+'/primary',{}).then(function(d){ if(d.ok) location.reload(); });
}
function deleteContact(gid, cid, btn) {
  if (!confirm('Eliminare questo referente?')) return;
  btn.disabled = true;
  _post('/assignment-groups/'+gid+'/contacts/'+cid+'/delete',{}).then(function(d){
    if (d.ok) btn.closest('tr').remove(); else { alert(d.error||'Errore'); btn.disabled=false; }
  });
}

/* Pagamenti */
function addPayment(e, gid) {
  e.preventDefault();
  var data = {}; new FormData(document.getElementById('payment-form')).forEach(function(v,k){ data[k]=v; });
  _post('/assignment-groups/'+gid+'/payments', data).then(function(d){
    if (d.ok) { _msg('payment-msg','✓ Aggiunto!',true); setTimeout(function(){ location.reload(); }, 800); }
    else _msg('payment-msg', d.error||'Errore', false);
  });
}
function updatePayStatus(gid, pid, status) {
  _post('/assignment-groups/'+gid+'/payments/'+pid+'/status',{status:status}).then(function(d){ if(!d.ok) alert(d.error||'Errore'); });
}
function deletePayment(gid, pid) {
  if (!confirm('Eliminare questa voce?')) return;
  _post('/assignment-groups/'+gid+'/payments/'+pid+'/delete',{}).then(function(d){
    if (d.ok) { var r=document.getElementById('pay-row-'+pid); if(r) r.remove(); } else alert(d.error||'Errore');
  });
}

/* Documenti */
function uploadDoc(e, gid) {
  e.preventDefault();
  var btn = e.target.querySelector('button[type=submit]'); btn.disabled=true; btn.textContent='⏳…';
  fetch('/assignment-groups/'+gid+'/documents',{method:'POST',body:new FormData(document.getElementById('doc-form'))})
    .then(function(r){ return r.json(); })
    .then(function(d){
      btn.disabled=false; btn.textContent='⬆ Carica';
      if (d.ok) { _msg('doc-msg','✓ Caricato!',true); setTimeout(function(){ location.reload(); }, 800); }
      else _msg('doc-msg', d.error||'Errore', false);
    });
}
function deleteDoc(gid, did) {
  if (!confirm('Eliminare documento?')) return;
  _post('/assignment-groups/'+gid+'/documents/'+did+'/delete',{}).then(function(d){
    if (d.ok) { var r=document.getElementById('doc-row-'+did); if(r) r.remove(); } else alert(d.error||'Errore');
  });
}

/* Stato contratto */
function setContractStatus(gid, status) {
  _post('/assignment-groups/'+gid+'/contract-status',{contract_status:status}).then(function(d){ if(d.ok) location.reload(); else alert(d.error||'Errore'); });
}

/* Finestra portale */
(function(){
  var wf = document.getElementById('window-form');
  if (!wf) return;
  wf.addEventListener('submit', function(e){
    e.preventDefault();
    var data = {}; new FormData(wf).forEach(function(v,k){ data[k]=v; });
    var msg = document.getElementById('window-msg'); msg.style.display='block';
    _post('/admin/groups/<%= groupInfo.id %>/portal/window', data).then(function(d){
      msg.style.color = d.ok ? '#2d6a4f' : '#c0392b';
      msg.textContent = d.ok ? '✓ Finestra salvata' : (d.error||'Errore');
      if (d.ok) setTimeout(function(){ location.reload(); }, 900);
    });
  });
})();
function clearWindow() {
  _post('/admin/groups/<%= groupInfo.id %>/portal/window',{portal_open_from:'',portal_open_until:''}).then(function(d){ if(d.ok) location.reload(); });
}

/* genTok / togP / map */
function genTok(id){if(!confirm('Generare nuovo token portale?'))return;fetch('/admin/groups/'+id+'/portal/token',{method:'POST'}).then(function(r){return r.json();}).then(function(d){if(d.token)location.reload();else alert('Errore:'+(d.error||'?'));});}
function togP(id){fetch('/admin/groups/'+id+'/portal/toggle',{method:'POST'}).then(function(){location.reload();});}
(function(){
  var mpf=document.getElementById('mpf');
  if(!mpf) return;
  mpf.addEventListener('submit',function(e){
    e.preventDefault(); var msg=document.getElementById('mpmsg');
    fetch('/admin/groups/<%= groupInfo.id %>/map-position',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'map_row='+document.getElementById('mr').value+'&map_col='+document.getElementById('mc').value+'&map_span='+document.getElementById('ms').value})
      .then(function(r){return r.json();})
      .then(function(d){msg.style.display='block';msg.style.color=d.ok?'#2d6a4f':'#c0392b';msg.textContent=d.ok?'✓ Salvato!':'Errore';setTimeout(function(){msg.style.display='none';},3000);});
  });
})();
function rmM(id){fetch('/admin/groups/'+id+'/map-position',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'map_row=&map_col=&map_span=1'}).then(function(){location.reload();});}
</script>

<script>
// ── Bulk status (visibile a tutti, incluso il visualizzatore) ──
function updateBulkBar(){
  var checked=document.querySelectorAll('.chk-group:checked');
  var bar=document.getElementById('bulk-status-bar');
  if(bar) bar.style.display=checked.length>0?'flex':'none';
}
document.addEventListener('DOMContentLoaded',function(){
  document.querySelectorAll('.chk-group').forEach(function(c){
    c.addEventListener('change',updateBulkBar);
  });
  var hdrChk=document.querySelector('thead input[type=checkbox]');
  if(hdrChk){
    hdrChk.addEventListener('change',function(){
      document.querySelectorAll('.chk-group').forEach(function(c){c.checked=this.checked;}.bind(this));
      updateBulkBar();
    });
  }
});
function deselectAll(){
  document.querySelectorAll('.chk-group').forEach(function(c){c.checked=false;});
  var hdr=document.querySelector('thead input[type=checkbox]');
  if(hdr) hdr.checked=false;
  updateBulkBar();
}
function applyBulkStatus(){
  var checked=document.querySelectorAll('.chk-group:checked');
  if(!checked.length){alert('Seleziona almeno un pass.');return;}
  var status=document.getElementById('bulk-status-select').value;
  var passIds=[];
  checked.forEach(function(c){
    var pid=c.getAttribute('data-pass-id');
    if(pid&&pid!=='0') passIds.push(pid);
  });
  if(!passIds.length){alert('I partecipanti selezionati non hanno pass da aggiornare.');return;}
  if(!confirm('Impostare "'+status+'" su '+passIds.length+' pass?')) return;
  var form=document.createElement('form');
  form.method='POST'; form.action='/passes/bulk-status';
  var addF=function(n,v){var i=document.createElement('input');i.type='hidden';i.name=n;i.value=v;form.appendChild(i);};
  passIds.forEach(function(id){addF('pass_ids',id);});
  addF('status',status);
  addF('group_id','<%= groupInfo.id %>');
  document.body.appendChild(form); form.submit();
}
</script>

<!-- Modal storico pass -->
<div id="storico-modal" style="display:none;position:fixed;inset:0;z-index:9999;
     background:rgba(0,0,0,.45);align-items:center;justify-content:center;">
  <div style="background:#fff;border-radius:10px;padding:1.5rem 1.75rem;
              max-width:520px;width:90%;max-height:80vh;overflow-y:auto;
              box-shadow:0 8px 32px rgba(0,0,0,.18);position:relative;">
    <button onclick="document.getElementById('storico-modal').style.display='none'"
            style="position:absolute;top:.75rem;right:.9rem;background:none;border:none;
                   font-size:1.3rem;cursor:pointer;color:#7a7974;">&times;</button>
    <h3 style="margin:0 0 1rem;font-size:1rem;font-weight:700;">&#128203; Storico Pass <span id="storico-pass-id" style="color:#6b3fa0;"></span></h3>
    <div id="storico-body">
      <p style="color:#7a7974;font-size:.85rem;">Caricamento...</p>
    </div>
  </div>
</div>
<script>

function mostraStorico(passId) {
  var modal = document.getElementById('storico-modal');
  var body  = document.getElementById('storico-body');
  var title = document.getElementById('storico-pass-id');
  modal.style.display = 'flex';
  title.textContent = '#' + passId;
  body.innerHTML = '<p style="color:#7a7974;font-size:.85rem;">Caricamento...</p>';
  fetch('/passes/' + passId + '/history')
    .then(function(r){ return r.json(); })
    .then(function(rows){
      if (!rows.length) {
        body.innerHTML = '<p style="color:#7a7974;font-size:.85rem;">Nessuno storico disponibile.</p>';
        return;
      }
      var sc = {
  GENERATO:'#6b3fa0',SCARICATO:'#1d6fa4',STAMPATO:'#c9a227',
  CONSEGNATO:'#2d6a4f',RICONSEGNATO:'#c0392b',INVALIDATO:'#9ca3af'
};
      var html = '<table style="width:100%;border-collapse:collapse;font-size:.82rem;">';
      html += '<thead><tr style="background:#f3f0ec;">'
            + '<th style="padding:.35rem .6rem;text-align:left;">Stato</th>'
            + '<th style="padding:.35rem .6rem;text-align:left;">Data / Ora</th>'
            + '<th style="padding:.35rem .6rem;text-align:left;">Utente</th>'
            + '</tr></thead><tbody>';
      rows.forEach(function(r, i){
        var bg = i%2===0?'#fff':'#fafaf8';
        var date = r.changed_at ? new Date(r.changed_at).toLocaleString('it-IT') : '—';
        var col  = sc[r.status] || '#9ca3af';
        html += '<tr style="background:'+bg+'">'
              + '<td style="padding:.3rem .6rem;">'
              + '<span style="display:inline-flex;padding:.15rem .45rem;border-radius:9999px;'
              + 'font-size:.68rem;font-weight:700;color:#fff;background:'+col+';white-space:nowrap;">'
              + r.status + '</span></td>'
              + '<td style="padding:.3rem .6rem;white-space:nowrap;">' + date + '</td>'
              + '<td style="padding:.3rem .6rem;">' + (r.username || '—') + '</td>'
              + '</tr>';
      });
      html += '</tbody></table>';
      body.innerHTML = html;
    })
    .catch(function(){
      body.innerHTML = '<p style="color:#c0392b;font-size:.85rem;">Errore nel caricamento.</p>';
    });
  // Chiudi cliccando fuori dal modal
  modal.onclick = function(e){ if(e.target===modal) modal.style.display='none'; };
}

</script>
<%-include('partials/footer') %>
