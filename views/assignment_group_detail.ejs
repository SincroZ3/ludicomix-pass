<%-include('partials/header') %>
<nav class="breadcrumb-bar">Sei in: <a href="/home">Home</a> <span class="sep">›</span> <a href="/participants">Assegnatari Pass</a> <span class="sep">›</span> <%= groupInfo.category_name %> <span class="sep">›</span> <strong><%= groupInfo.name %></strong></nav>
<h1 class="page-title"><%= groupInfo.name %></h1>

<% const isViewer = currentUser && currentUser.role === 'viewer';
   const VIEWER_STATUSES = ['SCARICATO','STAMPATO','CONSEGNATO','RICONSEGNATO'];
%>

<!-- ══════════════ TAB NAV CRM ══════════════ -->
<style>
.crm-tab-nav{display:flex;flex-wrap:wrap;gap:.35rem;margin:.6rem 0 1.1rem;border-bottom:2px solid #d1d9e6;padding-bottom:.5rem;}
.crm-tab{padding:.38rem .9rem;border-radius:6px 6px 0 0;border:1px solid transparent;background:none;font-size:.82rem;font-weight:600;cursor:pointer;color:#64748b;transition:all .15s;position:relative;bottom:-2px;}
.crm-tab:hover{color:#1d6fa4;border-color:#d1d9e6 #d1d9e6 #fff;}
.crm-tab.active{background:#fff;border-color:#d1d9e6 #d1d9e6 #fff;color:#1e2d4e;}
.crm-badge{display:inline-block;background:#e0e7ff;color:#3730a3;border-radius:9999px;font-size:.7rem;font-weight:700;padding:.05rem .4rem;margin-left:.25rem;}
.crm-badge-danger{background:#fee2e2;color:#b91c1c;}
.crm-panel{display:none;}.crm-panel.active{display:block;}
</style>
<div class="crm-tab-nav" id="crm-tab-nav">
  <button type="button" class="crm-tab active" data-tab="pass" onclick="crmTab('pass',this)">📋 Pass & Nominativi</button>
  <button type="button" class="crm-tab" data-tab="portale" onclick="crmTab('portale',this)">🌐 Portale</button>
<% if(!isViewer){ %>
  <button type="button" class="crm-tab" data-tab="referenti" onclick="crmTab('referenti',this)">👤 Referenti<% if(typeof contacts!=='undefined'&&contacts.length){ %> <span class="crm-badge"><%= contacts.length %></span><% } %></button>
  <button type="button" class="crm-tab" data-tab="pagamenti" onclick="crmTab('pagamenti',this)">💳 Pagamenti<% if(typeof payments!=='undefined'&&payments.length){ %><% var _scad=payments.filter(function(p){return p.status==='scaduto';}).length; %><% if(_scad){ %> <span class="crm-badge crm-badge-danger"><%= _scad %> ⚠</span><% }else{ %> <span class="crm-badge"><%= payments.length %></span><% } %><% } %></button>
  <button type="button" class="crm-tab" data-tab="documenti" onclick="crmTab('documenti',this)">📁 Documenti<% if(typeof groupDocs!=='undefined'&&groupDocs.length){ %> <span class="crm-badge"><%= groupDocs.length %></span><% } %></button>
<% } %>
</div>
<div id="tab-pass" class="crm-panel active">
<% if(typeof req !== 'undefined' && false){ %><% } %>
<% if(locals.replaceOk){ %>
  <div class="alert" style="background:#f0fdf4;border:1.5px solid #2d6a4f;border-radius:8px;padding:.7rem 1rem;margin-bottom:1rem;">
    <span>&#10003;</span> Pass sostituito con successo. Il nuovo pass con PDF è visibile qui sotto.
  </div>
<% } %>
<% if (isViewer) { %>
  <div class="alert alert-info"><span>&#128065;</span> Sei in modalit&#224; <strong>Visualizzatore</strong>: puoi consultare i dati e modificare lo stato dei pass, ma non aggiungere o eliminare assegnatari.</div>
<% } %>

<!-- AVVISO PASS DUPLICATI SALTATI -->
<% if (typeof dupSkipped !== 'undefined' && dupSkipped > 0) { %>
<div style="display:flex;align-items:flex-start;gap:1rem;background:#f3e5f5;border:2px solid #ce93d8;border-radius:8px;padding:1rem 1.25rem;margin-bottom:1.25rem;">
  <img src="/ciuchino_stop.png" alt="Stop" style="height:80px;width:auto;flex-shrink:0;">
  <div>
    <p style="font-weight:700;font-size:0.95rem;color:#4a148c;margin:0 0 0.35rem;">
      🛑 Alcuni pass non sono stati generati!
    </p>
    <p style="font-size:0.85rem;color:#6a1b9a;margin:0 0 0.25rem;">
      <strong><%= dupSkipped %></strong> su <strong><%= dupTotal %></strong> assegnatari selezionati
      avevano già un pass generato e sono stati <strong>saltati automaticamente</strong>.
    </p>
    <p style="font-size:0.82rem;color:#4a148c;margin:0;">
      Per rigenerare un pass duplicato usa la pagina 
      <a href="/passes/new" style="color:#6b3fa0;font-weight:700;">Nuovo Pass Singolo</a>.
    </p>
  </div>
</div>
<% } %>

<!-- INFO RIEPILOGO -->
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:0.75rem;margin-bottom:1.25rem;">
  <div class="card" style="margin:0;"><div class="card-title">Categoria</div><strong><%= groupInfo.category_name %></strong></div>
  <div class="card" style="margin:0;"><div class="card-title">Stand / Riferimento</div><strong><%= groupInfo.stand_name || groupInfo.name %></strong></div>
  <div class="card" style="margin:0;">
    <div class="card-title">Zona / Padiglione</div>
    <strong><%= groupInfo.zone || '&mdash;' %></strong>
    <% if (groupInfo.stand_code) { %>&nbsp;&middot;&nbsp;Codice: <strong><%= groupInfo.stand_code %></strong><% } %>
  </div>
  <div class="card" style="margin:0;">
    <div class="card-title">Pass</div>
    <strong><%= participants.length %></strong> assegnatari&nbsp;&middot;&nbsp;
    Limite: <strong><%= groupInfo.max_passes != null ? groupInfo.max_passes : 'illimitati' %></strong>
  </div>
  <% if (groupInfo.email) { %>
  <div class="card" style="margin:0;">
    <div class="card-title">Email riferimento</div>
    <a href="mailto:<%= groupInfo.email %>"><%= groupInfo.email %></a>
  </div>
  <% } %>
</div>

<% if (!isViewer) { %>
<details style="margin-bottom:1rem;">
  <summary style="cursor:pointer;font-weight:700;font-size:0.85rem;color:var(--accent-blue);padding:0.4rem 0;">&#9999;&#65039; Modifica dati gruppo / stand</summary>
  <div class="card" style="margin-top:0.5rem;">
    <form method="post" action="/assignment-groups/<%= groupInfo.id %>/edit" style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem 1rem;">
      <label>Nome gruppo <span style="color:#c0392b">*</span><br>
        <input type="text" name="name" value="<%= groupInfo.name %>" required>
      </label>
      <label>Nome stand / riferimento<br>
        <input type="text" name="stand_name" value="<%= groupInfo.stand_name || '' %>">
      </label>
      <label>Zona / Padiglione<br>
        <select name="zone">
          <option value="">&#8212; Nessuna &#8212;</option>
          <% (typeof zones !== 'undefined' ? zones : []).forEach(function(z){ %>
            <option value="<%= z.name %>" <%= groupInfo.zone === z.name ? 'selected' : '' %>><%= z.name %></option>
          <% }); %>
          <% if (groupInfo.zone && groupInfo.zone.trim() && (typeof zones === 'undefined' || !zones.find(function(z){ return z.name === groupInfo.zone; }))) { %>
            <option value="<%= groupInfo.zone %>" selected><%= groupInfo.zone %> (legacy)</option>
          <% } %>
        </select>
      </label>
      <label>Codice stand<br>
        <input type="text" name="stand_code" value="<%= groupInfo.stand_code || '' %>">
      </label>
      <div style="grid-column:1/-1;">
        <button type="submit" class="primary">Salva modifiche</button>
      </div>
    </form>
  </div>
</details>

<details style="margin-bottom:1rem;">
  <summary style="cursor:pointer;font-weight:700;font-size:0.85rem;color:var(--accent-blue);padding:0.4rem 0;">&#128221; Note ed Email gruppo <% if (groupInfo.notes || groupInfo.email) { %><span class="chip" style="background:#e8f5e9;color:#1b5e20;margin-left:0.4rem;">compilate</span><% } %></summary>
  <div class="card" style="margin-top:0.5rem;max-width:600px;">
    <form method="post" action="/assignment-groups/<%= groupInfo.id %>/notes" style="display:grid;gap:0.75rem;">
      <label>Note<br>
        <textarea name="notes" rows="3" style="resize:vertical;"><%= groupInfo.notes || '' %></textarea>
      </label>
      <label>Email di riferimento gruppo<br>
        <input type="email" name="email" value="<%= groupInfo.email || '' %>" placeholder="email@esempio.it">
      </label>
      <div><button type="submit" class="primary">Salva modifiche</button></div>
    </form>
  </div>
</details>
<% } else { %>
  <% if (groupInfo.notes) { %>
    <div class="alert alert-info" style="margin-bottom:1rem;"><span>&#128221;</span> <strong>Note:</strong> <%= groupInfo.notes %></div>
  <% } %>
<% } %>

<% if (!isViewer) { %>

<!-- MODIFICA LIMITE -->
<details style="margin-bottom:1rem;">
  <summary style="cursor:pointer;font-weight:700;font-size:0.85rem;color:var(--accent-blue);padding:0.4rem 0;">&#128295; Modifica limite massimo di pass per questo gruppo</summary>
  <div class="card" style="margin-top:0.5rem;max-width:440px;">
    <form method="post" action="/assignment-groups/<%= groupInfo.id %>/limit" style="display:grid;gap:0.75rem;">
      <label>Numero massimo di pass (0 o vuoto = illimitati)<br>
        <input type="number" name="max_passes" min="0" value="<%= groupInfo.max_passes || '' %>">
      </label>
      <label>Password amministratore <span style="color:#c0392b">*</span><br>
        <input type="password" name="admin_password" required>
      </label>
      <div><button type="submit" class="primary">Aggiorna limite</button></div>
    </form>
  </div>
</details>

<!-- INSERIMENTO MULTIPLO -->
<details open style="margin-bottom:1.25rem;">
  <summary style="cursor:pointer;font-weight:700;font-size:0.85rem;color:var(--accent-blue);padding:0.4rem 0;">&#10133; Aggiungi assegnatari (anche multipli)</summary>
  <div class="card" style="margin-top:0.5rem;">
    <p style="font-size:0.82rem;color:var(--text-secondary);margin:0 0 0.75rem;">
      Inserisci uno o pi&#249; nominativi, <strong>uno per riga</strong>, nel formato <code>Nome Cognome</code>.<br>
      Puoi incollare direttamente una lista da email o Excel.
    </p>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
      <div>
        <label>Lista nominativi <span style="color:#c0392b">*</span><br>
          <textarea id="bulk-names" rows="8"
            placeholder="Mario Rossi&#10;Anna Bianchi&#10;Luca Verdi&#10;..."
            style="font-family:monospace;font-size:0.85rem;resize:vertical;"
            oninput="aggiornaPrev()"></textarea>
        </label>
        <div id="bulk-count" style="font-size:0.78rem;color:var(--text-muted);margin-top:0.25rem;"></div>
      </div>
      <div style="display:flex;flex-direction:column;gap:0.5rem;">
        <div class="card" style="margin:0;background:var(--bg-section);flex:1;">
          <div class="card-title">Anteprima nominativi</div>
          <div id="bulk-preview-list" style="font-size:0.82rem;max-height:180px;overflow-y:auto;"></div>
        </div>
        <button type="button" class="primary"
          onclick="avviaBulk('<%= groupInfo.id %>')"
          style="align-self:flex-start;">
          &#10133; Inserisci nominativi
        </button>
        <div id="bulk-ok"  class="alert alert-success" style="display:none;margin:0;"></div>
        <div id="bulk-err" class="alert alert-danger"  style="display:none;margin:0;"></div>
      </div>
    </div>
  </div>
</details>
<% } %>

<!-- TABELLA ASSEGNATARI -->
<h2>Elenco assegnatari <span class="chip"><%= participants.length %></span></h2>

<% if(!isViewer){ %>
<button onclick="document.getElementById('imp-modal').style.display='flex'"
  style="margin-bottom:.75rem;font-size:.82rem;background:var(--accent-blue,#1d6fa4);color:#fff;border:none;padding:.42rem 1rem;border-radius:6px;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;gap:.4rem;">
  &#128229; Import CSV / Excel
</button>

<!-- ══ MODAL IMPORT ══ -->
<div id="imp-modal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.52);align-items:center;justify-content:center;padding:1rem;">
  <div style="background:#fff;border-radius:12px;width:100%;max-width:720px;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.3);display:flex;flex-direction:column;">
    <!-- header -->
    <div style="display:flex;align-items:center;justify-content:space-between;padding:.9rem 1.2rem;border-bottom:1px solid #e5e7eb;flex-shrink:0;">
      <strong style="font-size:.95rem;">&#128229; Import massivo assegnatari</strong>
      <button onclick="impClose()" style="font-size:1.2rem;background:none;border:none;cursor:pointer;color:#6b7280;line-height:1;">&times;</button>
    </div>
    <!-- body -->
    <div style="padding:1.1rem 1.2rem;flex:1;">

      <!-- STEP 1: selezione file -->
      <div id="imp-s1">
        <p style="font-size:.82rem;color:#6b7280;margin-bottom:.9rem;">
          Formato: <code>.csv</code> / <code>.xlsx</code> &mdash; Colonne: <code>cognome</code> <code>nome</code> <code>email</code> <code>ruolo</code>
          &nbsp;<a href="/import/template.csv" target="_blank" style="font-size:.77rem;">&#11015; Template</a>
        </p>
        <label style="display:block;font-weight:700;font-size:.85rem;margin-bottom:.55rem;">File CSV o Excel <span style="color:#c0392b">*</span></label>
        <input type="file" id="imp-file" accept=".csv,.xlsx,.xls"
               style="display:block;width:100%;margin-bottom:1rem;font-size:.83rem;">
        <div style="display:flex;gap:.6rem;">
          <button id="imp-btn-preview" class="primary" onclick="impPreview()" disabled
            style="font-size:.82rem;">&#128269; Analizza file</button>
          <button onclick="impClose()" class="secondary" style="font-size:.82rem;">Annulla</button>
        </div>
        <div id="imp-err" style="display:none;margin-top:.75rem;padding:.55rem .8rem;border-radius:7px;background:#fef2f2;border:1px solid #fca5a5;font-size:.8rem;color:#991b1b;"></div>
      </div>

      <!-- STEP 2: preview -->
      <div id="imp-s2" style="display:none;">
        <div id="imp-stats" style="display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:.85rem;"></div>
        <div style="overflow-x:auto;">
          <table id="imp-tbl" style="width:100%;border-collapse:collapse;font-size:.77rem;">
            <thead><tr style="background:#f3f4f6;">
              <th style="padding:.38rem .6rem;text-align:left;border-bottom:2px solid #d1d5db;font-size:.7rem;text-transform:uppercase;letter-spacing:.4px;">Riga</th>
              <th style="padding:.38rem .6rem;text-align:left;border-bottom:2px solid #d1d5db;">Cognome</th>
              <th style="padding:.38rem .6rem;text-align:left;border-bottom:2px solid #d1d5db;">Nome</th>
              <th style="padding:.38rem .6rem;text-align:left;border-bottom:2px solid #d1d5db;">Email</th>
              <th style="padding:.38rem .6rem;text-align:left;border-bottom:2px solid #d1d5db;">Stato</th>
            </tr></thead>
            <tbody id="imp-tbody"></tbody>
          </table>
        </div>
        <p id="imp-more" style="font-size:.74rem;color:#6b7280;text-align:center;margin:.5rem 0 0;display:none;"></p>
        <div style="display:flex;gap:.6rem;margin-top:1rem;flex-wrap:wrap;">
          <button id="imp-btn-confirm" onclick="impConfirm()"
            style="font-size:.82rem;background:#166534;color:#fff;border:none;padding:.42rem 1rem;border-radius:6px;font-weight:700;cursor:pointer;">
            &#128228; Conferma importazione
          </button>
          <button onclick="impReset()" class="secondary" style="font-size:.82rem;">&#9664; Torna</button>
        </div>
      </div>

      <!-- STEP 3: risultato -->
      <div id="imp-s3" style="display:none;">
        <div id="imp-result-box" style="border-radius:8px;padding:.9rem 1rem;margin-bottom:.85rem;border:1.5px solid;font-size:.85rem;"></div>
        <ul id="imp-err-list" style="display:none;list-style:none;padding:0;max-height:200px;overflow-y:auto;margin-bottom:.85rem;"></ul>
        <div style="display:flex;gap:.6rem;flex-wrap:wrap;">
          <button id="imp-btn-undo" onclick="impUndo(this)"
            style="display:none;font-size:.82rem;background:#d97706;color:#fff;border:none;padding:.42rem 1rem;border-radius:6px;font-weight:700;cursor:pointer;">
            &#128465; Annulla importazione
          </button>
          <a id="imp-err-dl" href="/import/errors.csv" target="_blank"
             style="display:none;font-size:.82rem;padding:.42rem 1rem;border-radius:6px;background:#fee2e2;color:#991b1b;border:1px solid #fca5a5;text-decoration:none;font-weight:700;">
            &#11015; Scarica errori CSV
          </a>
          <button onclick="location.reload()" class="primary" style="font-size:.82rem;">&#10003; Fatto — ricarica pagina</button>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
(function(){
  var GID = <%= groupInfo.id %>;
  var tempId = null;

  document.getElementById('imp-file').addEventListener('change', function(){
    document.getElementById('imp-btn-preview').disabled = !this.files.length;
    document.getElementById('imp-err').style.display = 'none';
  });

  function show(step){ ['imp-s1','imp-s2','imp-s3'].forEach(function(id){
    document.getElementById(id).style.display = (id===step)?'':'none';
  }); }
  function esc(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  window.impClose = function(){ document.getElementById('imp-modal').style.display='none'; impReset(); };
  window.impReset = function(){
    show('imp-s1');
    document.getElementById('imp-file').value='';
    document.getElementById('imp-btn-preview').disabled=true;
    document.getElementById('imp-err').style.display='none';
    tempId=null;
  };

  window.impPreview = function(){
    var f = document.getElementById('imp-file').files[0];
    if(!f) return;
    var btn = document.getElementById('imp-btn-preview');
    btn.textContent='⏳ Analisi...'; btn.disabled=true;
    document.getElementById('imp-err').style.display='none';
    var fd = new FormData();
    fd.append('group_id', GID);
    fd.append('file', f);
    fetch('/import/preview',{method:'POST',body:fd})
      .then(function(r){return r.json();})
      .then(function(d){
        btn.textContent='🔍 Analizza file'; btn.disabled=false;
        if(d.error){ document.getElementById('imp-err').textContent=d.error; document.getElementById('imp-err').style.display=''; return; }
        tempId = d.tempId;
        // stats
        var sc = document.getElementById('imp-stats');
        sc.innerHTML =
          '<span style="padding:.28rem .75rem;border-radius:9999px;font-size:.76rem;font-weight:700;background:#dbeafe;color:#1e40af">📋 '+d.total+' righe</span>' +
          '<span style="padding:.28rem .75rem;border-radius:9999px;font-size:.76rem;font-weight:700;background:#dcfce7;color:#166534">✅ '+d.willImport+' da importare</span>' +
          (d.willSkip>0?'<span style="padding:.28rem .75rem;border-radius:9999px;font-size:.76rem;font-weight:700;background:#fef9c3;color:#854d0e">⚠️ '+d.willSkip+' da saltare</span>':'');
        // table
        var tb = document.getElementById('imp-tbody');
        tb.innerHTML = d.preview.map(function(r){
          var dup = r.issues && r.issues.some(function(i){return i.includes('Già presente');});
          var warn = r.issues && r.issues.length && !dup;
          var bg = r.ok?'':'background:'+(dup?'#fef2f2':'#fffbea');
          var stato = r.ok
            ? '<span style="color:#166534;font-weight:700">✓ OK</span>'
            : (r.issues||[]).map(function(i){
                return '<span style="display:inline-block;padding:.08rem .38rem;border-radius:9999px;font-size:.66rem;font-weight:700;background:'+(i.includes('Già')?'#fee2e2':'#fef3c7')+';color:'+(i.includes('Già')?'#991b1b':'#92400e')+'">'+esc(i)+'</span>';
              }).join(' ');
          return '<tr style="'+bg+'"><td style="padding:.32rem .6rem;border-bottom:1px solid #f0f0f0;">'+r.row+'</td><td style="padding:.32rem .6rem;border-bottom:1px solid #f0f0f0;">'+esc(r.last)+'</td><td style="padding:.32rem .6rem;border-bottom:1px solid #f0f0f0;">'+esc(r.first)+'</td><td style="padding:.32rem .6rem;border-bottom:1px solid #f0f0f0;color:#6b7280;">'+esc(r.email||'—')+'</td><td style="padding:.32rem .6rem;border-bottom:1px solid #f0f0f0;">'+stato+'</td></tr>';
        }).join('');
        var more = document.getElementById('imp-more');
        if(d.hasMore){ more.textContent='... e altre '+(d.total-10)+' righe (mostrate le prime 10)'; more.style.display=''; }
        else { more.style.display='none'; }
        document.getElementById('imp-btn-confirm').disabled = d.willImport===0;
        show('imp-s2');
      })
      .catch(function(e){
        btn.textContent='🔍 Analizza file'; btn.disabled=false;
        document.getElementById('imp-err').textContent='Errore di rete: '+e.message;
        document.getElementById('imp-err').style.display='';
      });
  };

  window.impConfirm = function(){
    if(!tempId) return;
    var btn = document.getElementById('imp-btn-confirm');
    btn.textContent='⏳ Import in corso...'; btn.disabled=true;
    fetch('/import/confirm-ajax',{
      method:'POST',
      headers:{'Content-Type':'application/x-www-form-urlencoded'},
      body:'temp_id='+encodeURIComponent(tempId)+'&group_id='+GID
    })
    .then(function(r){return r.json();})
    .then(function(d){
      var box = document.getElementById('imp-result-box');
      if(d.error){ box.style.cssText='border-radius:8px;padding:.9rem 1rem;border:1.5px solid #c0392b;background:#fef2f2;font-size:.85rem;'; box.innerHTML='<strong>❌ Errore:</strong> '+esc(d.error); show('imp-s3'); return; }
      var isWarn = d.skipped>0;
      box.style.cssText='border-radius:8px;padding:.9rem 1rem;border:1.5px solid '+(isWarn?'#d97706':'#166534')+';background:'+(isWarn?'#fffbea':'#f0fdf4')+';font-size:.85rem;';
      box.innerHTML='<strong>'+(isWarn?'⚠️':'✅')+' Import completato</strong><br><span style="color:#166534;font-weight:700">'+d.imported+' importati</span>'+(d.skipped>0?' &middot; <span style="color:#d97706;font-weight:700">'+d.skipped+' saltati</span>':'');
      // errori list
      var el = document.getElementById('imp-err-list');
      if(d.errors&&d.errors.length){
        el.innerHTML=d.errors.map(function(e){return '<li style="padding:.28rem .5rem;border-radius:5px;font-size:.76rem;background:#fef2f2;color:#991b1b;margin-bottom:.22rem;border-left:3px solid #fca5a5;">'+esc(e)+'</li>';}).join('');
        el.style.display='';
      } else { el.style.display='none'; }
      // pulsanti
      if(d.imported>0){ document.getElementById('imp-btn-undo').style.display=''; }
      if(d.hasErrors){ document.getElementById('imp-err-dl').style.display=''; }
      show('imp-s3');
    })
    .catch(function(e){
      document.getElementById('imp-result-box').style.cssText='border:1.5px solid #c0392b;background:#fef2f2;padding:.9rem;border-radius:8px;';
      document.getElementById('imp-result-box').innerHTML='Errore di rete: '+esc(e.message);
      show('imp-s3');
    });
  };

  window.impUndo = function(btn){
    if(!confirm('Sei sicuro? Elimina tutti i partecipanti appena importati e i loro pass. Irreversibile.')) return;
    btn.textContent='⏳...'; btn.disabled=true;
    fetch('/import/undo',{method:'POST',headers:{'Content-Type':'application/json'}})
      .then(function(r){return r.json();})
      .then(function(d){
        if(d.ok){ alert('✅ Annullati '+d.deleted+' partecipanti.'); location.reload(); }
        else{ alert('❌ '+(d.error||'Errore sconosciuto')); btn.disabled=false; btn.textContent='🗑 Annulla importazione'; }
      }).catch(function(e){ alert('Errore di rete: '+e.message); btn.disabled=false; });
  };

  // chiudi con ESC
  document.addEventListener('keydown',function(e){ if(e.key==='Escape') impClose(); });
  // chiudi click fuori
  document.getElementById('imp-modal').addEventListener('click',function(e){ if(e.target===this) impClose(); });
})();
</script>
<% } %>
